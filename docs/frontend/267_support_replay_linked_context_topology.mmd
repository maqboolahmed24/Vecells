flowchart LR
    Ticket["Support ticket shell"] --> Conversation["Conversation child route"]
    Ticket --> History["SupportHistoryView"]
    Ticket --> Knowledge["SupportKnowledgeView"]
    Ticket --> Replay["SupportReplaySurface"]

    Replay --> Boundary["SupportReplayEvidenceBoundary"]
    Replay --> Delta["SupportReplayDeltaReviewPanel"]
    Replay --> Draft["SupportReplayDraftHold"]
    Replay --> Restore["SupportReplayRestoreBridge"]

    Restore -->|ready| Live["Live action workbench re-armed"]
    Restore -->|blocked| Recovery["Read-only recovery in same ticket shell"]
    Restore -->|return_to_replay| Replay

    Ticket --> Linked["SupportLinkedContextView"]
    Linked --> Subject["Subject 360 summary"]
    Linked --> History
    Linked --> Knowledge

    Replay --> History
    Replay --> Knowledge

    classDef replay fill:#eef1ff,stroke:#3347FF,color:#0F172A;
    classDef blocked fill:#fff1f2,stroke:#B42318,color:#0F172A;
    class Replay,Boundary,Delta,Draft,Restore replay;
    class Recovery blocked;
