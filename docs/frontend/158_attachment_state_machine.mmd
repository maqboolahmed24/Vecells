stateDiagram-v2
  [*] --> selecting
  selecting --> uploading_to_quarantine
  uploading_to_quarantine --> scanning : transport settled
  uploading_to_quarantine --> retryable_transfer_failure : transfer failed
  scanning --> ready_kept : clean + preview safe
  scanning --> preview_unavailable_kept : clean + preview deferred
  scanning --> quarantined_unsupported_type : policy rejected
  scanning --> quarantined_unreadable : unreadable or integrity failure
  scanning --> quarantined_malware : malware detected
  retryable_transfer_failure --> uploading_to_quarantine : retry
  ready_kept --> replaced : replace
  ready_kept --> removed : remove
  preview_unavailable_kept --> replaced : replace
  preview_unavailable_kept --> removed : remove
  quarantined_unsupported_type --> replaced : replace
  quarantined_unsupported_type --> removed : remove
  quarantined_unreadable --> replaced : replace
  quarantined_unreadable --> removed : remove
  quarantined_malware --> replaced : replace
  quarantined_malware --> removed : remove
