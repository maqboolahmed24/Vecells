{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "tool-playwright",
  "sourceRoot": "tests/playwright",
  "projectType": "library",
  "tags": ["artifact:tools-only", "context:analysis_validation", "class:tools_workspace"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} lint"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} typecheck"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} e2e"
      }
    }
  }
}
