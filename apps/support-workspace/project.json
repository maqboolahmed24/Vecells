{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "app-support-workspace",
  "sourceRoot": "apps/support-workspace/src",
  "projectType": "application",
  "tags": ["artifact:app", "context:support", "class:app_shell"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} lint"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} typecheck"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} dev"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} preview"
      }
    }
  }
}
