{
  "name": "@vecells/patient-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Patient Web placeholder shell scaffold.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4300",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview --host 127.0.0.1 --port 4400"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@vecells/api-contracts": "workspace:*",
    "@vecells/design-system": "workspace:*",
    "@vecells/domain-kernel": "workspace:*",
    "@vecells/observability": "workspace:*",
    "@vecells/persistent-shell": "workspace:*",
    "@vecells/surface-postures": "workspace:*",
    "@vecells/release-controls": "workspace:*"
  }
}
