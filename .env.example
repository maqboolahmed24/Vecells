# Phase 0 foundation scaffold environment
NODE_ENV=development
VECELLS_ENVIRONMENT=local

# App preview ports
PATIENT_WEB_DEV_PORT=4300
PATIENT_WEB_PREVIEW_PORT=4400
CLINICAL_WORKSPACE_DEV_PORT=4301
CLINICAL_WORKSPACE_PREVIEW_PORT=4401
HUB_DESK_DEV_PORT=4303
HUB_DESK_PREVIEW_PORT=4403
PHARMACY_CONSOLE_DEV_PORT=4304
PHARMACY_CONSOLE_PREVIEW_PORT=4404
SUPPORT_WORKSPACE_DEV_PORT=4305
SUPPORT_WORKSPACE_PREVIEW_PORT=4405
OPS_CONSOLE_DEV_PORT=4302
OPS_CONSOLE_PREVIEW_PORT=4402
GOVERNANCE_CONSOLE_DEV_PORT=4306
GOVERNANCE_CONSOLE_PREVIEW_PORT=4406

# Service ports
API_GATEWAY_PORT=7100
API_GATEWAY_SERVICE_HOST=127.0.0.1
API_GATEWAY_SERVICE_PORT=7100
API_GATEWAY_ADMIN_HOST=127.0.0.1
API_GATEWAY_ADMIN_PORT=7200
COMMAND_API_PORT=7101
COMMAND_API_SERVICE_HOST=127.0.0.1
COMMAND_API_SERVICE_PORT=7101
COMMAND_API_ADMIN_HOST=127.0.0.1
COMMAND_API_ADMIN_PORT=7201
PROJECTION_WORKER_PORT=7102
PROJECTION_WORKER_SERVICE_HOST=127.0.0.1
PROJECTION_WORKER_SERVICE_PORT=7102
PROJECTION_WORKER_ADMIN_HOST=127.0.0.1
PROJECTION_WORKER_ADMIN_PORT=7202
NOTIFICATION_WORKER_PORT=7103
NOTIFICATION_WORKER_SERVICE_HOST=127.0.0.1
NOTIFICATION_WORKER_SERVICE_PORT=7103
NOTIFICATION_WORKER_ADMIN_HOST=127.0.0.1
NOTIFICATION_WORKER_ADMIN_PORT=7203
ADAPTER_SIMULATORS_SERVICE_HOST=127.0.0.1
ADAPTER_SIMULATORS_PORT=7104
ADAPTER_SIMULATORS_SERVICE_PORT=7104
ADAPTER_SIMULATORS_ADMIN_PORT=7204

# Protected internal entrypoint
INTERNAL_ENTRYPOINT_HOST=127.0.0.1
INTERNAL_ENTRYPOINT_PORT=7300
# Required in Render. Generate with:
# INTERNAL_TEST_PASSWORD="replace-me" pnpm --dir services/internal-entrypoint hash-password
INTERNAL_TEST_PASSWORD_HASH=
# Required in Render. Generate outside Git with a cryptographically random value.
SESSION_SECRET=
INTERNAL_ENTRYPOINT_COOKIE_SECURE=false
INTERNAL_DATA_MODE=synthetic-disposable

# Placeholder runtime posture
ENABLE_ASSISTIVE_CONTROL_LAB=false
RELEASE_RING=alpha
OBSERVABILITY_SAMPLE_RATE=1.0
