{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase9/463_security_compliance_export_destination.schema.json",
  "title": "Phase 9 governed security compliance export destination binding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bindingId",
    "destinationClass",
    "destinationKind",
    "tenantRef",
    "environmentRef",
    "frameworkCode",
    "artifactClassesAllowed",
    "policyBinding",
    "artifactPresentationContractRef",
    "outboundNavigationGrantPolicyRef",
    "secretRef",
    "secretMaterialInline",
    "latestVerificationRecord",
    "latestDeliverySettlement"
  ],
  "properties": {
    "schemaVersion": {
      "const": "463.phase9.security-compliance-export-destination.v1"
    },
    "bindingId": {
      "type": "string",
      "pattern": "^export-destination-"
    },
    "destinationClass": {
      "type": "string"
    },
    "destinationKind": {
      "enum": ["security_reporting", "compliance_export"]
    },
    "tenantRef": {
      "type": "string",
      "minLength": 1
    },
    "environmentRef": {
      "type": "string",
      "minLength": 1
    },
    "frameworkCode": {
      "enum": [
        "DSPT",
        "DTAC",
        "DCB0129",
        "DCB0160",
        "NHS_APP_CHANNEL",
        "AUDIT",
        "RECORDS",
        "RESILIENCE",
        "CONFORMANCE",
        "LOCAL_TENANT"
      ]
    },
    "artifactClassesAllowed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "policyBinding": {
      "type": "object",
      "required": [
        "frameworkVersionRef",
        "standardsVersionMapRef",
        "redactionPolicyHash",
        "exportManifestHash",
        "reproductionHash",
        "rawExportUrlsAllowed",
        "unmanagedDownloadAllowed"
      ],
      "properties": {
        "frameworkVersionRef": { "type": "string" },
        "standardsVersionMapRef": { "type": "string" },
        "redactionPolicyHash": { "type": "string", "pattern": "^sha256:" },
        "exportManifestHash": { "type": "string", "pattern": "^sha256:" },
        "reproductionHash": { "type": "string", "pattern": "^sha256:" },
        "rawExportUrlsAllowed": { "const": false },
        "unmanagedDownloadAllowed": { "const": false }
      }
    },
    "artifactPresentationContractRef": {
      "const": "ArtifactPresentationContract"
    },
    "outboundNavigationGrantPolicyRef": {
      "const": "OutboundNavigationGrant"
    },
    "secretRef": {
      "type": "string",
      "pattern": "^vault-ref/"
    },
    "secretMaterialInline": {
      "const": false
    },
    "latestVerificationRecord": {
      "type": "object",
      "required": [
        "status",
        "serializedArtifactHash",
        "redactionPolicyHash",
        "exportManifestHash",
        "reproductionHash",
        "graphHash",
        "outboundGrantRef",
        "syntheticPayloadHash"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "serializedArtifactHash": { "type": "string", "pattern": "^sha256:" },
        "redactionPolicyHash": { "type": "string", "pattern": "^sha256:" },
        "exportManifestHash": { "type": "string", "pattern": "^sha256:" },
        "reproductionHash": { "type": "string", "pattern": "^sha256:" },
        "graphHash": { "type": "string", "pattern": "^sha256:" },
        "outboundGrantRef": {
          "type": "string",
          "pattern": "^outbound-navigation-grant:"
        },
        "syntheticPayloadHash": { "type": "string", "pattern": "^sha256:" }
      }
    },
    "latestDeliverySettlement": {
      "type": "object",
      "required": [
        "result",
        "artifactClass",
        "artifactRef",
        "artifactTransferSettlementRef",
        "outboundNavigationGrantRef",
        "fallbackDisposition",
        "authoritativeTransferState"
      ],
      "properties": {
        "result": {
          "type": "string"
        },
        "artifactClass": {
          "type": "string"
        },
        "artifactRef": {
          "type": "string"
        },
        "artifactTransferSettlementRef": {
          "type": "string",
          "pattern": "^artifact-transfer-settlement:"
        },
        "outboundNavigationGrantRef": {
          "type": "string",
          "pattern": "^outbound-navigation-grant:"
        },
        "fallbackDisposition": {
          "type": "string"
        },
        "authoritativeTransferState": {
          "type": "string"
        }
      }
    }
  }
}
