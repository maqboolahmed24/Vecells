{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_embedded_shell_consistency_projection_schema.json",
  "title": "EmbeddedShellConsistencyProjection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "consistencyId",
    "journeyPathId",
    "patientShellContinuityKey",
    "entityContinuityKey",
    "bundleVersion",
    "audienceTier",
    "governingObjectVersionRefs",
    "selectedAnchorRef",
    "returnContractRef",
    "placeholderContractRefs",
    "continuityEvidenceRefs",
    "currentBridgeCapabilityMatrixRef",
    "patientEmbeddedNavEligibilityRef",
    "shellState",
    "computedAt",
    "staleAt",
    "causalConsistencyState",
    "projectionTrustState"
  ],
  "properties": {
    "consistencyId": {
      "type": "string"
    },
    "journeyPathId": {
      "type": "string"
    },
    "patientShellContinuityKey": {
      "type": "string"
    },
    "entityContinuityKey": {
      "type": "string"
    },
    "bundleVersion": {
      "type": "string"
    },
    "audienceTier": {
      "type": "string"
    },
    "governingObjectVersionRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selectedAnchorRef": {
      "type": "string"
    },
    "returnContractRef": {
      "type": "string"
    },
    "placeholderContractRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "continuityEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "currentBridgeCapabilityMatrixRef": {
      "type": "string"
    },
    "patientEmbeddedNavEligibilityRef": {
      "type": "string"
    },
    "shellState": {
      "type": "string",
      "enum": ["live", "revalidate_only", "recovery_only", "blocked"]
    },
    "computedAt": {
      "type": "string",
      "format": "date-time"
    },
    "staleAt": {
      "type": "string",
      "format": "date-time"
    },
    "causalConsistencyState": {
      "type": "string",
      "enum": ["current", "stale", "conflict", "unknown"]
    },
    "projectionTrustState": {
      "type": "string",
      "enum": ["trusted", "degraded", "hint_only", "blocked"]
    }
  }
}
