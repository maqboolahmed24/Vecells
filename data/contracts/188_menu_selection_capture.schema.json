{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/188_menu_selection_capture.schema.json",
  "title": "MenuSelectionCapture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "menuCaptureRef",
    "callSessionRef",
    "selectedTopLevelPath",
    "rawTransportSourceFamily",
    "normalizedMenuCode",
    "capturedAt",
    "providerEventRef",
    "confidence",
    "parsePosture",
    "branchRepeatCount",
    "correctionOfCaptureRef",
    "maskedCallerContextRef",
    "sessionCorrelationRefs",
    "canonicalEventRef",
    "policyVersionRef",
    "createdByAuthority"
  ],
  "properties": {
    "schemaVersion": { "const": "188.phase2.menu-capture.v1" },
    "menuCaptureRef": { "type": "string", "pattern": "^tel_menu_capture_188_[A-Za-z0-9]+$" },
    "callSessionRef": { "type": "string" },
    "selectedTopLevelPath": { "enum": ["symptoms", "medications", "admin", "results", "unknown"] },
    "rawTransportSourceFamily": { "enum": ["dtmf", "speech", "operator", "simulator", "unknown"] },
    "normalizedMenuCode": {
      "enum": ["MENU_SYMPTOMS", "MENU_MEDS", "MENU_ADMIN", "MENU_RESULTS", "MENU_UNKNOWN"]
    },
    "capturedAt": { "type": "string", "format": "date-time" },
    "providerEventRef": { "type": "string" },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "parsePosture": {
      "enum": ["exact", "speech_confident", "speech_uncertain", "operator_confirmed", "unknown"]
    },
    "branchRepeatCount": { "type": "integer", "minimum": 0 },
    "correctionOfCaptureRef": { "type": ["string", "null"] },
    "maskedCallerContextRef": { "type": ["string", "null"] },
    "sessionCorrelationRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "canonicalEventRef": { "type": "string" },
    "policyVersionRef": { "const": "phase2-call-session-state-machine-188.v1" },
    "createdByAuthority": { "const": "TelephonyCallSessionService" }
  }
}
