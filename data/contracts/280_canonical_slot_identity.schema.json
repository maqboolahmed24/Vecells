{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells://contracts/CanonicalSlotIdentity",
  "title": "CanonicalSlotIdentity",
  "description": "Deduplication-safe canonical slot identity contract.",
  "type": "object",
  "additionalProperties": false,
  "x-taskId": "seq_280",
  "x-contractVersion": "280.phase4.booking-flow-freeze.v1",
  "required": [
    "canonicalSlotIdentityId",
    "supplierRef",
    "capacityUnitRef",
    "scheduleRef",
    "locationRef",
    "practitionerRef",
    "serviceRef",
    "slotStartAtEpoch",
    "slotEndAtEpoch",
    "modality",
    "canonicalTieBreakKey",
    "identityStrength",
    "sourceHash"
  ],
  "properties": {
    "canonicalSlotIdentityId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable canonical slot identity ref."
    },
    "supplierRef": {
      "type": "string",
      "minLength": 1,
      "description": "Supplier ref."
    },
    "supplierSlotRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Supplier-local slot identifier."
    },
    "capacityUnitRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical capacity unit ref."
    },
    "scheduleRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical schedule ref."
    },
    "locationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical location ref."
    },
    "practitionerRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical practitioner or clinician-type ref."
    },
    "serviceRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical service ref."
    },
    "slotStartAtEpoch": {
      "type": "integer",
      "description": "Normalized start epoch milliseconds."
    },
    "slotEndAtEpoch": {
      "type": "integer",
      "description": "Normalized end epoch milliseconds."
    },
    "modality": {
      "type": "string",
      "enum": [
        "in_person",
        "remote"
      ],
      "description": "Canonical modality."
    },
    "canonicalTieBreakKey": {
      "type": "string",
      "minLength": 1,
      "description": "Stable ordering tie-break key."
    },
    "identityStrength": {
      "type": "string",
      "enum": [
        "strong",
        "medium",
        "weak"
      ],
      "description": "Strength of slot-identity proof."
    },
    "sourceHash": {
      "type": "string",
      "minLength": 1,
      "description": "Hash of source-identifying normalized input."
    }
  },
  "x-sourceRefs": [
    "blueprint/phase-4-the-booking-engine.md",
    "blueprint/phase-0-the-foundation-protocol.md"
  ]
}
