{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/191_manual_audio_review_queue_entry.schema.json",
  "title": "ManualAudioReviewQueueEntryContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manualAudioReviewQueueEntryRef",
    "schemaVersion",
    "manualReviewDispositionRef",
    "callSessionRef",
    "triggerClass",
    "reviewMode",
    "reviewState",
    "transcriptReadinessRef",
    "evidenceReadinessAssessmentRef",
    "reasonCodes",
    "createdAt",
    "recordedBy"
  ],
  "properties": {
    "manualAudioReviewQueueEntryRef": {
      "type": "string",
      "pattern": "^manual_audio_review_queue_entry_191_"
    },
    "schemaVersion": { "const": "191.phase2.telephony-readiness.v1" },
    "manualReviewDispositionRef": { "type": "string" },
    "callSessionRef": { "type": "string" },
    "triggerClass": {
      "enum": [
        "recording_missing",
        "transcript_degraded",
        "contradictory_capture",
        "identity_ambiguous",
        "handset_untrusted",
        "urgent_live_without_routine_evidence"
      ]
    },
    "reviewMode": {
      "enum": [
        "audio_review",
        "callback_required",
        "staff_transcription",
        "follow_up_needed",
        "abandon"
      ]
    },
    "reviewState": { "const": "open" },
    "transcriptReadinessRef": { "type": ["string", "null"] },
    "evidenceReadinessAssessmentRef": { "type": ["string", "null"] },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyReadinessPipeline" }
  }
}
