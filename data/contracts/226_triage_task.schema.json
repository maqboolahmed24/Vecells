{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/226_triage_task.schema.json",
  "title": "226 TriageTask",
  "description": "Phase 3 triage-workflow kernel for the staff workspace. Workflow state is explicit and remains separate from ownership, freshness, trust, buffering, and settlement posture.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nullableId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "nullableDateTime": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "required": [
    "taskId",
    "requestId",
    "queueKey",
    "status",
    "reviewVersion",
    "ownershipEpoch",
    "fencingToken",
    "ownershipState",
    "reviewFreshnessState",
    "launchContextRef",
    "workspaceTrustEnvelopeRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "taskCompletionSettlementEnvelopeRef",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "requestId": {
      "$ref": "#/$defs/id"
    },
    "queueKey": {
      "$ref": "#/$defs/id"
    },
    "assignedTo": {
      "$ref": "#/$defs/nullableId"
    },
    "status": {
      "type": "string",
      "enum": [
        "triage_ready",
        "queued",
        "claimed",
        "in_review",
        "awaiting_patient_info",
        "review_resumed",
        "endpoint_selected",
        "escalated",
        "resolved_without_appointment",
        "handoff_pending",
        "closed",
        "reopened"
      ]
    },
    "priorityBand": {
      "type": "string",
      "description": "Queue-ranking and fairness semantics are frozen later by seq_227."
    },
    "dueAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "slaTargetAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "queueEnteredAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "lastMaterialReturnAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "expectedHandleMinutes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "urgencyCarry": {
      "type": "string",
      "description": "Carrier for urgency floor or elevated handling hints."
    },
    "lockState": {
      "type": "string",
      "description": "Operational lock semantics stay conservative here; later queue and ownership work may specialize the values."
    },
    "lockExpiresAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "reviewVersion": {
      "type": "integer",
      "minimum": 0
    },
    "latestEvidenceSnapshotRef": {
      "$ref": "#/$defs/nullableId"
    },
    "currentSafetyPreemptionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "currentSafetyDecisionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "workspaceSafetyInterruptProjectionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "duplicateClusterRef": {
      "$ref": "#/$defs/nullableId"
    },
    "duplicateResolutionDecisionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "duplicateReviewSnapshotRef": {
      "$ref": "#/$defs/nullableId"
    },
    "currentEndpointDecisionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "currentDecisionEpochRef": {
      "$ref": "#/$defs/nullableId"
    },
    "latestDecisionSupersessionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "approvalState": {
      "type": "string",
      "description": "Conservative placeholder frozen in seq_226; detailed approval posture is frozen by seq_228."
    },
    "endpointState": {
      "type": "string",
      "description": "Conservative placeholder frozen in seq_226; detailed endpoint-decision semantics are frozen by seq_228."
    },
    "lifecycleLeaseRef": {
      "$ref": "#/$defs/nullableId"
    },
    "leaseAuthorityRef": {
      "$ref": "#/$defs/nullableId"
    },
    "leaseTtlSeconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "lastHeartbeatAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "fencingToken": {
      "$ref": "#/$defs/id"
    },
    "ownershipEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "staleOwnerRecoveryRef": {
      "$ref": "#/$defs/nullableId"
    },
    "ownershipState": {
      "type": "string",
      "enum": [
        "active",
        "releasing",
        "expired",
        "broken"
      ]
    },
    "reviewFreshnessState": {
      "type": "string",
      "enum": [
        "fresh",
        "queued_updates",
        "review_required"
      ]
    },
    "activeReviewSessionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "activeQueueChangeBatchRef": {
      "$ref": "#/$defs/nullableId"
    },
    "launchContextRef": {
      "$ref": "#/$defs/id"
    },
    "workspaceTrustEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "$ref": "#/$defs/nullableId"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "routeFreezeDispositionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "releaseRecoveryDispositionRef": {
      "$ref": "#/$defs/nullableId"
    },
    "taskCompletionSettlementEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "changedSinceSeenAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    },
    "updatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-workflowStateField": "status",
  "x-orthogonalControlFacts": {
    "workflowStateField": "status",
    "ownershipStateField": "ownershipState",
    "reviewFreshnessStateField": "reviewFreshnessState",
    "bufferStateField": "ReviewSession.bufferState",
    "trustStateField": "WorkspaceTrustEnvelope.envelopeState",
    "focusProtectionField": "WorkspaceFocusProtectionLease.leaseState",
    "settlementAuthorityField": "TaskCommandSettlement.authoritativeOutcomeState"
  },
  "x-canonicalRequestMutationBoundary": {
    "canonicalRequestLifecycleAuthority": "LifecycleCoordinator",
    "triageMutationMode": "signal_only",
    "forbiddenLocalShortcut": "No triage-local UI, route, or BFF may write canonical request workflow state directly."
  },
  "x-governedInvariants": [
    "A task may remain claimed or in_review while reviewFreshnessState = queued_updates or review_required; freshness drift does not create a parallel workflow state.",
    "ownershipState = expired or broken is legal only while a canonical StaleOwnershipRecoveryRecord remains open.",
    "TaskLaunchContext is durable continuity state, not browser-history-only state.",
    "WorkspaceTrustEnvelope remains the sole authority for writable posture and calm completion."
  ]
}
