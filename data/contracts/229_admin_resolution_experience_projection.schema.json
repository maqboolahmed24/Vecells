      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "clinicalMeaningState": {
      "type": "string",
      "enum": [
        "bounded_admin_only",
        "clinician_reentry_required"
      ]
    },
    "operationalFollowUpScope": {
      "type": "string",
      "enum": [
        "bounded_admin_resolution"
      ]
    },
    "adminMutationAuthorityState": {
      "type": "string",
      "enum": [
        "bounded_admin_only",
        "frozen"
      ]
    },
    "boundaryReopenState": {
      "type": "string",
      "enum": [
        "stable",
        "reopen_required",
        "reopened",
        "blocked_pending_review"
      ]
    },
    "releaseState": {
      "type": "string",
      "minLength": 1
    },
    "trustState": {
      "type": "string",
      "enum": [
        "trusted",
        "degraded",
        "quarantined"
      ]
    },
    "visibilityTier": {
      "type": "string",
      "minLength": 1
    },
    "summarySafetyTier": {
      "type": "string",
      "minLength": 1
    },
