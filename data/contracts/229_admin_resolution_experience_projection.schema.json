      "$ref": "#/$defs/id"
    },
    "completionArtifactRef": {
      "$ref": "#/$defs/id"
    },
    "dependencySetRef": {
      "$ref": "#/$defs/id"
    },
    "releaseWatchRef": {
      "$ref": "#/$defs/id"
    },
    "patientShellConsistencyProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "patientEmbeddedSessionProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "staffWorkspaceConsistencyProjectionRef": {
      "$ref": "#/$defs/id"
