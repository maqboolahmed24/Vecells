{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/190_audio_ingest_settlement.schema.json",
  "title": "AudioIngestSettlementContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audioIngestSettlementRef",
    "schemaVersion",
    "recordingFetchJobRef",
    "callSessionRef",
    "providerRecordingRef",
    "quarantineAssessmentRef",
    "objectStorageRef",
    "documentReferenceRef",
    "settlementOutcome",
    "noOrphanGuarantee",
    "callSessionEventType",
    "callSessionEventPayloadRef",
    "reasonCodes",
    "settledAt",
    "recordedBy"
  ],
  "properties": {
    "audioIngestSettlementRef": {
      "type": "string",
      "pattern": "^tel_recording_ingest_settlement_190_"
    },
    "schemaVersion": { "const": "190.phase2.recording-ingest.v1" },
    "recordingFetchJobRef": { "type": "string" },
    "callSessionRef": { "type": "string" },
    "providerRecordingRef": { "type": "string" },
    "quarantineAssessmentRef": { "type": ["string", "null"] },
    "objectStorageRef": { "type": ["string", "null"] },
    "documentReferenceRef": { "type": ["string", "null"] },
    "settlementOutcome": {
      "enum": [
        "governed_audio_ready",
        "recording_missing",
        "manual_audio_review_required",
        "retry_scheduled",
        "blocked_terminal"
      ]
    },
    "noOrphanGuarantee": {
      "enum": [
        "quarantine_only_no_governed_object",
        "governed_object_has_document_reference",
        "retry_without_storage"
      ]
    },
    "callSessionEventType": {
      "enum": [
        "recording_available",
        "manual_followup_requested",
        "recording_fetch_retry_scheduled"
      ]
    },
    "callSessionEventPayloadRef": { "type": "string" },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "settledAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyRecordingIngestPipeline" }
  }
}
