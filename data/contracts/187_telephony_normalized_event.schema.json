{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/187_telephony_normalized_event.schema.json",
  "title": "NormalizedTelephonyEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "canonicalEventId",
    "providerEventFamily",
    "canonicalEventType",
    "ingressSource",
    "providerRef",
    "providerCallRef",
    "providerEventRef",
    "providerPayloadRef",
    "payloadDigest",
    "payloadStorageRule",
    "payloadDisclosureBoundary",
    "idempotencyKeyBasis",
    "idempotencyKey",
    "callSessionRef",
    "edgeCorrelationId",
    "occurredAt",
    "normalizedAt",
    "normalizerVersionRef",
    "normalizedPayload",
    "createdByAuthority"
  ],
  "properties": {
    "schemaVersion": { "const": "187.phase2.telephony-edge.v1" },
    "canonicalEventId": { "type": "string", "pattern": "^tel_evt_187_" },
    "providerEventFamily": {
      "enum": [
        "provider_call_started",
        "provider_menu_input",
        "provider_identity_input",
        "provider_recording_expected",
        "provider_recording_available",
        "provider_recording_timeout",
        "provider_transcript_ready",
        "provider_transcript_failed",
        "provider_call_abandoned",
        "provider_error",
        "provider_continuation_delivery"
      ]
    },
    "canonicalEventType": {
      "enum": [
        "call_started",
        "menu_selection_captured",
        "identity_capture_started",
        "identity_resolved",
        "identity_partial",
        "identity_failed",
        "recording_expected",
        "recording_available",
        "recording_missing",
        "audio_quarantined",
        "transcript_job_queued",
        "transcript_ready",
        "transcript_degraded",
        "evidence_readiness_assessed",
        "urgent_live_preempted",
        "continuation_eligibility_settled",
        "continuation_sent",
        "request_seeded",
        "submission_promoted",
        "call_closed",
        "call_abandoned",
        "provider_error_recorded",
        "manual_review_opened",
        "manual_followup_opened"
      ]
    },
    "ingressSource": { "enum": ["webhook", "polling", "simulator"] },
    "providerRef": { "const": "telephony_provider_simulator" },
    "providerCallRef": { "type": "string", "pattern": "^provider_call_187_" },
    "providerEventRef": { "type": "string", "pattern": "^provider_event_187_" },
    "providerPayloadRef": { "type": "string", "pattern": "^tel_payload_quarantine_187_" },
    "payloadDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "payloadStorageRule": { "const": "normalization_boundary_only" },
    "payloadDisclosureBoundary": { "const": "provider_payload_shape_stops_at_normalizer" },
    "idempotencyKeyBasis": {
      "enum": [
        "provider_event_id_plus_call_session",
        "provider_call_id_plus_event_type_plus_occurred_at",
        "polling_resource_version_plus_call_session",
        "payload_digest_plus_call_session"
      ]
    },
    "idempotencyKey": { "type": "string", "pattern": "^tel_idem_key_187_" },
    "callSessionRef": { "type": "string", "pattern": "^call_session_187_" },
    "sequence": { "type": ["integer", "null"], "minimum": 0 },
    "edgeCorrelationId": { "type": "string", "pattern": "^edge_corr_tel_187_" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "normalizedAt": { "type": "string", "format": "date-time" },
    "normalizerVersionRef": { "const": "telephony-edge-normalizer-187.v1" },
    "normalizedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reasonCodes"],
      "properties": {
        "menuSelection": { "enum": ["symptoms", "medications", "admin", "results", "unknown"] },
        "maskedCallerRef": { "type": "string", "pattern": "^masked_caller_187_" },
        "maskedCallerFragment": { "type": "string" },
        "recordingArtifactRef": { "type": "string", "pattern": "^recording_artifact_187_" },
        "recordingJobRef": { "type": "string", "pattern": "^recording_fetch_job_187_" },
        "providerErrorRef": { "type": "string", "pattern": "^provider_error_187_" },
        "providerStatusClass": { "type": "string" },
        "reasonCodes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "createdByAuthority": { "const": "TelephonyEdgeService" }
  }
}
