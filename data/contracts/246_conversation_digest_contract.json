{
  "schemaVersion": "246.phase3.conversation-digest-settlement.v1",
  "serviceName": "Phase3ConversationDigestSettlementApplication",
  "kernelServiceName": "Phase3ConversationControlService",
  "querySurfaces": [
    "GET /v1/workspace/tasks/{taskId}/conversation-control",
    "GET /v1/me/messages/{clusterId}/conversation-control"
  ],
  "commandRoutes": [
    "POST /internal/v1/conversations/tuples:publish",
    "POST /v1/me/messages/{clusterId}:acquire-composer",
    "POST /v1/me/messages/{clusterId}/composer-leases/{leaseId}:release",
    "POST /internal/v1/conversations/clusters/{clusterId}:recompute-urgent-diversion",
    "POST /internal/v1/workspace/tasks/{taskId}/message-thread/{threadId}:record-conversation-settlement",
    "POST /internal/v1/workspace/tasks/{taskId}/callback-case/{callbackCaseId}:record-conversation-settlement"
  ],
  "tupleContractRef": "data/contracts/246_247_conversation_tuple_contract.json",
  "digestAuthority": {
    "previewFields": [
      "unreadCount",
      "replyNeededState",
      "awaitingReviewState",
      "deliveryDisputeState",
      "deliveryRiskState",
      "authoritativeOutcomeState",
      "repairRequiredState",
      "dominantNextActionRef"
    ],
    "calmnessSources": [
      "ConversationTupleCompatibilitySnapshot",
      "PatientUrgentDiversionState",
      "ConversationCommandSettlement",
      "PatientExperienceContinuityEvidenceProjection(controlCode = conversation_settlement)"
    ],
    "forbiddenSources": [
      "local drafts",
      "scroll position",
      "support local acknowledgement",
      "transport acceptance alone"
    ]
  },
  "composerLaw": {
    "singleLiveComposerPerCluster": true,
    "resumePreserves": [
      "draftRef",
      "selectedAnchorRef",
      "routeIntentBindingRef",
      "experienceContinuityEvidenceRef"
    ]
  },
  "sharedSettlementGrammar": {
    "resultStates": [
      "accepted_in_place",
      "review_pending",
      "awaiting_external",
      "repair_required",
      "stale_recoverable",
      "blocked_policy",
      "denied_scope",
      "expired"
    ],
    "transportStates": [
      "local_only",
      "provider_accepted",
      "provider_rejected",
      "timed_out"
    ],
    "externalObservationStates": [
      "unobserved",
      "delivered",
      "answered",
      "failed",
      "disputed",
      "expired"
    ]
  },
  "staffMutationGuards": {
    "requiresReviewActionLease": true,
    "requiresProtectedCompositionWhenActive": true,
    "protectedModes": [
      "drafting",
      "compare_review",
      "delivery_dispute_review"
    ]
  },
  "recoveryContinuationResults": [
    "repair_required",
    "stale_recoverable",
    "blocked_policy",
    "review_pending"
  ]
}
