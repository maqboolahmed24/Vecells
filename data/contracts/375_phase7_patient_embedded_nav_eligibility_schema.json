{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_patient_embedded_nav_eligibility_schema.json",
  "title": "PatientEmbeddedNavEligibility",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "embeddedNavEligibilityId",
    "journeyPathRef",
    "routeFamilyRef",
    "patientEmbeddedSessionProjectionRef",
    "bridgeCapabilityMatrixRef",
    "minimumBridgeCapabilitiesRef",
    "requiredBridgeActionRefs",
    "allowedBridgeActionRefs",
    "fallbackActionRefs",
    "routeFreezeDispositionRef",
    "continuityEvidenceRef",
    "eligibilityState",
    "evaluatedAt"
  ],
  "properties": {
    "embeddedNavEligibilityId": {
      "type": "string"
    },
    "journeyPathRef": {
      "type": "string"
    },
    "routeFamilyRef": {
      "type": "string"
    },
    "patientEmbeddedSessionProjectionRef": {
      "type": "string"
    },
    "bridgeCapabilityMatrixRef": {
      "type": "string"
    },
    "minimumBridgeCapabilitiesRef": {
      "type": "string"
    },
    "requiredBridgeActionRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowedBridgeActionRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fallbackActionRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routeFreezeDispositionRef": {
      "type": "string"
    },
    "continuityEvidenceRef": {
      "type": "string"
    },
    "eligibilityState": {
      "type": "string",
      "enum": [
        "live",
        "read_only",
        "placeholder_only",
        "safe_browser_handoff",
        "recovery_required",
        "blocked"
      ]
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
