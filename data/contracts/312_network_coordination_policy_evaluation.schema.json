{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_network_coordination_policy_evaluation.schema.json",
  "title": "NetworkCoordinationPolicyEvaluation",
  "description": "Bound evaluation record that carries the five-family policy tuple, separate disposition vocabularies, and the exact `policyTupleHash` used for candidate normalization.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyEvaluationId",
    "hubCoordinationCaseId",
    "evaluationScope",
    "compiledPolicyBundleRef",
    "policyTupleHash",
    "routingPolicyPackRef",
    "varianceWindowPolicyRef",
    "serviceObligationPolicyRef",
    "practiceVisibilityPolicyRef",
    "capacityIngestionPolicyRef",
    "routingDisposition",
    "varianceDisposition",
    "serviceObligationDisposition",
    "practiceVisibilityDisposition",
    "capacityAdmissionDisposition",
    "sourceAdmissionSummary",
    "evaluatedAt",
    "sourceRefs"
  ],
  "properties": {
    "policyEvaluationId": {
      "type": "string",
      "minLength": 1,
      "description": "Evaluation identifier."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub case ref."
    },
    "evaluationScope": {
      "type": "string",
      "enum": [
        "candidate_snapshot"
      ],
      "description": "Current supported evaluation scope."
    },
    "compiledPolicyBundleRef": {
      "type": "string",
      "minLength": 1,
      "description": "CompiledPolicyBundle ref."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Hash of the exact five-family pack refs plus rank versions."
    },
    "routingPolicyPackRef": {
      "type": "string",
      "minLength": 1,
      "description": "Routing policy ref."
    },
    "varianceWindowPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Variance policy ref."
    },
    "serviceObligationPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Service-obligation policy ref."
    },
    "practiceVisibilityPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Practice-visibility policy ref."
    },
    "capacityIngestionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Capacity-ingestion policy ref."
    },
    "routingDisposition": {
      "type": "string",
      "enum": [
        "route_to_network",
        "retain_local",
        "bounce_back_urgent",
        "blocked"
      ],
      "description": "Routing result."
    },
    "varianceDisposition": {
      "type": "string",
      "enum": [
        "inside_required_window",
        "inside_approved_variance_window",
        "outside_window_visible_by_policy",
        "outside_window_blocked"
      ],
      "description": "Variance result."
    },
    "serviceObligationDisposition": {
      "type": "string",
      "enum": [
        "within_obligation",
        "make_up_required",
        "obligation_risk",
        "commissioner_exception_active"
      ],
      "description": "Service-obligation result."
    },
    "practiceVisibilityDisposition": {
      "type": "string",
      "enum": [
        "standard_origin_visibility",
        "visibility_restricted",
        "ack_debt_open",
        "delta_required"
      ],
      "description": "Practice-visibility result."
    },
    "capacityAdmissionDisposition": {
      "type": "string",
      "enum": [
        "trusted_admitted",
        "degraded_callback_only",
        "degraded_diagnostic_only",
        "quarantined_excluded",
        "stale_capacity",
        "missing_capacity"
      ],
      "description": "Capacity-admission result."
    },
    "sourceAdmissionSummary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceRef",
          "sourceTrustState",
          "candidateCount"
        ],
        "properties": {
          "sourceRef": {
            "type": "string",
            "minLength": 1,
            "description": "Capacity source ref."
          },
          "sourceTrustState": {
            "type": "string",
            "enum": [
              "trusted",
              "degraded",
              "quarantined"
            ],
            "description": "Admission trust state for the source."
          },
          "candidateCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Candidates seen from this source."
          }
        }
      },
      "description": "Per-source admission summary."
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Evaluation timestamp."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5C. Enhanced Access policy engine and network capacity ingestion",
    "blueprint/phase-5-the-network-horizon.md#5D. Coordination queue, candidate ranking, and SLA engine",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#ranking-order-and-visible-cues-must-derive-from-persisted-proof",
    "blueprint/phase-0-the-foundation-protocol.md#publication-and-bundle-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#assurance-and-trust-carry-forward",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md"
  ]
}
