{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells://contracts/TemporalNormalizationEnvelope",
  "title": "TemporalNormalizationEnvelope",
  "description": "Timezone, DST, and clock-skew normalization contract for booking slot search and commit.",
  "type": "object",
  "additionalProperties": false,
  "x-taskId": "seq_280",
  "x-contractVersion": "280.phase4.booking-flow-freeze.v1",
  "required": [
    "temporalNormalizationEnvelopeId",
    "slotSearchSessionRef",
    "sourceTimeZone",
    "displayTimeZone",
    "clockSkewMilliseconds",
    "ambiguousLocalTimePolicy",
    "normalizationVersionRef",
    "generatedAt"
  ],
  "properties": {
    "temporalNormalizationEnvelopeId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable normalization-envelope identifier."
    },
    "slotSearchSessionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Owning SlotSearchSession ref."
    },
    "sourceTimeZone": {
      "type": "string",
      "minLength": 1,
      "description": "Supplier or source timezone."
    },
    "displayTimeZone": {
      "type": "string",
      "minLength": 1,
      "description": "Audience-safe normalized timezone."
    },
    "clockSkewMilliseconds": {
      "type": "integer"
    },
    "ambiguousLocalTimePolicy": {
      "type": "string",
      "enum": [
        "prefer_fold_0",
        "prefer_fold_1",
        "require_supplier_offset",
        "reject_until_resolved"
      ],
      "description": "Policy for ambiguous DST local timestamps."
    },
    "dstBoundaryRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "normalizationVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Versioned normalization rule bundle ref."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Normalization timestamp."
    }
  },
  "x-sourceRefs": [
    "blueprint/phase-4-the-booking-engine.md",
    "blueprint/platform-runtime-and-release-blueprint.md"
  ]
}
