{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/171_auth_scope_bundle.schema.json",
  "title": "AuthScopeBundle",
  "description": "Frozen requested-scope, assurance, and consent-copy bundle. The same bundle is bound to authorize request, callback validation, patient copy, and security logging.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authScopeBundleId",
    "schemaVersion",
    "policyVersion",
    "bundleVersion",
    "requestedScopes",
    "assuranceRequirement",
    "consentCopyKey",
    "claimDisclosureClass",
    "patientVisiblePurpose",
    "minimumSessionDecision"
  ],
  "properties": {
    "authScopeBundleId": {
      "type": "string",
      "pattern": "^asb_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "171.phase2.auth-session.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-auth-session-v[0-9]+$"
    },
    "bundleVersion": {
      "type": "string"
    },
    "requestedScopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["openid", "profile", "email", "nhs_login_identity", "offline_access_prohibited"]
      }
    },
    "assuranceRequirement": {
      "type": "string",
      "enum": ["nhs_low", "nhs_p9", "nhs_p5_plus"]
    },
    "consentCopyKey": {
      "type": "string",
      "pattern": "^AUTH_171_COPY_[A-Z0-9_]+$"
    },
    "claimDisclosureClass": {
      "type": "string",
      "enum": ["vault_only", "masked_patient_shell", "support_redacted"]
    },
    "patientVisiblePurpose": {
      "type": "string"
    },
    "minimumSessionDecision": {
      "type": "string",
      "enum": ["create_fresh", "rotate_existing", "reuse_existing", "bounded_recovery"]
    },
    "rawClaimStorageRule": {
      "const": "vault_reference_only"
    }
  }
}
