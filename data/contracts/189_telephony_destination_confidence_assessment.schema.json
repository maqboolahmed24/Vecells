{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/189_telephony_destination_confidence_assessment.schema.json",
  "title": "TelephonyDestinationConfidenceAssessment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "destinationConfidenceAssessmentRef",
    "schemaVersion",
    "policyVersion",
    "callSessionRef",
    "routeSensitivity",
    "candidatePatientRef",
    "calibrationVersionRef",
    "seedCalibrationVersionRef",
    "thresholdProfileRef",
    "alphaDest",
    "destinationFeatureVector",
    "z_dest",
    "P_dest",
    "LCB_dest_alpha",
    "P_seed",
    "LCB_seed_alpha",
    "P_seed_lower",
    "seedLowerBoundMethod",
    "reasonCodes",
    "assessedAt"
  ],
  "properties": {
    "destinationConfidenceAssessmentRef": { "type": "string", "pattern": "^tdca_" },
    "schemaVersion": { "const": "189.phase2.telephony-verification.v1" },
    "policyVersion": { "const": "phase2-telephony-verification-189.v1" },
    "callSessionRef": { "type": "string" },
    "routeSensitivity": { "type": "string" },
    "candidatePatientRef": { "type": ["string", "null"] },
    "calibrationVersionRef": { "const": "Cal_dest_189_synthetic_adjudicated_v1" },
    "seedCalibrationVersionRef": { "const": "no_joint_seed_model_189_v1" },
    "thresholdProfileRef": { "type": "string" },
    "alphaDest": { "type": "number", "minimum": 0, "maximum": 1 },
    "destinationFeatureVector": {
      "type": "object",
      "required": [
        "verified_number_on_patient",
        "handset_step_up_success",
        "fresh_channel_control_proof"
      ],
      "properties": {
        "verified_number_on_patient": { "type": "number", "minimum": 0, "maximum": 1 },
        "handset_step_up_success": { "type": "number", "minimum": 0, "maximum": 1 },
        "fresh_channel_control_proof": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "z_dest": { "type": "number" },
    "P_dest": { "type": "number", "minimum": 0, "maximum": 1 },
    "LCB_dest_alpha": { "type": "number", "minimum": 0, "maximum": 1 },
    "P_seed": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "LCB_seed_alpha": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "P_seed_lower": { "type": "number", "minimum": 0, "maximum": 1 },
    "seedLowerBoundMethod": {
      "enum": ["joint_seed_calibrator", "dependence_safe_frechet_lower_bound"]
    },
    "reasonCodes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TEL_VERIFY_189_" }
    },
    "assessedAt": { "type": "string", "format": "date-time" }
  }
}
