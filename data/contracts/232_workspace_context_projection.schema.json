{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/232_workspace_context_projection.schema.json",
  "title": "232 WorkspaceContextProjectionBundle",
  "description": "Canonical task-scoped workspace read model that binds consistency, slice trust, protected composition, continuity evidence, and trust envelope into one response shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "requestId",
    "queueKey",
    "workspaceRef",
    "staffWorkspaceConsistencyProjection",
    "workspaceSliceTrustProjection",
    "workspaceContinuityEvidenceProjection",
    "workspaceTrustEnvelope"
  ],
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "nullableId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "projectionTrustState": {
      "type": "string",
      "enum": [
        "trusted",
        "degraded",
        "recovery_bound",
        "quarantined"
      ]
    },
    "sliceRenderMode": {
      "type": "string",
      "enum": [
        "interactive",
        "observe_only",
        "recovery_required"
      ]
    },
    "consistencyState": {
      "type": "string",
      "enum": [
        "consistent",
        "stale_recoverable",
        "recovery_required"
      ]
    },
    "compositionValidity": {
      "type": "string",
      "enum": [
        "live",
        "stale_recoverable",
        "recovery_only"
      ]
    },
    "continuityValidationState": {
      "type": "string",
      "enum": [
        "trusted",
        "degraded",
        "stale",
        "blocked"
      ]
    },
    "continuityLaunchState": {
      "type": "string",
      "enum": [
        "trusted_ready",
        "trusted_blocked",
        "degraded",
        "stale",
        "blocked"
      ]
    },
    "anchorContinuityState": {
      "type": "string",
      "enum": [
        "confirmed",
        "stale_remappable",
        "lost_recovery_required"
      ]
    },
    "reasonCode": {
      "type": "string"
    },
    "consistencyProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceConsistencyProjectionId",
        "taskId",
        "requestId",
        "entityContinuityKey",
        "bundleVersion",
        "audienceTier",
        "governingObjectRefs",
        "entityVersionRefs",
        "reviewVersionRef",
        "workspaceSnapshotVersion",
        "computedAt",
        "staleAt",
        "causalConsistencyState",
        "projectionTrustState",
        "blockingReasonRefs"
      ],
      "properties": {
        "workspaceConsistencyProjectionId": {
          "$ref": "#/$defs/id"
        },
        "taskId": {
          "$ref": "#/$defs/id"
        },
        "requestId": {
          "$ref": "#/$defs/id"
        },
        "entityContinuityKey": {
          "$ref": "#/$defs/id"
        },
        "bundleVersion": {
          "type": "integer",
          "minimum": 1
        },
        "audienceTier": {
          "$ref": "#/$defs/id"
        },
        "governingObjectRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "entityVersionRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "queueChangeBatchRef": {
          "$ref": "#/$defs/nullableId"
        },
        "reviewVersionRef": {
          "type": "integer",
          "minimum": 0
        },
        "workspaceSnapshotVersion": {
          "type": "integer",
          "minimum": 0
        },
        "computedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "staleAt": {
          "$ref": "#/$defs/dateTime"
        },
        "causalConsistencyState": {
          "$ref": "#/$defs/consistencyState"
        },
        "projectionTrustState": {
          "$ref": "#/$defs/projectionTrustState"
        },
        "blockingReasonRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reasonCode"
          }
        }
      }
    },
    "sliceTrustProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceSliceTrustProjectionId",
        "taskId",
        "queueSliceTrustState",
        "taskSliceTrustState",
        "attachmentSliceTrustState",
        "assistiveSliceTrustState",
        "dependencySliceTrustState",
        "assuranceSliceTrustRefs",
        "renderMode",
        "blockingDependencyRefs",
        "evaluatedAt"
      ],
      "properties": {
        "workspaceSliceTrustProjectionId": {
          "$ref": "#/$defs/id"
        },
        "taskId": {
          "$ref": "#/$defs/id"
        },
        "queueSliceTrustState": {
          "$ref": "#/$defs/projectionTrustState"
        },
        "taskSliceTrustState": {
          "$ref": "#/$defs/projectionTrustState"
        },
        "attachmentSliceTrustState": {
          "$ref": "#/$defs/projectionTrustState"
        },
        "assistiveSliceTrustState": {
          "$ref": "#/$defs/projectionTrustState"
        },
        "dependencySliceTrustState": {
          "$ref": "#/$defs/projectionTrustState"
        },
        "assuranceSliceTrustRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "renderMode": {
          "$ref": "#/$defs/sliceRenderMode"
        },
        "blockingDependencyRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "evaluatedAt": {
          "$ref": "#/$defs/dateTime"
        }
      }
    },
    "protectedCompositionState": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "protectedCompositionStateId",
        "taskId",
        "focusProtectionLeaseRef",
        "compositionMode",
        "draftArtifactRefs",
        "primarySelectedAnchorRef",
        "compareAnchorRefs",
        "primaryReadingTargetRef",
        "quietReturnTargetRef",
        "allowedLivePatchMode",
        "stateValidity",
        "releaseGateRef",
        "startedAt",
        "blockingReasonRefs"
      ],
      "properties": {
        "protectedCompositionStateId": {
          "$ref": "#/$defs/id"
        },
        "taskId": {
          "$ref": "#/$defs/id"
        },
        "focusProtectionLeaseRef": {
          "$ref": "#/$defs/id"
        },
        "compositionMode": {
          "$ref": "#/$defs/id"
        },
        "draftArtifactRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "primarySelectedAnchorRef": {
          "$ref": "#/$defs/id"
        },
        "compareAnchorRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "assistiveInsertionPointRef": {
          "$ref": "#/$defs/nullableId"
        },
        "primaryReadingTargetRef": {
          "$ref": "#/$defs/id"
        },
        "quietReturnTargetRef": {
          "$ref": "#/$defs/id"
        },
        "allowedLivePatchMode": {
          "$ref": "#/$defs/id"
        },
        "stateValidity": {
          "$ref": "#/$defs/compositionValidity"
        },
        "releaseGateRef": {
          "$ref": "#/$defs/id"
        },
        "startedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "releasedAt": {
          "$ref": "#/$defs/nullableId"
        },
        "invalidatingDriftState": {
          "$ref": "#/$defs/id"
        },
        "blockingReasonRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reasonCode"
          }
        }
      }
    },
    "continuityProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceContinuityEvidenceProjectionId",
        "taskId",
        "controlCode",
        "routeFamilyRef",
        "routeContinuityEvidenceContractRef",
        "selectedAnchorRef",
        "selectedAnchorTupleHashRef",
        "surfacePublicationRef",
        "runtimePublicationBundleRef",
        "sourceQueueRankSnapshotRef",
        "latestTaskCompletionSettlementRef",
        "experienceContinuityEvidenceRef",
        "continuityTupleHash",
        "validationState",
        "nextTaskLaunchState",
        "blockingRefs",
        "anchorContinuityState",
        "capturedAt"
      ],
      "properties": {
        "workspaceContinuityEvidenceProjectionId": {
          "$ref": "#/$defs/id"
        },
        "taskId": {
          "$ref": "#/$defs/id"
        },
        "controlCode": {
          "const": "workspace_task_completion"
        },
        "routeFamilyRef": {
          "$ref": "#/$defs/id"
        },
        "routeContinuityEvidenceContractRef": {
          "$ref": "#/$defs/id"
        },
        "selectedAnchorRef": {
          "$ref": "#/$defs/id"
        },
        "selectedAnchorTupleHashRef": {
          "$ref": "#/$defs/id"
        },
        "surfacePublicationRef": {
          "$ref": "#/$defs/id"
        },
        "runtimePublicationBundleRef": {
          "$ref": "#/$defs/id"
        },
        "sourceQueueRankSnapshotRef": {
          "$ref": "#/$defs/id"
        },
        "latestTaskCompletionSettlementRef": {
          "$ref": "#/$defs/id"
        },
        "latestPrefetchWindowRef": {
          "$ref": "#/$defs/nullableId"
        },
        "latestNextTaskLaunchLeaseRef": {
          "$ref": "#/$defs/nullableId"
        },
        "experienceContinuityEvidenceRef": {
          "$ref": "#/$defs/id"
        },
        "continuityTupleHash": {
          "$ref": "#/$defs/id"
        },
        "validationState": {
          "$ref": "#/$defs/continuityValidationState"
        },
        "nextTaskLaunchState": {
          "$ref": "#/$defs/continuityLaunchState"
        },
        "blockingRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reasonCode"
          }
        },
        "anchorContinuityState": {
          "$ref": "#/$defs/anchorContinuityState"
        },
        "anchorRepairTargetRef": {
          "$ref": "#/$defs/nullableId"
        },
        "capturedAt": {
          "$ref": "#/$defs/dateTime"
        }
      }
    }
  },
  "properties": {
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "requestId": {
      "$ref": "#/$defs/id"
    },
    "queueKey": {
      "$ref": "#/$defs/id"
    },
    "workspaceRef": {
      "$ref": "#/$defs/id"
    },
    "staffWorkspaceConsistencyProjection": {
      "$ref": "#/$defs/consistencyProjection"
    },
    "workspaceSliceTrustProjection": {
      "$ref": "#/$defs/sliceTrustProjection"
    },
    "protectedCompositionState": {
      "$ref": "#/$defs/protectedCompositionState"
    },
    "workspaceContinuityEvidenceProjection": {
      "$ref": "#/$defs/continuityProjection"
    },
    "workspaceTrustEnvelope": {
      "$ref": "https://vecells.local/contracts/232_workspace_trust_envelope.schema.json"
    }
  }
}
