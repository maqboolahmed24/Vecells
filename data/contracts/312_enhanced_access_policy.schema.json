{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_enhanced_access_policy.schema.json",
  "title": "EnhancedAccessPolicy",
  "description": "Compiled Phase 5 Enhanced Access policy tuple root carrying all five policy-family packs plus the current ranking plan refs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyId",
    "policyVersion",
    "policyState",
    "compiledPolicyBundleRef",
    "policyTupleHash",
    "effectiveAt",
    "pcnRef",
    "weeklyMinutesPer1000AdjustedPopulation",
    "networkStandardHours",
    "routingPolicyPackRef",
    "varianceWindowPolicyRef",
    "serviceObligationPolicyRef",
    "practiceVisibilityPolicyRef",
    "capacityIngestionPolicyRef",
    "rankPlanVersionRef",
    "uncertaintyModelVersionRef",
    "sourceRefs"
  ],
  "properties": {
    "policyId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable EnhancedAccessPolicy identifier."
    },
    "policyVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Versioned policy identifier."
    },
    "policyState": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "superseded"
      ],
      "description": "Lifecycle state."
    },
    "compiledPolicyBundleRef": {
      "type": "string",
      "minLength": 1,
      "description": "CompiledPolicyBundle ref."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Hash of the exact five-family tuple plus ranking versions."
    },
    "effectiveAt": {
      "type": "string",
      "format": "date-time",
      "description": "Policy effective start."
    },
    "effectiveUntil": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Policy effective end."
    },
    "pcnRef": {
      "type": "string",
      "minLength": 1,
      "description": "Owning PCN or network scope."
    },
    "weeklyMinutesPer1000AdjustedPopulation": {
      "type": "integer",
      "minimum": 0,
      "description": "Required Enhanced Access minutes per 1,000 adjusted population per week."
    },
    "networkStandardHours": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weekdayStartLocal",
        "weekdayEndLocal",
        "saturdayStartLocal",
        "saturdayEndLocal"
      ],
      "properties": {
        "weekdayStartLocal": {
          "type": "string",
          "minLength": 1,
          "description": "Weekday network standard hour start."
        },
        "weekdayEndLocal": {
          "type": "string",
          "minLength": 1,
          "description": "Weekday network standard hour end."
        },
        "saturdayStartLocal": {
          "type": "string",
          "minLength": 1,
          "description": "Saturday network standard hour start."
        },
        "saturdayEndLocal": {
          "type": "string",
          "minLength": 1,
          "description": "Saturday network standard hour end."
        }
      },
      "description": "Published network standard hours carried as policy facts."
    },
    "sameDayOnlineBookingRule": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable rule ref for same-day online booking when no triage is required."
    },
    "comparableOfferRule": {
      "type": "string",
      "minLength": 1,
      "description": "Rule ref that every PCN patient receives a comparable offer."
    },
    "routingPolicyPackRef": {
      "type": "string",
      "minLength": 1,
      "description": "Routing policy pack ref."
    },
    "varianceWindowPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Variance policy pack ref."
    },
    "serviceObligationPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Service-obligation policy pack ref."
    },
    "practiceVisibilityPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Practice-visibility policy pack ref."
    },
    "capacityIngestionPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Capacity-ingestion policy pack ref."
    },
    "rankPlanVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current rank-plan version ref."
    },
    "uncertaintyModelVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current uncertainty-model version ref."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Local blueprint refs that grounded the compiled tuple."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5C. Enhanced Access policy engine and network capacity ingestion",
    "blueprint/phase-5-the-network-horizon.md#5D. Coordination queue, candidate ranking, and SLA engine",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#ranking-order-and-visible-cues-must-derive-from-persisted-proof",
    "blueprint/phase-0-the-foundation-protocol.md#publication-and-bundle-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#assurance-and-trust-carry-forward",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md"
  ]
}
