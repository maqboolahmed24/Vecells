{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_duty_escalation_record.schema.json",
  "title": "228 DutyEscalationRecord",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "dutyEscalationRecordId",
    "taskId",
    "decisionEpochRef",
    "endpointDecisionRef",
    "triggerMode",
    "triggerReasonCode",
    "severityBand",
    "urgentTaskRef",
    "escalationState",
    "openedAt"
  ],
  "properties": {
    "dutyEscalationRecordId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "endpointDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "triggerMode": {
      "type": "string",
      "enum": [
        "reviewer_manual",
        "residual_high_risk",
        "safety_preemption",
        "supervisor_override"
      ]
    },
    "triggerReasonCode": {
      "type": "string"
    },
    "severityBand": {
      "type": "string",
      "enum": [
        "urgent",
        "critical"
      ]
    },
    "urgentTaskRef": {
      "$ref": "#/$defs/id"
    },
    "currentUrgentContactAttemptRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "currentUrgentEscalationOutcomeRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "escalationState": {
      "type": "string",
      "enum": [
        "active",
        "contact_in_progress",
        "direct_outcome_recorded",
        "handoff_pending",
        "returned_to_triage",
        "cancelled",
        "expired"
      ]
    },
    "openedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "closedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "x-governedInvariants": [
    "Urgent escalation is a first-class domain record, not a note or banner.",
    "Every urgent escalation remains bound to the current unsuperseded DecisionEpoch until it resolves, hands off, or returns to triage."
  ]
}
