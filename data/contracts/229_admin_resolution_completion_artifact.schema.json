{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_admin_resolution_completion_artifact.schema.json",
  "title": "229 AdminResolutionCompletionArtifact",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adminResolutionCompletionArtifactId",
    "adminResolutionCaseRef",
    "completionType",
    "completionEvidenceRefs",
    "patientExpectationTemplateRef",
    "patientVisibleSummaryRef",
    "artifactPresentationContractRef",
    "artifactByteGrantRefs",
    "outboundNavigationGrantRefs",
    "releaseState",
    "visibilityTier",
    "summarySafetyTier",
    "placeholderContractRef",
    "communicationDispatchRefs",
    "deliveryOutcomeRefs",
    "reopenPolicyRef",
    "artifactState",
    "recordedAt"
  ],
  "properties": {
    "adminResolutionCompletionArtifactId": {
      "$ref": "#/$defs/id"
    },
    "adminResolutionCaseRef": {
      "$ref": "#/$defs/id"
    },
    "completionType": {
      "type": "string",
      "enum": [
        "document_issued",
        "form_submitted",
        "result_notice_delivered",
        "medication_admin_answered",
        "demographics_updated",
        "routed_task_disposition_recorded"
      ]
    },
    "completionEvidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "patientExpectationTemplateRef": {
      "$ref": "#/$defs/id"
    },
    "patientVisibleSummaryRef": {
      "$ref": "#/$defs/id"
    },
    "artifactPresentationContractRef": {
      "$ref": "#/$defs/id"
    },
    "artifactByteGrantRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "outboundNavigationGrantRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "releaseState": {
      "type": "string",
      "minLength": 1
    },
    "visibilityTier": {
      "type": "string",
      "minLength": 1
    },
    "summarySafetyTier": {
      "type": "string",
      "minLength": 1
    },
    "placeholderContractRef": {
      "$ref": "#/$defs/id"
    },
    "communicationDispatchRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "deliveryOutcomeRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "reopenPolicyRef": {
      "$ref": "#/$defs/id"
    },
    "artifactState": {
      "type": "string",
      "enum": [
        "draft",
        "recorded",
        "delivered",
        "disputed",
        "superseded"
      ]
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "AdminResolutionCompletionArtifact is the typed proof of completion and patient-visible consequence.",
    "Admin settlement result completed is invalid without a matching completion artifact."
  ]
}
