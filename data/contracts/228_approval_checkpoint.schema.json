{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_approval_checkpoint.schema.json",
  "title": "228 ApprovalCheckpoint",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "checkpointId",
    "taskId",
    "decisionEpochRef",
    "actionType",
    "state",
    "approvalRequirementAssessmentRef",
    "requestedBy",
    "requestedAt",
    "lifecycleLeaseRef",
    "leaseAuthorityRef",
    "leaseTtlSeconds",
    "lastHeartbeatAt",
    "fencingToken",
    "ownershipEpoch"
  ],
  "properties": {
    "checkpointId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "actionType": {
      "type": "string",
      "enum": [
        "submit_endpoint",
        "issue_direct_resolution",
        "commit_admin_resolution",
        "commit_self_care",
        "commit_escalation_override"
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "not_required",
        "required",
        "pending",
        "approved",
        "rejected",
        "superseded"
      ]
    },
    "approvalRequirementAssessmentRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "requestedBy": {
      "$ref": "#/$defs/id"
    },
    "requestedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "approvedBy": {
      "type": [
        "string",
        "null"
      ]
    },
    "approvedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "rejectedBy": {
      "type": [
        "string",
        "null"
      ]
    },
    "rejectedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "rejectionReason": {
      "type": [
        "string",
        "null"
      ]
    },
    "invalidationReasonClass": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        null,
        "endpoint_changed",
        "payload_changed",
        "patient_reply",
        "duplicate_resolution",
        "publication_drift",
        "trust_drift",
        "epoch_superseded",
        "manual_replace"
      ]
    },
    "supersedesCheckpointRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "supersededByCheckpointRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "lifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "leaseAuthorityRef": {
      "$ref": "#/$defs/id"
    },
    "leaseTtlSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "lastHeartbeatAt": {
      "$ref": "#/$defs/dateTime"
    },
    "fencingToken": {
      "$ref": "#/$defs/id"
    },
    "ownershipEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "staleOwnerRecoveryRef": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-governedInvariants": [
    "ApprovalCheckpoint is bound to one DecisionEpoch, not generic task context.",
    "Any material decision drift, patient reply, duplicate change, or trust/publication replacement must supersede prior approval instead of silently reusing it."
  ]
}
