{
  "schemaVersion": "244.phase3.clinician-message-domain.v1",
  "serviceName": "Phase3ClinicianMessageDomainApplication",
  "ownedObjects": [
    "ClinicianMessageThread",
    "MessageDispatchEnvelope",
    "MessageDeliveryEvidenceBundle",
    "ThreadExpectationEnvelope",
    "ThreadResolutionGate",
    "MessagePatientReply"
  ],
  "querySurfaces": [
    "GET /v1/workspace/tasks/{taskId}/message-thread"
  ],
  "mutationRouteIds": [
    "workspace_task_create_message_thread",
    "workspace_task_save_message_draft",
    "workspace_task_approve_message_draft",
    "workspace_task_send_message_thread",
    "workspace_task_record_message_provider_receipt",
    "workspace_task_record_message_delivery_evidence",
    "workspace_task_ingest_message_reply",
    "workspace_task_settle_message_resolution_gate",
    "workspace_task_reopen_message_thread"
  ],
  "threadStates": [
    "drafted",
    "approved",
    "sent",
    "delivered",
    "delivery_failed",
    "delivery_disputed",
    "patient_replied",
    "awaiting_clinician_review",
    "contact_route_repair_pending",
    "escalated_to_callback",
    "closed",
    "reopened"
  ],
  "expectationStates": [
    "reply_needed",
    "awaiting_review",
    "reviewed",
    "reply_blocked",
    "delivery_repair_required",
    "closed"
  ],
  "resolutionDecisions": [
    "await_reply",
    "review_pending",
    "escalate_to_callback",
    "close",
    "reopen",
    "repair_route"
  ],
  "dispatchNaturalKey": [
    "threadRef",
    "threadVersionRef",
    "dispatchFenceEpoch"
  ],
  "outboxEffectTypes": [
    "projection_refresh",
    "reply_assimilation",
    "callback_escalation"
  ],
  "governedInvariants": [
    "MessageDispatchEnvelope is the sole send authority for one thread version and one dispatch fence.",
    "Provider acceptance alone cannot produce delivered, reviewed, or closed posture.",
    "ThreadExpectationEnvelope is the only patient-facing expectation authority.",
    "ThreadResolutionGate is the only close, reopen, repair-route, and callback-escalation authority.",
    "Patient replies enter ClinicianMessageThread before later 237 assimilation or resafety preemption."
  ]
}
