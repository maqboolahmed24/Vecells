{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecell.local/contracts/459_compliance_ledger_projection.schema.json",
  "title": "Task 459 Compliance Ledger Projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "schemaVersion",
    "route",
    "visualMode",
    "scenarioState",
    "selectedFrameworkCode",
    "selectedControlRef",
    "ledgerRows",
    "gapQueue",
    "evidenceGraphMiniMap",
    "ownerBurden",
    "gapQueueFilterSet",
    "resolutionActionPreview",
    "graphBlocker",
    "safeHandoffLinks",
    "actionControlState",
    "noRawArtifactUrls",
    "interfaceGapArtifactRef"
  ],
  "properties": {
    "taskId": { "const": "par_459" },
    "schemaVersion": { "const": "459.phase9.compliance-ledger-and-gap-queue.v1" },
    "route": { "const": "/ops/assurance" },
    "visualMode": { "const": "Compliance_Ledger_Calm_Accountability" },
    "scenarioState": {
      "enum": [
        "exact",
        "normal",
        "stable_service",
        "empty",
        "stale",
        "degraded",
        "quarantined",
        "blocked",
        "permission_denied",
        "freeze",
        "settlement_pending",
        "graph_drift",
        "overdue_owner"
      ]
    },
    "selectedFrameworkCode": {
      "enum": [
        "DSPT",
        "DTAC",
        "DCB0129",
        "DCB0160",
        "NHS_APP_CHANNEL",
        "IM1_CHANGE",
        "LOCAL_TENANT"
      ]
    },
    "selectedControlRef": { "type": "string", "minLength": 1 },
    "ledgerRows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "controlStatusSnapshotId",
          "assuranceControlRecordRef",
          "controlRef",
          "status",
          "ownerRef",
          "latestEvidenceRef",
          "coverageScore",
          "graphVerdictState",
          "artifactRefs",
          "selected"
        ],
        "properties": {
          "controlStatusSnapshotId": { "type": "string" },
          "assuranceControlRecordRef": { "type": "string" },
          "controlRef": { "type": "string" },
          "status": {
            "enum": ["satisfied", "warning", "missing", "exception", "expired", "blocked"]
          },
          "ownerRef": { "type": "string" },
          "latestEvidenceRef": { "type": "string" },
          "coverageScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "graphVerdictState": { "enum": ["complete", "stale", "blocked"] },
          "artifactRefs": { "type": "array", "items": { "type": "string" } },
          "selected": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "gapQueue": {
      "type": "object",
      "required": ["queueState", "graphVerdictState", "items"],
      "properties": {
        "queueState": {
          "enum": ["empty", "triage", "diagnostic_only", "blocked", "metadata_only"]
        },
        "graphVerdictState": { "enum": ["complete", "stale", "blocked"] },
        "items": { "type": "array" }
      },
      "additionalProperties": true
    },
    "evidenceGraphMiniMap": { "type": "object" },
    "ownerBurden": { "type": "object" },
    "gapQueueFilterSet": { "type": "object" },
    "resolutionActionPreview": {
      "type": "object",
      "required": ["actionAllowed", "actionControlState", "rawArtifactUrlSuppressed"],
      "properties": {
        "actionAllowed": { "type": "boolean" },
        "actionControlState": {
          "enum": [
            "review_ready",
            "diagnostic_only",
            "blocked",
            "metadata_only",
            "owner_review_only"
          ]
        },
        "rawArtifactUrlSuppressed": { "const": true }
      },
      "additionalProperties": true
    },
    "graphBlocker": { "type": "object" },
    "safeHandoffLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["targetSurface", "route", "rawArtifactUrlSuppressed"],
        "properties": {
          "targetSurface": {
            "enum": [
              "assurance_pack_preview",
              "incident_desk",
              "capa_tracker",
              "tenant_governance",
              "records_lifecycle",
              "resilience_evidence"
            ]
          },
          "route": { "type": "string", "pattern": "^/ops" },
          "rawArtifactUrlSuppressed": { "const": true }
        },
        "additionalProperties": true
      }
    },
    "actionControlState": {
      "enum": ["review_ready", "diagnostic_only", "blocked", "metadata_only", "owner_review_only"]
    },
    "noRawArtifactUrls": { "const": true },
    "interfaceGapArtifactRef": {
      "const": "PHASE9_BATCH_458_472_INTERFACE_GAP_459_COMPLIANCE_LEDGER_PROJECTION"
    }
  }
}
