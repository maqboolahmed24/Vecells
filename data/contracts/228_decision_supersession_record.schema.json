{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_decision_supersession_record.schema.json",
  "title": "228 DecisionSupersessionRecord",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "decisionSupersessionRecordId",
    "taskId",
    "supersededDecisionEpochRef",
    "replacementDecisionEpochRef",
    "supersededDecisionRef",
    "replacementDecisionRef",
    "reasonClass",
    "reasonRefs",
    "triggeringArtifactRefs",
    "recordedAt"
  ],
  "properties": {
    "decisionSupersessionRecordId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "supersededDecisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "replacementDecisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "supersededDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "replacementDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "reasonClass": {
      "type": "string",
      "enum": [
        "evidence_delta",
        "safety_delta",
        "duplicate_resolution",
        "approval_invalidation",
        "policy_drift",
        "publication_drift",
        "trust_downgrade",
        "identity_drift",
        "ownership_drift",
        "reopen",
        "manual_replace"
      ]
    },
    "reasonRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "triggeringArtifactRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "DecisionSupersessionRecord is the replayable explanation for why a once-live consequence rail became stale, blocked, or recovery-only."
  ]
}
