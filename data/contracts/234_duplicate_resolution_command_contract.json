{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/234_duplicate_resolution_command_contract.json",
  "title": "234 DuplicateResolutionDecisionCommandContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "duplicateReviewSnapshotRef",
    "decisionClass",
    "winningPairEvidenceRef",
    "reviewMode",
    "reasonCodes",
    "decidedByRef",
    "decidedAt"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "duplicateReviewSnapshotRef": {
      "type": "string",
      "minLength": 1
    },
    "decisionClass": {
      "type": "string",
      "enum": [
        "exact_retry_collapse",
        "same_request_attach",
        "same_episode_link",
        "related_episode_link",
        "separate_request",
        "review_required"
      ]
    },
    "winningPairEvidenceRef": {
      "type": "string",
      "minLength": 1
    },
    "continuityWitnessClass": {
      "type": "string",
      "enum": [
        "deterministic_replay",
        "submit_lineage",
        "workflow_return",
        "more_info_cycle",
        "telephony_continuation",
        "human_review",
        "none"
      ]
    },
    "continuityWitnessRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviewMode": {
      "type": "string",
      "enum": [
        "auto",
        "human_review",
        "replay_authority"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decidedByRef": {
      "type": "string",
      "minLength": 1
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    },
    "targetRequestRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "targetEpisodeRef": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-governedInvariants": [
    "Duplicate resolution commands must consume the latest DuplicateReviewSnapshot and one explicit winning pair evidence ref.",
    "same_request_attach requires an explicit continuity witness; score alone is insufficient.",
    "The command path is append-only and may supersede prior duplicate truth, but it may not rewrite earlier evidence or decisions in place."
  ]
}
