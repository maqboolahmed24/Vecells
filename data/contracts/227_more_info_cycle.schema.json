{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_more_info_cycle.schema.json",
  "title": "227 MoreInfoCycle",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "cycleId",
    "taskId",
    "questionSetVersion",
    "channel",
    "sentAt",
    "dueAt",
    "lateReplyReviewUntilAt",
    "state",
    "replyWindowPolicyRef",
    "replyWindowCheckpointRef",
    "reminderScheduleRef",
    "reminderCount",
    "lifecycleLeaseRef",
    "leaseAuthorityRef",
    "leaseTtlSeconds",
    "lastHeartbeatAt",
    "fencingToken",
    "ownershipEpoch"
  ],
  "properties": {
    "cycleId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "questionSetVersion": {
      "$ref": "#/$defs/id"
    },
    "channel": {
      "type": "string"
    },
    "sentAt": {
      "$ref": "#/$defs/dateTime"
    },
    "dueAt": {
      "$ref": "#/$defs/dateTime"
    },
    "lateReplyReviewUntilAt": {
      "$ref": "#/$defs/dateTime"
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "awaiting_delivery",
        "awaiting_patient_reply",
        "awaiting_late_review",
        "response_received",
        "review_resumed",
        "expired",
        "superseded",
        "cancelled"
      ]
    },
    "replyWindowPolicyRef": {
      "$ref": "#/$defs/id"
    },
    "replyWindowCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "reminderScheduleRef": {
      "$ref": "#/$defs/id"
    },
    "latestReminderAttemptRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "latestResponseDispositionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "responseSnapshotRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "supersedesCycleRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "supersededByCycleRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "responseRouteIntentBindingRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "requestReturnBundleRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "reachabilityDependencyRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "reminderCount": {
      "type": "integer",
      "minimum": 0
    },
    "lifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "leaseAuthorityRef": {
      "$ref": "#/$defs/id"
    },
    "leaseTtlSeconds": {
      "type": "integer",
      "minimum": 1
    },
    "lastHeartbeatAt": {
      "$ref": "#/$defs/dateTime"
    },
    "fencingToken": {
      "$ref": "#/$defs/id"
    },
    "ownershipEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "staleOwnerRecoveryRef": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-dueAuthority": "MoreInfoReplyWindowCheckpoint",
  "x-governedInvariants": [
    "MoreInfoCycle.dueAt is derived from the current MoreInfoReplyWindowCheckpoint and is not an independently editable timer.",
    "Exactly one actionable checkpoint may govern a lineage at a time."
  ]
}
