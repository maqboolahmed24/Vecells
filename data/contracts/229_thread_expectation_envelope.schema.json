{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_thread_expectation_envelope.schema.json",
  "title": "229 ThreadExpectationEnvelope",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "threadExpectationId",
    "threadRef",
    "reachabilityDependencyRef",
    "contactRepairJourneyRef",
    "identityRepairBranchDispositionRef",
    "patientVisibleState",
    "replyWindowRef",
    "deliveryRiskState",
    "stateConfidenceBand",
    "fallbackGuidanceRef",
    "routeIntentBindingRef",
    "requiredReleaseApprovalFreezeRef",
    "channelReleaseFreezeState",
    "requiredAssuranceSliceTrustRefs",
    "latestSupportActionSettlementRef",
    "transitionEnvelopeRef",
    "continuityEvidenceRef",
    "freezeDispositionRef",
    "causalToken",
    "monotoneRevision"
  ],
  "properties": {
    "threadExpectationId": {
      "$ref": "#/$defs/id"
    },
    "threadRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "contactRepairJourneyRef": {
      "$ref": "#/$defs/id"
    },
    "identityRepairBranchDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "patientVisibleState": {
      "type": "string",
      "enum": [
        "reply_needed",
        "awaiting_review",
        "reviewed",
        "reply_blocked",
        "delivery_repair_required",
        "closed"
      ]
    },
    "replyWindowRef": {
      "$ref": "#/$defs/id"
    },
    "deliveryRiskState": {
      "type": "string",
      "enum": [
        "on_track",
        "at_risk",
        "likely_failed",
        "disputed"
      ]
    },
    "stateConfidenceBand": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "fallbackGuidanceRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "requiredReleaseApprovalFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "channelReleaseFreezeState": {
      "type": "string",
      "enum": [
        "permitted",
        "guarded",
        "blocked"
      ]
    },
    "requiredAssuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "latestSupportActionSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "continuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "freezeDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    }
  },
  "x-governedInvariants": [
    "ThreadExpectationEnvelope is the sole patient-facing reply, repair, and awaiting-review posture.",
    "Delivery confidence may widen pending or repair guidance but may never manufacture delivered, reviewed, or closed truth without evidence and resolution."
  ]
}
