{
  "schemaVersion": "247.phase3.patient-conversation-tuple.v1",
  "serviceName": "Phase3PatientConversationProjectionApplication",
  "tupleContractRef": "data/contracts/246_247_conversation_tuple_contract.json",
  "querySurfaces": [
    "GET /v1/workspace/tasks/{taskId}/patient-conversation",
    "GET /v1/me/messages/{clusterId}/threading"
  ],
  "refreshRoute": "POST /internal/v1/workspace/tasks/{taskId}:refresh-patient-conversation",
  "backfillRoute": "POST /internal/v1/conversations/legacy-history:backfill",
  "projectionFamilies": [
    "PatientConversationCluster",
    "CommunicationEnvelope",
    "ConversationSubthreadProjection",
    "ConversationThreadProjection",
    "PatientCommunicationVisibilityProjection",
    "PatientReceiptEnvelope"
  ],
  "audienceTiers": [
    "patient_public",
    "patient_authenticated",
    "secure_link_recovery",
    "embedded_authenticated"
  ],
  "previewModes": [
    "public_safe_summary",
    "authenticated_summary",
    "step_up_required",
    "suppressed_recovery_only"
  ],
  "tuplePreviewCompatibility": {
    "public_safe_summary": "public_safe_summary",
    "authenticated_summary": "full",
    "step_up_required": "step_up_required",
    "suppressed_recovery_only": "suppressed_recovery_only"
  },
  "backfillPolicy": "Legacy callback or clinician-message history must enter placeholder or recovery posture before calm settled copy is permitted."
}
