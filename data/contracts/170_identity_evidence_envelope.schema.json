{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/170_identity_evidence_envelope.schema.json",
  "title": "IdentityEvidenceEnvelope",
  "description": "Append-only vault envelope for identity evidence. Hot operational rows, UI events, and route profiles may hold only references, digests, classes, and masked display hints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identityEvidenceEnvelopeId",
    "schemaVersion",
    "policyVersion",
    "vaultRef",
    "evidenceKind",
    "sourceChannel",
    "subjectRef",
    "claimDigest",
    "maskedDisplay",
    "keyVersionRef",
    "appendOnlySequence",
    "disclosureClass",
    "retentionClass",
    "createdAt"
  ],
  "properties": {
    "identityEvidenceEnvelopeId": {
      "type": "string",
      "pattern": "^iev_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "170.phase2.trust.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-trust-v[0-9]+$"
    },
    "vaultRef": {
      "type": "string",
      "description": "Opaque pointer to encrypted vault storage."
    },
    "evidenceKind": {
      "type": "string",
      "enum": [
        "nhs_login_claim_digest",
        "sms_seed_digest",
        "secure_link_digest",
        "telephony_capture_digest",
        "staff_assertion_digest",
        "system_repair_signal"
      ]
    },
    "sourceChannel": {
      "type": "string",
      "enum": ["web", "nhs_login", "sms", "secure_link", "ivr", "staff", "system"]
    },
    "subjectRef": {
      "type": "string",
      "description": "Opaque subject, draft, or request reference used for joins outside the vault."
    },
    "claimDigest": {
      "type": "string",
      "description": "Salted digest of the evidence payload used for dedupe and audit correlation."
    },
    "maskedDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "maskedContact", "confidenceHint"],
      "properties": {
        "label": {
          "type": "string"
        },
        "maskedContact": {
          "type": "string"
        },
        "confidenceHint": {
          "type": "string",
          "enum": ["none", "seeded", "asserted", "verified", "manual_review"]
        }
      }
    },
    "keyVersionRef": {
      "type": "string"
    },
    "appendOnlySequence": {
      "type": "integer",
      "minimum": 1
    },
    "previousEnvelopeRef": {
      "type": "string"
    },
    "disclosureClass": {
      "type": "string",
      "enum": ["vault_internal", "masked_operational", "support_redacted", "audit_only"]
    },
    "retentionClass": {
      "type": "string",
      "enum": ["identity_binding_evidence", "continuation_seed", "repair_signal", "audit_worm"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdByAuthority": {
      "type": "string",
      "enum": ["IdentityBindingAuthority", "IdentityEvidenceVault"]
    }
  }
}
