{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_advice_follow_up_watch_window.schema.json",
  "title": "229 AdviceFollowUpWatchWindow",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adviceFollowUpWatchWindowId",
    "requestRef",
    "adviceBundleVersionRef",
    "watchStartAt",
    "watchUntil",
    "recontactThresholdRef",
    "escalationThresholdRef",
    "rollbackReviewState",
    "watchRevision",
    "assuranceSliceTrustRefs",
    "watchState",
    "latestReviewOutcomeRef",
    "linkedAnalyticsRefs"
  ],
  "properties": {
    "adviceFollowUpWatchWindowId": {
      "$ref": "#/$defs/id"
    },
    "requestRef": {
      "$ref": "#/$defs/id"
    },
    "adviceBundleVersionRef": {
      "$ref": "#/$defs/id"
    },
    "watchStartAt": {
      "$ref": "#/$defs/dateTime"
    },
    "watchUntil": {
      "$ref": "#/$defs/dateTime"
    },
    "recontactThresholdRef": {
      "$ref": "#/$defs/id"
    },
    "escalationThresholdRef": {
      "$ref": "#/$defs/id"
    },
    "rollbackReviewState": {
      "type": "string",
      "enum": [
        "none",
        "pending",
        "recommended",
        "completed"
      ]
    },
    "watchRevision": {
      "type": "integer",
      "minimum": 1
    },
    "assuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "watchState": {
      "type": "string",
      "enum": [
        "monitoring",
        "review_required",
        "rollback_recommended",
        "closed"
      ]
    },
    "latestReviewOutcomeRef": {
      "$ref": "#/$defs/id"
    },
    "linkedAnalyticsRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    }
  },
  "x-governedInvariants": [
    "AdviceFollowUpWatchWindow is the canonical post-advice watch and rollback-review timer.",
    "Advice or admin flows may not claim stable calmness when the watch window remains review_required or rollback_recommended."
  ]
}
