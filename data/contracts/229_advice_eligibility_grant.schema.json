{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_advice_eligibility_grant.schema.json",
  "title": "229 AdviceEligibilityGrant",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adviceEligibilityGrantId",
    "requestRef",
    "evidenceSnapshotRef",
    "decisionEpochRef",
    "decisionSupersessionRecordRef",
    "safetyState",
    "routeFamily",
    "audienceTier",
    "channelRef",
    "localeRef",
    "compiledPolicyBundleRef",
    "adviceBundleVersionRef",
    "lineageFenceEpoch",
    "routeIntentRef",
    "subjectBindingVersionRef",
    "sessionEpochRef",
    "assuranceSliceTrustRefs",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "issuedAt",
    "expiresAt",
    "grantState"
  ],
  "properties": {
    "adviceEligibilityGrantId": {
      "$ref": "#/$defs/id"
    },
    "requestRef": {
      "$ref": "#/$defs/id"
    },
    "evidenceSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "safetyState": {
      "type": "string"
    },
    "routeFamily": {
      "type": "string"
    },
    "audienceTier": {
      "type": "string"
    },
    "channelRef": {
      "$ref": "#/$defs/id"
    },
    "localeRef": {
      "$ref": "#/$defs/id"
    },
    "compiledPolicyBundleRef": {
      "$ref": "#/$defs/id"
    },
    "adviceBundleVersionRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "routeIntentRef": {
      "$ref": "#/$defs/id"
    },
    "subjectBindingVersionRef": {
      "$ref": "#/$defs/id"
    },
    "sessionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "assuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "issuedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "expiresAt": {
      "$ref": "#/$defs/dateTime"
    },
    "grantState": {
      "type": "string",
      "enum": [
        "live",
        "superseded",
        "expired",
        "invalidated",
        "blocked"
      ]
    }
  },
  "x-governedInvariants": [
    "AdviceEligibilityGrant is the evidence-bound eligibility fence before advice may be rendered.",
    "Advice may not be issued when grantState is superseded, expired, invalidated, or blocked."
  ]
}
