{
  "contractId": "NHSAppReleaseControlContract:397:v1",
  "schemaVersion": "397.phase7.nhs-app-release-controls.v1",
  "releaseTuple": {
    "manifestVersionRef": "nhsapp-manifest-v0.1.0-freeze-374",
    "configFingerprint": "sha256:374-manifest-tuples-f488ecd-local-freeze-v1",
    "releaseCandidateRef": "release-candidate:phase7-nhs-app-contract-freeze-374",
    "releaseApprovalFreezeRef": "ReleaseApprovalFreeze:RAF-P7-374-CONTRACT-FREEZE",
    "compatibilityEvidenceRef": "CompatibilityEvidence:phase7-bridge-floor-freeze-374"
  },
  "objects": {
    "ChannelReleaseCohort": {
      "requiredFields": [
        "cohortId",
        "odsRules",
        "patientPopulationRules",
        "enabledJourneys",
        "releaseStage",
        "environment",
        "manifestVersionRef",
        "releaseApprovalFreezeRef",
        "guardrailPolicyRef",
        "killSwitchRef",
        "reversibleWithoutRedeploy"
      ],
      "routeRefs": [
        "jp_start_medical_request",
        "jp_request_status",
        "jp_manage_local_appointment",
        "jp_pharmacy_status"
      ]
    },
    "ReleaseGuardrailPolicy": {
      "freezeTriggers": [
        "telemetry_missing",
        "threshold_breach",
        "assurance_slice_degraded",
        "compatibility_drift",
        "continuity_evidence_degraded"
      ],
      "releaseRequires": ["operatorNoteRef", "sameManifestTuple", "freshGreenWindow"]
    },
    "ChannelReleaseFreezeRecord": {
      "activeStates": ["frozen", "kill_switch_active", "rollback_recommended"],
      "releaseAuthority": "operator_explicit_release_only"
    },
    "RouteFreezeDisposition": {
      "allowedModes": ["read_only", "placeholder_only", "redirect_to_safe_route"],
      "mustInclude": ["patientMessageRef", "safeRouteRef", "supportRecoveryRef"]
    },
    "NHSAppPerformancePack": {
      "source": "validated_aggregate_event_contracts",
      "prohibitedFields": [
        "assertedLoginIdentity",
        "asserted_login_identity",
        "access_token",
        "id_token",
        "grantId",
        "patientId",
        "subjectRef",
        "nhsNumber",
        "rawJwt"
      ]
    },
    "JourneyChangeNotice": {
      "minorLeadTime": "P1M",
      "significantOrNewJourneyLeadTime": "P3M",
      "mustBind": ["manifestVersion", "affectedJourneys", "integrationManagerRef"]
    }
  },
  "routes": [
    "phase7_nhs_app_release_control_cohort_manifest_validate",
    "phase7_nhs_app_release_control_guardrails_evaluate",
    "phase7_nhs_app_release_control_route_freeze_resolve",
    "phase7_nhs_app_release_control_kill_switch_rehearse",
    "phase7_nhs_app_release_control_monthly_pack_generate",
    "phase7_nhs_app_release_control_change_notice_submit"
  ]
}
