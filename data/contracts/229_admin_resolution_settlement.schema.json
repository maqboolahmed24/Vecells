{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_admin_resolution_settlement.schema.json",
  "title": "229 AdminResolutionSettlement",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adminResolutionSettlementId",
    "adminResolutionCaseRef",
    "adminResolutionActionRecordRef",
    "boundaryDecisionRef",
    "boundaryTupleHash",
    "clinicalMeaningState",
    "operationalFollowUpScope",
    "decisionEpochRef",
    "decisionSupersessionRecordRef",
    "commandSettlementRef",
    "transitionEnvelopeRef",
    "taskCompletionSettlementEnvelopeRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "dependencySetRef",
    "releaseWatchRef",
    "reopenState",
    "result",
    "trustState",
    "completionArtifactRef",
    "recoveryDispositionRef",
    "visibilityTier",
    "summarySafetyTier",
    "placeholderContractRef",
    "recoveryRouteRef",
    "recordedAt"
  ],
  "properties": {
    "adminResolutionSettlementId": {
      "$ref": "#/$defs/id"
    },
    "adminResolutionCaseRef": {
      "$ref": "#/$defs/id"
    },
    "adminResolutionActionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryTupleHash": {
      "$ref": "#/$defs/id"
    },
    "clinicalMeaningState": {
      "type": "string",
      "enum": [
        "bounded_admin_only",
        "clinician_reentry_required"
      ]
    },
    "operationalFollowUpScope": {
      "type": "string",
      "enum": [
        "bounded_admin_resolution"
      ]
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "commandSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "taskCompletionSettlementEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "dependencySetRef": {
      "$ref": "#/$defs/id"
    },
    "releaseWatchRef": {
      "$ref": "#/$defs/id"
    },
    "reopenState": {
      "type": "string",
      "enum": [
        "stable",
        "reopen_required",
        "reopened",
        "blocked_pending_review"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "queued",
        "patient_notified",
        "waiting_dependency",
        "completed",
        "reopened_for_review",
        "blocked_pending_safety",
        "stale_recoverable"
      ]
    },
    "trustState": {
      "type": "string",
      "enum": [
        "trusted",
        "degraded",
        "quarantined"
      ]
    },
    "completionArtifactRef": {
      "$ref": "#/$defs/id"
    },
    "recoveryDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityTier": {
      "type": "string",
      "minLength": 1
    },
    "summarySafetyTier": {
      "type": "string",
      "minLength": 1
    },
    "placeholderContractRef": {
      "$ref": "#/$defs/id"
    },
    "recoveryRouteRef": {
      "$ref": "#/$defs/id"
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "AdminResolutionSettlement.result=completed requires a matching AdminResolutionCompletionArtifact and the current boundaryTupleHash.",
    "Stale or reopened boundary decisions must freeze consequence in place and settle stale_recoverable or reopened_for_review."
  ]
}
