{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_patient_urgent_diversion_state.schema.json",
  "title": "229 PatientUrgentDiversionState",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "diversionStateId",
    "clusterRef",
    "currentEvidenceAssimilationRef",
    "currentMaterialDeltaAssessmentRef",
    "currentEvidenceClassificationRef",
    "currentSafetyPreemptionRef",
    "currentSafetyDecisionRef",
    "currentUrgentDiversionSettlementRef",
    "safetyDecisionEpoch",
    "triggerReasonCode",
    "severityBand",
    "asyncMessagingAllowedState",
    "composerFreezeState",
    "surfaceState",
    "diversionGuidanceRef",
    "reentryRuleRef"
  ],
  "properties": {
    "diversionStateId": {
      "$ref": "#/$defs/id"
    },
    "clusterRef": {
      "$ref": "#/$defs/id"
    },
    "currentEvidenceAssimilationRef": {
      "$ref": "#/$defs/id"
    },
    "currentMaterialDeltaAssessmentRef": {
      "$ref": "#/$defs/id"
    },
    "currentEvidenceClassificationRef": {
      "$ref": "#/$defs/id"
    },
    "currentSafetyPreemptionRef": {
      "$ref": "#/$defs/id"
    },
    "currentSafetyDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "currentUrgentDiversionSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "safetyDecisionEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "triggerReasonCode": {
      "type": "string",
      "minLength": 1
    },
    "severityBand": {
      "type": "string",
      "enum": [
        "moderate",
        "urgent",
        "critical"
      ]
    },
    "asyncMessagingAllowedState": {
      "type": "string",
      "enum": [
        "allowed",
        "blocked"
      ]
    },
    "composerFreezeState": {
      "type": "string",
      "enum": [
        "live",
        "frozen"
      ]
    },
    "surfaceState": {
      "type": "string",
      "enum": [
        "assimilation_pending",
        "review_pending",
        "urgent_required",
        "urgent_issued",
        "manual_review_required"
      ]
    },
    "diversionGuidanceRef": {
      "$ref": "#/$defs/id"
    },
    "reentryRuleRef": {
      "$ref": "#/$defs/id"
    }
  },
  "x-governedInvariants": [
    "PatientUrgentDiversionState preempts unsafe async interaction without losing conversation context.",
    "Unsafe reply or callback affordances must freeze while urgent diversion is current."
  ]
}
