{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_more_info_reminder_schedule.schema.json",
  "title": "227 MoreInfoReminderSchedule",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "reminderScheduleId",
    "cycleRef",
    "replyWindowCheckpointRef",
    "channelPlanRef",
    "quietHoursPolicyRef",
    "plannedReminderAts",
    "nextReminderDueAt",
    "scheduleState",
    "updatedAt"
  ],
  "properties": {
    "reminderScheduleId": {
      "$ref": "#/$defs/id"
    },
    "cycleRef": {
      "$ref": "#/$defs/id"
    },
    "replyWindowCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "channelPlanRef": {
      "$ref": "#/$defs/id"
    },
    "quietHoursPolicyRef": {
      "$ref": "#/$defs/id"
    },
    "plannedReminderAts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dateTime"
      }
    },
    "nextReminderDueAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "lastReminderSentAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "suppressionReasonRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "scheduleState": {
      "type": "string",
      "enum": [
        "scheduled",
        "suppressed",
        "exhausted",
        "completed",
        "cancelled"
      ]
    },
    "updatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "Reminder orchestration reads only MoreInfoReminderSchedule, MoreInfoReplyWindowCheckpoint, and current reachability posture.",
    "No reminder may send after checkpoint state becomes late_review, expired, superseded, or settled."
  ]
}
