{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/279_booking_capability_projection.schema.json",
  "title": "279 BookingCapabilityProjection",
  "description": "Audience-safe widening of one current BookingCapabilityResolution. Patient and staff surfaces consume this projection instead of re-running capability logic locally.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bookingCapabilityProjectionId",
    "schemaVersion",
    "bookingCaseId",
    "appointmentId",
    "bookingCapabilityResolutionRef",
    "selectionAudience",
    "requestedActionScope",
    "providerAdapterBindingRef",
    "capabilityTupleHash",
    "surfaceState",
    "dominantCapabilityCueCode",
    "controlState",
    "selfServiceActionRefs",
    "assistedActionRefs",
    "manageActionRefs",
    "fallbackActionRefs",
    "blockedActionReasonCodes",
    "exposedActionScopes",
    "parityGroupId",
    "underlyingCapabilityState",
    "renderedAt"
  ],
  "properties": {
    "bookingCapabilityProjectionId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable projection id."
    },
    "schemaVersion": {
      "const": "279.phase4.booking-capability-freeze.v1"
    },
    "bookingCaseId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "BookingCase ref if applicable."
    },
    "appointmentId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Appointment ref if applicable."
    },
    "bookingCapabilityResolutionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Resolution ref that owns this projection."
    },
    "selectionAudience": {
      "type": "string",
      "enum": [
        "patient",
        "staff"
      ],
      "description": "Audience consuming the projection."
    },
    "requestedActionScope": {
      "type": "string",
      "enum": [
        "search_slots",
        "book_slot",
        "cancel_appointment",
        "reschedule_appointment",
        "view_appointment",
        "hold_slot",
        "launch_local_component",
        "repair_gp_linkage",
        "request_staff_assist",
        "manage_appointment",
        "view_booking_summary"
      ],
      "description": "Requested action scope."
    },
    "providerAdapterBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "Binding ref copied from the owning resolution."
    },
    "capabilityTupleHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Capability tuple hash copied from the owning resolution."
    },
    "surfaceState": {
      "type": "string",
      "enum": [
        "self_service_live",
        "staff_assist_live",
        "assisted_only",
        "linkage_required",
        "local_component_required",
        "degraded_manual",
        "recovery_required",
        "blocked"
      ],
      "description": "Audience-safe surface posture."
    },
    "dominantCapabilityCueCode": {
      "type": "string",
      "minLength": 1,
      "description": "Dominant cue code for shell rendering."
    },
    "controlState": {
      "type": "string",
      "enum": [
        "writable",
        "read_only",
        "blocked"
      ],
      "description": "Live control posture for the shell."
    },
    "selfServiceActionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "search_slots",
          "book_slot",
          "cancel_appointment",
          "reschedule_appointment",
          "view_appointment",
          "hold_slot",
          "launch_local_component",
          "repair_gp_linkage",
          "request_staff_assist",
          "manage_appointment",
          "view_booking_summary"
        ],
        "description": "Patient-exposed action ref"
      }
    },
    "assistedActionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "search_slots",
          "book_slot",
          "cancel_appointment",
          "reschedule_appointment",
          "view_appointment",
          "hold_slot",
          "launch_local_component",
          "repair_gp_linkage",
          "request_staff_assist",
          "manage_appointment",
          "view_booking_summary"
        ],
        "description": "Staff-assisted action ref"
      }
    },
    "manageActionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "search_slots",
          "book_slot",
          "cancel_appointment",
          "reschedule_appointment",
          "view_appointment",
          "hold_slot",
          "launch_local_component",
          "repair_gp_linkage",
          "request_staff_assist",
          "manage_appointment",
          "view_booking_summary"
        ],
        "description": "Manage action ref"
      }
    },
    "fallbackActionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "fallback_repair_gp_linkage",
          "fallback_launch_local_component",
          "fallback_request_staff_assist",
          "fallback_contact_practice_support",
          "fallback_continue_read_only",
          "fallback_wait_for_confirmation",
          "fallback_manual_hub_booking"
        ],
        "description": "Fallback action ref"
      }
    },
    "blockedActionReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "reason_gp_linkage_required",
          "reason_local_component_required",
          "reason_self_service_not_supported",
          "reason_staff_assist_only",
          "reason_supplier_degraded_manual",
          "reason_publication_frozen",
          "reason_assurance_read_only",
          "reason_governing_object_stale",
          "reason_action_scope_not_supported",
          "reason_confirmation_gate_pending",
          "reason_policy_blocked"
        ],
        "description": "Blocked reason code"
      }
    },
    "exposedActionScopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "search_slots",
          "book_slot",
          "cancel_appointment",
          "reschedule_appointment",
          "view_appointment",
          "hold_slot",
          "launch_local_component",
          "repair_gp_linkage",
          "request_staff_assist",
          "manage_appointment",
          "view_booking_summary"
        ],
        "description": "Actually exposed action scope"
      }
    },
    "parityGroupId": {
      "type": "string",
      "minLength": 1,
      "description": "Group used to prove patient/staff parity from the same underlying tuple family."
    },
    "underlyingCapabilityState": {
      "type": "string",
      "enum": [
        "live_self_service",
        "live_staff_assist",
        "assisted_only",
        "linkage_required",
        "local_component_required",
        "degraded_manual",
        "recovery_only",
        "blocked"
      ],
      "description": "Underlying resolution capability state."
    },
    "renderedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
