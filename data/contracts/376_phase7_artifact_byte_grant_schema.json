{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_artifact_byte_grant_schema.json",
  "title": "ArtifactByteGrant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grantId",
    "artifactId",
    "artifactSurfaceContextRef",
    "artifactModeTruthProjectionRef",
    "bridgeCapabilityMatrixRef",
    "patientEmbeddedNavEligibilityRef",
    "selectedAnchorRef",
    "returnContractRef",
    "expiresAt",
    "maxDownloads",
    "maxBytes",
    "subjectBindingMode",
    "issuedBy",
    "grantState",
    "tupleHash"
  ],
  "properties": {
    "grantId": {
      "type": "string"
    },
    "artifactId": {
      "type": "string"
    },
    "artifactSurfaceContextRef": {
      "type": "string"
    },
    "artifactModeTruthProjectionRef": {
      "type": "string"
    },
    "bridgeCapabilityMatrixRef": {
      "type": "string"
    },
    "patientEmbeddedNavEligibilityRef": {
      "type": "string"
    },
    "selectedAnchorRef": {
      "type": "string"
    },
    "returnContractRef": {
      "type": "string"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "maxDownloads": {
      "type": "integer",
      "minimum": 1
    },
    "maxBytes": {
      "type": "integer",
      "minimum": 0
    },
    "subjectBindingMode": {
      "type": "string",
      "enum": ["same_subject_required", "step_up_required", "summary_only"]
    },
    "issuedBy": {
      "type": "string"
    },
    "grantState": {
      "type": "string",
      "enum": ["issued", "redeemed", "expired", "superseded", "blocked"]
    },
    "tupleHash": {
      "type": "string",
      "pattern": "^sha256:"
    }
  }
}
