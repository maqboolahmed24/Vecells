{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_cross_site_decision_plan.schema.json",
  "title": "CrossSiteDecisionPlan",
  "description": "Persisted cross-site decision plan carrying dominance removals, ordered candidate refs, and the patient-offerable or direct-commit frontiers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decisionPlanId",
    "hubCoordinationCaseId",
    "snapshotId",
    "policyEvaluationRef",
    "policyTupleHash",
    "orderedCandidateRefs",
    "patientOfferableFrontierRefs",
    "directCommitFrontierRefs",
    "callbackReasoningRefs",
    "diagnosticOnlyRefs",
    "dominanceDecisions",
    "generatedAt",
    "sourceRefs"
  ],
  "properties": {
    "decisionPlanId": {
      "type": "string",
      "minLength": 1,
      "description": "Decision plan identifier."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub case ref."
    },
    "snapshotId": {
      "type": "string",
      "minLength": 1,
      "description": "Source snapshot ref."
    },
    "policyEvaluationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Bound policy evaluation ref."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Active policy tuple hash."
    },
    "orderedCandidateRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Stable lexicographic order across all normalized candidates."
    },
    "patientOfferableFrontierRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Candidates allowed into patient-offerable surfaces."
    },
    "directCommitFrontierRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Candidates allowed into direct-commit surfaces."
    },
    "callbackReasoningRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Candidates visible only for callback reasoning."
    },
    "diagnosticOnlyRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Candidates retained only for diagnostic visibility."
    },
    "dominanceDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "winnerCandidateRef",
          "loserCandidateRef",
          "weaklyDominatedOn",
          "strictCoordinates",
          "persistedEffect"
        ],
        "properties": {
          "winnerCandidateRef": {
            "type": "string",
            "minLength": 1,
            "description": "Dominating candidate ref."
          },
          "loserCandidateRef": {
            "type": "string",
            "minLength": 1,
            "description": "Removed candidate ref."
          },
          "weaklyDominatedOn": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Coordinates used for weak dominance."
          },
          "strictCoordinates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Coordinates with strict improvement."
          },
          "persistedEffect": {
            "type": "string",
            "minLength": 1,
            "description": "Material frontier effect."
          }
        }
      },
      "description": "Persisted dominance decisions."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Decision-plan generation timestamp."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5C. Enhanced Access policy engine and network capacity ingestion",
    "blueprint/phase-5-the-network-horizon.md#5D. Coordination queue, candidate ranking, and SLA engine",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#ranking-order-and-visible-cues-must-derive-from-persisted-proof",
    "blueprint/phase-0-the-foundation-protocol.md#publication-and-bundle-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#assurance-and-trust-carry-forward",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md"
  ]
}
