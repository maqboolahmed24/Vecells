{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/173_call_session.schema.json",
  "title": "CallSession",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "callSessionId",
    "providerCorrelationRef",
    "callState",
    "stateSequence",
    "canonicalEventRefs",
    "recordingAvailabilityState",
    "transcriptReadinessRef",
    "evidenceReadinessAssessmentRef",
    "continuationEligibilityRef",
    "manualReviewDispositionRef",
    "continuationContextRef",
    "requestSeedRef",
    "latestSubmissionIngressRef",
    "lineageRef",
    "policyVersionRef",
    "rebuildRule",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "173.phase2.telephony.call-session.v1"
    },
    "callSessionId": {
      "type": "string",
      "pattern": "^call_sess_[A-Za-z0-9_:-]+$"
    },
    "providerCorrelationRef": {
      "type": "string",
      "description": "Reference to the normalized provider correlation record. Raw vendor payloads stay at the normalization boundary."
    },
    "menuSelection": {
      "type": "string",
      "enum": ["symptoms", "medications", "admin", "results", "unknown"]
    },
    "verificationState": {
      "type": "string",
      "enum": [
        "not_started",
        "identity_in_progress",
        "identity_resolved",
        "identity_partial",
        "identity_failed",
        "manual_followup_required"
      ]
    },
    "callState": {
      "$ref": "#/$defs/callState"
    },
    "stateSequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/callState"
      }
    },
    "sideBranchReason": {
      "type": "string",
      "enum": [
        "identity_failed",
        "abandoned",
        "provider_error",
        "manual_followup_required",
        "manual_audio_review_required",
        "recording_missing",
        "transcript_degraded"
      ]
    },
    "canonicalEventRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^tel_evt_[A-Za-z0-9_:-]+$"
      }
    },
    "capturedIdentifierRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Masked evidence references only; never raw phone numbers or raw caller identifiers."
    },
    "recordingRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(docref|object|quarantine)_[A-Za-z0-9_:-]+$"
      }
    },
    "recordingAvailabilityState": {
      "type": "string",
      "enum": ["expected", "available", "fetched", "quarantined", "verified", "missing", "expired"]
    },
    "transcriptReadinessRef": {
      "type": ["string", "null"],
      "pattern": "^tel_tr_[A-Za-z0-9_:-]+$"
    },
    "evidenceReadinessAssessmentRef": {
      "type": ["string", "null"],
      "pattern": "^tel_era_[A-Za-z0-9_:-]+$"
    },
    "continuationEligibilityRef": {
      "type": ["string", "null"],
      "pattern": "^tel_ce_[A-Za-z0-9_:-]+$"
    },
    "manualReviewDispositionRef": {
      "type": ["string", "null"],
      "pattern": "^tel_mrd_[A-Za-z0-9_:-]+$"
    },
    "continuationContextRef": {
      "type": ["string", "null"],
      "pattern": "^tel_ctx_[A-Za-z0-9_:-]+$"
    },
    "continuationAccessGrantRef": {
      "type": ["string", "null"],
      "description": "Present only when TelephonyContinuationEligibility recommends a redeemable canonical AccessGrant family."
    },
    "requestSeedRef": {
      "type": ["string", "null"]
    },
    "latestSubmissionIngressRef": {
      "type": ["string", "null"]
    },
    "lineageRef": {
      "type": "string"
    },
    "policyVersionRef": {
      "type": "string"
    },
    "capabilityCeiling": {
      "type": "string",
      "enum": [
        "urgent_live_only",
        "continuation_challenge",
        "continuation_seeded_verified",
        "routine_submission"
      ]
    },
    "rebuildRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "eventOrdering", "readinessRecordHandling", "providerPayloadHandling"],
      "properties": {
        "source": {
          "const": "canonical_telephony_events_plus_immutable_readiness_records"
        },
        "eventOrdering": {
          "const": "monotonic_sequence_then_recorded_at_with_idempotency_key"
        },
        "readinessRecordHandling": {
          "const": "append_only_latest_settled_record_wins_by_assessed_at"
        },
        "providerPayloadHandling": {
          "const": "payload_ref_only_raw_payload_never_replayed_below_normalization"
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "callState": {
      "type": "string",
      "enum": [
        "initiated",
        "menu_selected",
        "identity_in_progress",
        "identity_resolved",
        "identity_partial",
        "recording_expected",
        "recording_available",
        "evidence_preparing",
        "evidence_pending",
        "urgent_live_only",
        "continuation_eligible",
        "evidence_ready",
        "continuation_sent",
        "request_seeded",
        "submitted",
        "closed",
        "identity_failed",
        "abandoned",
        "provider_error",
        "manual_followup_required",
        "manual_audio_review_required",
        "recording_missing",
        "transcript_degraded"
      ]
    }
  }
}
