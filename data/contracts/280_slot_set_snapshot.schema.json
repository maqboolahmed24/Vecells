{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells://contracts/SlotSetSnapshot",
  "title": "SlotSetSnapshot",
  "description": "Persisted searchable and selectable slot set for one SlotSearchSession.",
  "type": "object",
  "additionalProperties": false,
  "x-taskId": "seq_280",
  "x-contractVersion": "280.phase4.booking-flow-freeze.v1",
  "required": [
    "slotSetSnapshotId",
    "searchSessionId",
    "searchPolicyRef",
    "caseVersionRef",
    "policyBundleHash",
    "providerAdapterBindingRef",
    "providerAdapterBindingHash",
    "capabilityResolutionRef",
    "capabilityTupleHash",
    "slotCount",
    "candidateCount",
    "snapshotChecksum",
    "candidateIndexRef",
    "filterPlanVersion",
    "rankPlanVersion",
    "coverageState",
    "recoveryStateRef",
    "fetchedAt",
    "expiresAt"
  ],
  "properties": {
    "slotSetSnapshotId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable SlotSetSnapshot identifier."
    },
    "searchSessionId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning SlotSearchSession ref."
    },
    "searchPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Owning SearchPolicy ref."
    },
    "caseVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "BookingCase version bound into the snapshot."
    },
    "policyBundleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Compiled policy bundle hash."
    },
    "providerAdapterBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "Binding ref from 279."
    },
    "providerAdapterBindingHash": {
      "type": "string",
      "minLength": 1,
      "description": "Binding hash from 279."
    },
    "capabilityResolutionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Capability resolution ref from 279."
    },
    "capabilityTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Capability tuple hash from 279."
    },
    "slotCount": {
      "type": "integer",
      "minimum": 0
    },
    "candidateCount": {
      "type": "integer",
      "minimum": 0
    },
    "snapshotChecksum": {
      "type": "string",
      "minLength": 1,
      "description": "Checksum over the persisted normalized candidate set."
    },
    "candidateIndexRef": {
      "type": "string",
      "minLength": 1,
      "description": "Frozen candidate index ref."
    },
    "filterPlanVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Versioned hard-filter plan ref."
    },
    "rankPlanVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Versioned RankPlan ref."
    },
    "coverageState": {
      "type": "string",
      "enum": [
        "complete",
        "partial_coverage",
        "timeout",
        "degraded",
        "failed"
      ],
      "description": "Aggregated coverage state."
    },
    "recoveryStateRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current SlotSnapshotRecoveryState ref."
    },
    "fetchedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Snapshot fetch completion time."
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "Snapshot selectability expiry time."
    }
  },
  "x-formulas": {
    "SnapshotSelectable": {
      "name": "SnapshotSelectable(q,t)",
      "expression": "SnapshotSelectable(q,t) = 1[t <= q.expiresAt] * 1[q.caseVersionRef matches the active BookingCase version] * 1[q.policyBundleHash matches the active compiled policy bundle] * 1[q.providerAdapterBindingHash matches the current BookingCapabilityResolution.providerAdapterBindingHash] * 1[q.capabilityTupleHash matches the current BookingCapabilityResolution.capabilityTupleHash] * 1[q.coverageState in {complete, partial_coverage}] * 1[recoveryState(q).viewState != stale_refresh_required]",
      "machineFields": [
        "expiresAt",
        "caseVersionRef",
        "policyBundleHash",
        "providerAdapterBindingHash",
        "capabilityTupleHash",
        "coverageState",
        "recoveryState.viewState"
      ],
      "inputObjects": [
        "SlotSetSnapshot",
        "SlotSnapshotRecoveryState",
        "BookingCase",
        "BookingCapabilityResolution"
      ],
      "failurePosture": "selection may preserve provenance and day anchor, but confirm-path mutation must fail closed and require refresh or governed recovery before a slot can be committed"
    }
  },
  "x-sourceRefs": [
    "blueprint/phase-4-the-booking-engine.md",
    "docs/architecture/279_phase4_provider_capability_matrix_and_adapter_seam.md"
  ]
}
