{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase1/draft-autosave-patch-envelope.schema.json",
  "title": "DraftAutosavePatchEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draftVersion",
    "clientCommandId",
    "idempotencyKey",
    "leaseId",
    "resumeToken",
    "recordedAt"
  ],
  "properties": {
    "draftVersion": {
      "type": "integer",
      "minimum": 1
    },
    "clientCommandId": {
      "type": "string"
    },
    "idempotencyKey": {
      "type": "string"
    },
    "leaseId": {
      "type": "string"
    },
    "resumeToken": {
      "type": "string",
      "pattern": "^rtk_[A-Za-z0-9_-]{12,128}$"
    },
    "requestType": {
      "type": "string",
      "enum": ["Symptoms", "Meds", "Admin", "Results"]
    },
    "structuredAnswers": {
      "type": "object"
    },
    "freeTextNarrative": {
      "type": "string",
      "maxLength": 4000
    },
    "attachmentRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contactPreferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredChannel": {
          "type": "string",
          "enum": ["sms", "phone", "email"]
        },
        "contactWindow": {
          "type": "string",
          "enum": ["weekday_daytime", "weekday_evening", "anytime"]
        },
        "voicemailAllowed": {
          "type": "boolean"
        }
      }
    },
    "currentStepKey": {
      "type": "string"
    },
    "completedStepKeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "currentPathname": {
      "type": "string"
    },
    "shellContinuityKey": {
      "type": "string"
    },
    "selectedAnchorKey": {
      "type": "string"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
