{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_network_manage_capabilities.schema.json",
  "title": "NetworkManageCapabilities",
  "description": "Leased manage authority for one current appointment version. May degrade to stale, blocked, or expired without leaving stale CTAs live.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "networkManageCapabilitiesId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable manage-capability identifier."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "hubAppointmentId": {
      "type": "string",
      "minLength": 1,
      "description": "HubAppointmentRecord that manage posture refers to."
    },
    "appointmentVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current appointment version used for manage decisions."
    },
    "capabilityState": {
      "type": "string",
      "enum": [
        "live",
        "stale",
        "blocked",
        "expired"
      ],
      "description": "Current capability lease state."
    },
    "readOnlyMode": {
      "type": "string",
      "enum": [
        "interactive",
        "read_only"
      ],
      "description": "Interactive or read-only posture."
    },
    "reasonCode": {
      "type": "string",
      "minLength": 1,
      "description": "Primary reason for the current capability posture."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy tuple hash."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash."
    },
    "visibilityEnvelopeVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Visibility envelope version active for manage posture."
    },
    "supplierTruthVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Supplier truth version or mirror revision used to compile the lease."
    },
    "sessionFenceToken": {
      "type": "string",
      "minLength": 1,
      "description": "Current session fence."
    },
    "subjectFenceToken": {
      "type": "string",
      "minLength": 1,
      "description": "Current subject fence."
    },
    "manageWindowEndsAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time at which the current lease naturally expires."
    },
    "allowedActions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Currently allowed actions under the lease."
    },
    "blockedReasonRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Typed blockers that demoted the lease."
    },
    "fallbackRouteRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Fallback route for blocked or stale manage posture."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "networkManageCapabilitiesId",
    "hubCoordinationCaseId",
    "hubAppointmentId",
    "appointmentVersionRef",
    "capabilityState",
    "readOnlyMode",
    "reasonCode",
    "policyTupleHash",
    "truthTupleHash",
    "visibilityEnvelopeVersionRef",
    "supplierTruthVersionRef",
    "sessionFenceToken",
    "subjectFenceToken",
    "manageWindowEndsAt",
    "allowedActions",
    "blockedReasonRefs",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
