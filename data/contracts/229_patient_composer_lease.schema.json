{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_patient_composer_lease.schema.json",
  "title": "229 PatientComposerLease",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "leaseId",
    "clusterRef",
    "composerScope",
    "routeIntentBindingRef",
    "lineageFenceEpoch",
    "draftRef",
    "reachabilityDependencyRef",
    "reachabilityAssessmentRef",
    "reachabilityEpoch",
    "contactRepairRef",
    "contactRepairJourneyRef",
    "consentCheckpointRef",
    "selectedAnchorRef",
    "resumeContinuationRef",
    "latestSettlementRef",
    "visibilityProjectionRef",
    "transitionEnvelopeRef",
    "experienceContinuityEvidenceRef",
    "receiptGrammarVersionRef",
    "leaseState",
    "expiresAt"
  ],
  "properties": {
    "leaseId": {
      "$ref": "#/$defs/id"
    },
    "clusterRef": {
      "$ref": "#/$defs/id"
    },
    "composerScope": {
      "type": "string",
      "enum": [
        "reply",
        "acknowledgement",
        "availability_update"
      ]
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "draftRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityAssessmentRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "contactRepairRef": {
      "$ref": "#/$defs/id"
    },
    "contactRepairJourneyRef": {
      "$ref": "#/$defs/id"
    },
    "consentCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "resumeContinuationRef": {
      "$ref": "#/$defs/id"
    },
    "latestSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "experienceContinuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "receiptGrammarVersionRef": {
      "$ref": "#/$defs/id"
    },
    "leaseState": {
      "type": "string",
      "enum": [
        "active",
        "blocked",
        "resume_required",
        "released"
      ]
    },
    "expiresAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "There may be one live patient composer at a time for the current conversation cluster.",
    "Repair-required, review-pending, or route-blocked states keep the same composer anchor visible instead of opening a second live composer."
  ]
}
