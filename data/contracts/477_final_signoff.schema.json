{
  "$id": "https://vecells.example/contracts/477_final_signoff.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "activeExceptions": {
      "type": "array"
    },
    "authorities": {
      "minItems": 5,
      "type": "array"
    },
    "commandSettlementCurrent": {
      "type": "boolean"
    },
    "evidenceBindings": {
      "minItems": 5,
      "type": "array"
    },
    "launchApprovalPermitted": {
      "type": "boolean"
    },
    "launchDecision": {
      "required": [
        "releaseCandidateRef",
        "runtimePublicationBundleRef",
        "waveManifestRef",
        "signoffBlockerCount",
        "backendCommandSettlementState"
      ],
      "type": "object"
    },
    "overallSignoffState": {
      "enum": [
        "ready",
        "ready_with_constraints",
        "blocked",
        "expired_signoff",
        "missing_signoff",
        "tuple_mismatch"
      ]
    },
    "recordHash": {
      "maxLength": 64,
      "minLength": 64,
      "type": "string"
    },
    "recordType": {
      "const": "FinalLaunchSignoffRegister"
    },
    "registerId": {
      "minLength": 1,
      "type": "string"
    },
    "releaseBinding": {
      "required": [
        "releaseCandidateRef",
        "runtimePublicationBundleRef",
        "waveManifestRef",
        "waveManifestHash",
        "tenantScope",
        "tenantCohortScope",
        "channelScope",
        "assistiveScope",
        "routeFamilies"
      ],
      "type": "object"
    },
    "scenarioState": {
      "enum": [
        "ready",
        "ready_with_constraints",
        "blocked",
        "expired_signoff",
        "missing_signoff",
        "tuple_mismatch",
        "exception_blocking"
      ]
    },
    "schemaVersion": {
      "const": "477.programme.final-launch-signoff.v1"
    },
    "signoffReviewPermitted": {
      "type": "boolean"
    }
  },
  "required": [
    "schemaVersion",
    "recordType",
    "registerId",
    "releaseBinding",
    "authorities",
    "evidenceBindings",
    "activeExceptions",
    "launchDecision",
    "recordHash"
  ],
  "title": "Task 477 final launch signoff register",
  "type": "object"
}
