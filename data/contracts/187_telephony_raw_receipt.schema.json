{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/187_telephony_raw_receipt.schema.json",
  "title": "TelephonyRawWebhookReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rawReceiptRef",
    "providerRef",
    "receivedAt",
    "requestUrl",
    "headerDigest",
    "payloadDigest",
    "rawPayloadQuarantineRef",
    "retentionClass",
    "validationState",
    "signatureKeyVersionRef",
    "disclosureBoundary",
    "reasonCodes",
    "createdByAuthority"
  ],
  "properties": {
    "rawReceiptRef": { "type": "string", "pattern": "^tel_raw_receipt_187_" },
    "providerRef": { "const": "telephony_provider_simulator" },
    "receivedAt": { "type": "string", "format": "date-time" },
    "sourceIpRef": { "type": ["string", "null"] },
    "requestUrl": { "type": "string" },
    "headerDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "payloadDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "rawPayloadQuarantineRef": { "type": "string", "pattern": "^tel_payload_quarantine_187_" },
    "retentionClass": { "const": "edge_quarantine_short_retention" },
    "validationState": { "enum": ["validated", "signature_failed"] },
    "signatureKeyVersionRef": { "type": "string" },
    "disclosureBoundary": { "const": "provider_payload_shape_stops_at_normalizer" },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "createdByAuthority": { "const": "TelephonyEdgeService" }
  }
}
