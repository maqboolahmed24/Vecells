{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_binary_artifact_delivery_schema.json",
  "title": "BinaryArtifactDelivery",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactId",
    "artifactType",
    "artifactSurfaceContextRef",
    "artifactModeTruthProjectionRef",
    "deliveryMode",
    "byteGrantRef",
    "mimeType",
    "filename",
    "contentLengthBytes",
    "checksum",
    "cachePolicy",
    "watermarkMode",
    "ttl",
    "accessScope",
    "channelProfile",
    "selectedAnchorRef",
    "returnContractRef",
    "deliveryState",
    "deliveryTupleHash"
  ],
  "properties": {
    "artifactId": {
      "type": "string"
    },
    "artifactType": {
      "type": "string",
      "enum": ["letter", "confirmation", "instruction", "receipt", "record_summary", "attachment"]
    },
    "artifactSurfaceContextRef": {
      "type": "string"
    },
    "artifactModeTruthProjectionRef": {
      "type": "string"
    },
    "deliveryMode": {
      "type": "string",
      "enum": ["byte_download", "overlay_handoff", "external_browser", "secure_send_later"]
    },
    "byteGrantRef": {
      "type": ["string", "null"]
    },
    "mimeType": {
      "type": "string"
    },
    "filename": {
      "type": "string"
    },
    "contentLengthBytes": {
      "type": "integer",
      "minimum": 0
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "cachePolicy": {
      "type": "string",
      "enum": ["no_store", "private_short_ttl", "not_cacheable"]
    },
    "watermarkMode": {
      "type": "string",
      "enum": ["none", "patient_visible", "audit_only"]
    },
    "ttl": {
      "type": "string"
    },
    "accessScope": {
      "type": "string"
    },
    "channelProfile": {
      "type": "string",
      "enum": ["embedded", "browser", "constrained_browser"]
    },
    "selectedAnchorRef": {
      "type": "string"
    },
    "returnContractRef": {
      "type": "string"
    },
    "deliveryState": {
      "type": "string",
      "enum": ["prepared", "bridge_ready", "transferred", "returned", "expired", "blocked"]
    },
    "deliveryTupleHash": {
      "type": "string",
      "pattern": "^sha256:"
    }
  }
}
