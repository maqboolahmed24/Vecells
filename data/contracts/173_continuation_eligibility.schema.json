{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/173_continuation_eligibility.schema.json",
  "title": "TelephonyContinuationEligibility",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "telephonyContinuationEligibilityId",
    "callSessionRef",
    "evidenceReadinessAssessmentRef",
    "identityConfidenceRef",
    "destinationConfidenceRef",
    "grantFamilyRecommendation",
    "lineageScope",
    "eligibilityState",
    "grantIssuance",
    "manualOnlyGrantRule",
    "reasonCodes",
    "evaluatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "173.phase2.telephony.continuation-eligibility.v1"
    },
    "telephonyContinuationEligibilityId": {
      "type": "string",
      "pattern": "^tel_ce_[A-Za-z0-9_:-]+$"
    },
    "callSessionRef": {
      "type": "string"
    },
    "evidenceReadinessAssessmentRef": {
      "type": "string"
    },
    "identityConfidenceRef": {
      "type": ["string", "null"]
    },
    "destinationConfidenceRef": {
      "type": ["string", "null"]
    },
    "grantFamilyRecommendation": {
      "type": "string",
      "enum": ["continuation_seeded_verified", "continuation_challenge", "manual_only"]
    },
    "lineageScope": {
      "type": "string",
      "enum": ["same_submission_envelope", "same_request_lineage", "none"]
    },
    "eligibilityState": {
      "type": "string",
      "enum": ["not_eligible", "eligible_seeded", "eligible_challenge", "manual_only"]
    },
    "grantIssuance": {
      "type": "string",
      "enum": [
        "canonical_access_grant_seeded",
        "canonical_access_grant_challenge",
        "no_redeemable_grant"
      ]
    },
    "manualOnlyGrantRule": {
      "const": "manual_only_creates_no_redeemable_grant"
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "grantFamilyRecommendation": {
            "const": "manual_only"
          }
        }
      },
      "then": {
        "properties": {
          "eligibilityState": {
            "const": "manual_only"
          },
          "grantIssuance": {
            "const": "no_redeemable_grant"
          },
          "lineageScope": {
            "const": "none"
          }
        }
      }
    }
  ]
}
