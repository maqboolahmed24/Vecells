{
  "taskId": "seq_202",
  "schemaVersion": "202.phase2.nhs-login-selector-manifest.v1",
  "visualMode": "Identity_Config_Control_Board",
  "defaultMode": "dry_run",
  "liveMutationGate": {
    "allowFlag": "ALLOW_REAL_PROVIDER_MUTATION",
    "requiresTargetEnvironment": true,
    "requiresCredentialRefs": true,
    "requiresApprovalRecord": true,
    "requiresRollbackSnapshot": true,
    "requiresRedaction": true
  },
  "localTwinSelectors": {
    "root": "[data-testid='NHS_Login_Config_Control_Board']",
    "environmentRail": "[data-testid='environment-rail']",
    "manifestBoard": "[data-testid='manifest-board']",
    "evidenceDrawer": "[data-testid='evidence-drawer']",
    "redirectGraph": "[data-testid='redirect-ownership-graph']",
    "redirectGraphTable": "[data-testid='redirect-ownership-table']",
    "scopeMatrix": "[data-testid='scope-bundle-matrix']",
    "scopeMatrixTable": "[data-testid='scope-bundle-table']",
    "testUserCoverageTable": "[data-testid='test-user-coverage-table']",
    "liveGateChecklist": "[data-testid='live-gate-checklist']",
    "redactedScreenshotList": "[data-testid='redacted-screenshot-list']",
    "tabPrefix": "[data-config-tab]",
    "manifestVersion": "[data-testid='manifest-version']"
  },
  "providerConsoleSelectors": {
    "sandpitCandidate": {
      "consoleLane": "sandpit_candidate",
      "mutationAllowedByDefault": false,
      "friendlyServiceName": "[name='friendly_name'], [data-field='friendly-service-name']",
      "redirectUri": "[name='redirect_uri'], [data-field='redirect-uri']",
      "publicKey": "[name='public_key'], [data-field='public-key-reference']",
      "scopeList": "[name='scopes'], [data-field='scope-list']",
      "saveDraft": "[data-action='save-draft']",
      "finalSubmit": "[data-action='submit']"
    },
    "integrationCandidate": {
      "consoleLane": "integration_candidate",
      "mutationAllowedByDefault": false,
      "clientId": "[name='client_id'], [data-field='client-id']",
      "redirectUri": "[name='redirect_uri'], [data-field='redirect-uri']",
      "scopeList": "[name='scopes'], [data-field='scope-list']",
      "testUserRequest": "[data-field='test-user-request']",
      "conformanceEvidenceUpload": "[data-field='conformance-evidence-upload']",
      "saveDraft": "[data-action='save-draft']",
      "finalSubmit": "[data-action='submit']"
    }
  },
  "redactionSelectors": [
    "[data-redact='client-id']",
    "[data-redact='secret-ref']",
    "[data-redact='test-user-credential']",
    "[data-redact='redirect-host']"
  ],
  "evidenceArtifacts": [
    {
      "artifactId": "local-control-board-screenshot",
      "pathPattern": "output/playwright/202-nhs-login-config-control-board.png",
      "redactionRequired": true
    },
    {
      "artifactId": "local-harness-evidence",
      "pathPattern": "output/playwright/202-nhs-login-console-harness-evidence.json",
      "redactionRequired": true
    },
    {
      "artifactId": "selector-snapshot",
      "pathPattern": "output/playwright/202-nhs-login-selector-snapshot.json",
      "redactionRequired": true
    }
  ]
}
