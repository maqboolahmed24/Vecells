{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_conversation_command_settlement.schema.json",
  "title": "229 ConversationCommandSettlement",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "conversationSettlementId",
    "actionRecordRef",
    "clusterRef",
    "threadId",
    "subthreadRef",
    "latestCommunicationEnvelopeRef",
    "routeIntentBindingRef",
    "commandSettlementRef",
    "actionScope",
    "governingObjectRef",
    "identityRepairBranchDispositionRef",
    "latestReceiptEnvelopeRef",
    "latestCallbackStatusRef",
    "visibilityProjectionRef",
    "reachabilityDependencyRef",
    "reachabilityAssessmentRef",
    "reachabilityEpoch",
    "contactRepairJourneyRef",
    "verificationCheckpointRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "transitionEnvelopeRef",
    "releaseRecoveryDispositionRef",
    "result",
    "localAckState",
    "transportState",
    "externalObservationState",
    "authoritativeOutcomeState",
    "stateConfidenceBand",
    "sameShellRecoveryRef",
    "projectionVersionRef",
    "experienceContinuityEvidenceRef",
    "receiptGrammarVersionRef",
    "threadTupleHash",
    "causalToken",
    "recoveryRouteRef",
    "monotoneRevision",
    "recordedAt"
  ],
  "properties": {
    "conversationSettlementId": {
      "$ref": "#/$defs/id"
    },
    "actionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "clusterRef": {
      "$ref": "#/$defs/id"
    },
    "threadId": {
      "$ref": "#/$defs/id"
    },
    "subthreadRef": {
      "$ref": "#/$defs/id"
    },
    "latestCommunicationEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "commandSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "actionScope": {
      "type": "string",
      "enum": [
        "message_reply",
        "message_send",
        "message_repair",
        "callback_schedule",
        "callback_reschedule",
        "callback_cancel",
        "callback_acknowledgement",
        "contact_route_repair"
      ]
    },
    "governingObjectRef": {
      "$ref": "#/$defs/id"
    },
    "identityRepairBranchDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "latestReceiptEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "latestCallbackStatusRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityAssessmentRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "contactRepairJourneyRef": {
      "$ref": "#/$defs/id"
    },
    "verificationCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "releaseRecoveryDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "result": {
      "type": "string",
      "enum": [
        "accepted_in_place",
        "review_pending",
        "awaiting_external",
        "repair_required",
        "stale_recoverable",
        "blocked_policy",
        "denied_scope",
        "expired"
      ]
    },
    "localAckState": {
      "type": "string",
      "enum": [
        "none",
        "shown",
        "superseded"
      ]
    },
    "transportState": {
      "type": "string",
      "enum": [
        "local_only",
        "provider_accepted",
        "provider_rejected",
        "timed_out"
      ]
    },
    "externalObservationState": {
      "type": "string",
      "enum": [
        "unobserved",
        "delivered",
        "answered",
        "failed",
        "disputed",
        "expired"
      ]
    },
    "authoritativeOutcomeState": {
      "type": "string",
      "enum": [
        "awaiting_external",
        "awaiting_reply",
        "callback_scheduled",
        "awaiting_review",
        "reviewed",
        "settled",
        "recovery_required"
      ]
    },
    "stateConfidenceBand": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "sameShellRecoveryRef": {
      "$ref": "#/$defs/id"
    },
    "projectionVersionRef": {
      "$ref": "#/$defs/id"
    },
    "experienceContinuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "receiptGrammarVersionRef": {
      "$ref": "#/$defs/id"
    },
    "threadTupleHash": {
      "$ref": "#/$defs/id"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "recoveryRouteRef": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-settlementChain": [
    "RouteIntentBinding",
    "CommandActionRecord",
    "CommandSettlementRecord",
    "ConversationCommandSettlement",
    "TransitionEnvelope",
    "RecoveryContinuationToken"
  ],
  "x-governedInvariants": [
    "Every callback or message mutation must settle through ConversationCommandSettlement.",
    "Route-local repair or resend may not bypass evidence assimilation, reachability repair, or the authoritative command-settlement chain."
  ]
}
