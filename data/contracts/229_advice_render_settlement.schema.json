{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_advice_render_settlement.schema.json",
  "title": "229 AdviceRenderSettlement",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adviceRenderSettlementId",
    "adviceEligibilityGrantRef",
    "boundaryDecisionRef",
    "boundaryTupleHash",
    "decisionEpochRef",
    "decisionSupersessionRecordRef",
    "adviceBundleVersionRef",
    "adviceVariantSetRef",
    "routeIntentBindingRef",
    "commandActionRef",
    "commandSettlementRef",
    "releaseApprovalFreezeRef",
    "channelReleaseFreezeRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "dependencySetRef",
    "clinicalMeaningState",
    "operationalFollowUpScope",
    "reopenState",
    "renderState",
    "trustState",
    "reasonCodeRefs",
    "patientTimelineRef",
    "communicationTemplateRef",
    "controlStatusSnapshotRef",
    "artifactPresentationContractRef",
    "outboundNavigationGrantPolicyRef",
    "transitionEnvelopeRef",
    "recoveryDispositionRef",
    "visibilityTier",
    "summarySafetyTier",
    "placeholderContractRef",
    "recoveryRouteRef",
    "settledAt"
  ],
  "properties": {
    "adviceRenderSettlementId": {
      "$ref": "#/$defs/id"
    },
    "adviceEligibilityGrantRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryTupleHash": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "adviceBundleVersionRef": {
      "$ref": "#/$defs/id"
    },
    "adviceVariantSetRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "commandActionRef": {
      "$ref": "#/$defs/id"
    },
    "commandSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "releaseApprovalFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "channelReleaseFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "dependencySetRef": {
      "$ref": "#/$defs/id"
    },
    "clinicalMeaningState": {
      "type": "string"
    },
    "operationalFollowUpScope": {
      "type": "string"
    },
    "reopenState": {
      "type": "string",
      "enum": [
        "stable",
        "reopen_required",
        "reopened",
        "blocked_pending_review"
      ]
    },
    "renderState": {
      "type": "string",
      "enum": [
        "renderable",
        "withheld",
        "invalidated",
        "superseded",
        "quarantined"
      ]
    },
    "trustState": {
      "type": "string",
      "enum": [
        "trusted",
        "degraded",
        "quarantined"
      ]
    },
    "reasonCodeRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "patientTimelineRef": {
      "$ref": "#/$defs/id"
    },
    "communicationTemplateRef": {
      "$ref": "#/$defs/id"
    },
    "controlStatusSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "artifactPresentationContractRef": {
      "$ref": "#/$defs/id"
    },
    "outboundNavigationGrantPolicyRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "recoveryDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityTier": {
      "type": "string"
    },
    "summarySafetyTier": {
      "type": "string"
    },
    "placeholderContractRef": {
      "$ref": "#/$defs/id"
    },
    "recoveryRouteRef": {
      "$ref": "#/$defs/id"
    },
    "settledAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "AdviceRenderSettlement must echo the current boundaryTupleHash and decisionEpochRef.",
    "Stale or mismatched boundary tuples must settle as invalidated or superseded rather than retargeting patient-facing advice."
  ]
}
