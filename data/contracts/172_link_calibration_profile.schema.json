{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/172_link_calibration_profile.schema.json",
  "title": "LinkCalibrationProfile",
  "description": "Versioned calibration and threshold profile for patient linkage. Missing calibration fails closed and cannot be treated as a usable probability.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "linkCalibrationProfileId",
    "schemaVersion",
    "policyVersion",
    "calibrationVersionRef",
    "thresholdVersionRef",
    "routeSensitivityFamily",
    "calibratorType",
    "alphaLink",
    "alphaSubject",
    "deltaDrift",
    "thresholds",
    "minimumCalibrationPosture",
    "metrics",
    "createdAt"
  ],
  "properties": {
    "linkCalibrationProfileId": {
      "type": "string",
      "pattern": "^lcp_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "172.phase2.patient-link.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-patient-link-v[0-9]+$"
    },
    "calibrationVersionRef": {
      "type": "string"
    },
    "thresholdVersionRef": {
      "type": "string"
    },
    "routeSensitivityFamily": {
      "type": "string"
    },
    "calibratorType": {
      "type": "string",
      "enum": ["isotonic", "platt_logistic", "conservative_placeholder"]
    },
    "alphaLink": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 1
    },
    "alphaSubject": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 1
    },
    "deltaDrift": {
      "type": "number",
      "minimum": 0
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "autoLinkLcbMin",
        "provisionalLcbMin",
        "runnerUpUcbMax",
        "subjectLcbMin",
        "gapLogitMin",
        "driftFailClosedPosture"
      ],
      "properties": {
        "autoLinkLcbMin": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "provisionalLcbMin": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "runnerUpUcbMax": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "subjectLcbMin": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "gapLogitMin": {
          "type": "number",
          "minimum": 0
        },
        "driftFailClosedPosture": {
          "type": "string",
          "enum": ["manual_review_only", "ambiguous", "provisional_verified", "none"]
        }
      }
    },
    "minimumCalibrationPosture": {
      "type": "string",
      "enum": ["auto_link_allowed", "provisional_only", "manual_review_only"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["brierScoreMax", "calibrationSlopeRange", "minimumAdjudicatedExamples"],
      "properties": {
        "brierScoreMax": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "calibrationSlopeRange": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number"
          }
        },
        "minimumAdjudicatedExamples": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
