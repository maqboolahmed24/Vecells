{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/374_phase7_continuity_evidence_bundle_schema.json",
  "title": "NHSAppContinuityEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundleId",
    "manifestVersionRef",
    "journeyPathRef",
    "continuityControlCode",
    "governingContractRef",
    "experienceContinuityEvidenceRefs",
    "validationState",
    "blockingRefs",
    "releaseApprovalFreezeRef",
    "capturedAt"
  ],
  "properties": {
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "manifestVersionRef": {
      "type": "string",
      "minLength": 1
    },
    "journeyPathRef": {
      "type": "string",
      "minLength": 1
    },
    "continuityControlCode": {
      "type": "string",
      "minLength": 1
    },
    "governingContractRef": {
      "type": "string",
      "minLength": 1
    },
    "experienceContinuityEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "validationState": {
      "type": "string",
      "enum": ["trusted", "degraded", "stale", "blocked"]
    },
    "blockingRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "releaseApprovalFreezeRef": {
      "type": "string",
      "minLength": 1
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
