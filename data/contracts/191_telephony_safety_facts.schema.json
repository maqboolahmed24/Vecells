{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/191_telephony_safety_facts.schema.json",
  "title": "TelephonySafetyFacts",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "telephonySafetyFactsRef",
    "schemaVersion",
    "callSessionRef",
    "transcriptJobRef",
    "derivationPackageRef",
    "extractionVersionRef",
    "transcriptDigest",
    "transcriptWordCount",
    "transcriptFactSignals",
    "keypadFactSignals",
    "operatorSupplementRefs",
    "contradictionFlags",
    "coverageGaps",
    "clinicallyRelevantSnippetRefs",
    "factCompleteness",
    "createdAt",
    "recordedBy"
  ],
  "properties": {
    "telephonySafetyFactsRef": { "type": "string", "pattern": "^tel_safety_facts_191_" },
    "schemaVersion": { "const": "191.phase2.telephony-readiness.v1" },
    "callSessionRef": { "type": "string" },
    "transcriptJobRef": { "type": "string" },
    "derivationPackageRef": { "type": "string" },
    "extractionVersionRef": { "const": "phase2-telephony-fact-extractor-191.v1" },
    "transcriptDigest": { "type": "string" },
    "transcriptWordCount": { "type": "integer", "minimum": 0 },
    "transcriptFactSignals": { "type": "array", "items": { "type": "object" } },
    "keypadFactSignals": { "type": "array", "items": { "type": "object" } },
    "operatorSupplementRefs": { "type": "array", "items": { "type": "string" } },
    "contradictionFlags": { "type": "array", "items": { "type": "string" } },
    "coverageGaps": { "type": "array", "items": { "type": "string" } },
    "clinicallyRelevantSnippetRefs": { "type": "array", "items": { "type": "string" } },
    "factCompleteness": { "enum": ["none", "partial", "complete"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyReadinessPipeline" }
  }
}
