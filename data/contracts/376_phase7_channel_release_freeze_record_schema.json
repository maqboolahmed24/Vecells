{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_channel_release_freeze_record_schema.json",
  "title": "ChannelReleaseFreezeRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "freezeRecordId",
    "manifestVersionRef",
    "releaseApprovalFreezeRef",
    "cohortRef",
    "journeyPathRefs",
    "triggerType",
    "assuranceSliceTrustRefs",
    "continuityEvidenceRefs",
    "freezeState",
    "openedAt",
    "releasedAt",
    "operatorNoteRef"
  ],
  "properties": {
    "freezeRecordId": {
      "type": "string"
    },
    "manifestVersionRef": {
      "type": "string"
    },
    "releaseApprovalFreezeRef": {
      "type": "string"
    },
    "cohortRef": {
      "type": "string"
    },
    "journeyPathRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "triggerType": {
      "type": "string",
      "enum": [
        "telemetry_missing",
        "threshold_breach",
        "assurance_slice_degraded",
        "compatibility_drift",
        "continuity_evidence_degraded"
      ]
    },
    "assuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "continuityEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "freezeState": {
      "type": "string",
      "enum": ["monitoring", "frozen", "kill_switch_active", "rollback_recommended", "released"]
    },
    "openedAt": {
      "type": "string",
      "format": "date-time"
    },
    "releasedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "operatorNoteRef": {
      "type": "string"
    }
  }
}
