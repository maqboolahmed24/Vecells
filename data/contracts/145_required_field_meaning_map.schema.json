{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase1/required-field-meaning-map.schema.json",
  "title": "RequiredFieldMeaningMap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mapSchemaVersion",
    "bundleRef",
    "requestType",
    "rows"
  ],
  "properties": {
    "mapSchemaVersion": {
      "type": "string",
      "const": "REQUIRED_FIELD_MEANING_MAP_V1"
    },
    "bundleRef": {
      "type": "string"
    },
    "requestType": {
      "type": "string",
      "enum": [
        "Symptoms",
        "Meds",
        "Admin",
        "Results"
      ]
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requiredFieldMeaningRow"
      }
    }
  },
  "$defs": {
    "requiredFieldMeaningRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "questionKey",
        "requestType",
        "stepKey",
        "visibilityState",
        "requiredState",
        "answerState",
        "activePayloadDisposition",
        "normalizationTarget",
        "summaryRenderer",
        "safetyRelevance"
      ],
      "properties": {
        "questionKey": {
          "type": "string"
        },
        "requestType": {
          "type": "string",
          "enum": [
            "Symptoms",
            "Meds",
            "Admin",
            "Results"
          ]
        },
        "stepKey": {
          "type": "string"
        },
        "visibilityState": {
          "type": "string",
          "enum": [
            "visible",
            "hidden"
          ]
        },
        "requiredState": {
          "type": "string",
          "enum": [
            "required",
            "optional"
          ]
        },
        "answerState": {
          "type": "string",
          "enum": [
            "valid",
            "missing",
            "invalid",
            "superseded",
            "inactive",
            "optional_unanswered"
          ]
        },
        "activePayloadDisposition": {
          "type": "string",
          "enum": [
            "included",
            "excluded"
          ]
        },
        "normalizationTarget": {
          "type": "string"
        },
        "summaryRenderer": {
          "type": "string"
        },
        "safetyRelevance": {
          "type": "string",
          "enum": [
            "none",
            "triage_relevant",
            "safety_relevant"
          ]
        }
      }
    }
  }
}
