{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_message_delivery_evidence_bundle.schema.json",
  "title": "229 MessageDeliveryEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "bundleId",
    "dispatchEnvelopeRef",
    "dispatchFenceEpoch",
    "threadVersionRef",
    "receiptCheckpointRef",
    "deliveryState",
    "evidenceStrength",
    "providerDispositionRef",
    "deliveryArtifactRefs",
    "reachabilityDependencyRef",
    "supportActionSettlementRef",
    "causalToken",
    "recordedAt"
  ],
  "properties": {
    "bundleId": {
      "$ref": "#/$defs/id"
    },
    "dispatchEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "dispatchFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "threadVersionRef": {
      "$ref": "#/$defs/id"
    },
    "receiptCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "deliveryState": {
      "type": "string",
      "enum": [
        "delivered",
        "disputed",
        "failed",
        "expired"
      ]
    },
    "evidenceStrength": {
      "type": "string",
      "enum": [
        "direct_provider_receipt",
        "durable_channel_ack",
        "manual_attestation",
        "contradictory_signal"
      ]
    },
    "providerDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "deliveryArtifactRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "supportActionSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "MessageDeliveryEvidenceBundle is the only durable source of delivered, disputed, failed, or expired thread truth.",
    "Provider acceptance or local acknowledgement may not stand in for delivery evidence."
  ]
}
