{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/458_governance_role_scope_studio_projection.schema.json",
  "title": "Governance Role Scope Studio Projection",
  "type": "object",
  "required": [
    "taskId",
    "schemaVersion",
    "visualMode",
    "route",
    "scenarioState",
    "bindingState",
    "actionControlState",
    "governanceScopeRibbon",
    "roleGrantMatrix",
    "effectiveAccessPreview",
    "accessPreviewArtifactMask",
    "breakGlassElevationSummary",
    "releaseFreezeCards",
    "deniedActionExplainers",
    "scopeTupleInspector",
    "governanceReturnContextStrip",
    "telemetryDisclosureFence",
    "actionRail",
    "sourceAlgorithmRefs",
    "upstreamSchemaVersions",
    "automationAnchors"
  ],
  "properties": {
    "taskId": {
      "const": "par_458"
    },
    "schemaVersion": {
      "const": "458.phase9.governance-role-scope-studio.v1"
    },
    "visualMode": {
      "const": "Role_Scope_Proof_Studio"
    },
    "route": {
      "type": "string",
      "pattern": "^/ops/access/"
    },
    "scenarioState": {
      "enum": [
        "normal",
        "empty",
        "stale",
        "degraded",
        "blocked",
        "permission_denied",
        "settlement_pending",
        "frozen",
        "masked"
      ]
    },
    "bindingState": {
      "enum": [
        "live",
        "stale_review",
        "degraded_read_only",
        "blocked",
        "permission_denied",
        "settlement_pending",
        "release_frozen"
      ]
    },
    "actionControlState": {
      "enum": [
        "preview_only",
        "diagnostic_only",
        "recovery_only",
        "blocked",
        "metadata_only",
        "settlement_pending",
        "frozen"
      ]
    },
    "governanceScopeRibbon": {
      "type": "object",
      "required": [
        "tenantRef",
        "organisationRef",
        "purposeOfUseRef",
        "actingRoleRef",
        "governanceScopeTokenRef",
        "actingScopeTupleRef",
        "scopeTupleHash",
        "runtimePublicationState",
        "releaseFreezeVerdict",
        "writeState",
        "gapArtifactRef"
      ]
    },
    "roleGrantMatrix": {
      "type": "object",
      "required": ["roleRef", "capabilityColumns", "rows", "selectedRouteFamilyRef"],
      "properties": {
        "capabilityColumns": {
          "type": "array",
          "minItems": 7
        },
        "rows": {
          "type": "array"
        }
      }
    },
    "effectiveAccessPreview": {
      "type": "object",
      "required": [
        "subjectRef",
        "personaRef",
        "actingScopeTupleRef",
        "scopeTupleHash",
        "decision",
        "previewState",
        "decisionReasonRefs",
        "visiblePanels",
        "maskedFields",
        "hiddenFields",
        "exportBlockedDestinationControls",
        "telemetryPreview"
      ]
    },
    "accessPreviewArtifactMask": {
      "type": "object",
      "required": [
        "beforeRegions",
        "afterRegions",
        "maskPolicyRef",
        "hiddenFieldsNotRendered",
        "telemetryRedacted",
        "syntheticFixtureOnly"
      ],
      "properties": {
        "hiddenFieldsNotRendered": {
          "const": true
        },
        "telemetryRedacted": {
          "const": true
        },
        "syntheticFixtureOnly": {
          "const": true
        }
      }
    },
    "releaseFreezeCards": {
      "type": "array",
      "minItems": 6
    },
    "deniedActionExplainers": {
      "type": "array",
      "minItems": 3
    },
    "telemetryDisclosureFence": {
      "type": "object",
      "required": [
        "fenceRef",
        "allowedPayloadKeys",
        "blockedPayloadKeys",
        "rawSensitiveTextAbsent",
        "screenshotFixtureClass"
      ],
      "properties": {
        "rawSensitiveTextAbsent": {
          "const": true
        },
        "screenshotFixtureClass": {
          "const": "synthetic_only"
        }
      }
    },
    "actionRail": {
      "type": "array",
      "minItems": 5
    },
    "sourceAlgorithmRefs": {
      "type": "array",
      "minItems": 5
    },
    "upstreamSchemaVersions": {
      "type": "object",
      "required": ["448", "449", "457", "phase5ActingContextKernel"]
    },
    "automationAnchors": {
      "type": "array",
      "minItems": 10
    }
  },
  "additionalProperties": true
}
