{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_admin_resolution_action_record.schema.json",
  "title": "229 AdminResolutionActionRecord",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adminResolutionActionRecordId",
    "adminResolutionCaseRef",
    "boundaryDecisionRef",
    "boundaryTupleHash",
    "clinicalMeaningState",
    "operationalFollowUpScope",
    "decisionEpochRef",
    "decisionSupersessionRecordRef",
    "actionType",
    "routeIntentBindingRef",
    "reviewActionLeaseRef",
    "reviewActionOwnershipEpochRef",
    "reviewActionFencingToken",
    "workspaceConsistencyProjectionRef",
    "workspaceTrustProjectionRef",
    "commandActionRef",
    "policyBundleRef",
    "releaseApprovalFreezeRef",
    "channelReleaseFreezeRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "lineageFenceEpoch",
    "reasonCode",
    "idempotencyKey",
    "createdByRef",
    "createdAt"
  ],
  "properties": {
    "adminResolutionActionRecordId": {
      "$ref": "#/$defs/id"
    },
    "adminResolutionCaseRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryTupleHash": {
      "$ref": "#/$defs/id"
    },
    "clinicalMeaningState": {
      "type": "string",
      "enum": [
        "bounded_admin_only",
        "clinician_reentry_required"
      ]
    },
    "operationalFollowUpScope": {
      "type": "string",
      "enum": [
        "bounded_admin_resolution"
      ]
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "actionType": {
      "type": "string",
      "enum": [
        "claim",
        "issue_advice",
        "notify_patient",
        "wait_dependency",
        "record_completion",
        "reopen_for_review",
        "cancel_wait",
        "reclassify_subtype"
      ]
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "reviewActionLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "reviewActionOwnershipEpochRef": {
      "$ref": "#/$defs/id"
    },
    "reviewActionFencingToken": {
      "$ref": "#/$defs/id"
    },
    "workspaceConsistencyProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "workspaceTrustProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "commandActionRef": {
      "$ref": "#/$defs/id"
    },
    "policyBundleRef": {
      "$ref": "#/$defs/id"
    },
    "releaseApprovalFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "channelReleaseFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "reasonCode": {
      "type": "string",
      "minLength": 1
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "createdByRef": {
      "$ref": "#/$defs/id"
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    },
    "settledAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "x-governedInvariants": [
    "AdminResolutionActionRecord must echo the current boundaryTupleHash or settle stale_recoverable downstream.",
    "Local UI acknowledgement may not imply completed admin work without command settlement."
  ]
}
