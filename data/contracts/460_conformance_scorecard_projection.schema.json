{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "460.phase9.service-owner-conformance-scorecard.schema.json",
  "title": "Task 460 CrossPhaseConformanceScorecardProjection",
  "type": "object",
  "required": [
    "taskId",
    "schemaVersion",
    "route",
    "visualMode",
    "scenarioState",
    "scorecardHash",
    "phaseRows",
    "visibleRows",
    "controlFamilyMatrix",
    "runtimeTupleCoverage",
    "governanceOpsProofRail",
    "blockerQueue",
    "bauSignoffReadiness",
    "sourceTrace",
    "rowDiff",
    "safeHandoffLinks",
    "noRawArtifactUrls",
    "interfaceGapArtifactRef"
  ],
  "properties": {
    "taskId": { "const": "par_460" },
    "schemaVersion": { "const": "460.phase9.service-owner-conformance-scorecard.v1" },
    "route": { "const": "/ops/conformance" },
    "visualMode": { "const": "Service_Owner_Conformance_Ledger" },
    "scenarioState": {
      "enum": [
        "exact",
        "stale",
        "blocked",
        "summary_drift",
        "missing_verification",
        "stale_runtime_tuple",
        "missing_ops_proof",
        "deferred_channel",
        "no_blocker",
        "permission_denied"
      ]
    },
    "scorecardHash": {
      "type": "object",
      "required": ["scorecardRef", "scorecardState", "scorecardHash", "graphVerdictState"],
      "properties": {
        "scorecardState": { "enum": ["exact", "stale", "blocked"] },
        "graphVerdictState": { "enum": ["exact", "stale", "blocked"] },
        "scorecardHash": { "type": "string", "minLength": 12 }
      },
      "additionalProperties": true
    },
    "phaseRows": {
      "type": "array",
      "items": { "$ref": "#/$defs/phaseRow" },
      "minItems": 1
    },
    "visibleRows": {
      "type": "array",
      "items": { "$ref": "#/$defs/phaseRow" }
    },
    "controlFamilyMatrix": {
      "type": "object",
      "required": ["families", "dimensions", "cells"],
      "properties": {
        "families": { "type": "array", "minItems": 10 },
        "dimensions": { "type": "array", "minItems": 7 },
        "cells": { "type": "array", "minItems": 70 }
      },
      "additionalProperties": true
    },
    "bauSignoffReadiness": {
      "type": "object",
      "required": ["actionState", "actionAllowed", "disabledReason", "blockerRefs"],
      "properties": {
        "actionState": {
          "enum": ["ready", "blocked", "diagnostic_only", "permission_denied"]
        },
        "actionAllowed": { "type": "boolean" },
        "disabledReason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "sourceTrace": {
      "type": "object",
      "required": ["selectedRowRef", "drawerState", "returnTokenRef", "steps"],
      "properties": {
        "drawerState": { "enum": ["open", "closed"] },
        "returnTokenRef": { "type": "string", "pattern": "^return-token:460:" },
        "steps": { "type": "array", "minItems": 8 }
      },
      "additionalProperties": true
    },
    "safeHandoffLinks": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "required": ["targetSurface", "route", "returnTokenRef", "rawArtifactUrlSuppressed"],
        "properties": {
          "route": { "type": "string", "pattern": "^/ops/" },
          "rawArtifactUrlSuppressed": { "const": true }
        },
        "additionalProperties": true
      }
    },
    "noRawArtifactUrls": { "const": true },
    "interfaceGapArtifactRef": {
      "const": "PHASE9_BATCH_458_472_INTERFACE_GAP_460_CONFORMANCE_PROJECTION"
    }
  },
  "$defs": {
    "phaseRow": {
      "type": "object",
      "required": [
        "phaseConformanceRowId",
        "phaseCode",
        "rowKind",
        "ownerKey",
        "summaryAlignmentState",
        "contractAdoptionState",
        "verificationCoverageState",
        "operationalProofState",
        "governanceProofState",
        "recoveryPostureState",
        "endStateProofState",
        "rowState",
        "rowHash",
        "blockerRefs"
      ],
      "properties": {
        "rowKind": { "enum": ["phase", "control_family", "deferred_channel"] },
        "rowState": { "enum": ["exact", "stale", "blocked"] },
        "blockerRefs": { "type": "array" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
