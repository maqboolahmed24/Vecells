{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/374_phase7_manifest_promotion_bundle_schema.json",
  "title": "ManifestPromotionBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundleId",
    "manifestVersion",
    "environment",
    "configFingerprint",
    "releaseCandidateRef",
    "releaseApprovalFreezeRef",
    "behaviorContractSetRef",
    "surfaceSchemaSetRef",
    "compatibilityEvidenceRef",
    "approvedBy",
    "promotedAt",
    "rollbackRef"
  ],
  "properties": {
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": ["local_preview", "sandpit", "aos", "limited_release", "full_release"]
    },
    "configFingerprint": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "releaseCandidateRef": {
      "type": "string",
      "minLength": 1
    },
    "releaseApprovalFreezeRef": {
      "type": "string",
      "minLength": 1
    },
    "behaviorContractSetRef": {
      "type": "string",
      "minLength": 1
    },
    "surfaceSchemaSetRef": {
      "type": "string",
      "minLength": 1
    },
    "compatibilityEvidenceRef": {
      "type": "string",
      "minLength": 1
    },
    "approvedBy": {
      "type": "string",
      "minLength": 1
    },
    "promotedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "rollbackRef": {
      "type": "string",
      "minLength": 1
    }
  }
}
