{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_hub_variance_window_policy.schema.json",
  "title": "HubVarianceWindowPolicy",
  "description": "Policy family that resolves the required clinical window, approved variance window, and whether outside-window candidates remain visible only as governed explanations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "varianceWindowPolicyId",
    "policyVersion",
    "policyTupleHash",
    "requiredWindowRule",
    "approvedVarianceBeforeMinutes",
    "approvedVarianceAfterMinutes",
    "outsideWindowVisibleByPolicy",
    "varianceDisposition",
    "sourceRefs"
  ],
  "properties": {
    "varianceWindowPolicyId": {
      "type": "string",
      "minLength": 1,
      "description": "Variance pack identifier."
    },
    "policyVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Variance pack version."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Compiled tuple hash."
    },
    "requiredWindowRule": {
      "type": "string",
      "minLength": 1,
      "description": "Rule ref for case-derived required window."
    },
    "approvedVarianceBeforeMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Allowed variance before the required window."
    },
    "approvedVarianceAfterMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Allowed variance after the required window."
    },
    "outsideWindowVisibleByPolicy": {
      "type": "boolean",
      "description": "Whether outside-window candidates may remain visible as governed explanation rows."
    },
    "varianceDisposition": {
      "type": "string",
      "enum": [
        "inside_required_window",
        "inside_approved_variance_window",
        "outside_window_visible_by_policy",
        "outside_window_blocked"
      ],
      "description": "Resolved variance vocabulary."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5C. Enhanced Access policy engine and network capacity ingestion",
    "blueprint/phase-5-the-network-horizon.md#5D. Coordination queue, candidate ranking, and SLA engine",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#ranking-order-and-visible-cues-must-derive-from-persisted-proof",
    "blueprint/phase-0-the-foundation-protocol.md#publication-and-bundle-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#assurance-and-trust-carry-forward",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md"
  ]
}
