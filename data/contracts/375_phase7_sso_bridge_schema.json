{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_sso_bridge_schema.json",
  "title": "SSOBridgeFamily",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ssoEntryGrant",
    "authBridgeTransaction",
    "identityAssertionBinding",
    "sessionMergeDecision",
    "ssoReturnDisposition"
  ],
  "properties": {
    "ssoEntryGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entryGrantId",
        "journeyPathId",
        "assertedIdentityHash",
        "requestHash",
        "receivedAt",
        "expiresAt",
        "consumedAt",
        "redactedAt",
        "stateRef",
        "returnIntentRef",
        "consumptionFenceEpoch",
        "originChannelRef",
        "maxRedemptions",
        "redemptionCount",
        "grantState"
      ],
      "properties": {
        "entryGrantId": {
          "type": "string"
        },
        "journeyPathId": {
          "type": "string"
        },
        "assertedIdentityHash": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "requestHash": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "receivedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "consumedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "redactedAt": {
          "type": "string",
          "format": "date-time"
        },
        "stateRef": {
          "type": "string"
        },
        "returnIntentRef": {
          "type": "string"
        },
        "consumptionFenceEpoch": {
          "type": "string"
        },
        "originChannelRef": {
          "type": "string"
        },
        "maxRedemptions": {
          "type": "integer",
          "const": 1
        },
        "redemptionCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "grantState": {
          "type": "string",
          "enum": ["pending", "consumed", "superseded", "expired", "denied"]
        }
      }
    },
    "authBridgeTransaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transactionId",
        "entryGrantId",
        "stateHash",
        "nonceHash",
        "codeVerifierRef",
        "promptMode",
        "responseMode",
        "status",
        "errorRef",
        "completedAt",
        "manifestVersionRef",
        "bridgeCapabilityMatrixRef",
        "contextFenceRef",
        "transactionState"
      ],
      "properties": {
        "transactionId": {
          "type": "string"
        },
        "entryGrantId": {
          "type": "string"
        },
        "stateHash": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "nonceHash": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "codeVerifierRef": {
          "type": "string"
        },
        "promptMode": {
          "type": "string",
          "const": "none"
        },
        "responseMode": {
          "type": "string",
          "enum": ["query", "form_post"]
        },
        "status": {
          "type": "string"
        },
        "errorRef": {
          "type": ["string", "null"]
        },
        "completedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "manifestVersionRef": {
          "type": "string"
        },
        "bridgeCapabilityMatrixRef": {
          "type": "string"
        },
        "contextFenceRef": {
          "type": "string"
        },
        "transactionState": {
          "type": "string",
          "enum": [
            "opened",
            "awaiting_callback",
            "callback_received",
            "verified",
            "recovery_required",
            "denied"
          ]
        }
      }
    },
    "identityAssertionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingId",
        "entryGrantRef",
        "assertedIdentityHash",
        "nhsLoginSubjectRef",
        "claimSetHash",
        "localSubjectBindingRef",
        "bindingState",
        "evaluatedAt"
      ],
      "properties": {
        "bindingId": {
          "type": "string"
        },
        "entryGrantRef": {
          "type": "string"
        },
        "assertedIdentityHash": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "nhsLoginSubjectRef": {
          "type": "string"
        },
        "claimSetHash": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "localSubjectBindingRef": {
          "type": "string"
        },
        "bindingState": {
          "type": "string",
          "enum": ["matched", "mismatched", "repair_required", "denied"]
        },
        "evaluatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "sessionMergeDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mergeDecisionId",
        "transactionRef",
        "existingSessionRef",
        "resolvedSessionRef",
        "subjectComparisonState",
        "draftClaimDisposition",
        "resumeIntentDisposition",
        "decision",
        "decidedAt"
      ],
      "properties": {
        "mergeDecisionId": {
          "type": "string"
        },
        "transactionRef": {
          "type": "string"
        },
        "existingSessionRef": {
          "type": ["string", "null"]
        },
        "resolvedSessionRef": {
          "type": ["string", "null"]
        },
        "subjectComparisonState": {
          "type": "string",
          "enum": [
            "no_session",
            "anonymous_session",
            "same_subject_same_binding",
            "same_subject_binding_advanced",
            "different_subject",
            "mismatched_secure_link_subject",
            "stale_existing"
          ]
        },
        "draftClaimDisposition": {
          "type": "string",
          "enum": [
            "none",
            "claim_route_required",
            "draft_claim_allowed",
            "request_shell_required",
            "blocked_other_subject"
          ]
        },
        "resumeIntentDisposition": {
          "type": "string",
          "enum": ["consume_intent", "consume_to_recovery", "supersede_intent", "deny_intent"]
        },
        "decision": {
          "type": "string",
          "enum": ["reuse", "rotate", "terminate_and_reenter", "deny"]
        },
        "decidedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "ssoReturnDisposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "returnDispositionId",
        "transactionRef",
        "outcome",
        "patientRouteRef",
        "appReturnTargetRef",
        "copyVariantRef",
        "allowRetry",
        "evidenceRef"
      ],
      "properties": {
        "returnDispositionId": {
          "type": "string"
        },
        "transactionRef": {
          "type": "string"
        },
        "outcome": {
          "type": "string",
          "enum": [
            "silent_success",
            "consent_denied",
            "silent_failure",
            "manifest_drift",
            "context_drift",
            "session_conflict",
            "safe_reentry_required"
          ]
        },
        "patientRouteRef": {
          "type": "string"
        },
        "appReturnTargetRef": {
          "type": "string"
        },
        "copyVariantRef": {
          "type": "string"
        },
        "allowRetry": {
          "type": "boolean"
        },
        "evidenceRef": {
          "type": "string"
        }
      }
    }
  }
}
