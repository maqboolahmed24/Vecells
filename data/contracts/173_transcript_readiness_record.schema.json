{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/173_transcript_readiness_record.schema.json",
  "title": "TelephonyTranscriptReadinessRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "telephonyTranscriptReadinessRecordId",
    "callSessionRef",
    "recordingArtifactRef",
    "transcriptJobRef",
    "transcriptState",
    "coverageClass",
    "qualityBand",
    "sufficiencyState",
    "derivedFactsPackageRef",
    "blockingReasonCodes",
    "immutabilityRule",
    "checkedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "173.phase2.telephony.transcript-readiness.v1"
    },
    "telephonyTranscriptReadinessRecordId": {
      "type": "string",
      "pattern": "^tel_tr_[A-Za-z0-9_:-]+$"
    },
    "callSessionRef": {
      "type": "string"
    },
    "recordingArtifactRef": {
      "type": ["string", "null"],
      "description": "Object-store or DocumentReference pointer; raw audio never appears inline."
    },
    "transcriptJobRef": {
      "type": ["string", "null"]
    },
    "transcriptState": {
      "type": "string",
      "enum": ["not_started", "queued", "running", "partial", "ready", "failed", "superseded"]
    },
    "coverageClass": {
      "type": "string",
      "enum": ["none", "keyword_only", "partial_utterance", "clinically_sufficient"]
    },
    "qualityBand": {
      "type": "string",
      "enum": ["unknown", "low", "medium", "high"]
    },
    "sufficiencyState": {
      "type": "string",
      "enum": [
        "not_sufficient",
        "sufficient_for_urgent_live",
        "sufficient_for_structured_capture",
        "sufficient_for_safety_review"
      ]
    },
    "derivedFactsPackageRef": {
      "type": ["string", "null"],
      "description": "Immutable EvidenceDerivationPackage reference for extracted facts."
    },
    "blockingReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "recording_missing",
          "transcript_job_running",
          "transcript_job_failed",
          "coverage_not_clinically_sufficient",
          "quality_too_low",
          "contradictory_capture",
          "manual_audio_review_required"
        ]
      }
    },
    "immutabilityRule": {
      "const": "append_new_record_for_rerun_or_manual_correction"
    },
    "checkedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
