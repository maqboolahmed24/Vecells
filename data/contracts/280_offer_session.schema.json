{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells://contracts/OfferSession",
  "title": "OfferSession",
  "description": "OfferSession contract over pre-ranked candidates, not raw supplier slot ids.",
  "type": "object",
  "additionalProperties": false,
  "x-taskId": "seq_280",
  "x-contractVersion": "280.phase4.booking-flow-freeze.v1",
  "required": [
    "offerSessionId",
    "bookingCaseId",
    "slotSetSnapshotRef",
    "rankPlanVersion",
    "capacityRankProofRef",
    "selectionToken",
    "selectedCandidateHash",
    "selectedCanonicalSlotIdentityRef",
    "reservationTruthProjectionRef",
    "selectionProofHash",
    "truthMode",
    "expiresAt"
  ],
  "properties": {
    "offerSessionId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable OfferSession identifier."
    },
    "bookingCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning BookingCase identifier."
    },
    "slotSetSnapshotRef": {
      "type": "string",
      "minLength": 1,
      "description": "Selected SlotSetSnapshot ref."
    },
    "rankPlanVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Current RankPlan version ref."
    },
    "capacityRankProofRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current CapacityRankProof ref."
    },
    "selectionToken": {
      "type": "string",
      "minLength": 1,
      "description": "Interaction-scoped selection token."
    },
    "selectedCandidateHash": {
      "type": "string",
      "minLength": 1,
      "description": "Hash of the selected candidate proof row."
    },
    "selectedCanonicalSlotIdentityRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical slot identity ref."
    },
    "reservationTruthProjectionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current ReservationTruthProjection ref."
    },
    "selectionProofHash": {
      "type": "string",
      "minLength": 1,
      "description": "Hash of the exact proof tuple shown to the user."
    },
    "truthMode": {
      "type": "string",
      "enum": [
        "truthful_nonexclusive",
        "exclusive_hold",
        "degraded_manual_pending"
      ],
      "description": "Interaction truth mode for the dominant offer."
    },
    "compareModeState": {
      "type": "string",
      "enum": [
        "list",
        "calendar",
        "compare"
      ],
      "description": "Visible offer presentation mode."
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "Interaction TTL. Never proof of exclusivity by itself."
    }
  },
  "x-formulas": {
    "Frontier_b": {
      "name": "Frontier_b",
      "expression": "Frontier_b = { s : windowClass(s)=b and startAtEpoch(s) <= earliestStart_b + Delta_reorder_b }",
      "machineFields": [
        "windowClass",
        "startAtEpoch",
        "earliestStart_b",
        "Delta_reorder_b"
      ],
      "compiledFrom": "SearchPolicy.sameBandReorderSlackMinutesByWindow"
    },
    "softScore": {
      "name": "softScore(s)",
      "expression": "softScore(s) = w_delay * f_delay(s) + w_continuity * f_continuity(s) + w_site * f_site(s) + w_tod * f_tod(s) + w_travel * f_travel(s) + w_modality * f_modality(s)",
      "machineFields": [
        "w_delay",
        "w_continuity",
        "w_site",
        "w_tod",
        "w_travel",
        "w_modality",
        "f_delay",
        "f_continuity",
        "f_site",
        "f_tod",
        "f_travel",
        "f_modality"
      ],
      "constraints": [
        "sum w_* = 1",
        "do not include both waitMinutes and waitDays in the same linear score"
      ]
    }
  },
  "x-sourceRefs": [
    "blueprint/phase-4-the-booking-engine.md",
    "blueprint/phase-0-the-foundation-protocol.md"
  ]
}
