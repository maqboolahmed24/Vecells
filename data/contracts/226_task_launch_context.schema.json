{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/226_task_launch_context.schema.json",
  "title": "226 TaskLaunchContext",
  "description": "Durable queue-to-task continuity contract for active review, return stubs, selected-anchor persistence, and next-task readiness.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "launchContextId",
    "taskId",
    "sourceQueueKey",
    "sourceQueueRankSnapshotRef",
    "returnAnchorRef",
    "returnAnchorTupleHash",
    "selectedAnchorRef",
    "selectedAnchorTupleHash",
    "nextTaskLaunchState",
    "departingTaskReturnStubState",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "launchContextId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "sourceQueueKey": {
      "$ref": "#/$defs/id"
    },
    "sourceSavedViewRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "sourceRowIndex": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "sourceQueueRankSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "returnAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "returnAnchorTupleHash": {
      "$ref": "#/$defs/id"
    },
    "nextTaskCandidateRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "nextTaskRankSnapshotRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "previewSnapshotRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "previewDigestRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "prefetchWindowRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "prefetchCandidateRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "prefetchRankSnapshotRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorTupleHash": {
      "$ref": "#/$defs/id"
    },
    "changedSinceSeenAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "nextTaskBlockingReasonRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "nextTaskLaunchState": {
      "type": "string",
      "enum": [
        "blocked",
        "gated",
        "ready",
        "launched"
      ]
    },
    "departingTaskReturnStubState": {
      "type": "string",
      "enum": [
        "none",
        "pinned",
        "released"
      ]
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    },
    "updatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "TaskLaunchContext is the durable continuity contract between queue, preview, active task, child routes, reopen flows, and next-task movement.",
    "Queue preview and background next-task prefetch remain summary-first and read-only; they may not mint ReviewActionLease or impersonate task-open.",
    "nextTaskCandidateRefs, prefetchCandidateRefs, nextTaskRankSnapshotRef, and prefetchRankSnapshotRef must agree on one committed queue snapshot or degrade to stale or recovery posture."
  ]
}
