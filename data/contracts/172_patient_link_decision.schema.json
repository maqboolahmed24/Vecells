{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/172_patient_link_decision.schema.json",
  "title": "PatientLinkDecision",
  "description": "Calibrated subject-to-patient link decision. Authentication success, PDS enrichment, and local session state are inputs only; this record emits a bounded binding intent for IdentityBindingAuthority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "patientLinkDecisionId",
    "schemaVersion",
    "policyVersion",
    "candidateSearchSpecRef",
    "matchEvidenceBasisRefs",
    "subjectRef",
    "winnerCandidateRef",
    "runnerUpCandidateRef",
    "P_link",
    "LCB_link_alpha",
    "UCB_link_alpha",
    "P_subject",
    "LCB_subject_alpha",
    "runnerUpProbabilityUpperBound",
    "gap_logit",
    "confidenceModelState",
    "linkState",
    "decisionClass",
    "autoLinkChecks",
    "identityBindingAuthorityIntent",
    "reasonCodes",
    "decidedAt"
  ],
  "properties": {
    "patientLinkDecisionId": {
      "type": "string",
      "pattern": "^pld_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "172.phase2.patient-link.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-patient-link-v[0-9]+$"
    },
    "candidateSearchSpecRef": {
      "type": "string"
    },
    "matchEvidenceBasisRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "subjectRef": {
      "type": "string"
    },
    "winnerCandidateRef": {
      "type": "string"
    },
    "runnerUpCandidateRef": {
      "type": ["string", "null"]
    },
    "P_link": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "LCB_link_alpha": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "UCB_link_alpha": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "P_subject": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "LCB_subject_alpha": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "runnerUpProbabilityUpperBound": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "gap_logit": {
      "type": "number"
    },
    "confidenceModelState": {
      "type": "string",
      "enum": ["calibrated", "drift_review", "out_of_domain"]
    },
    "linkState": {
      "type": "string",
      "enum": [
        "none",
        "candidate",
        "provisional_verified",
        "verified_patient",
        "ambiguous",
        "correction_pending",
        "revoked"
      ]
    },
    "decisionClass": {
      "type": "string",
      "enum": [
        "candidate_refresh",
        "provisional_verify",
        "verified_bind",
        "manual_review_required",
        "correction_pending",
        "revoked"
      ]
    },
    "autoLinkChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "winnerLowerBoundPass",
        "runnerUpCeilingPass",
        "gapLogitPass",
        "subjectProofFloorPass",
        "driftPass",
        "policyAllowsAutoLink"
      ],
      "properties": {
        "winnerLowerBoundPass": {
          "type": "boolean"
        },
        "runnerUpCeilingPass": {
          "type": "boolean"
        },
        "gapLogitPass": {
          "type": "boolean"
        },
        "subjectProofFloorPass": {
          "type": "boolean"
        },
        "driftPass": {
          "type": "boolean"
        },
        "policyAllowsAutoLink": {
          "type": "boolean"
        }
      }
    },
    "identityBindingAuthorityIntent": {
      "type": "string",
      "enum": [
        "submit_candidate_refresh",
        "submit_provisional_verify",
        "submit_verified_bind",
        "submit_repair_signal",
        "submit_revocation_signal"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^LINK_172_[A-Z0-9_]+$"
      }
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
