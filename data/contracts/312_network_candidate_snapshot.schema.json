{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_network_candidate_snapshot.schema.json",
  "title": "NetworkCandidateSnapshot",
  "description": "Persisted candidate snapshot that binds normalized candidates, rank-proof refs, and the active policy tuple under one durable snapshot ref.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshotId",
    "hubCoordinationCaseId",
    "policyEvaluationRef",
    "policyTupleHash",
    "rankPlanVersionRef",
    "uncertaintyModelVersionRef",
    "fetchedAt",
    "expiresAt",
    "candidateRefs",
    "candidateCount",
    "trustedCandidateCount",
    "degradedCandidateCount",
    "quarantinedCandidateCount",
    "capacityRankProofRef",
    "capacityRankExplanationRefs",
    "sourceRefs"
  ],
  "properties": {
    "snapshotId": {
      "type": "string",
      "minLength": 1,
      "description": "Snapshot identifier."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub case ref."
    },
    "policyEvaluationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Bound policy evaluation ref."
    },
    "compiledPolicyBundleRef": {
      "type": "string",
      "minLength": 1,
      "description": "Compiled bundle ref."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Hash of the tuple used for this snapshot."
    },
    "rankPlanVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Rank-plan version ref."
    },
    "uncertaintyModelVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Uncertainty-model version ref."
    },
    "fetchedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Fetch timestamp."
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "Snapshot expiry timestamp."
    },
    "candidateRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "All normalized candidate refs."
    },
    "candidateCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Count of normalized candidates."
    },
    "trustedCandidateCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Trusted candidate count."
    },
    "degradedCandidateCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Degraded candidate count."
    },
    "quarantinedCandidateCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Quarantined candidate count."
    },
    "capacityRankProofRef": {
      "type": "string",
      "minLength": 1,
      "description": "Rank proof ref."
    },
    "capacityRankExplanationRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Explanation refs."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
