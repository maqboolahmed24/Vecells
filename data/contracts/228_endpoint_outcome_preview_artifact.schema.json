{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_endpoint_outcome_preview_artifact.schema.json",
  "title": "228 EndpointOutcomePreviewArtifact",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "endpointOutcomePreviewArtifactId",
    "taskId",
    "endpointDecisionRef",
    "decisionEpochRef",
    "artifactType",
    "artifactPresentationContractRef",
    "outboundNavigationGrantPolicyRef",
    "audienceSurfaceRuntimeBindingRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "releasePublicationParityRef",
    "visibilityTier",
    "summarySafetyTier",
    "placeholderContractRef",
    "artifactState",
    "createdAt"
  ],
  "properties": {
    "endpointOutcomePreviewArtifactId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "endpointDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "artifactType": {
      "type": "string",
      "enum": [
        "patient_outcome_preview",
        "endpoint_rationale_summary",
        "handoff_seed_preview",
        "escalation_summary"
      ]
    },
    "artifactPresentationContractRef": {
      "$ref": "#/$defs/id"
    },
    "outboundNavigationGrantPolicyRef": {
      "$ref": "#/$defs/id"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "releasePublicationParityRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityTier": {
      "type": "string"
    },
    "summarySafetyTier": {
      "type": "string"
    },
    "placeholderContractRef": {
      "$ref": "#/$defs/id"
    },
    "artifactState": {
      "type": "string",
      "enum": [
        "summary_only",
        "interactive_same_shell",
        "external_handoff_ready",
        "recovery_only"
      ]
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "Outcome previews are governed presentation artifacts, not detached pages or raw file URLs.",
    "External or cross-app consequence handoff requires the bound OutboundNavigationGrant policy for the current epoch and route family."
  ]
}
