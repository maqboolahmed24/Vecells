{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_queue_rank_plan.schema.json",
  "title": "227 QueueRankPlan",
  "description": "Versioned canonical queue-ordering contract for Phase 3 triage queues.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    }
  },
  "required": [
    "queueRankPlanId",
    "queueFamilyRef",
    "eligibilityRuleSetRef",
    "lexicographicTierPolicy",
    "withinTierFormula",
    "withinTierWeightSet",
    "thresholdSet",
    "fairnessMergePolicy",
    "overloadGuardPolicy",
    "assignmentSuggestionPolicy",
    "explanationSchema",
    "canonicalTieBreakPolicy",
    "planHash",
    "effectiveAt"
  ],
  "properties": {
    "queueRankPlanId": {
      "$ref": "#/$defs/id"
    },
    "queueFamilyRef": {
      "$ref": "#/$defs/id"
    },
    "eligibilityRuleSetRef": {
      "$ref": "#/$defs/id"
    },
    "lexicographicTierPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sortOrder"
      ],
      "properties": {
        "sortOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 9
        },
        "criticalBypassRule": {
          "type": "string"
        }
      }
    },
    "withinTierFormula": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula"
      ],
      "properties": {
        "formula": {
          "type": "string",
          "minLength": 1
        },
        "factorDefinitions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "withinTierWeightSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "w_sla",
        "w_age",
        "w_residual",
        "w_contact",
        "w_return",
        "w_carry",
        "w_vulnerability",
        "beta_warn",
        "beta_late"
      ],
      "properties": {
        "w_sla": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "w_age": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "w_residual": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "w_contact": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "w_return": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "w_carry": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "w_vulnerability": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "beta_warn": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "beta_late": {
          "$ref": "#/$defs/nonNegativeNumber"
        }
      }
    },
    "thresholdSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "s_min_minutes",
        "theta_sla_critical_minutes",
        "theta_sla_warn_minutes",
        "tau_sla_minutes",
        "tau_late_minutes",
        "H_late_minutes",
        "tau_age_minutes",
        "A_cap_minutes",
        "r_base",
        "r_delta",
        "r_wait",
        "tau_return_minutes",
        "H_return_minutes"
      ],
      "properties": {
        "s_min_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "theta_sla_critical_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "theta_sla_warn_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "tau_sla_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "tau_late_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "H_late_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "tau_age_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "A_cap_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "r_base": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "r_delta": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "r_wait": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "tau_return_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "H_return_minutes": {
          "$ref": "#/$defs/nonNegativeNumber"
        }
      }
    },
    "fairnessMergePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "bands"
      ],
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "bands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "fairnessBandRef",
              "fixedBandOrder",
              "q_b",
              "gamma_age",
              "A_b_minutes",
              "H_b_minutes",
              "s_quantum_minutes"
            ],
            "properties": {
              "fairnessBandRef": {
                "$ref": "#/$defs/id"
              },
              "fixedBandOrder": {
                "type": "integer",
                "minimum": 1
              },
              "q_b": {
                "$ref": "#/$defs/nonNegativeNumber"
              },
              "gamma_age": {
                "$ref": "#/$defs/nonNegativeNumber"
              },
              "A_b_minutes": {
                "$ref": "#/$defs/nonNegativeNumber"
              },
              "H_b_minutes": {
                "$ref": "#/$defs/nonNegativeNumber"
              },
              "s_quantum_minutes": {
                "$ref": "#/$defs/nonNegativeNumber"
              },
              "eligibilitySummary": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "overloadGuardPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula",
        "rho_guard",
        "overloadEventId"
      ],
      "properties": {
        "formula": {
          "type": "string"
        },
        "rho_guard": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "overloadEventId": {
          "type": "string"
        },
        "suppressedPromises": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "triggeredResponses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "assignmentSuggestionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula",
        "candidateWindowSize",
        "epsilon_assign",
        "softWipCapRatio",
        "weights",
        "mayRewriteCanonicalOrder"
      ],
      "properties": {
        "formula": {
          "type": "string"
        },
        "candidateWindowSize": {
          "type": "integer",
          "minimum": 1
        },
        "epsilon_assign": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "softWipCapRatio": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "mayRewriteCanonicalOrder": {
          "type": "boolean",
          "const": false
        },
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "lambda_skill",
            "lambda_cont",
            "lambda_load",
            "lambda_sticky",
            "lambda_ctx",
            "lambda_focus"
          ],
          "properties": {
            "lambda_skill": {
              "$ref": "#/$defs/nonNegativeNumber"
            },
            "lambda_cont": {
              "$ref": "#/$defs/nonNegativeNumber"
            },
            "lambda_load": {
              "$ref": "#/$defs/nonNegativeNumber"
            },
            "lambda_sticky": {
              "$ref": "#/$defs/nonNegativeNumber"
            },
            "lambda_ctx": {
              "$ref": "#/$defs/nonNegativeNumber"
            },
            "lambda_focus": {
              "$ref": "#/$defs/nonNegativeNumber"
            }
          }
        }
      }
    },
    "explanationSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredPayloadFields"
      ],
      "properties": {
        "requiredPayloadFields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "canonicalTieBreakPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formula"
      ],
      "properties": {
        "formula": {
          "type": "string"
        }
      }
    },
    "planHash": {
      "$ref": "#/$defs/id"
    },
    "effectiveAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "QueueRankPlan is the only versioned source of canonical queue ordering.",
    "reviewer-specific skill, continuity, and focus may influence QueueAssignmentSuggestionSnapshot only after canonical queue order is fixed.",
    "coverageFit_i may not increase urgency; it remains a routing and suggestion concern only.",
    "overload honesty must suppress starvation promises when rho_crit >= rho_guard."
  ]
}
