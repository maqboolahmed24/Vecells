{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/279_provider_capability_matrix.schema.json",
  "title": "279 ProviderCapabilityMatrix inventory",
  "description": "Static booking-capability inventory. Matrix rows are published static capability ceilings and contract refs, not live route or UI authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "providerCapabilityMatrixId",
    "schemaVersion",
    "inventoryVersionRef",
    "ownerContext",
    "publishedAt",
    "rows"
  ],
  "properties": {
    "providerCapabilityMatrixId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable matrix bundle id."
    },
    "schemaVersion": {
      "const": "279.phase4.booking-capability-freeze.v1"
    },
    "inventoryVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Static inventory version ref."
    },
    "ownerContext": {
      "const": "booking"
    },
    "publishedAt": {
      "type": "string",
      "format": "date"
    },
    "rows": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "providerCapabilityMatrixRef",
          "matrixVersionRef",
          "rowOwnerRef",
          "tenantId",
          "practiceRef",
          "organisationRef",
          "supplierRef",
          "integrationMode",
          "deploymentType",
          "assuranceStateRef",
          "supportedActionScopes",
          "capabilities",
          "manageCapabilityState",
          "reservationMode",
          "authoritativeReadMode",
          "primaryDependencyDegradationProfileRef",
          "authoritativeReadAndConfirmationPolicyRef",
          "searchNormalizationContractRef",
          "revalidationContractRef",
          "manageSupportContractRef",
          "contractState",
          "publishedAt",
          "rowHash"
        ],
        "properties": {
          "providerCapabilityMatrixRef": {
            "type": "string",
            "minLength": 1,
            "description": "Static row id consumed by capability resolution."
          },
          "matrixVersionRef": {
            "type": "string",
            "minLength": 1,
            "description": "Version ref that must supersede instead of mutating in place."
          },
          "rowOwnerRef": {
            "type": "string",
            "minLength": 1,
            "description": "Explicit row ownership for controlled updates."
          },
          "tenantId": {
            "type": "string",
            "minLength": 1,
            "description": "Tenant scope."
          },
          "practiceRef": {
            "type": "string",
            "minLength": 1,
            "description": "Practice scope."
          },
          "organisationRef": {
            "type": "string",
            "minLength": 1,
            "description": "Organisation scope."
          },
          "supplierRef": {
            "type": "string",
            "minLength": 1,
            "description": "Supplier or provider family ref."
          },
          "supplierLabel": {
            "type": "string",
            "minLength": 1,
            "description": "Display label for atlas and audits."
          },
          "integrationMode": {
            "type": "string",
            "enum": [
              "im1_patient_api",
              "im1_transaction_api",
              "gp_connect_existing",
              "local_gateway_component",
              "manual_assist_only"
            ],
            "description": "Frozen booking integration mode."
          },
          "deploymentType": {
            "type": "string",
            "minLength": 1,
            "description": "Deployment or runtime shape."
          },
          "assuranceStateRef": {
            "type": "string",
            "minLength": 1,
            "description": "Assurance or onboarding posture."
          },
          "supportedActionScopes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "search_slots",
                "book_slot",
                "cancel_appointment",
                "reschedule_appointment",
                "view_appointment",
                "hold_slot",
                "launch_local_component",
                "repair_gp_linkage",
                "request_staff_assist",
                "manage_appointment",
                "view_booking_summary"
              ],
              "description": "Supported action scope"
            }
          },
          "capabilities": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "can_search_slots",
              "can_book",
              "can_cancel",
              "can_reschedule",
              "can_view_appointment",
              "can_hold_slot",
              "requires_gp_linkage_details",
              "supports_patient_self_service",
              "supports_staff_assisted_booking",
              "supports_async_commit_confirmation",
              "requires_local_consumer_component"
            ],
            "properties": {
              "can_search_slots": {
                "type": "boolean",
                "description": "Frozen capability field `can_search_slots`."
              },
              "can_book": {
                "type": "boolean",
                "description": "Frozen capability field `can_book`."
              },
              "can_cancel": {
                "type": "boolean",
                "description": "Frozen capability field `can_cancel`."
              },
              "can_reschedule": {
                "type": "boolean",
                "description": "Frozen capability field `can_reschedule`."
              },
              "can_view_appointment": {
                "type": "boolean",
                "description": "Frozen capability field `can_view_appointment`."
              },
              "can_hold_slot": {
                "type": "boolean",
                "description": "Frozen capability field `can_hold_slot`."
              },
              "requires_gp_linkage_details": {
                "type": "boolean",
                "description": "Frozen capability field `requires_gp_linkage_details`."
              },
              "supports_patient_self_service": {
                "type": "boolean",
                "description": "Frozen capability field `supports_patient_self_service`."
              },
              "supports_staff_assisted_booking": {
                "type": "boolean",
                "description": "Frozen capability field `supports_staff_assisted_booking`."
              },
              "supports_async_commit_confirmation": {
                "type": "boolean",
                "description": "Frozen capability field `supports_async_commit_confirmation`."
              },
              "requires_local_consumer_component": {
                "type": "boolean",
                "description": "Frozen capability field `requires_local_consumer_component`."
              }
            }
          },
          "manageCapabilityState": {
            "type": "string",
            "enum": [
              "full",
              "partial",
              "summary_only",
              "none"
            ],
            "description": "Static manage ceiling for this row."
          },
          "reservationMode": {
            "type": "string",
            "enum": [
              "exclusive_hold",
              "truthful_nonexclusive",
              "degraded_manual_pending"
            ],
            "description": "Reservation semantics ceiling for the row."
          },
          "authoritativeReadMode": {
            "type": "string",
            "enum": [
              "durable_provider_reference",
              "read_after_write",
              "gate_required"
            ],
            "description": "Authoritative confirmation proof ceiling for the row."
          },
          "primaryDependencyDegradationProfileRef": {
            "type": "string",
            "minLength": 1,
            "description": "Default degradation profile to compile into the binding."
          },
          "authoritativeReadAndConfirmationPolicyRef": {
            "type": "string",
            "minLength": 1,
            "description": "Authoritative-read and confirmation-gate policy seam ref."
          },
          "searchNormalizationContractRef": {
            "type": "string",
            "minLength": 1,
            "description": "Search normalization contract ref."
          },
          "revalidationContractRef": {
            "type": "string",
            "minLength": 1,
            "description": "Revalidation contract ref."
          },
          "manageSupportContractRef": {
            "type": "string",
            "minLength": 1,
            "description": "Manage-support contract ref."
          },
          "contractState": {
            "type": "string",
            "enum": [
              "draft",
              "active",
              "superseded",
              "withdrawn"
            ],
            "description": "Published row state."
          },
          "publishedAt": {
            "type": "string",
            "format": "date"
          },
          "rowHash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "Lower-hex SHA-256 over the canonical row payload."
          }
        }
      }
    }
  }
}
