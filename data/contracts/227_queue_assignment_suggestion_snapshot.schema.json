{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_queue_assignment_suggestion_snapshot.schema.json",
  "title": "227 QueueAssignmentSuggestionSnapshot",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "suggestionSnapshotId",
    "rankSnapshotRef",
    "reviewerScopeRef",
    "candidateWindowSize",
    "suggestionRows",
    "governedAutoClaimRefs",
    "authorityBoundary",
    "generatedAt"
  ],
  "properties": {
    "suggestionSnapshotId": {
      "$ref": "#/$defs/id"
    },
    "rankSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "reviewerScopeRef": {
      "$ref": "#/$defs/id"
    },
    "candidateWindowSize": {
      "type": "integer",
      "minimum": 1
    },
    "suggestionRows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskRef",
          "sourceOrdinal",
          "suggestedReviewerRef",
          "assignScore",
          "loadHeadroom",
          "skillScore",
          "continuityScore",
          "sameContext",
          "contextSwitchCost",
          "focusPenalty",
          "suggestionType"
        ],
        "properties": {
          "taskRef": {
            "$ref": "#/$defs/id"
          },
          "sourceOrdinal": {
            "type": "integer",
            "minimum": 1
          },
          "suggestedReviewerRef": {
            "$ref": "#/$defs/id"
          },
          "assignScore": {
            "type": "number"
          },
          "loadHeadroom": {
            "type": "number"
          },
          "skillScore": {
            "type": "number"
          },
          "continuityScore": {
            "type": "number"
          },
          "sameContext": {
            "type": "boolean"
          },
          "contextSwitchCost": {
            "type": "number"
          },
          "focusPenalty": {
            "type": "number"
          },
          "suggestionType": {
            "type": "string",
            "enum": [
              "suggested_reviewer",
              "governed_auto_claim_candidate"
            ]
          }
        }
      }
    },
    "governedAutoClaimRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mayRewriteCanonicalOrder"
      ],
      "properties": {
        "mayRewriteCanonicalOrder": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "generatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "QueueAssignmentSuggestionSnapshot is downstream of QueueRankSnapshot and may not rewrite task ordinals, eligibility, or explanation payloads from the source snapshot."
  ]
}
