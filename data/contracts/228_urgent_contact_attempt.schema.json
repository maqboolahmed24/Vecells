{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_urgent_contact_attempt.schema.json",
  "title": "228 UrgentContactAttempt",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "urgentContactAttemptId",
    "dutyEscalationRecordRef",
    "decisionEpochRef",
    "attemptOrdinal",
    "contactRouteClass",
    "attemptState",
    "attemptedAt"
  ],
  "properties": {
    "urgentContactAttemptId": {
      "$ref": "#/$defs/id"
    },
    "dutyEscalationRecordRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "attemptOrdinal": {
      "type": "integer",
      "minimum": 1
    },
    "contactRouteClass": {
      "type": "string",
      "enum": [
        "primary_phone",
        "secondary_phone",
        "practice_transfer",
        "secure_message_notice"
      ]
    },
    "attemptState": {
      "type": "string",
      "enum": [
        "queued",
        "ringing",
        "voicemail_left",
        "connected",
        "no_answer",
        "failed",
        "cancelled"
      ]
    },
    "attemptedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "completedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "outcomeNote": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-governedInvariants": [
    "Urgent contact attempts are append-only audit steps inside the escalation lane.",
    "Contact attempts remain tied to the current DecisionEpoch and may not be silently recycled across superseded consequence rails."
  ]
}
