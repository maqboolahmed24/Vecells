{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_hub_capacity_ingestion_policy.schema.json",
  "title": "HubCapacityIngestionPolicy",
  "description": "Policy family that turns feed freshness, assurance slices, duplicate-capacity collision risk, and supplier drift into trusted, degraded, or quarantined admission posture.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capacityIngestionPolicyId",
    "policyVersion",
    "policyTupleHash",
    "freshnessThresholdMinutes",
    "staleThresholdMinutes",
    "quarantineTriggers",
    "degradedTriggers",
    "duplicateCapacityCollisionPolicy",
    "degradedVisibilityModes",
    "patientOfferableTrustStates",
    "directCommitTrustStates",
    "capacityAdmissionDisposition",
    "sourceRefs"
  ],
  "properties": {
    "capacityIngestionPolicyId": {
      "type": "string",
      "minLength": 1,
      "description": "Capacity-ingestion policy identifier."
    },
    "policyVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Policy version."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Compiled tuple hash."
    },
    "freshnessThresholdMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Minutes after which a feed leaves the `fresh` band."
    },
    "staleThresholdMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Minutes after which a feed becomes stale."
    },
    "quarantineTriggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Conditions that force quarantined admission."
    },
    "degradedTriggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Conditions that force degraded admission."
    },
    "duplicateCapacityCollisionPolicy": {
      "type": "string",
      "minLength": 1,
      "description": "Rule ref for overlapping-slot deduplication."
    },
    "degradedVisibilityModes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "callback_only_reasoning",
          "diagnostic_only"
        ]
      },
      "description": "The only visibility modes allowed for degraded supply."
    },
    "patientOfferableTrustStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "trusted"
        ]
      },
      "description": "Trust states allowed into the patient-offerable frontier."
    },
    "directCommitTrustStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "trusted"
        ]
      },
      "description": "Trust states allowed into the direct-commit frontier."
    },
    "capacityAdmissionDisposition": {
      "type": "string",
      "enum": [
        "trusted_admitted",
        "degraded_callback_only",
        "degraded_diagnostic_only",
        "quarantined_excluded",
        "stale_capacity",
        "missing_capacity"
      ],
      "description": "Resolved admission posture vocabulary."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5C. Enhanced Access policy engine and network capacity ingestion",
    "blueprint/phase-5-the-network-horizon.md#5D. Coordination queue, candidate ranking, and SLA engine",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#ranking-order-and-visible-cues-must-derive-from-persisted-proof",
    "blueprint/phase-0-the-foundation-protocol.md#publication-and-bundle-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#assurance-and-trust-carry-forward",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md"
  ]
}
