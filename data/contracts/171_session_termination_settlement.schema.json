{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/171_session_termination_settlement.schema.json",
  "title": "SessionTerminationSettlement",
  "description": "Authoritative settlement for logout, timeout, revocation, downgrade, and forced termination. Cookie disappearance is never the only source of truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionTerminationSettlementId",
    "schemaVersion",
    "policyVersion",
    "sessionEpochRef",
    "terminationType",
    "settlementDecision",
    "cookieAction",
    "csrfAction",
    "grantAction",
    "projectionPosture",
    "reasonCodes",
    "settledAt"
  ],
  "properties": {
    "sessionTerminationSettlementId": {
      "type": "string",
      "pattern": "^sts_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "171.phase2.auth-session.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-auth-session-v[0-9]+$"
    },
    "sessionEpochRef": {
      "type": "string"
    },
    "terminationType": {
      "type": "string",
      "enum": [
        "logout",
        "idle_timeout",
        "absolute_timeout",
        "revocation",
        "downgrade",
        "forced_termination",
        "subject_conflict",
        "stale_return"
      ]
    },
    "settlementDecision": {
      "type": "string",
      "enum": ["terminated", "rotated_down", "bounded_recovery", "deny"]
    },
    "cookieAction": {
      "type": "string",
      "enum": ["clear", "rotate", "preserve_read_only", "none"]
    },
    "csrfAction": {
      "type": "string",
      "enum": ["clear", "rotate", "preserve_read_only", "none"]
    },
    "grantAction": {
      "type": "string",
      "enum": ["supersede_all", "supersede_writable", "preserve_read_only", "none"]
    },
    "projectionPosture": {
      "type": "string",
      "enum": [
        "signed_out",
        "read_only",
        "re_auth_required",
        "session_expired",
        "subject_conflict",
        "stale_return",
        "bounded_recovery"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^AUTH_171_[A-Z0-9_]+$"
      }
    },
    "settledAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
