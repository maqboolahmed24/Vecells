{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/235_suggestion_envelope.schema.json",
  "title": "235 SuggestionEnvelope",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "suggestionEnvelopeId",
    "taskId",
    "reviewBundleRef",
    "sourceType",
    "suggestionVersion",
    "priorityBand",
    "complexityBand",
    "candidateEndpoints",
    "recommendedQuestionSetIds",
    "rationaleBullets",
    "confidenceDescriptor",
    "visibilityState",
    "reviewVersionRef",
    "decisionEpochRef",
    "policyBundleRef",
    "lineageFenceEpoch",
    "allowedSuggestionSetHash",
    "authoritativeWorkflowInfluence",
    "staleAt",
    "invalidatedAt"
  ],
  "properties": {
    "suggestionEnvelopeId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "reviewBundleRef": {
      "$ref": "#/$defs/id"
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "rules",
        "shadow_model"
      ]
    },
    "suggestionVersion": {
      "type": "string",
      "minLength": 1
    },
    "priorityBand": {
      "type": "string",
      "enum": [
        "urgent",
        "elevated",
        "routine"
      ]
    },
    "complexityBand": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high"
      ]
    },
    "candidateEndpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "endpointRef",
          "endpointCode",
          "rationale",
          "supportingEvidenceRefs"
        ],
        "properties": {
          "endpointRef": {
            "$ref": "#/$defs/id"
          },
          "endpointCode": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "supportingEvidenceRefs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/id"
            }
          }
        }
      }
    },
    "recommendedQuestionSetIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "rationaleBullets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidenceDescriptor": {
      "type": "string",
      "minLength": 1
    },
    "visibilityState": {
      "type": "string",
      "enum": [
        "visible",
        "observe_only",
        "silent_shadow",
        "blocked"
      ]
    },
    "reviewVersionRef": {
      "type": "integer",
      "minimum": 0
    },
    "decisionEpochRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "policyBundleRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "allowedSuggestionSetHash": {
      "$ref": "#/$defs/id"
    },
    "authoritativeWorkflowInfluence": {
      "type": "string",
      "const": "advisory_only"
    },
    "staleAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "invalidatedAt": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-governedInvariants": [
    "Rules suggestions may guide review but may not settle workflow directly.",
    "Shadow-model output must remain silent_shadow in Phase 3.",
    "SuggestionEnvelope must degrade when parity or DecisionEpoch truth drifts."
  ]
}
