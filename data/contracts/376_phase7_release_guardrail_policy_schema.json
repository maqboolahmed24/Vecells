{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_release_guardrail_policy_schema.json",
  "title": "ReleaseGuardrailPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policyId",
    "minimumSampleSize",
    "maxAuthFailureRate",
    "maxJourneyErrorRate",
    "maxDownloadFailureRate",
    "maxSupportContactRate",
    "freezeDuration",
    "rollbackAction"
  ],
  "properties": {
    "policyId": {
      "type": "string"
    },
    "minimumSampleSize": {
      "type": "integer",
      "minimum": 1
    },
    "maxAuthFailureRate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "maxJourneyErrorRate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "maxDownloadFailureRate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "maxSupportContactRate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freezeDuration": {
      "type": "string"
    },
    "rollbackAction": {
      "type": "string"
    }
  }
}
