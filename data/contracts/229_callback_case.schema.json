{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_callback_case.schema.json",
  "title": "229 CallbackCase",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "callbackCaseId",
    "episodeRef",
    "requestRef",
    "requestLineageRef",
    "lineageCaseLinkRef",
    "requestLifecycleLeaseRef",
    "callbackUrgency",
    "contactRouteRef",
    "preferredWindowRef",
    "activeIntentLeaseRef",
    "attemptCounter",
    "latestSettledAttemptRef",
    "currentExpectationEnvelopeRef",
    "latestOutcomeEvidenceRef",
    "activeResolutionGateRef",
    "retryPolicyRef",
    "reachabilityDependencyRef",
    "patientVisibleExpectationState",
    "caseState",
    "openedAt"
  ],
  "properties": {
    "callbackCaseId": {
      "$ref": "#/$defs/id"
    },
    "episodeRef": {
      "$ref": "#/$defs/id"
    },
    "requestRef": {
      "$ref": "#/$defs/id"
    },
    "requestLineageRef": {
      "$ref": "#/$defs/id"
    },
    "lineageCaseLinkRef": {
      "$ref": "#/$defs/id"
    },
    "requestLifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "callbackUrgency": {
      "type": "string",
      "enum": [
        "routine",
        "priority",
        "urgent"
      ]
    },
    "contactRouteRef": {
      "$ref": "#/$defs/id"
    },
    "preferredWindowRef": {
      "$ref": "#/$defs/id"
    },
    "activeIntentLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "attemptCounter": {
      "type": "integer",
      "minimum": 0
    },
    "latestSettledAttemptRef": {
      "$ref": "#/$defs/id"
    },
    "currentExpectationEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "latestOutcomeEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "activeResolutionGateRef": {
      "$ref": "#/$defs/id"
    },
    "retryPolicyRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "patientVisibleExpectationState": {
      "type": "string",
      "enum": [
        "queued",
        "scheduled",
        "attempting_now",
        "retry_planned",
        "route_repair_required",
        "escalated",
        "closed"
      ]
    },
    "caseState": {
      "type": "string",
      "enum": [
        "created",
        "queued",
        "scheduled",
        "ready_for_attempt",
        "attempt_in_progress",
        "awaiting_outcome_evidence",
        "answered",
        "no_answer",
        "voicemail_left",
        "contact_route_repair_pending",
        "awaiting_retry",
        "escalation_review",
        "completed",
        "cancelled",
        "expired",
        "closed",
        "reopened"
      ]
    },
    "openedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "closedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "x-canonicalLifecycle": [
    "created",
    "queued",
    "scheduled",
    "ready_for_attempt",
    "attempt_in_progress",
    "awaiting_outcome_evidence",
    "answered",
    "no_answer",
    "voicemail_left",
    "contact_route_repair_pending",
    "awaiting_retry",
    "escalation_review",
    "completed",
    "cancelled",
    "expired",
    "closed"
  ],
  "x-governedInvariants": [
    "Callback promise truth is patient-visible only through CallbackExpectationEnvelope.",
    "Callback completion may not close the case until CallbackResolutionGate decides complete and the current CallbackOutcomeEvidenceBundle is durable."
  ]
}
