{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/190_recording_document_reference_link.schema.json",
  "title": "RecordingDocumentReferenceLinkContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "documentReferenceLinkRef",
    "schemaVersion",
    "documentReferenceRef",
    "documentReferenceLogicalId",
    "representationSetRef",
    "documentReferenceRecordRef",
    "callSessionRef",
    "providerRecordingRef",
    "objectStorageRef",
    "canonicalObjectRef",
    "contentDigest",
    "mediaType",
    "byteSize",
    "durationSeconds",
    "artifactUrl",
    "sourceAggregateRefs",
    "linkedAt",
    "recordedBy"
  ],
  "properties": {
    "documentReferenceLinkRef": {
      "type": "string",
      "pattern": "^tel_recording_document_link_190_"
    },
    "schemaVersion": { "const": "190.phase2.recording-ingest.v1" },
    "documentReferenceRef": { "type": "string" },
    "documentReferenceLogicalId": { "type": "string", "pattern": "^docref_recording_" },
    "representationSetRef": { "type": "string", "pattern": "^fhir_set_recording_" },
    "documentReferenceRecordRef": { "type": "string" },
    "callSessionRef": { "type": "string" },
    "providerRecordingRef": { "type": "string" },
    "objectStorageRef": { "type": "string" },
    "canonicalObjectRef": { "type": "string", "pattern": "^governed-audio://" },
    "contentDigest": { "type": "string" },
    "mediaType": { "enum": ["audio/wav", "audio/mpeg", "audio/mp4", "audio/ogg", "audio/webm"] },
    "byteSize": { "type": "integer", "minimum": 0 },
    "durationSeconds": { "type": "integer", "minimum": 0 },
    "artifactUrl": { "type": "string", "pattern": "^artifact://recording-audio/" },
    "sourceAggregateRefs": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
    "linkedAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyRecordingIngestPipeline" }
  }
}
