{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/226_review_session.schema.json",
  "title": "226 ReviewSession",
  "description": "Phase 3 active-review session contract. Session lifecycle remains separate from buffer, trust, freshness, and settlement posture.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nullableId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "required": [
    "reviewSessionId",
    "taskId",
    "openedBy",
    "openedAt",
    "lastActivityAt",
    "sessionState",
    "workspaceSnapshotVersion",
    "selectedAnchorRef",
    "selectedAnchorTupleHashRef",
    "bufferState",
    "lineageFenceEpoch",
    "staffWorkspaceConsistencyProjectionRef",
    "workspaceSliceTrustProjectionRef",
    "workspaceTrustEnvelopeRef",
    "requestLifecycleLeaseRef",
    "reviewActionLeaseRef",
    "ownershipEpochRef",
    "audienceSurfaceRuntimeBindingRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "releaseRecoveryDispositionRef"
  ],
  "properties": {
    "reviewSessionId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "openedBy": {
      "$ref": "#/$defs/id"
    },
    "openedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "lastActivityAt": {
      "$ref": "#/$defs/dateTime"
    },
    "sessionState": {
      "type": "string",
      "enum": [
        "opening",
        "active",
        "release_pending",
        "released",
        "superseded",
        "closed"
      ]
    },
    "workspaceSnapshotVersion": {
      "type": "integer",
      "minimum": 0
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorTupleHashRef": {
      "$ref": "#/$defs/id"
    },
    "bufferState": {
      "type": "string",
      "enum": [
        "none",
        "queued_updates",
        "review_required"
      ]
    },
    "bufferedDeltaBatchRef": {
      "$ref": "#/$defs/nullableId"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/nullableId"
    },
    "commandFollowingTokenRef": {
      "$ref": "#/$defs/nullableId"
    },
    "staffWorkspaceConsistencyProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "workspaceSliceTrustProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "workspaceTrustEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "requestLifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "reviewActionLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "ownershipEpochRef": {
      "type": "integer",
      "minimum": 0
    },
    "workspaceFocusProtectionLeaseRef": {
      "$ref": "#/$defs/nullableId"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/nullableId"
    },
    "releaseRecoveryDispositionRef": {
      "$ref": "#/$defs/id"
    }
  },
  "x-governedInvariants": [
    "sessionState is a review-session lifecycle only; trust drift, freshness drift, and recovery posture remain outside sessionState.",
    "selectedAnchorRef and selectedAnchorTupleHashRef must survive same-shell child-route transitions and bounded recovery.",
    "An active review must hold current StaffWorkspaceConsistencyProjection, WorkspaceSliceTrustProjection, WorkspaceTrustEnvelope, and ReviewActionLease together."
  ]
}
