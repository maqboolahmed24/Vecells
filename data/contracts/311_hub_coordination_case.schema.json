{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/311_hub_coordination_case.schema.json",
  "title": "311 HubCoordinationCase",
  "description": "Durable Phase 5 hub aggregate. Operational state remains distinct from patient assurance, practice visibility, and closeability.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "hubCoordinationCaseId",
    "episodeRef",
    "requestLineageRef",
    "lineageCaseLinkRef",
    "parentLineageCaseLinkRef",
    "networkBookingRequestId",
    "servingPcnId",
    "status",
    "ownerState",
    "claimedBy",
    "actingOrg",
    "ownershipLeaseRef",
    "activeOwnershipTransitionRef",
    "ownershipFenceToken",
    "ownershipEpoch",
    "compiledPolicyBundleRef",
    "enhancedAccessPolicyRef",
    "policyEvaluationRef",
    "policyTupleHash",
    "candidateSnapshotRef",
    "crossSiteDecisionPlanRef",
    "activeAlternativeOfferSessionRef",
    "activeOfferOptimisationPlanRef",
    "latestOfferRegenerationSettlementRef",
    "selectedCandidateRef",
    "bookingEvidenceRef",
    "networkAppointmentRef",
    "offerToConfirmationTruthRef",
    "activeFallbackRef",
    "callbackExpectationRef",
    "activeIdentityRepairCaseRef",
    "identityRepairBranchDispositionRef",
    "identityRepairReleaseSettlementRef",
    "externalConfirmationState",
    "practiceAckGeneration",
    "practiceAckDueAt",
    "openCaseBlockerRefs",
    "lastProgressAt",
    "slaTargetAt",
    "queueEnteredAt",
    "lastMaterialReturnAt",
    "expectedCoordinationMinutes",
    "urgencyCarry",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable HubCoordinationCase identifier."
    },
    "episodeRef": {
      "type": "string",
      "minLength": 1,
      "description": "Episode reference preserved from the originating branch."
    },
    "requestLineageRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical RequestLineage identifier shared across booking and hub branches."
    },
    "lineageCaseLinkRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current hub LineageCaseLink(caseFamily = hub)."
    },
    "parentLineageCaseLinkRef": {
      "type": "string",
      "minLength": 1,
      "description": "Parent booking LineageCaseLink from which the hub child was opened."
    },
    "networkBookingRequestId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning NetworkBookingRequest identifier."
    },
    "servingPcnId": {
      "type": "string",
      "minLength": 1,
      "description": "PCN or equivalent network coordination domain responsible for the case."
    },
    "status": {
      "type": "string",
      "enum": [
        "hub_requested",
        "intake_validated",
        "queued",
        "claimed",
        "candidate_searching",
        "candidates_ready",
        "coordinator_selecting",
        "candidate_revalidating",
        "native_booking_pending",
        "confirmation_pending",
        "booked_pending_practice_ack",
        "booked",
        "closed",
        "alternatives_offered",
        "patient_choice_pending",
        "callback_transfer_pending",
        "callback_offered",
        "escalated_back"
      ],
      "description": "Durable operational state vocabulary for HubCoordinationCase."
    },
    "ownerState": {
      "type": "string",
      "enum": [
        "unclaimed",
        "claimed_active",
        "release_pending",
        "transfer_pending",
        "supervisor_override",
        "stale_owner_recovery"
      ],
      "description": "Ownership posture for the case. This is distinct from HubCoordinationCase.status."
    },
    "claimedBy": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current coordinating staff user, if one owns the active lease."
    },
    "actingOrg": {
      "type": [
        "object",
        "null"
      ],
      "description": "Organisation or site currently acting under the live ownership fence.",
      "additionalProperties": false,
      "required": [
        "organisationRef",
        "organisationKind"
      ],
      "properties": {
        "organisationRef": {
          "type": "string",
          "minLength": 1,
          "description": "Acting organisation or site ref."
        },
        "organisationKind": {
          "type": "string",
          "enum": [
            "practice",
            "hub",
            "pcn",
            "site",
            "platform"
          ],
          "description": "Kind of acting organisation."
        },
        "siteRef": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 0,
          "description": "Optional site ref when the acting organisation resolves to a site."
        }
      }
    },
    "ownershipLeaseRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Live ownership lease ref derived from RequestLifecycleLease."
    },
    "activeOwnershipTransitionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current HubOwnershipTransition ref, if a claim or transfer is still open."
    },
    "ownershipFenceToken": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current ownership fence token required by all writable commands."
    },
    "ownershipEpoch": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonic ownership epoch that changes on every successful claim or takeover."
    },
    "compiledPolicyBundleRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Compiled policy bundle ref frozen by seq_312 seam."
    },
    "enhancedAccessPolicyRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "EnhancedAccessPolicy ref frozen by seq_312 seam."
    },
    "policyEvaluationRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current NetworkCoordinationPolicyEvaluation ref."
    },
    "policyTupleHash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Stable hash naming the current policy tuple and evaluation inputs."
    },
    "candidateSnapshotRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current NetworkCandidateSnapshot ref."
    },
    "crossSiteDecisionPlanRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current CrossSiteDecisionPlan ref."
    },
    "activeAlternativeOfferSessionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current AlternativeOfferSession ref."
    },
    "activeOfferOptimisationPlanRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current AlternativeOfferOptimisationPlan ref."
    },
    "latestOfferRegenerationSettlementRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Most recent AlternativeOfferRegenerationSettlement ref."
    },
    "selectedCandidateRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Currently selected NetworkSlotCandidate ref."
    },
    "bookingEvidenceRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current HubBookingEvidenceBundle ref."
    },
    "networkAppointmentRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current HubAppointmentRecord ref."
    },
    "offerToConfirmationTruthRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current HubOfferToConfirmationTruthProjection ref."
    },
    "activeFallbackRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current HubFallbackRecord ref."
    },
    "callbackExpectationRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current CallbackExpectationEnvelope ref."
    },
    "activeIdentityRepairCaseRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current identity repair case ref, if the hub branch is quarantined or compensating."
    },
    "identityRepairBranchDispositionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current identity repair disposition for the hub lineage branch."
    },
    "identityRepairReleaseSettlementRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current identity repair release settlement ref."
    },
    "externalConfirmationState": {
      "type": "string",
      "enum": [
        "not_started",
        "pending",
        "confirmed",
        "disputed",
        "expired",
        "recovery_required"
      ],
      "description": "Supplier or imported confirmation posture for the active commit tuple."
    },
    "practiceAckGeneration": {
      "type": "integer",
      "minimum": 0,
      "description": "Current origin-practice acknowledgement generation that must be satisfied before close is legal."
    },
    "practiceAckDueAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Current due time for origin-practice acknowledgement."
    },
    "openCaseBlockerRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Current open blocker refs. This must represent the union of live ownership lease, ownership transition, truth blockers, fallback linkage blockers, supplier drift, continuity evidence, and identity repair blockers."
    },
    "lastProgressAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Last timestamp at which meaningful hub progress occurred."
    },
    "slaTargetAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Current SLA target for hub coordination or acknowledgement handling."
    },
    "queueEnteredAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Timestamp at which the case joined the queue."
    },
    "lastMaterialReturnAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Timestamp at which the case last materially returned to practice or supervisor control."
    },
    "expectedCoordinationMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Estimated coordination effort in minutes for queue and workload planning."
    },
    "urgencyCarry": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized urgency carry passed into return-to-practice or fallback logic."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Case creation time."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last case update time."
    }
  }
}
