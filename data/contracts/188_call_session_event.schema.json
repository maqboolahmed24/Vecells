{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/188_call_session_event.schema.json",
  "title": "CallSessionCanonicalEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "callSessionEventRef",
    "eventType",
    "sourceCanonicalEventRef",
    "sourceCanonicalEventType",
    "callSessionRef",
    "providerCorrelationRef",
    "idempotencyKey",
    "sequence",
    "occurredAt",
    "recordedAt",
    "payload",
    "reasonCodes",
    "policyVersionRef",
    "createdByAuthority"
  ],
  "properties": {
    "schemaVersion": { "const": "188.phase2.call-session-event.v1" },
    "callSessionEventRef": { "type": "string", "pattern": "^tel_call_session_event_188_[A-Za-z0-9]+$" },
    "eventType": {
      "type": "string",
      "enum": [
        "call_initiated",
        "call_answered",
        "menu_captured",
        "identity_step_started",
        "identity_resolved",
        "identity_partial",
        "identity_attempt_failed",
        "recording_promised",
        "recording_available",
        "provider_error",
        "call_abandoned",
        "call_completed",
        "urgent_live_signal_observed",
        "operator_override_requested",
        "manual_followup_requested",
        "transcript_readiness_recorded",
        "evidence_readiness_assessed",
        "continuation_eligibility_settled",
        "continuation_sent",
        "request_seeded",
        "submission_promoted",
        "call_closed"
      ]
    },
    "sourceCanonicalEventRef": { "type": "string" },
    "sourceCanonicalEventType": { "type": "string" },
    "callSessionRef": { "type": "string" },
    "providerCorrelationRef": { "type": "string" },
    "idempotencyKey": { "type": "string" },
    "sequence": { "type": ["integer", "null"] },
    "occurredAt": { "type": "string", "format": "date-time" },
    "recordedAt": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "menuPath": { "enum": ["symptoms", "medications", "admin", "results", "unknown"] },
        "rawTransportSourceFamily": { "enum": ["dtmf", "speech", "operator", "simulator", "unknown"] },
        "normalizedMenuCode": { "type": "string" },
        "maskedCallerContextRef": { "type": ["string", "null"] },
        "maskedCallerFragment": { "type": ["string", "null"] },
        "recordingArtifactRef": { "type": "string" },
        "urgentSignalRefs": { "type": "array", "items": { "type": "string" } },
        "evidenceReadinessAssessmentRef": { "type": "string" }
      }
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "enum": [
          "TEL_SESSION_188_NO_RAW_PROVIDER_PAYLOAD",
          "TEL_SESSION_188_MENU_CAPTURE_APPENDED",
          "TEL_SESSION_188_PROVIDER_COMPLETION_NOT_PLATFORM_CLOSED",
          "TEL_SESSION_188_PROVIDER_ERROR_RECORDED",
          "TEL_SESSION_188_RECORDING_REF_ATTACHED",
          "TEL_SESSION_188_TIMEOUT_POLICY_APPLIED"
        ]
      }
    },
    "policyVersionRef": { "const": "phase2-call-session-state-machine-188.v1" },
    "createdByAuthority": { "const": "TelephonyCallSessionService" }
  }
}
