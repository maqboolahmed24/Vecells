{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_endpoint_decision.schema.json",
  "title": "228 EndpointDecision",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "endpointClass": {
      "type": "string",
      "enum": [
        "admin_resolution",
        "self_care_and_safety_net",
        "clinician_message",
        "clinician_callback",
        "appointment_required",
        "pharmacy_first_candidate",
        "duty_clinician_escalation"
      ]
    },
    "approvalMode": {
      "type": "string",
      "enum": [
        "not_required",
        "required"
      ]
    }
  },
  "required": [
    "decisionId",
    "taskId",
    "decisionEpochRef",
    "chosenEndpoint",
    "decisionVersion",
    "payloadHash",
    "reasoningText",
    "payload",
    "requiredApprovalMode",
    "previewArtifactRef",
    "decisionState",
    "createdAt"
  ],
  "properties": {
    "decisionId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "chosenEndpoint": {
      "$ref": "#/$defs/endpointClass"
    },
    "decisionVersion": {
      "type": "integer",
      "minimum": 1
    },
    "payloadHash": {
      "$ref": "#/$defs/id"
    },
    "reasoningText": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "payloadContractRef": {
      "$ref": "#/$defs/id"
    },
    "requiredApprovalMode": {
      "$ref": "#/$defs/approvalMode"
    },
    "downstreamPayloadRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "previewArtifactRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "decisionState": {
      "type": "string",
      "enum": [
        "drafting",
        "preview_ready",
        "awaiting_approval",
        "submitted",
        "superseded",
        "abandoned"
      ]
    },
    "supersedesDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "supersededByDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    },
    "supersededAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "chosenEndpoint": {
            "const": "admin_resolution"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "resolutionSubtype",
              "outcomeNote",
              "notificationTemplateRef"
            ],
            "properties": {
              "resolutionSubtype": {
                "type": "string"
              },
              "outcomeNote": {
                "type": "string"
              },
              "notificationTemplateRef": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "chosenEndpoint": {
            "const": "self_care_and_safety_net"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "adviceTemplateRef",
              "safetyNetWordingRef",
              "reContactThresholdRef"
            ],
            "properties": {
              "adviceTemplateRef": {
                "type": "string"
              },
              "safetyNetWordingRef": {
                "type": "string"
              },
              "reContactThresholdRef": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "chosenEndpoint": {
            "const": "clinician_message"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "messageBody",
              "responseExpectation",
              "closureRule"
            ],
            "properties": {
              "messageBody": {
                "type": "string"
              },
              "responseExpectation": {
                "type": "string"
              },
              "closureRule": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "chosenEndpoint": {
            "const": "clinician_callback"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "callbackUrgency",
              "timeWindowRef",
              "contactRouteRef",
              "fallbackRule"
            ],
            "properties": {
              "callbackUrgency": {
                "type": "string"
              },
              "timeWindowRef": {
                "type": "string"
              },
              "contactRouteRef": {
                "type": "string"
              },
              "fallbackRule": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "chosenEndpoint": {
            "const": "appointment_required"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "modality",
              "timeframe",
              "clinicianType",
              "continuityPreference",
              "accessNeeds"
            ],
            "properties": {
              "modality": {
                "type": "string"
              },
              "timeframe": {
                "type": "string"
              },
              "clinicianType": {
                "type": "string"
              },
              "continuityPreference": {
                "type": "string"
              },
              "accessNeeds": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "chosenEndpoint": {
            "const": "pharmacy_first_candidate"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "suspectedPathway",
              "exclusionCheckStatus",
              "patientChoicePending"
            ],
            "properties": {
              "suspectedPathway": {
                "type": "string"
              },
              "exclusionCheckStatus": {
                "type": "string"
              },
              "patientChoicePending": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "chosenEndpoint": {
            "const": "duty_clinician_escalation"
          }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "escalationReason",
              "urgency",
              "immediateActionNote",
              "contactAttemptRequirement"
            ],
            "properties": {
              "escalationReason": {
                "type": "string"
              },
              "urgency": {
                "type": "string"
              },
              "immediateActionNote": {
                "type": "string"
              },
              "contactAttemptRequirement": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  ],
  "x-governedInvariants": [
    "EndpointDecision is typed by the fixed endpoint taxonomy; local prose-only note fields are insufficient.",
    "Every consequence-bearing decision must remain bound to the current unsuperseded DecisionEpoch.",
    "Payload minima must be enough to validate, preview, assess approval burden, and mint downstream seeds without ad hoc free-text interpretation."
  ]
}
