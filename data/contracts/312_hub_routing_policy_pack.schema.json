{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_hub_routing_policy_pack.schema.json",
  "title": "HubRoutingPolicyPack",
  "description": "Policy family that decides whether a case routes into network coordination and which sites or service families are eligible for candidate construction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "routingPolicyPackId",
    "policyVersion",
    "policyTupleHash",
    "routingDisposition",
    "eligibleSiteRefs",
    "sourceRefs"
  ],
  "properties": {
    "routingPolicyPackId": {
      "type": "string",
      "minLength": 1,
      "description": "Routing pack identifier."
    },
    "policyVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Routing pack version."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Compiled tuple hash that names this pack."
    },
    "routeReasonCode": {
      "type": "string",
      "minLength": 1,
      "description": "Reason code for using the hub path."
    },
    "routingDisposition": {
      "type": "string",
      "enum": [
        "route_to_network",
        "retain_local",
        "bounce_back_urgent",
        "blocked"
      ],
      "description": "Resolved routing disposition vocabulary."
    },
    "eligibleSiteRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Sites allowed to contribute capacity under this pack."
    },
    "serviceFamilyRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Clinical or service families allowed in the current route."
    },
    "sourceNamespaceRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Source namespaces eligible for ingestion."
    },
    "commissionerApprovalRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Optional commissioner approval or override ref."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
