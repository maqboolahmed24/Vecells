{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells/contracts/236_more_info_outbox_entry.schema.json",
  "title": "MoreInfoOutboxEntry",
  "type": "object",
  "required": [
    "outboxEntryId",
    "cycleId",
    "checkpointRef",
    "scheduleRef",
    "requestLineageRef",
    "effectType",
    "effectKey",
    "dispatchState",
    "dueAt",
    "createdAt",
    "version"
  ],
  "properties": {
    "outboxEntryId": { "type": "string" },
    "cycleId": { "type": "string" },
    "checkpointRef": { "type": "string" },
    "scheduleRef": { "type": "string" },
    "requestLineageRef": { "type": "string" },
    "effectType": {
      "type": "string",
      "enum": ["initial_delivery", "reminder_send", "callback_fallback_seed"]
    },
    "effectKey": { "type": "string" },
    "reminderOrdinal": { "type": ["integer", "null"], "minimum": 1 },
    "dispatchState": { "type": "string", "enum": ["pending", "dispatched", "cancelled"] },
    "reasonRef": { "type": ["string", "null"] },
    "dueAt": { "type": "string", "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "dispatchedAt": { "type": ["string", "null"], "format": "date-time" },
    "cancelledAt": { "type": ["string", "null"], "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
