{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_patient_embedded_session_binding_contract.json",
  "title": "PatientEmbeddedSessionBindingContract",
  "taskId": "par_375",
  "schemaVersion": "375.phase7.embedded-context-sso-navigation.v1",
  "patientEmbeddedSessionProjection": {
    "required": [
      "patientEmbeddedSessionProjectionId",
      "subjectRef",
      "identityBindingRef",
      "sessionEpochRef",
      "subjectBindingVersionRef",
      "manifestVersionRef",
      "releaseApprovalFreezeRef",
      "channelReleaseFreezeState",
      "minimumBridgeCapabilitiesRef",
      "currentBridgeCapabilityMatrixRef",
      "routeFreezeDispositionRef",
      "experienceContinuityEvidenceRef",
      "eligibilityState",
      "recoveryRouteRef",
      "computedAt"
    ],
    "allowedEligibilityStates": [
      "live",
      "read_only",
      "placeholder_only",
      "safe_browser_handoff",
      "recovery_required",
      "blocked"
    ],
    "allowedChannelReleaseFreezeStates": [
      "monitoring",
      "frozen",
      "kill_switch_active",
      "rollback_recommended",
      "released"
    ]
  },
  "bindingRules": [
    {
      "ruleId": "PESB_375_001",
      "name": "embedded_actionability_requires_projection",
      "rule": "No embedded route may expose live actionability without a current PatientEmbeddedSessionProjection."
    },
    {
      "ruleId": "PESB_375_002",
      "name": "session_and_subject_exactness",
      "rule": "subjectRef, identityBindingRef, sessionEpochRef, and subjectBindingVersionRef must match the active local session and resolved RouteIntentBinding."
    },
    {
      "ruleId": "PESB_375_003",
      "name": "manifest_release_bridge_exactness",
      "rule": "manifestVersionRef, releaseApprovalFreezeRef, minimumBridgeCapabilitiesRef, and currentBridgeCapabilityMatrixRef must match the current manifest and bridge floor."
    },
    {
      "ruleId": "PESB_375_004",
      "name": "drift_degrades_in_place",
      "rule": "Session, subject, manifest, bridge, release, or continuity drift must downgrade through routeFreezeDispositionRef in the same shell."
    }
  ],
  "exampleProjection": {
    "patientEmbeddedSessionProjectionId": "pesp_375_jp_request_status",
    "subjectRef": "subject:example-patient",
    "identityBindingRef": "IdentityBinding:example-current",
    "sessionEpochRef": "SessionEpoch:example-42",
    "subjectBindingVersionRef": "SubjectBindingVersion:example-7",
    "manifestVersionRef": "nhsapp-manifest-v0.1.0-freeze-374",
    "releaseApprovalFreezeRef": "ReleaseApprovalFreeze:RAF-P7-374-CONTRACT-FREEZE",
    "channelReleaseFreezeState": "monitoring",
    "minimumBridgeCapabilitiesRef": "MinimumBridgeCapabilities:phase7-embedded-floor-375-pending",
    "currentBridgeCapabilityMatrixRef": "BridgeCapabilityMatrix:nhs-app-js-v2-minimum",
    "routeFreezeDispositionRef": "RouteFreezeDisposition:nhs-app-freeze-in-place-v1",
    "experienceContinuityEvidenceRef": "ExperienceContinuityControlEvidence:request-status-embedded-current",
    "eligibilityState": "live",
    "recoveryRouteRef": "/requests",
    "computedAt": "2026-04-27T00:10:15Z"
  }
}
