{
  "contractId": "NHSAppSupportOpsSurfaceContract:398:v1",
  "schemaVersion": "398.phase7.nhs-app-channel-support-ops.v1",
  "visualMode": "NHSApp_Channel_Control_Workbench",
  "routePrefixes": [
    "/ops/support/channels/nhs-app",
    "/ops/support/cases",
    "/ops/release/nhs-app/cases",
    "/ops/audit/channel/nhs-app"
  ],
  "urlState": ["case", "tab", "event", "channel", "route", "sso", "freeze", "dock"],
  "components": [
    "NHSAppChannelContextRibbon",
    "NHSAppJumpOffRouteChip",
    "EmbeddedSSOOutcomePill",
    "WhatPatientSawPanel",
    "NHSAppChannelEventTimeline",
    "NHSAppRouteFreezeInspector",
    "NHSAppArtifactPostureCard",
    "NHSAppAuditDeepLinkStrip",
    "NHSAppSupportRecoveryActionBar",
    "NHSAppChannelStatePreviewCard"
  ],
  "stableAutomationHooks": {
    "root": "NHSAppChannelControlWorkbench",
    "contextRibbon": "NHSAppChannelContextRibbon",
    "jumpOffRoute": "NHSAppJumpOffRouteChip",
    "ssoOutcome": "EmbeddedSSOOutcomePill",
    "timeline": "NHSAppChannelEventTimeline",
    "patientPreview": "WhatPatientSawPanel",
    "freezeInspector": "NHSAppRouteFreezeInspector",
    "artifactPosture": "NHSAppArtifactPostureCard",
    "auditDeepLinks": "NHSAppAuditDeepLinkStrip",
    "recoveryActionBar": "NHSAppSupportRecoveryActionBar",
    "statePreview": "NHSAppChannelStatePreviewCard",
    "caseRowPattern": "ChannelCaseRow-${caseId}",
    "timelineEventPattern": "ChannelTimelineEvent-${eventId}",
    "tabPattern": "ChannelWorkbenchTab-${tab}"
  },
  "channelTruthGrammar": {
    "channelTypes": ["embedded_nhs_app", "standalone_web"],
    "ssoOutcomes": ["silent_success", "silent_failed", "consent_denied", "safe_reentry_required"],
    "freezePostures": [
      "none",
      "read_only",
      "placeholder_only",
      "redirect_to_safe_route",
      "kill_switch_active"
    ],
    "artifactPostures": ["available", "summary_first", "download_blocked", "placeholder_only"],
    "recoveryKinds": [
      "continue_embedded",
      "safe_reentry",
      "read_only_status",
      "browser_safe_route",
      "contact_practice"
    ],
    "timelineKinds": [
      "entry",
      "route_resolution",
      "sso",
      "navigation",
      "artifact",
      "freeze",
      "recovery"
    ]
  },
  "requiredCaseCoverage": {
    "minimumCases": 3,
    "mustIncludeEmbedded": true,
    "mustIncludeStandalone": true,
    "mustIncludeConsentDenied": true,
    "mustIncludeSafeReentry": true,
    "mustIncludeFrozenDisposition": true,
    "mustIncludeArtifactBlocked": true
  },
  "guardrails": {
    "supportActionSubordinateToFreezePosture": true,
    "auditRowsDisclosureSafeOnly": true,
    "patientVisibleStateRequired": true,
    "manualSpreadsheetCrossReferenceAllowed": false
  }
}
