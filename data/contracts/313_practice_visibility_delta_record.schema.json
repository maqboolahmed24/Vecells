{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_practice_visibility_delta_record.schema.json",
  "title": "PracticeVisibilityDeltaRecord",
  "description": "Monotone-safe practice-visibility delta. May not lower ackGeneration or supersede newer envelope versions.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "practiceVisibilityDeltaRecordId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable delta identifier."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "priorProjectionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Previous projection reference."
    },
    "nextProjectionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Next projection reference."
    },
    "priorAckGeneration": {
      "type": "integer",
      "minimum": 0,
      "description": "Previous acknowledgement generation."
    },
    "nextAckGeneration": {
      "type": "integer",
      "minimum": 0,
      "description": "Next acknowledgement generation."
    },
    "priorVisibilityEnvelopeVersionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Previous visibility envelope version."
    },
    "nextVisibilityEnvelopeVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Next visibility envelope version."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash used for the delta."
    },
    "deltaReason": {
      "type": "string",
      "enum": [
        "truth_changed",
        "ack_generation_incremented",
        "manage_capability_degraded",
        "appointment_version_changed",
        "policy_tuple_changed",
        "reminder_failure"
      ],
      "description": "Reason for the delta emission."
    },
    "monotoneValidation": {
      "type": "string",
      "enum": [
        "valid",
        "rejected_lower_generation",
        "rejected_stale_envelope"
      ],
      "description": "Validation outcome proving the delta did not move backward in generation or envelope ordering."
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the delta was recorded."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "practiceVisibilityDeltaRecordId",
    "hubCoordinationCaseId",
    "nextProjectionRef",
    "priorAckGeneration",
    "nextAckGeneration",
    "nextVisibilityEnvelopeVersionRef",
    "truthTupleHash",
    "deltaReason",
    "monotoneValidation",
    "recordedAt",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
