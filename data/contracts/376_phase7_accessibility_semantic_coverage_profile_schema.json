{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_accessibility_semantic_coverage_profile_schema.json",
  "title": "AccessibilitySemanticCoverageProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profileId",
    "journeyPathRef",
    "accessibleContentVariantRefs",
    "auditEvidenceRefs",
    "uiStateContractRefs",
    "keyboardInteractionContractRef",
    "focusTransitionContractRef",
    "assistiveAnnouncementContractRef",
    "timeoutRecoveryContractRef",
    "freshnessAccessibilityContractRef",
    "automationAnchorProfileRef",
    "surfaceStateSemanticsProfileRef",
    "designContractPublicationBundleRef",
    "visualizationFallbackContractRef",
    "visualizationTableContractRef",
    "manualAssistiveTestingState",
    "deviceLabTestingState",
    "coverageState",
    "lastEvaluatedAt"
  ],
  "properties": {
    "profileId": {
      "type": "string"
    },
    "journeyPathRef": {
      "type": "string"
    },
    "accessibleContentVariantRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auditEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uiStateContractRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "keyboardInteractionContractRef": {
      "type": "string"
    },
    "focusTransitionContractRef": {
      "type": "string"
    },
    "assistiveAnnouncementContractRef": {
      "type": "string"
    },
    "timeoutRecoveryContractRef": {
      "type": "string"
    },
    "freshnessAccessibilityContractRef": {
      "type": "string"
    },
    "automationAnchorProfileRef": {
      "type": "string"
    },
    "surfaceStateSemanticsProfileRef": {
      "type": "string"
    },
    "designContractPublicationBundleRef": {
      "type": "string"
    },
    "visualizationFallbackContractRef": {
      "type": "string"
    },
    "visualizationTableContractRef": {
      "type": "string"
    },
    "manualAssistiveTestingState": {
      "type": "string",
      "enum": ["not_started", "scheduled", "in_progress", "passed", "blocked"]
    },
    "deviceLabTestingState": {
      "type": "string",
      "enum": ["not_started", "scheduled", "in_progress", "passed", "blocked"]
    },
    "coverageState": {
      "type": "string",
      "enum": ["complete", "partial", "blocked", "not_started"]
    },
    "lastEvaluatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
