{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_practice_continuity_message.schema.json",
  "title": "PracticeContinuityMessage",
  "description": "Outward origin-practice message contract. Separates transport acceptance, delivery evidence, delivery risk, and acknowledgement evidence while binding them to the current tuple and current generation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "practiceContinuityMessageId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for the continuity message."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "appointmentRecordRef": {
      "type": "string",
      "minLength": 1,
      "description": "HubAppointmentRecord referenced by the message."
    },
    "continuityChannel": {
      "type": "string",
      "enum": [
        "mesh",
        "direct_api",
        "manual_secure_mail",
        "internal_transfer"
      ],
      "description": "Delivery channel selected for cross-organisation continuity."
    },
    "dispatchWorkflowId": {
      "type": "string",
      "minLength": 1,
      "description": "Workflow or routing identifier used by the transport."
    },
    "visibilityEnvelopeVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Visibility envelope version used to assemble the payload."
    },
    "practiceVisibilityPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current practice visibility policy ref."
    },
    "serviceObligationPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current service-obligation policy ref."
    },
    "policyEvaluationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy evaluation ref used for message emission."
    },
    "ackGeneration": {
      "type": "integer",
      "minimum": 0,
      "description": "Current acknowledgement generation carried by this message."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash."
    },
    "causalToken": {
      "type": "string",
      "minLength": 1,
      "description": "Causal token that correlates message, projection, and acknowledgement."
    },
    "transportState": {
      "type": "string",
      "enum": [
        "not_dispatched",
        "queued",
        "accepted",
        "rejected"
      ],
      "description": "Transport acceptance state."
    },
    "transportAcceptedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Time at which transport acceptance occurred."
    },
    "deliveryState": {
      "type": "string",
      "enum": [
        "unknown",
        "available_for_collection",
        "downloaded",
        "expired",
        "failed"
      ],
      "description": "Delivery evidence state."
    },
    "deliveryEvidenceRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Delivery evidence or receipt checkpoint ref."
    },
    "deliveryRiskState": {
      "type": "string",
      "enum": [
        "none",
        "awaiting_download",
        "non_delivery_risk",
        "failed"
      ],
      "description": "Current delivery risk posture."
    },
    "acknowledgementEvidenceState": {
      "type": "string",
      "enum": [
        "ack_missing",
        "ack_received",
        "ack_superseded",
        "ack_exception_recorded"
      ],
      "description": "Whether acknowledgement evidence is missing, current, superseded, or legally excepted."
    },
    "acknowledgementEvidenceRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current acknowledgement evidence ref."
    },
    "payloadChecksum": {
      "type": "string",
      "minLength": 1,
      "description": "Checksum of the emitted payload."
    },
    "dedupeKey": {
      "type": "string",
      "minLength": 1,
      "description": "Dedupe contract for retries and replay-safe resends."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "practiceContinuityMessageId",
    "hubCoordinationCaseId",
    "appointmentRecordRef",
    "continuityChannel",
    "dispatchWorkflowId",
    "visibilityEnvelopeVersionRef",
    "practiceVisibilityPolicyRef",
    "serviceObligationPolicyRef",
    "policyEvaluationRef",
    "ackGeneration",
    "truthTupleHash",
    "causalToken",
    "transportState",
    "deliveryState",
    "deliveryRiskState",
    "acknowledgementEvidenceState",
    "payloadChecksum",
    "dedupeKey",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
