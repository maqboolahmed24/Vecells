{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_enhanced_access_minutes_ledger.schema.json",
  "title": "EnhancedAccessMinutesLedger",
  "description": "Operational ledger that tracks required, delivered, available, cancelled, and make-up minutes against the current minutes-per-1,000 obligation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "enhancedAccessMinutesLedgerId",
    "pcnRef",
    "policyTupleHash",
    "weekStartAt",
    "weekEndAt",
    "adjustedPopulation",
    "minutesPer1000Required",
    "requiredMinutes",
    "deliveredMinutes",
    "availableMinutes",
    "cancelledMinutes",
    "replacementMinutes",
    "ledgerState",
    "sourceRefs"
  ],
  "properties": {
    "enhancedAccessMinutesLedgerId": {
      "type": "string",
      "minLength": 1,
      "description": "Ledger identifier."
    },
    "pcnRef": {
      "type": "string",
      "minLength": 1,
      "description": "PCN or network ref."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy tuple hash."
    },
    "weekStartAt": {
      "type": "string",
      "format": "date-time",
      "description": "Start of the obligation week."
    },
    "weekEndAt": {
      "type": "string",
      "format": "date-time",
      "description": "End of the obligation week."
    },
    "adjustedPopulation": {
      "type": "integer",
      "minimum": 0,
      "description": "Adjusted population for the obligation week."
    },
    "minutesPer1000Required": {
      "type": "integer",
      "minimum": 0,
      "description": "Required minutes per 1,000 adjusted population."
    },
    "requiredMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Resolved required minutes for the week."
    },
    "deliveredMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Delivered minutes counted toward the obligation."
    },
    "availableMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Available bookable minutes published."
    },
    "cancelledMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Cancelled minutes in the same week."
    },
    "replacementMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Replacement or make-up minutes provided."
    },
    "ledgerState": {
      "type": "string",
      "enum": [
        "on_track",
        "at_risk",
        "make_up_required",
        "completed"
      ],
      "description": "Current ledger posture."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
