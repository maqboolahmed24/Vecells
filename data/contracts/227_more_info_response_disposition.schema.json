{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_more_info_response_disposition.schema.json",
  "title": "227 MoreInfoResponseDisposition",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "responseDispositionId",
    "cycleRef",
    "responseCaptureBundleRef",
    "replyWindowCheckpointRef",
    "idempotencyRecordRef",
    "receivedAt",
    "disposition",
    "resultingTaskState",
    "decidedAt"
  ],
  "properties": {
    "responseDispositionId": {
      "$ref": "#/$defs/id"
    },
    "cycleRef": {
      "$ref": "#/$defs/id"
    },
    "responseCaptureBundleRef": {
      "$ref": "#/$defs/id"
    },
    "replyWindowCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "idempotencyRecordRef": {
      "$ref": "#/$defs/id"
    },
    "receivedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "disposition": {
      "type": "string",
      "enum": [
        "accepted_in_window",
        "accepted_late_review",
        "superseded_duplicate",
        "expired_rejected",
        "blocked_repair"
      ]
    },
    "resultingSnapshotRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "resultingEvidenceAssimilationRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "resultingSafetyDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "resultingTaskState": {
      "type": "string",
      "enum": [
        "awaiting_re_safety",
        "review_resumed",
        "escalated",
        "recovery_only"
      ]
    },
    "supersedingCycleRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "recoveryRouteRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "decidedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "MoreInfoResponseDisposition classifies replies before evidence assimilation and re-safety proceed.",
    "superseded_duplicate, expired_rejected, and blocked_repair may preserve receipt and recovery context, but they may not mint a second snapshot or reopen routine queue flow implicitly."
  ]
}
