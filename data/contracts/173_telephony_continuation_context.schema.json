{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/173_telephony_continuation_context.schema.json",
  "title": "TelephonyContinuationContext",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "continuationContextId",
    "callSessionId",
    "contextState",
    "targetChannel",
    "phoneNumberHash",
    "handoffNonceRef",
    "requestedGrantFamily",
    "capabilityCeiling",
    "currentReadinessVerdict",
    "evidenceReadinessAssessmentRef",
    "continuationEligibilityRef",
    "lineageScope",
    "requestSeedRef",
    "routeFamilyRef",
    "actionScope",
    "authoritySettledBindingFence",
    "manifestVersionRef",
    "releaseApprovalFreezeRef",
    "minimumBridgeCapabilitiesRef",
    "channelReleaseFreezeState",
    "grantFenceState",
    "issuedAt",
    "expiresAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "173.phase2.telephony.continuation-context.v1"
    },
    "continuationContextId": {
      "type": "string",
      "pattern": "^tel_ctx_[A-Za-z0-9_:-]+$"
    },
    "callSessionId": {
      "type": "string"
    },
    "contextState": {
      "type": "string",
      "enum": ["pending", "grant_issued", "no_grant_manual_only", "consumed", "expired"]
    },
    "targetChannel": {
      "type": "string",
      "enum": ["sms", "support_callback", "none"]
    },
    "phoneNumberHash": {
      "type": ["string", "null"],
      "pattern": "^(sha256:[a-f0-9]{64}|)$"
    },
    "handoffNonceRef": {
      "type": ["string", "null"]
    },
    "attemptCount": {
      "type": "integer",
      "minimum": 0
    },
    "requestedGrantFamily": {
      "type": "string",
      "enum": ["continuation_seeded_verified", "continuation_challenge", "manual_only"]
    },
    "capabilityCeiling": {
      "type": "string",
      "enum": ["minimal_detail_entry", "challenge_before_disclosure", "manual_only_no_disclosure"]
    },
    "currentReadinessVerdict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usabilityState", "promotionReadiness"],
      "properties": {
        "usabilityState": {
          "type": "string",
          "enum": [
            "awaiting_recording",
            "awaiting_transcript",
            "awaiting_structured_capture",
            "urgent_live_only",
            "safety_usable",
            "manual_review_only",
            "unusable_terminal"
          ]
        },
        "promotionReadiness": {
          "type": "string",
          "enum": ["blocked", "continuation_only", "ready_to_seed", "ready_to_promote"]
        }
      }
    },
    "evidenceReadinessAssessmentRef": {
      "type": "string"
    },
    "continuationEligibilityRef": {
      "type": "string"
    },
    "identityConfidenceRef": {
      "type": ["string", "null"]
    },
    "destinationConfidenceRef": {
      "type": ["string", "null"]
    },
    "lineageScope": {
      "type": "string",
      "enum": ["same_submission_envelope", "same_request_lineage", "none"]
    },
    "requestSeedRef": {
      "type": ["string", "null"]
    },
    "routeFamilyRef": {
      "type": ["string", "null"]
    },
    "actionScope": {
      "type": "string",
      "enum": ["secure_resume", "envelope_resume", "contact_route_repair", "manual_followup"]
    },
    "resumeContinuationRef": {
      "type": ["string", "null"]
    },
    "authoritySettledBindingFence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundSubjectRef",
        "boundIdentityBindingRef",
        "boundSessionEpoch",
        "boundSubjectBindingVersion",
        "lineageFenceEpoch"
      ],
      "properties": {
        "boundSubjectRef": {
          "type": ["string", "null"]
        },
        "boundIdentityBindingRef": {
          "type": ["string", "null"]
        },
        "boundSessionEpoch": {
          "type": ["string", "null"]
        },
        "boundSubjectBindingVersion": {
          "type": ["string", "null"]
        },
        "lineageFenceEpoch": {
          "type": ["string", "null"]
        }
      }
    },
    "manifestVersionRef": {
      "type": "string"
    },
    "releaseApprovalFreezeRef": {
      "type": "string"
    },
    "minimumBridgeCapabilitiesRef": {
      "type": "string"
    },
    "channelReleaseFreezeState": {
      "type": "string",
      "enum": ["live", "constrained", "frozen", "blocked"]
    },
    "grantFenceState": {
      "type": "string",
      "enum": [
        "not_applicable",
        "pending_access_grant_service",
        "grant_issued",
        "consumed",
        "superseded",
        "blocked"
      ]
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "resolvedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "requestedGrantFamily": {
            "const": "manual_only"
          }
        }
      },
      "then": {
        "properties": {
          "contextState": {
            "const": "no_grant_manual_only"
          },
          "grantFenceState": {
            "const": "not_applicable"
          }
        }
      }
    }
  ]
}
