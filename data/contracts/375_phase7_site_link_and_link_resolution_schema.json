{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_site_link_and_link_resolution_schema.json",
  "title": "SiteLinkManifestAndLinkResolutionAudit",
  "type": "object",
  "additionalProperties": false,
  "required": ["siteLinkManifest", "linkResolutionAudit"],
  "properties": {
    "siteLinkManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestId",
        "androidAssetLinksRef",
        "iosAssociationRef",
        "allowedPathPatterns",
        "environmentMappings",
        "canonicalGrantServiceRef",
        "routeIntentBindingRequired"
      ],
      "properties": {
        "manifestId": {
          "type": "string"
        },
        "androidAssetLinksRef": {
          "type": "string"
        },
        "iosAssociationRef": {
          "type": "string"
        },
        "allowedPathPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "environmentMappings": {
          "type": "object"
        },
        "canonicalGrantServiceRef": {
          "type": "string",
          "const": "AccessGrantService"
        },
        "routeIntentBindingRequired": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "linkResolutionAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolutionId",
        "incomingPath",
        "channelDetected",
        "embeddedState",
        "subjectLinked",
        "manifestVersionRef",
        "routeFamilyRef",
        "sessionEpochRef",
        "grantFenceState",
        "resolutionOutcome"
      ],
      "properties": {
        "resolutionId": {
          "type": "string"
        },
        "incomingPath": {
          "type": "string"
        },
        "channelDetected": {
          "type": "string"
        },
        "embeddedState": {
          "type": "string",
          "enum": ["trusted_embedded", "hinted_embedded", "standalone", "blocked"]
        },
        "subjectLinked": {
          "type": "boolean"
        },
        "manifestVersionRef": {
          "type": "string"
        },
        "routeFamilyRef": {
          "type": "string"
        },
        "sessionEpochRef": {
          "type": ["string", "null"]
        },
        "grantFenceState": {
          "type": "string",
          "enum": ["valid", "redeemed", "expired", "revoked", "missing", "mismatched"]
        },
        "resolutionOutcome": {
          "type": "string",
          "enum": [
            "resolved",
            "verification_required",
            "placeholder_only",
            "bounded_recovery",
            "denied"
          ]
        }
      }
    }
  }
}
