{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/279_booking_provider_adapter_binding.schema.json",
  "title": "279 BookingProviderAdapterBinding",
  "description": "Canonical booking-provider binding compiled from one matrix row plus one adapter profile, one degradation profile, and one confirmation policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bookingProviderAdapterBindingId",
    "providerCapabilityMatrixRef",
    "matrixVersionRef",
    "supplierRef",
    "integrationMode",
    "deploymentType",
    "actionScopeSet",
    "selectionAudienceSet",
    "adapterContractProfileRef",
    "dependencyDegradationProfileRef",
    "searchNormalizationContractRef",
    "temporalNormalizationContractRef",
    "revalidationContractRef",
    "reservationSemantics",
    "commitContractRef",
    "authoritativeReadContractRef",
    "manageSupportContractRef",
    "authoritativeReadAndConfirmationPolicyRef",
    "bindingHash",
    "bindingState",
    "bindingCompilationOwnerRule",
    "publishedAt"
  ],
  "properties": {
    "bookingProviderAdapterBindingId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable compiled binding id."
    },
    "providerCapabilityMatrixRef": {
      "type": "string",
      "minLength": 1,
      "description": "Static matrix row id."
    },
    "matrixVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Matrix version consumed by this binding."
    },
    "supplierRef": {
      "type": "string",
      "minLength": 1,
      "description": "Supplier ref."
    },
    "integrationMode": {
      "type": "string",
      "enum": [
        "im1_patient_api",
        "im1_transaction_api",
        "gp_connect_existing",
        "local_gateway_component",
        "manual_assist_only"
      ],
      "description": "Integration mode."
    },
    "deploymentType": {
      "type": "string",
      "minLength": 1,
      "description": "Deployment type."
    },
    "actionScopeSet": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "search_slots",
          "book_slot",
          "cancel_appointment",
          "reschedule_appointment",
          "view_appointment",
          "hold_slot",
          "launch_local_component",
          "repair_gp_linkage",
          "request_staff_assist",
          "manage_appointment",
          "view_booking_summary"
        ],
        "description": "Compiled action scope."
      }
    },
    "selectionAudienceSet": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "patient",
          "staff"
        ],
        "description": "Audience allowed to consume this binding."
      }
    },
    "adapterContractProfileRef": {
      "type": "string",
      "minLength": 1,
      "description": "Chosen AdapterContractProfile."
    },
    "dependencyDegradationProfileRef": {
      "type": "string",
      "minLength": 1,
      "description": "Chosen DependencyDegradationProfile."
    },
    "searchNormalizationContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Search-normalization contract ref."
    },
    "temporalNormalizationContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Temporal-normalization contract ref."
    },
    "revalidationContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Revalidation contract ref."
    },
    "reservationSemantics": {
      "type": "string",
      "enum": [
        "exclusive_hold",
        "truthful_nonexclusive",
        "degraded_manual_pending"
      ],
      "description": "Reservation semantics bound into the adapter seam."
    },
    "commitContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Commit contract ref."
    },
    "authoritativeReadContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Authoritative-read contract ref."
    },
    "manageSupportContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Manage-support contract ref."
    },
    "authoritativeReadAndConfirmationPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Confirmation policy seam required for durable booking truth."
    },
    "bindingHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Lower-hex SHA-256 over the canonical compiled binding payload."
    },
    "bindingState": {
      "type": "string",
      "enum": [
        "live",
        "recovery_only",
        "blocked",
        "superseded"
      ],
      "description": "Binding posture. Only one live binding may exist for one exact tuple key."
    },
    "bindingCompilationOwnerRule": {
      "type": "string",
      "minLength": 1,
      "description": "Deterministic owner rule for compiler tie-breaks."
    },
    "publishedAt": {
      "type": "string",
      "format": "date"
    }
  }
}
