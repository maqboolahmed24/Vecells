{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/171_auth_transaction.schema.json",
  "title": "AuthTransaction",
  "description": "Server-side NHS login authorization-code transaction with PKCE, state, nonce, issuer/audience validation, exact callback-consumption fencing, and no raw tokens or claims in hot records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authTransactionId",
    "schemaVersion",
    "policyVersion",
    "providerMode",
    "flow",
    "lifecycle",
    "scopeBundleRef",
    "postAuthReturnIntentRef",
    "authorizationRequest",
    "callbackFence",
    "expiresAt",
    "createdAt"
  ],
  "properties": {
    "authTransactionId": {
      "type": "string",
      "pattern": "^atx_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "171.phase2.auth-session.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-auth-session-v[0-9]+$"
    },
    "providerMode": {
      "type": "string",
      "enum": ["nhs_login_simulator", "nhs_login_live"]
    },
    "flow": {
      "type": "string",
      "enum": ["server_authorization_code_pkce"]
    },
    "lifecycle": {
      "type": "string",
      "enum": [
        "initialized",
        "authorize_redirect_issued",
        "callback_received",
        "callback_consumed",
        "token_validated",
        "session_decision_emitted",
        "settled_success",
        "settled_recovery",
        "settled_denied",
        "expired",
        "replayed",
        "failed_validation"
      ]
    },
    "scopeBundleRef": {
      "type": "string"
    },
    "postAuthReturnIntentRef": {
      "type": "string"
    },
    "authorizationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuerRef",
        "audienceRef",
        "clientRef",
        "redirectUriRef",
        "stateDigest",
        "nonceDigest",
        "pkceChallengeDigest",
        "pkceMethod",
        "responseType",
        "requestedAt"
      ],
      "properties": {
        "issuerRef": {
          "type": "string"
        },
        "audienceRef": {
          "type": "string"
        },
        "clientRef": {
          "type": "string"
        },
        "redirectUriRef": {
          "type": "string",
          "description": "Reference to an allowlisted callback route. Never a user-supplied return URL."
        },
        "stateDigest": {
          "type": "string"
        },
        "nonceDigest": {
          "type": "string"
        },
        "pkceChallengeDigest": {
          "type": "string"
        },
        "pkceMethod": {
          "const": "S256"
        },
        "responseType": {
          "const": "code"
        },
        "requestedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "callbackFence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumptionState",
        "compareAndSwapVersion",
        "firstConsumedAt",
        "callbackOutcome"
      ],
      "properties": {
        "consumptionState": {
          "type": "string",
          "enum": ["unconsumed", "consumed", "expired", "replayed", "invalid"]
        },
        "compareAndSwapVersion": {
          "type": "integer",
          "minimum": 0
        },
        "firstConsumedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "callbackOutcome": {
          "type": "string",
          "enum": [
            "pending",
            "success",
            "consent_declined",
            "insufficient_assurance",
            "expired_transaction",
            "replayed_callback",
            "token_validation_failure",
            "linkage_unavailable",
            "internal_fallback"
          ]
        },
        "securityEventRef": {
          "type": "string"
        }
      }
    },
    "validatedTokenEnvelopeRef": {
      "type": "string",
      "description": "Reference to vaulted token and claim evidence. Raw tokens and claims are not embedded."
    },
    "sessionDecisionRef": {
      "type": "string"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
