    "SyntheticDatasetPrivacyAttestation": {
      "required": [
        "attestationId",
        "syntheticOnly",
        "noPhi",
        "noPii",
        "tenantCrossingIdentifiersPresent",
        "rawIdentifierFields",
        "attestationHash"
      ],
      "type": "object"
    }
