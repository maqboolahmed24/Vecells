    "ReferenceDatasetRecordClass": {
      "required": [
        "recordClassId",
        "tenantScope",
        "phiClassification",
        "piiClassification",
        "maskingState",
        "retentionClass",
        "allowedUsageContexts",
        "recordClassHash"
      ],
      "type": "object"
