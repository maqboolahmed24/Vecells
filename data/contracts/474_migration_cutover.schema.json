    "CutoverManualFallbackBinding": {
      "required": [
        "bindingId",
        "routeFamily",
        "fallbackMode",
        "settlementRequired",
        "bindingHash"
      ],
      "type": "object"
    },
    "CutoverRollbackDecision": {
      "required": [
        "rollbackDecisionId",
        "targetRef",
        "decisionState",
        "stopCondition",
        "rollbackPath",
        "rollforwardPath",
        "manualFallbackBindingRef",
        "wormAuditRef",
        "decisionHash"
      ],
      "type": "object"
    },
    "CutoverStep": {
      "required": [
        "stepId",
        "order",
        "owner",
        "settlementState",
        "idempotencyKeyScope",
        "wormAuditRef",
        "stepHash"
      ],
      "type": "object"
    },
    "PoisonBackfillRecord": {
      "required": [
        "poisonRecordId",
        "projectionFamily",
        "poisonState",
        "tenantWideBlock",
        "safeToContinue",
