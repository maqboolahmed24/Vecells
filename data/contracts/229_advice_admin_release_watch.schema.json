{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_advice_admin_release_watch.schema.json",
  "title": "229 AdviceAdminReleaseWatch",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adviceAdminReleaseWatchId",
    "domainType",
    "domainRef",
    "releaseApprovalFreezeRef",
    "channelReleaseFreezeRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "releaseRecoveryDispositionRef",
    "assuranceSliceTrustRefs",
    "watchTupleHash",
    "watchState",
    "degradedDisposition",
    "lastEvaluatedAt"
  ],
  "properties": {
    "adviceAdminReleaseWatchId": {
      "$ref": "#/$defs/id"
    },
    "domainType": {
      "type": "string",
      "enum": [
        "self_care",
        "admin_resolution"
      ]
    },
    "domainRef": {
      "$ref": "#/$defs/id"
    },
    "releaseApprovalFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "channelReleaseFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "releaseRecoveryDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "assuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "watchTupleHash": {
      "$ref": "#/$defs/id"
    },
    "watchState": {
      "type": "string",
      "enum": [
        "trusted",
        "degraded",
        "frozen",
        "quarantined",
        "rollback_review_required"
      ]
    },
    "degradedDisposition": {
      "type": "string",
      "enum": [
        "render_blocked",
        "read_only",
        "placeholder_only",
        "rollback_review_required"
      ]
    },
    "lastEvaluatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "AdviceAdminReleaseWatch is the live release and assurance trust guard for self-care and admin surfaces.",
    "Degraded or quarantined watch states may not authorize fresh patient-facing advice or terminal admin completion."
  ]
}
