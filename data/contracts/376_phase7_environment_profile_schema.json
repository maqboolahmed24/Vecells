{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_environment_profile_schema.json",
  "title": "NHSAppEnvironmentProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "environment",
    "baseUrl",
    "journeyPaths",
    "ssoConfigRef",
    "siteLinkConfigRef",
    "telemetryNamespace",
    "allowedCohorts",
    "releaseCandidateRef",
    "releaseApprovalFreezeRef",
    "behaviorContractSetRef",
    "surfaceSchemaSetRef",
    "compatibilityEvidenceRef",
    "watchTupleHash",
    "guardrailPolicyRef",
    "stabilizationCriteriaRef",
    "manifestVersion",
    "configFingerprint"
  ],
  "properties": {
    "environment": {
      "type": "string",
      "enum": ["local_preview", "sandpit", "aos", "limited_release", "full_release"]
    },
    "baseUrl": {
      "type": "string",
      "format": "uri"
    },
    "journeyPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ssoConfigRef": {
      "type": "string"
    },
    "siteLinkConfigRef": {
      "type": "string"
    },
    "telemetryNamespace": {
      "type": "string"
    },
    "allowedCohorts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "releaseCandidateRef": {
      "type": "string"
    },
    "releaseApprovalFreezeRef": {
      "type": "string"
    },
    "behaviorContractSetRef": {
      "type": "string"
    },
    "surfaceSchemaSetRef": {
      "type": "string"
    },
    "compatibilityEvidenceRef": {
      "type": "string"
    },
    "watchTupleHash": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "guardrailPolicyRef": {
      "type": "string"
    },
    "stabilizationCriteriaRef": {
      "type": "string"
    },
    "manifestVersion": {
      "type": "string"
    },
    "configFingerprint": {
      "type": "string",
      "pattern": "^sha256:"
    }
  }
}
