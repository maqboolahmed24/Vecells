{
  "taskId": "seq_203",
  "schemaVersion": "203.signal-provider-selector-manifest.v1",
  "controlBoard": "docs/frontend/203_signal_edge_control_board.html",
  "localTwinSelectors": {
    "root": "[data-testid='Signal_Edge_Control_Board']",
    "familyTabRail": "[data-testid='family-tab-rail']",
    "telephonyTab": "[data-config-tab='Telephony']",
    "smsTab": "[data-config-tab='SMS']",
    "emailTab": "[data-config-tab='Email']",
    "replayTab": "[data-config-tab='Replay']",
    "evidenceTab": "[data-config-tab='Evidence']",
    "endpointCoverageBoard": "[data-testid='endpoint-coverage-board']",
    "endpointProviderFamilyMatrix": "[data-testid='endpoint-provider-family-matrix']",
    "endpointProviderFamilyTable": "[data-testid='endpoint-provider-family-table']",
    "eventSubscriptionCoverageDiagram": "[data-testid='event-subscription-coverage-diagram']",
    "eventSubscriptionCoverageTable": "[data-testid='event-subscription-coverage-table']",
    "signatureReplayGuardBoard": "[data-testid='signature-replay-guard-board']",
    "signatureReplayGuardTable": "[data-testid='signature-replay-guard-table']",
    "evidenceDrawer": "[data-testid='evidence-drawer']",
    "redactedScreenshotList": "[data-testid='redacted-screenshot-list']",
    "liveGateChecklist": "[data-testid='live-gate-checklist']",
    "lowerEndpointParityStrip": "[data-testid='lower-endpoint-parity-strip']",
    "duplicateEndpointWarning": "[data-testid='duplicate-endpoint-warning']",
    "dryRunEvidenceButton": "[data-testid='dry-run-evidence-button']"
  },
  "providerConsoleSelectors": [
    {
      "provider": "twilio_voice",
      "family": "telephony",
      "mutationAllowedByDefault": false,
      "consoleSurface": "phone-number-or-twiml-app-webhook-settings",
      "selectors": {
        "voiceUrl": "[name='VoiceUrl']",
        "statusCallback": "[name='StatusCallback']",
        "statusCallbackEvents": "[data-testid='status-callback-events']",
        "recordingStatusCallback": "[name='RecordingStatusCallback']",
        "save": "button:has-text('Save')"
      },
      "requiredEvidence": [
        "before_redacted_screenshot",
        "after_redacted_screenshot",
        "selector_snapshot"
      ]
    },
    {
      "provider": "vonage_voice",
      "family": "telephony",
      "mutationAllowedByDefault": false,
      "consoleSurface": "voice-application-answer-and-event-settings",
      "selectors": {
        "answerUrl": "[name='answer_url']",
        "eventUrl": "[name='event_url']",
        "numberVoiceStatusCallback": "[name='voiceStatusCallback']",
        "save": "button:has-text('Save')"
      },
      "requiredEvidence": [
        "before_redacted_screenshot",
        "after_redacted_screenshot",
        "selector_snapshot"
      ]
    },
    {
      "provider": "twilio_sms",
      "family": "sms",
      "mutationAllowedByDefault": false,
      "consoleSurface": "messaging-service-status-callback",
      "selectors": {
        "statusCallback": "[name='StatusCallback']",
        "deliveryStatusWebhook": "[data-testid='delivery-status-webhook']",
        "save": "button:has-text('Save')"
      },
      "requiredEvidence": [
        "before_redacted_screenshot",
        "after_redacted_screenshot",
        "selector_snapshot"
      ]
    },
    {
      "provider": "vonage_sms",
      "family": "sms",
      "mutationAllowedByDefault": false,
      "consoleSurface": "sms-application-inbound-and-status-settings",
      "selectors": {
        "statusUrl": "[name='status_url']",
        "inboundUrl": "[name='inbound_url']",
        "signatureMethod": "[name='signature_method']",
        "save": "button:has-text('Save')"
      },
      "requiredEvidence": [
        "before_redacted_screenshot",
        "after_redacted_screenshot",
        "selector_snapshot"
      ]
    },
    {
      "provider": "mailgun_email",
      "family": "email",
      "mutationAllowedByDefault": false,
      "consoleSurface": "domain-event-webhooks",
      "selectors": {
        "eventWebhookUrl": "[name='webhook_url']",
        "eventCheckboxes": "[data-testid='event-webhook-checkboxes']",
        "signingKeyDisplay": "[data-testid='webhook-signing-key']",
        "save": "button:has-text('Save')"
      },
      "requiredEvidence": [
        "before_redacted_screenshot",
        "after_redacted_screenshot",
        "selector_snapshot"
      ]
    },
    {
      "provider": "sendgrid_email",
      "family": "email",
      "mutationAllowedByDefault": false,
      "consoleSurface": "event-webhook-signed-settings",
      "selectors": {
        "eventWebhookUrl": "[name='event_webhook_url']",
        "signedWebhookToggle": "[data-testid='signed-event-webhook-toggle']",
        "publicKeyDisplay": "[data-testid='event-webhook-public-key']",
        "save": "button:has-text('Save')"
      },
      "requiredEvidence": [
        "before_redacted_screenshot",
        "after_redacted_screenshot",
        "selector_snapshot"
      ]
    }
  ],
  "evidenceRedactionSelectors": {
    "maskTextPatterns": [
      "credential://[^\\s\"']+",
      "https://[^\\s\"']+",
      "Bearer\\s+[^\\s\"']+",
      "api[_-]?key[^\\s\"']*",
      "auth[_-]?token[^\\s\"']*"
    ],
    "maskElements": [
      "[data-sensitive='credential-ref']",
      "[data-sensitive='callback-host']",
      "[data-sensitive='provider-credential']"
    ]
  },
  "gateSelectors": {
    "allowMutationFlag": "ALLOW_SIGNAL_PROVIDER_MUTATION",
    "targetEnvironmentEnv": "SIGNAL_PROVIDER_TARGET_ENVIRONMENT",
    "providerFamilyEnv": "SIGNAL_PROVIDER_FAMILY",
    "approvalEnv": "SIGNAL_PROVIDER_APPROVAL_REF"
  }
}
