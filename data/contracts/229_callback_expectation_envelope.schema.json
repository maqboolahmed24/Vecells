{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_callback_expectation_envelope.schema.json",
  "title": "229 CallbackExpectationEnvelope",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "expectationEnvelopeId",
    "callbackCaseRef",
    "identityRepairBranchDispositionRef",
    "patientVisibleState",
    "expectedWindowRef",
    "windowLowerAt",
    "windowUpperAt",
    "windowRiskState",
    "stateConfidenceBand",
    "predictionModelRef",
    "fallbackGuidanceRef",
    "grantSetRef",
    "routeIntentBindingRef",
    "requiredReleaseApprovalFreezeRef",
    "channelReleaseFreezeState",
    "requiredAssuranceSliceTrustRefs",
    "transitionEnvelopeRef",
    "continuityEvidenceRef",
    "causalToken",
    "freezeDispositionRef",
    "monotoneRevision"
  ],
  "properties": {
    "expectationEnvelopeId": {
      "$ref": "#/$defs/id"
    },
    "callbackCaseRef": {
      "$ref": "#/$defs/id"
    },
    "identityRepairBranchDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "patientVisibleState": {
      "type": "string",
      "enum": [
        "queued",
        "scheduled",
        "attempting_now",
        "retry_planned",
        "route_repair_required",
        "escalated",
        "closed"
      ]
    },
    "expectedWindowRef": {
      "$ref": "#/$defs/id"
    },
    "windowLowerAt": {
      "$ref": "#/$defs/dateTime"
    },
    "windowUpperAt": {
      "$ref": "#/$defs/dateTime"
    },
    "windowRiskState": {
      "type": "string",
      "enum": [
        "on_track",
        "at_risk",
        "missed_window",
        "repair_required"
      ]
    },
    "stateConfidenceBand": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "predictionModelRef": {
      "$ref": "#/$defs/id"
    },
    "fallbackGuidanceRef": {
      "$ref": "#/$defs/id"
    },
    "grantSetRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "requiredReleaseApprovalFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "channelReleaseFreezeState": {
      "type": "string",
      "enum": [
        "permitted",
        "guarded",
        "blocked"
      ]
    },
    "requiredAssuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "continuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "freezeDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    }
  },
  "x-governedInvariants": [
    "CallbackExpectationEnvelope is the sole patient-facing callback promise and repair guide.",
    "Calibrated probabilities may widen pending or repair posture, but they may never manufacture callback completion without CallbackOutcomeEvidenceBundle and CallbackResolutionGate."
  ]
}
