{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_clinician_message_thread.schema.json",
  "title": "229 ClinicianMessageThread",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "threadId",
    "episodeRef",
    "requestRef",
    "requestLineageRef",
    "lineageCaseLinkRef",
    "requestLifecycleLeaseRef",
    "threadPurpose",
    "closureRule",
    "authorRef",
    "approverRef",
    "threadVersionRef",
    "currentDispatchEnvelopeRef",
    "currentDeliveryEvidenceRef",
    "currentExpectationEnvelopeRef",
    "currentResolutionGateRef",
    "reachabilityDependencyRef",
    "threadState",
    "patientVisibleState",
    "lastMeaningfulUpdateAt"
  ],
  "properties": {
    "threadId": {
      "$ref": "#/$defs/id"
    },
    "episodeRef": {
      "$ref": "#/$defs/id"
    },
    "requestRef": {
      "$ref": "#/$defs/id"
    },
    "requestLineageRef": {
      "$ref": "#/$defs/id"
    },
    "lineageCaseLinkRef": {
      "$ref": "#/$defs/id"
    },
    "requestLifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "threadPurpose": {
      "type": "string",
      "minLength": 1
    },
    "closureRule": {
      "type": "string",
      "minLength": 1
    },
    "authorRef": {
      "$ref": "#/$defs/id"
    },
    "approverRef": {
      "$ref": "#/$defs/id"
    },
    "threadVersionRef": {
      "$ref": "#/$defs/id"
    },
    "currentDispatchEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "currentDeliveryEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "currentExpectationEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "currentResolutionGateRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "threadState": {
      "type": "string",
      "enum": [
        "drafted",
        "approved",
        "sent",
        "delivered",
        "patient_replied",
        "awaiting_clinician_review",
        "delivery_failed",
        "contact_route_repair_pending",
        "reopened",
        "closed"
      ]
    },
    "patientVisibleState": {
      "type": "string",
      "enum": [
        "reply_needed",
        "awaiting_review",
        "reviewed",
        "reply_blocked",
        "delivery_repair_required",
        "closed"
      ]
    },
    "lastMeaningfulUpdateAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-canonicalPrimaryPath": [
    "drafted",
    "approved",
    "sent",
    "delivered",
    "patient_replied",
    "awaiting_clinician_review",
    "closed"
  ],
  "x-canonicalRepairPath": [
    "sent",
    "delivery_failed",
    "contact_route_repair_pending",
    "approved",
    "sent"
  ],
  "x-governedInvariants": [
    "Patient-visible reply timing and repair posture derive only from ThreadExpectationEnvelope.",
    "Thread closure may not occur on transport optimism alone; it requires MessageDeliveryEvidenceBundle and ThreadResolutionGate."
  ]
}
