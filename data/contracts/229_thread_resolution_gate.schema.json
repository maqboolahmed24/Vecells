{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_thread_resolution_gate.schema.json",
  "title": "229 ThreadResolutionGate",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "resolutionGateId",
    "threadRef",
    "latestDispatchRef",
    "latestReplyRef",
    "latestExpectationEnvelopeRef",
    "latestSupportActionSettlementRef",
    "decision",
    "decisionReasonRef",
    "sameShellRecoveryRef",
    "requiresLifecycleReview",
    "causalToken",
    "monotoneRevision",
    "decidedAt"
  ],
  "properties": {
    "resolutionGateId": {
      "$ref": "#/$defs/id"
    },
    "threadRef": {
      "$ref": "#/$defs/id"
    },
    "latestDispatchRef": {
      "$ref": "#/$defs/id"
    },
    "latestReplyRef": {
      "$ref": "#/$defs/id"
    },
    "latestExpectationEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "latestSupportActionSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "decision": {
      "type": "string",
      "enum": [
        "await_reply",
        "review_pending",
        "escalate_to_callback",
        "close",
        "reopen",
        "repair_route"
      ]
    },
    "decisionReasonRef": {
      "$ref": "#/$defs/id"
    },
    "sameShellRecoveryRef": {
      "$ref": "#/$defs/id"
    },
    "requiresLifecycleReview": {
      "type": "boolean"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    },
    "decidedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "ThreadResolutionGate is the only authority for repair routing, reopen, callback escalation, and closure.",
    "It must hold closure while delivery dispute, reply review, reachability repair, or safety preemption remains unsettled."
  ]
}
