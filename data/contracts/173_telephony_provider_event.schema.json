{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/173_telephony_provider_event.schema.json",
  "title": "TelephonyProviderEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "canonicalEventId",
    "providerEventFamily",
    "canonicalEventType",
    "ingressSource",
    "providerPayloadRef",
    "payloadDigest",
    "payloadStorageRule",
    "idempotencyKeyBasis",
    "callSessionRef",
    "occurredAt",
    "normalizedAt",
    "normalizerVersionRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": "173.phase2.telephony.provider-event.v1"
    },
    "canonicalEventId": {
      "type": "string",
      "pattern": "^tel_evt_[A-Za-z0-9_:-]+$"
    },
    "providerEventFamily": {
      "type": "string",
      "enum": [
        "provider_call_started",
        "provider_menu_input",
        "provider_identity_input",
        "provider_recording_expected",
        "provider_recording_available",
        "provider_recording_timeout",
        "provider_transcript_ready",
        "provider_transcript_failed",
        "provider_call_abandoned",
        "provider_error",
        "provider_continuation_delivery"
      ]
    },
    "canonicalEventType": {
      "type": "string",
      "enum": [
        "call_started",
        "menu_selection_captured",
        "identity_capture_started",
        "identity_resolved",
        "identity_partial",
        "identity_failed",
        "recording_expected",
        "recording_available",
        "recording_missing",
        "audio_quarantined",
        "transcript_job_queued",
        "transcript_ready",
        "transcript_degraded",
        "evidence_readiness_assessed",
        "urgent_live_preempted",
        "continuation_eligibility_settled",
        "continuation_sent",
        "request_seeded",
        "submission_promoted",
        "call_closed",
        "call_abandoned",
        "provider_error_recorded",
        "manual_review_opened",
        "manual_followup_opened"
      ]
    },
    "ingressSource": {
      "type": "string",
      "enum": ["webhook", "polling", "simulator"]
    },
    "providerPayloadRef": {
      "type": "string",
      "description": "Opaque quarantine/object-store pointer to the raw provider payload."
    },
    "payloadDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "payloadStorageRule": {
      "const": "normalization_boundary_only"
    },
    "payloadDisclosureBoundary": {
      "const": "provider_payload_shape_stops_at_normalizer"
    },
    "idempotencyKeyBasis": {
      "type": "string",
      "enum": [
        "provider_event_id_plus_call_session",
        "provider_call_id_plus_event_type_plus_occurred_at",
        "polling_resource_version_plus_call_session",
        "payload_digest_plus_call_session"
      ]
    },
    "callSessionRef": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "normalizedAt": {
      "type": "string",
      "format": "date-time"
    },
    "normalizerVersionRef": {
      "type": "string"
    },
    "normalizedPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "menuSelection": {
          "type": "string",
          "enum": ["symptoms", "medications", "admin", "results", "unknown"]
        },
        "recordingArtifactRef": {
          "type": "string"
        },
        "transcriptJobRef": {
          "type": "string"
        },
        "deliverySettlementRef": {
          "type": "string"
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
