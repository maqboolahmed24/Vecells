{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/234_duplicate_review_snapshot.schema.json",
  "title": "234 DuplicateReviewSnapshot",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "decisionClass": {
      "type": "string",
      "enum": [
        "exact_retry_collapse",
        "same_request_attach",
        "same_episode_link",
        "related_episode_link",
        "separate_request",
        "review_required"
      ]
    },
    "decisionState": {
      "type": "string",
      "enum": [
        "applied",
        "superseded",
        "reverted"
      ]
    },
    "instabilityState": {
      "type": "string",
      "enum": [
        "stable",
        "oscillating",
        "blocked_conflict"
      ]
    },
    "continuityWitnessClass": {
      "type": "string",
      "enum": [
        "deterministic_replay",
        "submit_lineage",
        "workflow_return",
        "more_info_cycle",
        "telephony_continuation",
        "human_review",
        "none"
      ]
    },
    "invalidationTargetType": {
      "type": "string",
      "enum": [
        "endpoint_decision",
        "approval_checkpoint",
        "endpoint_outcome_preview",
        "booking_intent",
        "pharmacy_intent",
        "patient_offer_link",
        "analytics_join",
        "workspace_assumption",
        "reopen_assumption",
        "handoff_seed"
      ]
    }
  },
  "required": [
    "duplicateReviewSnapshotId",
    "taskId",
    "duplicateClusterRef",
    "candidateRequestRefs",
    "pairEvidenceRefs",
    "currentResolutionDecisionRef",
    "currentDecisionClass",
    "currentDecisionState",
    "continuityWitnessSummaryRef",
    "continuityWitnessRequirementState",
    "requiredContinuityWitnessClasses",
    "instabilityState",
    "authorityBoundary",
    "candidateMembers",
    "queueRelevance",
    "workspaceRelevance",
    "currentInvalidationBurden",
    "lastRenderedAt"
  ],
  "properties": {
    "duplicateReviewSnapshotId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "duplicateClusterRef": {
      "$ref": "#/$defs/id"
    },
    "candidateRequestRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "pairEvidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "winningPairEvidenceRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "competingPairEvidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "currentResolutionDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "currentDecisionClass": {
      "$ref": "#/$defs/decisionClass"
    },
    "currentDecisionState": {
      "$ref": "#/$defs/decisionState"
    },
    "continuityWitnessSummaryRef": {
      "$ref": "#/$defs/id"
    },
    "continuityWitnessRequirementState": {
      "type": "string",
      "enum": [
        "not_required",
        "required_for_attach",
        "satisfied"
      ]
    },
    "requiredContinuityWitnessClasses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/continuityWitnessClass"
      }
    },
    "instabilityState": {
      "$ref": "#/$defs/instabilityState"
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duplicateClusterAuthority",
        "sameRequestAttachAuthority",
        "replayAuthority",
        "reviewProjectionMode"
      ],
      "properties": {
        "duplicateClusterAuthority": {
          "type": "string",
          "const": "DuplicateCluster"
        },
        "sameRequestAttachAuthority": {
          "type": "string",
          "const": "DuplicateResolutionDecision"
        },
        "replayAuthority": {
          "type": "string",
          "const": "IdempotencyRecord"
        },
        "reviewProjectionMode": {
          "type": "string",
          "const": "phase0_projection_reuse"
        }
      }
    },
    "candidateMembers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requestRef",
          "episodeRef",
          "dominantDecisionClass",
          "dominantScore",
          "uncertaintyScore",
          "hardBlockerRefs"
        ],
        "properties": {
          "requestRef": {
            "$ref": "#/$defs/id"
          },
          "episodeRef": {
            "$ref": "#/$defs/id"
          },
          "dominantDecisionClass": {
            "type": "string",
            "enum": [
              "exact_retry_collapse",
              "same_request_attach",
              "same_episode_link",
              "related_episode_link",
              "separate_request"
            ]
          },
          "dominantScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "uncertaintyScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "hardBlockerRefs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/id"
            }
          }
        }
      }
    },
    "queueRelevance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queueBlockingState",
        "canonicalDuplicateReviewFlag",
        "queueAuthorityRef"
      ],
      "properties": {
        "queueBlockingState": {
          "type": "string",
          "enum": [
            "explicit_review_required",
            "resolved"
          ]
        },
        "canonicalDuplicateReviewFlag": {
          "type": "boolean"
        },
        "queueAuthorityRef": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "workspaceRelevance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspaceState",
        "actionScope",
        "commandSurface"
      ],
      "properties": {
        "workspaceState": {
          "type": "string",
          "enum": [
            "explicit_review_required",
            "resolved"
          ]
        },
        "actionScope": {
          "type": "string",
          "const": "resolve_duplicate_cluster"
        },
        "commandSurface": {
          "type": "string",
          "const": "/internal/v1/workspace/tasks/{taskId}/duplicate-review/resolve"
        }
      }
    },
    "currentInvalidationBurden": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "burdenState",
        "totalCount",
        "targetTypes",
        "invalidationRefs"
      ],
      "properties": {
        "burdenState": {
          "type": "string",
          "enum": [
            "none",
            "stale_consequences_pending"
          ]
        },
        "totalCount": {
          "type": "integer",
          "minimum": 0
        },
        "targetTypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/invalidationTargetType"
          }
        },
        "invalidationRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "lastRenderedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "DuplicateReviewSnapshot is the task-facing read model over canonical Phase 0 duplicate authority, not a second duplicate system.",
    "Replay authority remains IdempotencyRecord while attach, link, and separation authority remain DuplicateResolutionDecision.",
    "DuplicateReviewSnapshot must render explicit invalidation burden when earlier duplicate truth is superseded."
  ]
}
