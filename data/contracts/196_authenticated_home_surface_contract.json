{
  "taskId": "par_196",
  "contractId": "AUTHENTICATED_HOME_SURFACE_CONTRACT_196_V1",
  "visualMode": "Quiet_Portal_Atlas",
  "consumes": [
    "data/analysis/185_portal_projection_matrix.csv",
    "docs/architecture/185_authenticated_portal_projection_and_status_access_controls.md"
  ],
  "routes": [
    "/portal/home",
    "/portal/quiet",
    "/portal/requests",
    "/portal/requests/REQ-4219",
    "/portal/requests/REQ-4219/narrowed",
    "/portal/reachability-blocker",
    "/portal/session-expiring",
    "/portal/session-expired"
  ],
  "projections": [
    "PatientPortalEntryProjection",
    "PatientHomeProjection",
    "PatientSpotlightDecisionProjection",
    "PatientPortalNavigationProjection",
    "PatientRequestsIndexProjection",
    "PatientRequestSummaryProjection",
    "PatientRequestDetailProjection",
    "PatientRequestReturnBundle",
    "PatientAudienceCoverageProjection",
    "PatientActionRecoveryProjection",
    "PatientIdentityHoldProjection"
  ],
  "layoutContract": {
    "topShellBandPx": 64,
    "leftNavPx": 240,
    "centerColumn": "minmax(720px, 1fr)",
    "optionalRightPx": 320,
    "maxWidthPx": 1440,
    "horizontalPaddingPx": 32,
    "desktopHomeRows": [
      "row1: spotlight 8/12 plus compact cards 4/12",
      "row2: request tracker",
      "row3: quiet disclosure"
    ],
    "mobile": "one column"
  },
  "dominantActionLaw": {
    "sourceProjection": "PatientSpotlightDecisionProjection",
    "maxDominantActions": 1,
    "contactPreferencePromotionRule": "secondary unless PatientIdentityHoldProjection.blocksCurrentAction is true",
    "forbiddenLivePatterns": [
      "dashboard filler charts",
      "rotating carousels",
      "route-local card scores",
      "generic home redirect during recoverable continuity"
    ]
  },
  "audienceDisclosureLaw": {
    "rowCoverage": "PatientAudienceCoverageProjection.maxVisibleDetail controls row fields",
    "detailCoverage": "PatientAudienceCoverageProjection.maxVisibleDetail narrows detail before rendering",
    "suppressed": [
      "raw identifiers",
      "staff internal notes",
      "clinical reasoning not cleared for patient view",
      "message bodies when summary_only"
    ]
  },
  "continuityLaw": {
    "returnBundle": "PatientRequestReturnBundle",
    "preservedAcross": [
      "soft navigation",
      "browser back",
      "refresh replay",
      "bounded post-expiry recovery"
    ],
    "fields": [
      "selectedRequestId",
      "selectedFilter",
      "selectedAnchorId",
      "focusTestId",
      "originPathname"
    ]
  }
}
