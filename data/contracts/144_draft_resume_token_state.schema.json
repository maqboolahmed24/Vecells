{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase1/draft-resume-token-state.schema.json",
  "title": "DraftResumeTokenState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draftPublicId",
    "resumeToken",
    "continuityState",
    "resumeBlockedReasonCodes",
    "mutatingResumeState",
    "sameShellRecoveryRouteRef"
  ],
  "properties": {
    "draftPublicId": {
      "type": "string",
      "pattern": "^dft_[a-z0-9]{10,32}$"
    },
    "resumeToken": {
      "type": "string",
      "pattern": "^rtk_[A-Za-z0-9_-]{12,128}$"
    },
    "continuityState": {
      "type": "string",
      "enum": ["stable_writable", "stable_read_only", "recovery_only", "blocked"]
    },
    "activeLeaseRef": {
      "type": ["string", "null"]
    },
    "resumeBlockedReasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mutatingResumeState": {
      "type": "string",
      "enum": ["allowed", "rebind_required", "blocked"]
    },
    "sameShellRecoveryRouteRef": {
      "type": "string"
    }
  }
}
