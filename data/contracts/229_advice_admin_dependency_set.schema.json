{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_advice_admin_dependency_set.schema.json",
  "title": "229 AdviceAdminDependencySet",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adviceAdminDependencySetId",
    "requestRef",
    "boundaryDecisionRef",
    "boundaryTupleHash",
    "reachabilityDependencyRef",
    "contactRepairJourneyRef",
    "deliveryDisputeRef",
    "consentCheckpointRef",
    "identityRepairCaseRef",
    "externalDependencyRef",
    "dominantRecoveryRouteRef",
    "reopenTriggerRefs",
    "clinicalReentryTriggerRefs",
    "dependencyState",
    "reopenState",
    "evaluatedAt"
  ],
  "properties": {
    "adviceAdminDependencySetId": {
      "$ref": "#/$defs/id"
    },
    "requestRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryTupleHash": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "contactRepairJourneyRef": {
      "$ref": "#/$defs/id"
    },
    "deliveryDisputeRef": {
      "$ref": "#/$defs/id"
    },
    "consentCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "identityRepairCaseRef": {
      "$ref": "#/$defs/id"
    },
    "externalDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "dominantRecoveryRouteRef": {
      "$ref": "#/$defs/id"
    },
    "reopenTriggerRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "clinicalReentryTriggerRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "dependencyState": {
      "type": "string",
      "enum": [
        "clear",
        "repair_required",
        "disputed",
        "blocked_pending_identity",
        "blocked_pending_consent",
        "blocked_pending_external_confirmation"
      ]
    },
    "reopenState": {
      "type": "string",
      "enum": [
        "stable",
        "reopen_required",
        "reopened",
        "blocked_pending_review"
      ]
    },
    "evaluatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "AdviceAdminDependencySet is the canonical reopen fence for advice and admin follow-up.",
    "Generic waiting is invalid without a blocker owner, dependency type, and dominant recovery route."
  ]
}
