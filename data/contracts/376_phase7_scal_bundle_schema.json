{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_scal_bundle_schema.json",
  "title": "SCALBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundleId", "environment", "evidenceRefs", "owner", "submissionState"],
  "properties": {
    "bundleId": {
      "type": "string"
    },
    "environment": {
      "type": "string",
      "enum": ["sandpit", "aos", "limited_release", "full_release"]
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owner": {
      "type": "string"
    },
    "submissionState": {
      "type": "string",
      "enum": ["not_started", "drafting", "submitted", "changes_requested", "signed_off", "blocked"]
    }
  }
}
