{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/171_post_auth_return_intent.schema.json",
  "title": "PostAuthReturnIntent",
  "description": "Governed post-auth return model. It converts to exactly one RouteIntentBinding and never carries an arbitrary URL string.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "postAuthReturnIntentId",
    "schemaVersion",
    "policyVersion",
    "routeIntentBindingRef",
    "lineageRef",
    "routeFamilyRef",
    "subjectRef",
    "bindingVersionRef",
    "sessionEpochRef",
    "channelManifestRef",
    "selectedAnchorRef",
    "allowedNextSurface",
    "redirectMode",
    "staleDisposition",
    "createdAt"
  ],
  "properties": {
    "postAuthReturnIntentId": {
      "type": "string",
      "pattern": "^pai_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "171.phase2.auth-session.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-auth-session-v[0-9]+$"
    },
    "routeIntentBindingRef": {
      "type": "string"
    },
    "lineageRef": {
      "type": "string"
    },
    "routeFamilyRef": {
      "type": "string"
    },
    "subjectRef": {
      "type": "string",
      "description": "Opaque subject or draft actor reference. Never a direct patient identifier."
    },
    "bindingVersionRef": {
      "type": "string"
    },
    "sessionEpochRef": {
      "type": "string"
    },
    "channelManifestRef": {
      "type": "string"
    },
    "selectedAnchorRef": {
      "type": "string"
    },
    "allowedNextSurface": {
      "type": "string",
      "enum": [
        "patient_home",
        "claim_draft",
        "request_status",
        "attachment_addition",
        "bounded_recovery",
        "re_auth",
        "signed_out_safe_entry"
      ]
    },
    "redirectMode": {
      "const": "route_intent_binding_only"
    },
    "staleDisposition": {
      "type": "string",
      "enum": ["deny", "bounded_recovery", "read_only", "re_auth_required"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
