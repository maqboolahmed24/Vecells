{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_callback_intent_lease.schema.json",
  "title": "229 CallbackIntentLease",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "leaseId",
    "callbackCaseRef",
    "requestLifecycleLeaseRef",
    "leaseAuthorityRef",
    "ownedByActorRef",
    "ownedBySessionRef",
    "serviceWindowRef",
    "contactRouteRef",
    "routeIntentBindingRef",
    "lineageFenceEpoch",
    "ownershipEpoch",
    "fencingToken",
    "leaseMode",
    "caseVersionRef",
    "lastHeartbeatAt",
    "staleOwnerRecoveryRef",
    "expiresAt"
  ],
  "properties": {
    "leaseId": {
      "$ref": "#/$defs/id"
    },
    "callbackCaseRef": {
      "$ref": "#/$defs/id"
    },
    "requestLifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "leaseAuthorityRef": {
      "$ref": "#/$defs/id"
    },
    "ownedByActorRef": {
      "$ref": "#/$defs/id"
    },
    "ownedBySessionRef": {
      "$ref": "#/$defs/id"
    },
    "serviceWindowRef": {
      "$ref": "#/$defs/id"
    },
    "contactRouteRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "ownershipEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "fencingToken": {
      "$ref": "#/$defs/id"
    },
    "leaseMode": {
      "type": "string",
      "enum": [
        "queued",
        "scheduled",
        "ready_for_attempt",
        "suspended_for_repair"
      ]
    },
    "caseVersionRef": {
      "$ref": "#/$defs/id"
    },
    "lastHeartbeatAt": {
      "$ref": "#/$defs/dateTime"
    },
    "staleOwnerRecoveryRef": {
      "$ref": "#/$defs/id"
    },
    "expiresAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "CallbackIntentLease is the sole authority for claim, schedule, reschedule, cancel, and ready-for-attempt arming.",
    "Material urgency, route, or preferred-window drift must invalidate and replace the live lease before another callback attempt may begin."
  ]
}
