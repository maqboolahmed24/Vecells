{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_patient_conversation_cluster.schema.json",
  "title": "229 PatientConversationCluster",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "clusterId",
    "threadId",
    "governingRequestRef",
    "careEpisodeRef",
    "callbackCaseRefs",
    "messageThreadRefs",
    "reminderPlanRefs",
    "typedSubthreadRefs",
    "communicationEnvelopeRefs",
    "selectedAnchorRef",
    "clusterTupleHash",
    "clusterState",
    "lastMeaningfulUpdateAt"
  ],
  "properties": {
    "clusterId": {
      "$ref": "#/$defs/id"
    },
    "threadId": {
      "$ref": "#/$defs/id"
    },
    "governingRequestRef": {
      "$ref": "#/$defs/id"
    },
    "careEpisodeRef": {
      "$ref": "#/$defs/id"
    },
    "callbackCaseRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "messageThreadRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "reminderPlanRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "typedSubthreadRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "communicationEnvelopeRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "clusterTupleHash": {
      "$ref": "#/$defs/id"
    },
    "clusterState": {
      "type": "string",
      "enum": [
        "active",
        "awaiting_review",
        "repair_required",
        "settled",
        "closed",
        "recovery_only"
      ]
    },
    "lastMeaningfulUpdateAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "PatientConversationCluster is the sole grouping identity for patient conversation surfaces.",
    "There may be one authoritative conversation cluster and one authoritative reply path for the current thread at a time."
  ]
}
