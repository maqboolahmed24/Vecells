{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/191_transcript_job_contract.schema.json",
  "title": "TranscriptJobContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "transcriptJobRef",
    "schemaVersion",
    "callSessionRef",
    "recordingArtifactRef",
    "audioIngestSettlementRef",
    "recordingDocumentReferenceRef",
    "idempotencyKey",
    "jobState",
    "workerAttemptCount",
    "supersedesTranscriptJobRef",
    "derivationPackageRef",
    "transcriptReadinessRef",
    "evidenceReadinessAssessmentRef",
    "terminalOutcome",
    "reasonCodes",
    "createdAt",
    "updatedAt",
    "recordedBy"
  ],
  "properties": {
    "transcriptJobRef": { "type": "string", "pattern": "^tel_transcript_job_191_" },
    "schemaVersion": { "const": "191.phase2.telephony-readiness.v1" },
    "callSessionRef": { "type": "string" },
    "recordingArtifactRef": { "type": "string" },
    "audioIngestSettlementRef": { "type": "string" },
    "recordingDocumentReferenceRef": { "type": "string" },
    "idempotencyKey": { "type": "string" },
    "jobState": { "enum": ["queued", "running", "succeeded", "degraded", "failed"] },
    "workerAttemptCount": { "type": "integer", "minimum": 0 },
    "supersedesTranscriptJobRef": { "type": ["string", "null"] },
    "derivationPackageRef": { "type": ["string", "null"] },
    "transcriptReadinessRef": { "type": ["string", "null"] },
    "evidenceReadinessAssessmentRef": { "type": ["string", "null"] },
    "terminalOutcome": { "enum": ["pending", "ready", "degraded", "failed", "unusable_terminal"] },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyReadinessPipeline" }
  }
}
