{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_hub_offer_to_confirmation_truth_projection.schema.json",
  "title": "HubOfferToConfirmationTruthProjection",
  "description": "Single monotone truth object that resolves offer, selection, commit, appointment truth, practice continuity, acknowledgement, visibility, and closure blockers into one current projection.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "hubOfferToConfirmationTruthProjectionId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for the projection."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "offerSessionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current or most recent offer session."
    },
    "selectedOfferEntryRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current selected ranked offer entry."
    },
    "fallbackCardRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current fallback card where callback or return posture is live."
    },
    "commitAttemptRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current or winning HubCommitAttempt."
    },
    "evidenceBundleRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current or winning evidence bundle."
    },
    "appointmentRecordRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current HubAppointmentRecord."
    },
    "continuityMessageRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current PracticeContinuityMessage."
    },
    "acknowledgementRecordRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current PracticeAcknowledgementRecord."
    },
    "visibilityProjectionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current PracticeVisibilityProjection."
    },
    "offerState": {
      "type": "string",
      "enum": [
        "no_live_offer",
        "live_offer",
        "selected",
        "fallback_selected",
        "superseded"
      ],
      "description": "Offer-side posture resolved into the current projection."
    },
    "confirmationTruthState": {
      "type": "string",
      "enum": [
        "offer_only",
        "commit_pending",
        "confirmation_pending",
        "confirmed_pending_practice_ack",
        "confirmed",
        "disputed",
        "blocked_by_drift"
      ],
      "description": "Current confirmation truth posture after applying the confirmation gate and drift laws."
    },
    "patientConfirmationState": {
      "type": "string",
      "enum": [
        "not_shown",
        "pending_copy",
        "calm_confirmed",
        "blocked"
      ],
      "description": "Patient-facing confirmation posture kept separate from practice acknowledgement."
    },
    "practiceVisibilityState": {
      "type": "string",
      "enum": [
        "not_informed",
        "transport_pending",
        "delivered_pending_ack",
        "ack_pending",
        "acknowledged",
        "stale_generation",
        "blocked"
      ],
      "description": "Practice-side continuity or acknowledgement posture."
    },
    "fallbackLinkageState": {
      "type": "string",
      "enum": [
        "none",
        "callback_pending",
        "callback_linked",
        "returned_to_practice",
        "linkage_debt"
      ],
      "description": "Callback or return linkage posture kept explicit in the same projection."
    },
    "closureState": {
      "type": "string",
      "enum": [
        "not_closable",
        "closable",
        "closed"
      ],
      "description": "Current closure legality."
    },
    "openBlockerRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Current closure or mutation blockers."
    },
    "currentAckGeneration": {
      "type": "integer",
      "minimum": 0,
      "description": "Live acknowledgement generation."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy tuple hash."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time the projection was computed or refreshed."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "hubOfferToConfirmationTruthProjectionId",
    "hubCoordinationCaseId",
    "offerState",
    "confirmationTruthState",
    "patientConfirmationState",
    "practiceVisibilityState",
    "fallbackLinkageState",
    "closureState",
    "openBlockerRefs",
    "currentAckGeneration",
    "policyTupleHash",
    "truthTupleHash",
    "generatedAt",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
