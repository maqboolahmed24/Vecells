{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells/contracts/236_more_info_cycle.schema.json",
  "title": "MoreInfoCycle",
  "type": "object",
  "required": [
    "cycleId",
    "taskId",
    "requestId",
    "requestLineageRef",
    "state",
    "promptSetRef",
    "channelRef",
    "responseRouteFamilyRef",
    "dueAt",
    "lateReviewStartsAt",
    "expiresAt",
    "lifecycleLeaseRef",
    "leaseAuthorityRef",
    "ownershipEpoch",
    "fencingToken",
    "currentLineageFenceEpoch",
    "activeCheckpointRef",
    "reminderScheduleRef",
    "createdAt",
    "updatedAt",
    "version"
  ],
  "properties": {
    "cycleId": { "type": "string" },
    "taskId": { "type": "string" },
    "requestId": { "type": "string" },
    "requestLineageRef": { "type": "string" },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "awaiting_delivery",
        "awaiting_patient_reply",
        "awaiting_late_review",
        "response_received",
        "review_resumed",
        "expired",
        "superseded",
        "cancelled"
      ]
    },
    "promptSetRef": { "type": "string" },
    "channelRef": { "type": "string" },
    "responseRouteFamilyRef": { "type": "string" },
    "dueAt": { "type": "string", "format": "date-time" },
    "lateReviewStartsAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "lifecycleLeaseRef": { "type": "string" },
    "leaseAuthorityRef": { "type": "string" },
    "ownershipEpoch": { "type": "integer", "minimum": 0 },
    "fencingToken": { "type": "string" },
    "currentLineageFenceEpoch": { "type": "integer", "minimum": 0 },
    "activeCheckpointRef": { "type": "string" },
    "reminderScheduleRef": { "type": "string" },
    "responseGrantRef": { "type": ["string", "null"] },
    "responseGrantExpiresAt": { "type": ["string", "null"], "format": "date-time" },
    "supersedesCycleRef": { "type": ["string", "null"] },
    "supersededByCycleRef": { "type": ["string", "null"] },
    "latestResponseClassification": { "type": ["string", "null"] },
    "responseReceivedAt": { "type": ["string", "null"], "format": "date-time" },
    "callbackFallbackSeedRef": { "type": ["string", "null"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
