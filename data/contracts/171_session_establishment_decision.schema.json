{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/171_session_establishment_decision.schema.json",
  "title": "SessionEstablishmentDecision",
  "description": "Local Vecells session decision emitted after callback validation. NHS login success is an input, not a session by itself.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionEstablishmentDecisionId",
    "schemaVersion",
    "policyVersion",
    "authTransactionRef",
    "postAuthReturnIntentRef",
    "decision",
    "writableAuthorityState",
    "sessionEpochAction",
    "cookieRotationAction",
    "csrfRotationAction",
    "maxGrantCeiling",
    "projectionPosture",
    "reasonCodes",
    "decidedAt"
  ],
  "properties": {
    "sessionEstablishmentDecisionId": {
      "type": "string",
      "pattern": "^sed_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "171.phase2.auth-session.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-auth-session-v[0-9]+$"
    },
    "authTransactionRef": {
      "type": "string"
    },
    "postAuthReturnIntentRef": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": ["create_fresh", "rotate_existing", "reuse_existing", "deny", "bounded_recovery"]
    },
    "writableAuthorityState": {
      "type": "string",
      "enum": ["writable", "read_only", "blocked"]
    },
    "sessionEpochAction": {
      "type": "string",
      "enum": ["create", "rotate", "reuse", "terminate", "no_session"]
    },
    "cookieRotationAction": {
      "type": "string",
      "enum": [
        "set_secure_http_only",
        "rotate_secure_http_only",
        "clear",
        "preserve_read_only",
        "none"
      ]
    },
    "csrfRotationAction": {
      "type": "string",
      "enum": ["issue", "rotate", "clear", "preserve_read_only", "none"]
    },
    "maxGrantCeiling": {
      "type": "string",
      "enum": [
        "none",
        "authenticated_draft_only",
        "request_status_read",
        "request_attachment_write",
        "continuation_recovery_only"
      ]
    },
    "projectionPosture": {
      "type": "string",
      "enum": [
        "signed_in",
        "claim_pending",
        "read_only",
        "re_auth_required",
        "session_expired",
        "consent_declined",
        "subject_conflict",
        "stale_return",
        "bounded_recovery"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^AUTH_171_[A-Z0-9_]+$"
      }
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
