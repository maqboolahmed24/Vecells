{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells/contracts/149_normalized_submission_contract.json",
  "title": "NormalizedSubmission",
  "description": "Canonical deterministic Phase 1 intake package derived from one immutable submission snapshot and its pinned intake bundle.",
  "taskId": "par_149",
  "contractId": "PHASE1_NORMALIZED_SUBMISSION_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "normalizedSubmissionSchemaVersion",
    "normalizedSubmissionId",
    "submissionEnvelopeRef",
    "primaryIngressRecordRef",
    "governingSnapshotRef",
    "submissionSnapshotFreezeRef",
    "evidenceCaptureBundleRef",
    "requestType",
    "narrativeRef",
    "structuredAnswersRef",
    "channelMetadataRef",
    "identityContextRef",
    "attachmentRefs",
    "audioRefs",
    "submissionSourceTimestamp",
    "dedupeFingerprintRef",
    "dedupeFingerprint",
    "channelCapabilityCeiling",
    "contactAuthorityClass",
    "evidenceReadinessState",
    "normalizationVersionRef",
    "normalizedHash",
    "intakeExperienceBundleRef",
    "questionDefinitionContractRef",
    "sourceLineageRef",
    "requestShape",
    "activeStructuredAnswers",
    "summaryFragments",
    "authoredNarrative",
    "dedupeFeatures",
    "normalizationReasonCodes",
    "gapRefs",
    "createdAt",
    "version"
  ],
  "properties": {
    "normalizedSubmissionSchemaVersion": {
      "const": "NORMALIZED_SUBMISSION_V1"
    },
    "normalizedSubmissionId": {
      "type": "string",
      "minLength": 1
    },
    "submissionEnvelopeRef": {
      "type": "string",
      "minLength": 1
    },
    "requestLineageRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "primaryIngressRecordRef": {
      "type": "string",
      "minLength": 1
    },
    "governingSnapshotRef": {
      "type": "string",
      "minLength": 1
    },
    "submissionSnapshotFreezeRef": {
      "type": "string",
      "minLength": 1
    },
    "evidenceCaptureBundleRef": {
      "type": "string",
      "minLength": 1
    },
    "requestType": {
      "enum": [
        "Symptoms",
        "Meds",
        "Admin",
        "Results"
      ]
    },
    "narrativeRef": {
      "type": "string",
      "minLength": 1
    },
    "structuredAnswersRef": {
      "type": "string",
      "minLength": 1
    },
    "channelMetadataRef": {
      "type": "string",
      "minLength": 1
    },
    "identityContextRef": {
      "type": "string",
      "minLength": 1
    },
    "attachmentRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audioRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contactPreferencesRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "submissionSourceTimestamp": {
      "type": "string",
      "format": "date-time"
    },
    "patientMatchConfidenceRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "dedupeFingerprintRef": {
      "type": "string",
      "minLength": 1
    },
    "dedupeFingerprint": {
      "type": "string",
      "minLength": 32
    },
    "channelCapabilityCeiling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canUploadFiles",
        "canRenderTrackStatus",
        "canRenderEmbedded",
        "mutatingResumeState"
      ],
      "properties": {
        "canUploadFiles": {
          "type": "boolean"
        },
        "canRenderTrackStatus": {
          "type": "boolean"
        },
        "canRenderEmbedded": {
          "type": "boolean"
        },
        "mutatingResumeState": {
          "enum": [
            "allowed",
            "rebind_required",
            "blocked"
          ]
        }
      }
    },
    "contactAuthorityClass": {
      "enum": [
        "self_asserted",
        "nhs_login_claim",
        "verified_destination",
        "authority_confirmed"
      ]
    },
    "evidenceReadinessState": {
      "enum": [
        "urgent_live_only",
        "safety_usable",
        "manual_review_only"
      ]
    },
    "normalizationVersionRef": {
      "const": "PHASE1_NORMALIZED_SUBMISSION_V1"
    },
    "normalizedHash": {
      "type": "string",
      "minLength": 32
    },
    "supersedesNormalizedSubmissionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "intakeExperienceBundleRef": {
      "type": "string",
      "minLength": 1
    },
    "questionDefinitionContractRef": {
      "const": "QDC_140_PHASE1_V1"
    },
    "sourceLineageRef": {
      "type": "string",
      "minLength": 1
    },
    "requestShape": {
      "type": "object"
    },
    "activeStructuredAnswers": {
      "type": "object"
    },
    "summaryFragments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "questionKey",
          "normalizationTarget",
          "summaryRendererRef",
          "safetyRelevance",
          "valueHash",
          "fragmentText"
        ],
        "properties": {
          "questionKey": {
            "type": "string"
          },
          "normalizationTarget": {
            "type": "string"
          },
          "summaryRendererRef": {
            "type": "string"
          },
          "safetyRelevance": {
            "enum": [
              "none",
              "triage_relevant",
              "safety_relevant"
            ]
          },
          "valueHash": {
            "type": "string"
          },
          "fragmentText": {
            "type": "string"
          }
        }
      }
    },
    "authoredNarrative": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceKind",
        "authoredText",
        "canonicalText",
        "tokenFingerprint"
      ],
      "properties": {
        "sourceKind": {
          "enum": [
            "free_text",
            "request_field",
            "none"
          ]
        },
        "authoredText": {
          "type": [
            "string",
            "null"
          ]
        },
        "canonicalText": {
          "type": [
            "string",
            "null"
          ]
        },
        "tokenFingerprint": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "dedupeFeatures": {
      "type": "object"
    },
    "normalizationReasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gapRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "const": 1
    }
  }
}
