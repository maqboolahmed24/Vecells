{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/235_review_bundle.schema.json",
  "title": "235 ReviewBundle",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "reviewBundleId",
    "taskId",
    "requestId",
    "publicationState",
    "summaryVisibilityState",
    "provenance",
    "requestSummary",
    "structuredAnswers",
    "patientNarrative",
    "safetyScreening",
    "telephony",
    "transcript",
    "attachments",
    "identitySummary",
    "contactPreferenceSummary",
    "priorPatientResponses",
    "duplicateClusterStatus",
    "latestSlaState",
    "deterministicSummary",
    "sourceArtifactRefs",
    "deltaPacketRef",
    "visibleSuggestionEnvelopeRefs",
    "hiddenSuggestionEnvelopeRefs",
    "gapArtifactRefs",
    "bundleDigest",
    "assembledAt"
  ],
  "properties": {
    "reviewBundleId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "requestId": {
      "$ref": "#/$defs/id"
    },
    "publicationState": {
      "type": "string",
      "enum": [
        "ready",
        "stale_recoverable",
        "recovery_required"
      ]
    },
    "summaryVisibilityState": {
      "type": "string",
      "enum": [
        "authoritative",
        "provisional",
        "suppressed"
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewVersion",
        "evidenceSnapshotRef",
        "captureBundleRef",
        "evidenceSummaryParityRef",
        "lineageFenceEpoch",
        "decisionEpochRef",
        "decisionSupersessionRef"
      ],
      "properties": {
        "reviewVersion": {
          "type": "integer",
          "minimum": 0
        },
        "evidenceSnapshotRef": {
          "$ref": "#/$defs/id"
        },
        "captureBundleRef": {
          "$ref": "#/$defs/id"
        },
        "evidenceSummaryParityRef": {
          "$ref": "#/$defs/id"
        },
        "lineageFenceEpoch": {
          "type": "integer",
          "minimum": 0
        },
        "decisionEpochRef": {
          "type": [
            "string",
            "null"
          ]
        },
        "decisionSupersessionRef": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "structuredAnswers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "questionId",
          "question",
          "answer",
          "sourceArtifactRefs"
        ],
        "properties": {
          "questionId": {
            "$ref": "#/$defs/id"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "answer": {
            "type": "string",
            "minLength": 1
          },
          "sourceArtifactRefs": {
            "$ref": "#/$defs/stringArray"
          }
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "attachmentRef",
          "label",
          "mediaType",
          "byteLength",
          "previewState",
          "sourceArtifactRef",
          "previewArtifactRef"
        ],
        "properties": {
          "attachmentRef": {
            "$ref": "#/$defs/id"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "byteLength": {
            "type": "integer",
            "minimum": 0
          },
          "previewState": {
            "type": "string",
            "enum": [
              "available",
              "preview_unavailable",
              "summary_only"
            ]
          },
          "sourceArtifactRef": {
            "$ref": "#/$defs/id"
          },
          "previewArtifactRef": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "priorPatientResponses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entryRef",
          "channel",
          "authoredBy",
          "sentAt",
          "summary",
          "authoritativeOutcomeState",
          "deliveryRiskState",
          "sourceArtifactRefs",
          "expectationEnvelopeRef"
        ],
        "properties": {
          "entryRef": {
            "$ref": "#/$defs/id"
          },
          "channel": {
            "type": "string"
          },
          "authoredBy": {
            "type": "string"
          },
          "sentAt": {
            "$ref": "#/$defs/dateTime"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "authoritativeOutcomeState": {
            "type": "string",
            "minLength": 1
          },
          "deliveryRiskState": {
            "type": [
              "string",
              "null"
            ]
          },
          "sourceArtifactRefs": {
            "$ref": "#/$defs/stringArray"
          },
          "expectationEnvelopeRef": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "visibleSuggestionEnvelopeRefs": {
      "$ref": "#/$defs/stringArray"
    },
    "hiddenSuggestionEnvelopeRefs": {
      "$ref": "#/$defs/stringArray"
    },
    "sourceArtifactRefs": {
      "$ref": "#/$defs/stringArray"
    },
    "gapArtifactRefs": {
      "$ref": "#/$defs/stringArray"
    },
    "bundleDigest": {
      "$ref": "#/$defs/id"
    },
    "deltaPacketRef": {
      "$ref": "#/$defs/id"
    },
    "assembledAt": {
      "$ref": "#/$defs/dateTime"
    },
    "requestSummary": {
      "type": "object"
    },
    "patientNarrative": {
      "type": "object"
    },
    "safetyScreening": {
      "type": "object"
    },
    "telephony": {
      "type": "object"
    },
    "transcript": {
      "type": "object"
    },
    "identitySummary": {
      "type": "object"
    },
    "contactPreferenceSummary": {
      "type": "object"
    },
    "duplicateClusterStatus": {
      "type": "object"
    },
    "latestSlaState": {
      "type": "object"
    },
    "deterministicSummary": {
      "type": "object"
    }
  },
  "x-governedInvariants": [
    "ReviewBundle is a read model and may not become mutation authority.",
    "Every rendered bundle must point to one EvidenceSnapshot, one EvidenceCaptureBundle, and one EvidenceSummaryParityRecord.",
    "Unsafe parity may not surface regenerated summary text as authoritative evidence."
  ]
}
