{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/190_recording_fetch_job.schema.json",
  "title": "RecordingFetchJobContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recordingFetchJobRef",
    "schemaVersion",
    "policyVersion",
    "retryPolicyVersion",
    "callSessionRef",
    "providerRecordingRef",
    "canonicalEventRef",
    "idempotencyKey",
    "retryCount",
    "nextRetryAt",
    "timeoutPosture",
    "currentPhase",
    "quarantineAssessmentRef",
    "objectStorageRef",
    "documentReferenceRef",
    "terminalOutcome",
    "terminalOutcomeAt",
    "reasonCodes",
    "createdAt",
    "updatedAt",
    "recordedBy"
  ],
  "properties": {
    "recordingFetchJobRef": { "type": "string", "pattern": "^tel_recording_fetch_job_190_" },
    "schemaVersion": { "const": "190.phase2.recording-ingest.v1" },
    "policyVersion": { "const": "phase2-recording-ingest-190.v1" },
    "retryPolicyVersion": { "const": "phase2-recording-fetch-retry-190.v1" },
    "callSessionRef": { "type": "string", "minLength": 1 },
    "providerRecordingRef": { "type": "string", "minLength": 1 },
    "canonicalEventRef": { "type": "string", "minLength": 1 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "retryCount": { "type": "integer", "minimum": 0 },
    "nextRetryAt": { "type": ["string", "null"], "format": "date-time" },
    "timeoutPosture": {
      "enum": ["within_provider_sla", "retry_backoff_active", "timeout_manual_review", "terminal"]
    },
    "currentPhase": {
      "enum": [
        "scheduled",
        "fetch_pending",
        "fetch_in_progress",
        "fetched_to_quarantine",
        "quarantine_assessed",
        "governed_storage_settled",
        "document_reference_linked",
        "terminal_blocked",
        "terminal_succeeded"
      ]
    },
    "quarantineAssessmentRef": { "type": ["string", "null"] },
    "objectStorageRef": { "type": ["string", "null"] },
    "documentReferenceRef": { "type": ["string", "null"] },
    "terminalOutcome": {
      "enum": [
        "pending",
        "succeeded",
        "recording_missing",
        "provider_unavailable_retryable",
        "corrupt_or_integrity_failed",
        "unsupported_format",
        "malware_or_scan_blocked",
        "size_or_duration_exceeded",
        "provider_ref_mismatch",
        "manual_audio_review_required"
      ]
    },
    "terminalOutcomeAt": { "type": ["string", "null"], "format": "date-time" },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyRecordingIngestPipeline" }
  }
}
