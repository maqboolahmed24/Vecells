{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/189_telephony_candidate_evidence_package.schema.json",
  "title": "TelephonyCandidateEvidencePackage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidencePackageRef",
    "schemaVersion",
    "policyVersion",
    "callSessionRef",
    "routeSensitivity",
    "subjectRef",
    "candidatePatientRef",
    "identityConfidenceAssessmentRef",
    "destinationConfidenceAssessmentRef",
    "captureAttemptRefs",
    "vaultEvidenceRefs",
    "thresholdProfileRef",
    "calibrationVersionRefs",
    "bindingAuthorityName",
    "bindingMutationAuthority",
    "localBindingMutation",
    "reasonCodes",
    "packagedAt"
  ],
  "properties": {
    "evidencePackageRef": { "type": "string", "pattern": "^tcep_" },
    "schemaVersion": { "const": "189.phase2.telephony-verification.v1" },
    "policyVersion": { "const": "phase2-telephony-verification-189.v1" },
    "callSessionRef": { "type": "string" },
    "routeSensitivity": { "type": "string" },
    "subjectRef": { "type": "string" },
    "candidatePatientRef": { "type": "string" },
    "identityConfidenceAssessmentRef": { "type": "string", "pattern": "^tida_" },
    "destinationConfidenceAssessmentRef": { "type": "string", "pattern": "^tdca_" },
    "captureAttemptRefs": { "type": "array", "items": { "type": "string", "pattern": "^tica_" } },
    "vaultEvidenceRefs": { "type": "array", "items": { "type": "string" } },
    "thresholdProfileRef": { "type": "string" },
    "calibrationVersionRefs": { "type": "array", "items": { "type": "string" } },
    "bindingAuthorityName": { "const": "IdentityBindingAuthority" },
    "bindingMutationAuthority": { "const": "IdentityBindingAuthority" },
    "localBindingMutation": { "const": "forbidden" },
    "reasonCodes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TEL_VERIFY_189_" }
    },
    "packagedAt": { "type": "string", "format": "date-time" }
  }
}
