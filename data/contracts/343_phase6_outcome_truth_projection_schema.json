{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PharmacyOutcomeTruthProjection",
  "description": "Audience-safe outcome truth projection derived from ingest attempts, reconciliation gates, and continuity evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pharmacyOutcomeTruthProjectionId",
    "pharmacyCaseId",
    "latestOutcomeSettlementRef",
    "latestOutcomeRecordRef",
    "latestIngestAttemptRef",
    "outcomeReconciliationGateRef",
    "outcomeTruthState",
    "resolutionClass",
    "matchConfidenceBand",
    "contradictionScore",
    "manualReviewState",
    "closeEligibilityState",
    "patientVisibilityState",
    "continuityEvidenceRef",
    "audienceMessageRef",
    "computedAt"
  ],
  "properties": {
    "pharmacyOutcomeTruthProjectionId": {
      "type": "string",
      "minLength": 1,
      "description": "Outcome truth projection identifier."
    },
    "pharmacyCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning pharmacy case identifier."
    },
    "latestOutcomeSettlementRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "description": "Latest outcome settlement reference.",
          "properties": {
            "targetFamily": {
              "const": "PharmacyOutcomeSettlement"
            },
            "refId": {
              "type": "string",
              "minLength": 1
            },
            "ownerTask": {
              "const": "seq_343"
            }
          },
          "required": [
            "targetFamily",
            "refId",
            "ownerTask"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Latest outcome settlement reference."
    },
    "latestOutcomeRecordRef": {
      "type": "string",
      "minLength": 1,
      "description": "Latest outcome record reference."
    },
    "latestIngestAttemptRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "description": "Latest ingest attempt reference.",
          "properties": {
            "targetFamily": {
              "const": "PharmacyOutcomeIngestAttempt"
            },
            "refId": {
              "type": "string",
              "minLength": 1
            },
            "ownerTask": {
              "const": "seq_343"
            }
          },
          "required": [
            "targetFamily",
            "refId",
            "ownerTask"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Latest ingest attempt reference."
    },
    "outcomeReconciliationGateRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "description": "Outcome reconciliation gate reference.",
          "properties": {
            "targetFamily": {
              "const": "PharmacyOutcomeReconciliationGate"
            },
            "refId": {
              "type": "string",
              "minLength": 1
            },
            "ownerTask": {
              "const": "seq_343"
            }
          },
          "required": [
            "targetFamily",
            "refId",
            "ownerTask"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Outcome reconciliation gate reference."
    },
    "outcomeTruthState": {
      "type": "string",
      "enum": [
        "waiting_for_outcome",
        "review_required",
        "resolved_pending_projection",
        "reopened_for_safety",
        "unmatched",
        "duplicate_ignored",
        "settled_resolved"
      ],
      "description": "Outcome truth state."
    },
    "resolutionClass": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "advice_only",
            "medicine_supplied",
            "resolved_no_supply",
            "onward_referral",
            "urgent_gp_action",
            "unable_to_contact",
            "pharmacy_unable_to_complete",
            "unmatched"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Resolution class."
    },
    "matchConfidenceBand": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "description": "Match confidence band."
    },
    "contradictionScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Contradiction score."
    },
    "manualReviewState": {
      "type": "string",
      "enum": [
        "none",
        "required",
        "in_review",
        "approved_apply",
        "approved_reopen",
        "approved_unmatched"
      ],
      "description": "Manual review state."
    },
    "closeEligibilityState": {
      "type": "string",
      "enum": [
        "blocked_by_reconciliation",
        "blocked_by_safety",
        "eligible_pending_projection",
        "not_closable"
      ],
      "description": "Close eligibility state."
    },
    "patientVisibilityState": {
      "type": "string",
      "enum": [
        "review_placeholder",
        "recovery_required",
        "quiet_result",
        "hidden"
      ],
      "description": "Patient visibility state."
    },
    "continuityEvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "description": "Continuity evidence reference.",
      "properties": {
        "targetFamily": {
          "const": "PharmacyContinuityEvidenceProjection"
        },
        "refId": {
          "type": "string",
          "minLength": 1
        },
        "ownerTask": {
          "const": "seq_343"
        }
      },
      "required": [
        "targetFamily",
        "refId",
        "ownerTask"
      ]
    },
    "audienceMessageRef": {
      "type": "string",
      "minLength": 1,
      "description": "Audience message reference."
    },
    "computedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Computation timestamp."
    }
  },
  "x-vecells-task-id": "seq_343_phase6_freeze_directory_discovery_referral_dispatch_and_outcome_reconciliation_contracts",
  "x-vecells-contract-version": "343.phase6.discovery-dispatch-outcome-freeze.v1"
}
