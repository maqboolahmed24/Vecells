{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/170_capability_decision.schema.json",
  "title": "CapabilityDecision",
  "description": "Canonical route capability decision envelope emitted by the CapabilityDecisionEngine. It never mutates IdentityBinding and cannot raise authority state above the declared ceilings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capabilityDecisionId",
    "schemaVersion",
    "policyVersion",
    "routeProfileRef",
    "identityContextRef",
    "decision",
    "writableAuthorityState",
    "maxGrantCeiling",
    "reasonCodes",
    "decisionInputs",
    "evaluatedAt"
  ],
  "properties": {
    "capabilityDecisionId": {
      "type": "string",
      "pattern": "^cdx_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "170.phase2.trust.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-trust-v[0-9]+$"
    },
    "routeProfileRef": {
      "type": "string"
    },
    "identityContextRef": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "step_up_required", "recover_only", "deny"]
    },
    "writableAuthorityState": {
      "type": "string",
      "enum": ["writable", "read_only", "blocked"]
    },
    "maxGrantCeiling": {
      "type": "string",
      "enum": [
        "none",
        "draft_lease_only",
        "continuation_recovery_only",
        "authenticated_draft_only",
        "request_status_read",
        "request_attachment_write",
        "future_denied"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^CAP_170_[A-Z0-9_]+$"
      }
    },
    "decisionInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identitySource",
        "verificationLevel",
        "patientLinkPosture",
        "freshnessState",
        "policyRestrictions"
      ],
      "properties": {
        "identitySource": {
          "type": "string"
        },
        "verificationLevel": {
          "type": "string"
        },
        "patientLinkPosture": {
          "type": "string"
        },
        "freshnessState": {
          "type": "string",
          "enum": ["fresh", "stale", "expired", "future_placeholder"]
        },
        "policyRestrictions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "routeProfileLifecycle": {
          "type": "string"
        }
      }
    },
    "identityBindingMutation": {
      "type": "string",
      "enum": ["none", "authority_signal_only"]
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
