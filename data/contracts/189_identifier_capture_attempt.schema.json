{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/189_identifier_capture_attempt.schema.json",
  "title": "TelephonyIdentifierCaptureAttempt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "captureAttemptRef",
    "schemaVersion",
    "policyVersion",
    "callSessionRef",
    "routeSensitivity",
    "fieldFamily",
    "captureOrderIndex",
    "captureSource",
    "validationResult",
    "normalizedValueHash",
    "vaultEvidenceRef",
    "maskedFragment",
    "evidenceEnvelopeRef",
    "idempotencyKey",
    "reasonCodes",
    "capturedAt",
    "recordedBy"
  ],
  "properties": {
    "captureAttemptRef": { "type": "string", "pattern": "^tica_" },
    "schemaVersion": { "const": "189.phase2.telephony-verification.v1" },
    "policyVersion": { "const": "phase2-telephony-verification-189.v1" },
    "callSessionRef": { "type": "string" },
    "routeSensitivity": { "type": "string" },
    "fieldFamily": {
      "enum": [
        "nhs_number",
        "date_of_birth",
        "surname",
        "postcode",
        "caller_id_hint",
        "verified_callback",
        "handset_step_up_proof",
        "ivr_consistency",
        "operator_correction"
      ]
    },
    "captureOrderIndex": { "type": "integer", "minimum": 1, "maximum": 9 },
    "captureSource": {
      "enum": ["ivr", "speech", "operator", "provider_callback", "handset_step_up", "system"]
    },
    "validationResult": {
      "enum": [
        "valid",
        "invalid_format",
        "unsupported_family",
        "operator_correction_recorded",
        "contradictory_identifier"
      ]
    },
    "normalizedValueHash": {
      "description": "Only a hash of the normalized captured value; the raw identifier is vaulted.",
      "type": ["string", "null"],
      "pattern": "^sha256:"
    },
    "vaultEvidenceRef": { "type": ["string", "null"] },
    "vaultRef": { "type": ["string", "null"] },
    "maskedFragment": { "type": "string" },
    "evidenceEnvelopeRef": { "type": ["string", "null"] },
    "relatedCandidateSetRef": { "type": ["string", "null"] },
    "idempotencyKey": { "type": "string" },
    "reasonCodes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TEL_VERIFY_189_" },
      "minItems": 1
    },
    "capturedAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyVerificationPipeline" }
  }
}
