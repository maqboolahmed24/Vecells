{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_return_intent_schema.json",
  "title": "ReturnIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "returnIntentId",
    "postAuthRoute",
    "postAuthParams",
    "embeddedState",
    "fallbackAppPage",
    "submissionEnvelopeRef",
    "submissionPromotionRecordRef",
    "draftLeaseRef",
    "draftContinuityEvidenceRef",
    "subjectRef",
    "sessionEpochRef",
    "subjectBindingVersionRef",
    "manifestVersionRef",
    "routeFamilyRef",
    "minimumBridgeCapabilitiesRef",
    "lineageFenceEpoch",
    "releaseApprovalFreezeRef",
    "continuityEvidenceRef",
    "routeFreezeDispositionRef",
    "expiresAt",
    "intentState"
  ],
  "properties": {
    "returnIntentId": {
      "type": "string"
    },
    "postAuthRoute": {
      "type": "string"
    },
    "postAuthParams": {
      "type": "object"
    },
    "embeddedState": {
      "type": "string",
      "enum": ["embedded", "standalone", "recovery"]
    },
    "fallbackAppPage": {
      "type": "string",
      "enum": ["HOME_PAGE", "SERVICES", "YOUR_HEALTH", "MESSAGES", "UPLIFT", "ACCOUNT", "GO_BACK"]
    },
    "submissionEnvelopeRef": {
      "type": ["string", "null"]
    },
    "submissionPromotionRecordRef": {
      "type": ["string", "null"]
    },
    "draftLeaseRef": {
      "type": ["string", "null"]
    },
    "draftContinuityEvidenceRef": {
      "type": ["string", "null"]
    },
    "subjectRef": {
      "type": "string"
    },
    "sessionEpochRef": {
      "type": "string"
    },
    "subjectBindingVersionRef": {
      "type": "string"
    },
    "manifestVersionRef": {
      "type": "string"
    },
    "routeFamilyRef": {
      "type": "string"
    },
    "minimumBridgeCapabilitiesRef": {
      "type": "string"
    },
    "lineageFenceEpoch": {
      "type": "string"
    },
    "releaseApprovalFreezeRef": {
      "type": "string"
    },
    "continuityEvidenceRef": {
      "type": "string"
    },
    "routeFreezeDispositionRef": {
      "type": "string"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "intentState": {
      "type": "string",
      "enum": ["pending", "consumed", "superseded", "recovered", "denied"]
    }
  }
}
