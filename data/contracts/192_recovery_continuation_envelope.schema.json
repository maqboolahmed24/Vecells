{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/192_recovery_continuation_envelope.schema.json",
  "title": "RecoveryContinuationEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recoveryContinuationRef",
    "schemaVersion",
    "policyVersion",
    "continuationContextRef",
    "callSessionRef",
    "lineageScope",
    "routeFamilyRef",
    "routeIntentRef",
    "resumeObjectRef",
    "requestSeedRef",
    "returnContractRef",
    "patientShellConsistencyRef",
    "shellContinuityKey",
    "selectedMobileStep",
    "patientActionRecoveryEnvelopeRef",
    "sameShellRequired",
    "recoveryReasonCode",
    "recoveryTupleHash",
    "reasonCodes",
    "issuedAt",
    "expiresAt",
    "recordedBy"
  ],
  "properties": {
    "recoveryContinuationRef": {
      "type": "string",
      "pattern": "^rct_192_"
    },
    "schemaVersion": {
      "const": "192.phase2.telephony-continuation.v1"
    },
    "policyVersion": {
      "const": "phase2-telephony-continuation-recovery-192.v1"
    },
    "continuationContextRef": {
      "type": "string"
    },
    "callSessionRef": {
      "type": "string"
    },
    "lineageScope": {
      "type": "string",
      "enum": ["same_submission_envelope", "same_request_lineage", "none"]
    },
    "routeFamilyRef": {
      "type": ["string", "null"]
    },
    "routeIntentRef": {
      "type": ["string", "null"]
    },
    "resumeObjectRef": {
      "type": ["string", "null"]
    },
    "requestSeedRef": {
      "type": ["string", "null"]
    },
    "returnContractRef": {
      "type": "string"
    },
    "patientShellConsistencyRef": {
      "type": "string"
    },
    "shellContinuityKey": {
      "type": "string"
    },
    "selectedMobileStep": {
      "type": "string",
      "enum": ["identity_challenge", "contact_route_repair", "stale_link_recovery"]
    },
    "patientActionRecoveryEnvelopeRef": {
      "type": ["string", "null"]
    },
    "sameShellRequired": {
      "const": true
    },
    "recoveryReasonCode": {
      "type": "string"
    },
    "recoveryTupleHash": {
      "type": "string"
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedBy": {
      "const": "TelephonyContinuationGrantService"
    }
  }
}
