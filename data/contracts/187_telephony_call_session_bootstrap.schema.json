{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/187_telephony_call_session_bootstrap.schema.json",
  "title": "TelephonyEdgeCallSession",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "callSessionRef",
    "providerCallRef",
    "callState",
    "menuSelection",
    "maskedCallerRef",
    "maskedCallerFragment",
    "recordingRefs",
    "urgentLiveAssessmentRef",
    "firstEventRef",
    "lastEventRef",
    "stateRevision",
    "reasonCodes",
    "createdAt",
    "updatedAt",
    "createdByAuthority"
  ],
  "properties": {
    "callSessionRef": { "type": "string", "pattern": "^call_session_187_" },
    "providerCallRef": { "type": "string", "pattern": "^provider_call_187_" },
    "callState": {
      "enum": [
        "initiated",
        "menu_selected",
        "recording_expected",
        "recording_available",
        "provider_error",
        "abandoned",
        "continuation_sent"
      ]
    },
    "menuSelection": {
      "type": ["string", "null"],
      "enum": ["symptoms", "medications", "admin", "results", "unknown", null]
    },
    "maskedCallerRef": { "type": ["string", "null"] },
    "maskedCallerFragment": { "type": ["string", "null"] },
    "recordingRefs": { "type": "array", "items": { "type": "string" } },
    "urgentLiveAssessmentRef": {
      "type": "string",
      "pattern": "^tel_urgent_live_assessment_187_"
    },
    "firstEventRef": { "type": "string", "pattern": "^tel_evt_187_" },
    "lastEventRef": { "type": "string", "pattern": "^tel_evt_187_" },
    "stateRevision": { "type": "integer", "minimum": 1 },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "createdByAuthority": { "const": "TelephonyWebhookWorker" }
  }
}
