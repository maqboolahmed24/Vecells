{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/173_manual_review_disposition.schema.json",
  "title": "TelephonyManualReviewDisposition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "telephonyManualReviewDispositionId",
    "callSessionRef",
    "triggerClass",
    "reviewMode",
    "reviewState",
    "closureBlocking",
    "routinePromotionBlocked",
    "reasonCodes",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "173.phase2.telephony.manual-review-disposition.v1"
    },
    "telephonyManualReviewDispositionId": {
      "type": "string",
      "pattern": "^tel_mrd_[A-Za-z0-9_:-]+$"
    },
    "callSessionRef": {
      "type": "string"
    },
    "triggerClass": {
      "type": "string",
      "enum": [
        "recording_missing",
        "transcript_degraded",
        "contradictory_capture",
        "identity_ambiguous",
        "handset_untrusted",
        "urgent_live_without_routine_evidence"
      ]
    },
    "reviewMode": {
      "type": "string",
      "enum": [
        "audio_review",
        "callback_required",
        "staff_transcription",
        "follow_up_needed",
        "abandon"
      ]
    },
    "reviewState": {
      "type": "string",
      "enum": ["open", "assigned", "settled", "superseded"]
    },
    "closureBlocking": {
      "type": "boolean"
    },
    "routinePromotionBlocked": {
      "const": true
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "settledAt": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
