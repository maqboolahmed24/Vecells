{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/374_phase7_service_desk_profile_schema.json",
  "title": "ServiceDeskProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "serviceDeskProfileId",
    "publicFacingContactMethods",
    "documentedSupportHours",
    "majorIncidentContactPath",
    "clinicalSafetyContactRef",
    "serviceManagementProtocolRef",
    "lastReviewedAt"
  ],
  "properties": {
    "serviceDeskProfileId": {
      "type": "string",
      "minLength": 1
    },
    "publicFacingContactMethods": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "documentedSupportHours": {
      "type": "string",
      "minLength": 1
    },
    "majorIncidentContactPath": {
      "type": "string",
      "minLength": 1
    },
    "clinicalSafetyContactRef": {
      "type": "string",
      "minLength": 1
    },
    "serviceManagementProtocolRef": {
      "type": "string",
      "minLength": 1
    },
    "lastReviewedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
