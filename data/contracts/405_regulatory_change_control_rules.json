  "failClosedRules": [
    "unclassified change types route as regulatory_posture_change",
    "unknown medical-purpose boundary sets mhraAssessmentRequired and medicalDeviceReassessmentRequired true",
    "unknown IM1 impact sets im1RfcRequired and scalUpdateRequired true",
    "unknown data processing impact sets dpiaDeltaRequired true",
    "unknown clinical safety impact sets dcb0129DeltaRequired and dcb0160DependencyNoteRequired true"
  ],
  "invariants": [
    {
      "invariantId": "INV405_REG_001",
      "statement": "A material AI or significant functional enhancement must route through the IM1 RFC decision path."
    },
    {
      "invariantId": "INV405_REG_002",
      "statement": "DTAC delta decisions are alongside, not a replacement for, DCB, DPIA, IM1, or medical-device decisions."
    },
    {
      "invariantId": "INV405_REG_003",
      "statement": "Regulatory uncertainty blocks promotion until a resolved RegulatoryChangeDecision exists."
    }
  ]
