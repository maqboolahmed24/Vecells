{
  "taskId": "par_405",
  "schemaVersion": "405.regulatory-change-control-rules.v1",
  "contractFamily": "assistive_release_regulatory_change_control",
  "sourceReleaseCandidateContractRef": "data/contracts/405_assistive_release_candidate_contracts.json",
  "sourceGateRef": "data/contracts/403_phase8_track_readiness_registry.json",
  "launchPacketRef": "data/launchpacks/403_track_launch_packet_405.json",
  "ownedBy": "assistive_regulatory_trigger_rules",
  "decisionOutputs": [
    "im1RfcRequired",
    "scalUpdateRequired",
    "dtacDeltaRequired",
    "dcb0129DeltaRequired",
    "dcb0160DependencyNoteRequired",
    "dpiaDeltaRequired",
    "mhraAssessmentRequired",
    "medicalDeviceReassessmentRequired"
  ],
  "objectContracts": [
    {
      "objectName": "RFCBundle",
      "objectRole": "IM1 request-for-change evidence package for material AI or functional change",
      "requiredFields": [
        "rfcBundleId",
        "im1ProductRef",
        "changeRequestId",
        "releaseCandidateRef",
        "SCALDeltaRef",
        "safetyCaseDeltaRef",
        "documentationRefs",
        "evidenceBaselineRef",
        "approvalGraphRef",
        "submissionState",
        "expiresAt"
      ],
      "states": ["not_required", "draft", "ready_for_submission", "submitted", "accepted", "rejected", "expired", "superseded"],
      "dependencyRules": [
        "ready_for_submission requires a complete ChangeImpactAssessment and candidateHash",
        "submitted requires approvalGraphRef with required pre-submission signoffs",
        "expired blocks promotion until refreshed or explicitly not_required by a new impact assessment"
      ]
    },
    {
      "objectName": "RegulatoryTriggerRule",
      "objectRole": "published rule mapping change evidence to regulatory decision outputs",
      "requiredFields": [
        "triggerRuleId",
        "changeType",
        "boundaryState",
        "inputSignals",
        "decisionOutputs",
        "minimumEvidenceRefs",
        "approvalProfileRef",
        "failClosedDefault",
        "ruleState"
      ],
      "states": ["draft", "published", "superseded", "withdrawn"],
      "dependencyRules": [
        "published rules are immutable",
        "withdrawn rules cause ChangeImpactAssessment blocked until a replacement is published",
        "failClosedDefault must be true for all AI, intended-use, endpoint, and regulatory posture changes"
      ]
    },
    {
      "objectName": "RegulatoryChangeDecision",
      "objectRole": "resolved machine-readable regulatory trigger decision for one impact assessment",
      "requiredFields": [
        "regulatoryChangeDecisionId",
        "impactAssessmentRef",
        "triggerRuleRefs",
        "im1RfcRequired",
        "scalUpdateRequired",
        "dtacDeltaRequired",
        "dcb0129DeltaRequired",
        "dcb0160DependencyNoteRequired",
        "dpiaDeltaRequired",
        "mhraAssessmentRequired",
        "medicalDeviceReassessmentRequired",
        "decisionState",
        "blockingReasonCodes"
      ],
      "states": ["pending", "resolved", "blocked", "superseded"],
      "dependencyRules": [
        "blocked must be emitted when any trigger cannot be classified",
        "resolved true outputs must appear in RFCBundle, SafetyCaseDelta, MedicalDeviceAssessmentRef, or ReleaseApprovalGraph as applicable",
        "decisionState resolved is required before approval graph can be satisfied"
      ]
    },
    {
      "objectName": "ProductDocumentationDelta",
      "objectRole": "versioned documentation delta for SCAL, DTAC, safety, DPIA, medical-device, and product wording packs",
      "requiredFields": [
        "productDocumentationDeltaId",
        "releaseCandidateRef",
        "changedDocumentRefs",
        "newDocumentRefs",
        "obsoleteDocumentRefs",
        "documentationClass",
        "reviewOwnerRole",
        "approvalGraphRef",
        "documentationState"
      ],
      "states": ["draft", "review_ready", "approved", "blocked", "superseded"],
      "dependencyRules": [
        "documentationClass must map to at least one decision output",
        "approved documentation deltas must bind to the candidateHash",
        "blocked documentation deltas force promotion_blocked"
      ]
    }
  ],
  "triggerMatrix": [
    {
      "changeType": "template_copy_only_no_behavior",
