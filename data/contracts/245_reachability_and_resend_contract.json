{
  "schemaVersion": "245.phase3.communication-repair.v1",
  "serviceName": "Phase3CommunicationReachabilityRepairApplication",
  "querySurfaces": [
    "GET /v1/workspace/tasks/{taskId}/communication-repair"
  ],
  "authorizationKinds": [
    "controlled_resend",
    "channel_change",
    "attachment_recovery",
    "callback_reschedule"
  ],
  "bindingStates": [
    "monitoring",
    "repair_required",
    "awaiting_verification",
    "rebound_pending",
    "clear"
  ],
  "repairGrantActionScope": "contact_route_repair",
  "requiredRoutes": [
    "workspace_task_communication_repair_current",
    "workspace_task_record_callback_reachability",
    "workspace_task_record_message_reachability",
    "workspace_task_attach_contact_route_candidate",
    "workspace_task_issue_contact_route_verification",
    "workspace_task_settle_contact_route_verification",
    "workspace_task_authorize_message_repair_action",
    "workspace_task_authorize_callback_reschedule"
  ],
  "dominantFailureObservations": [
    "bounce",
    "invalid_route",
    "no_answer",
    "preference_change",
    "demographic_change",
    "manual_dispute",
    "verification_failure"
  ]
}
