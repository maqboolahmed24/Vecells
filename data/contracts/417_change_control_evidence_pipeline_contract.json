{
  "taskId": "par_417",
  "schemaVersion": "417.change-control-evidence-pipeline.v1",
  "packageName": "@vecells/domain-assistive-assurance",
  "services": [
    {
      "serviceName": "ChangeImpactAssessmentService",
      "owns": ["ChangeImpactAssessment", "ModelChangeRequest"],
      "contract": "Classifies material assistive changes from real surface, workflow, rollout, disclosure, intended-use, artifact, and medical-purpose deltas."
    },
    {
      "serviceName": "RFCBundleAssembler",
      "owns": ["RFCBundle"],
      "contract": "Assembles RFC evidence without treating IM1 pairing as AI-specific technical assurance."
    },
    {
      "serviceName": "AssuranceBaselineSnapshotService",
      "owns": [
        "AssuranceBaselineSnapshot",
        "SubprocessorAssuranceRef",
        "MedicalDeviceAssessmentRef",
        "SafetyCaseDelta"
      ],
      "contract": "Pins guidance, SCAL, DTAC, DCB, DPIA, supplier, medical-device, evaluation, replay, disclosure, and safety-delta baselines."
    },
    {
      "serviceName": "ReleaseApprovalGraphService",
      "owns": ["ReleaseApprovalGraph"],
      "contract": "Enforces no-self-approval, independent safety review, and trigger-derived approval roles."
    },
    {
      "serviceName": "RollbackReadinessBundleService",
      "owns": ["RollbackReadinessBundle"],
      "contract": "Requires rollback target, data and policy compatibility, kill switch plan, runtime publication parity, runbook, and verification evidence."
    },
    {
      "serviceName": "AssuranceFreezeStateService",
      "owns": ["AssuranceFreezeState"],
      "contract": "Maintains assurance freeze posture when baselines, supplier assurance, approvals, or rollback readiness drift."
    },
    {
      "serviceName": "AssistiveReleaseActionService",
      "owns": ["AssistiveReleaseActionRecord", "AssistiveReleaseActionSettlement"],
      "contract": "Records and settles approve, promote, freeze, unfreeze, and rollback actions against exact candidate hashes and evidence tuples."
    },
    {
      "serviceName": "AssistiveRegulatoryEvidenceExporter",
      "owns": ["AssistiveRegulatoryEvidenceExport"],
      "contract": "Exports RFC, approval, rollback, and runbook evidence only through governed artifact presentation and outbound navigation refs."
    }
  ],
  "persistedObjects": [
    "ModelChangeRequest",
    "ChangeImpactAssessment",
    "RFCBundle",
    "SubprocessorAssuranceRef",
    "MedicalDeviceAssessmentRef",
    "SafetyCaseDelta",
    "AssuranceBaselineSnapshot",
    "ReleaseApprovalGraph",
    "RollbackReadinessBundle",
    "AssuranceFreezeState",
    "AssistiveReleaseActionRecord",
    "AssistiveReleaseActionSettlement",
    "AssistiveRegulatoryEvidenceExport",
    "AssistiveAssuranceAuditRecord"
  ],
  "changeClassificationPolicy": {
    "allowedClasses": [
      "copy_template_only",
      "prompt_or_threshold",
      "model_version",
      "subprocessor_or_inference_host",
      "capability_expansion",
      "intended_use",
      "regulatory_posture"
    ],
    "realDeltaInputs": [
      "surfaceDeltaRefs",
      "surfacePublicationDeltaRefs",
      "rolloutLadderDelta",
      "rolloutSliceDeltaRefs",
      "workflowDecisionDelta",
      "artifactDeliveryDelta",
      "uiTelemetryDisclosureDelta",
      "intendedUseDelta",
      "patientFacingWordingDelta",
      "medicalPurposeBoundaryState"
    ],
    "copyTemplateOnlyBlockers": [
      "copy_template_only_claim_has_material_delta",
      "copy_template_only_requires_stable_candidate_hash"
    ]
  },
  "regulatoryTriggerPolicy": {
    "im1AndScalTriggers": [
      "model_version",
      "capability_expansion",
      "intended_use",
      "regulatory_posture",
      "workflowDecisionDelta",
      "rolloutLadderDelta",
      "artifactDeliveryDelta"
    ],
    "dtacAreas": [
      "clinical_safety",
      "data_protection",
      "technical_security",
      "interoperability",
      "usability_accessibility"
    ],
    "dcbTriggers": [
      "workflowDecisionDelta",
      "medicalPurposeBoundaryState",
      "artifactDeliveryDelta"
    ],
    "dpiaTriggers": [
      "subprocessor_or_inference_host",
      "model_version",
      "uiTelemetryDisclosureDelta",
      "artifactDeliveryDelta"
    ],
    "mhraTriggers": [
      "intended_use",
      "regulatory_posture",
      "endpoint_suggestion_clinically_consequential_decision_support"
    ],
    "localTechnicalAssuranceIsSeparateFromIM1": true
  },
  "baselinePolicy": {
    "requiredRefs": [
      "im1GuidanceVersionRef",
      "dtacVersionRef",
      "dcbStandardVersionRef",
      "dpiaRef",
      "scalVersionRef",
      "medicalDeviceAssessmentRef",
      "evaluationDatasetRef",
      "replayHarnessVersionRef",
      "supplierAssuranceRefs",
      "disclosureBaselineRef",
      "safetyCaseDeltaRef"
    ],
    "staleStatesBlockPromotion": ["stale", "superseded", "withdrawn"],
    "supplierStatesThatFreeze": ["stale", "drifted", "suspended", "withdrawn"]
  },
  "approvalPolicy": {
    "requiredBaseRoles": ["product_owner", "deployment_approver", "independent_safety_reviewer"],
    "triggeredRoles": [
      "clinical_safety_officer",
      "information_governance_lead",
      "regulatory_owner",
      "rollback_owner"
    ],
    "noSelfApproval": true,
    "independentSafetyReviewRequired": true
  },
  "releaseActionPolicy": {
    "allowedActions": ["approve", "promote", "freeze", "unfreeze", "rollback"],
    "exactTupleMembers": [
      "releaseCandidateHash",
      "baselineSnapshotHash",
      "runtimePublicationBundleRef",
      "uiTelemetryDisclosureBaselineRef",
      "rollbackBundleHash",
      "rolloutSliceContractRef",
      "rolloutVerdictRef",
      "releaseRecoveryDispositionRef"
    ],
    "promotionBlockers": [
      "baseline_stale",
      "supplier_assurance_drifted",
      "approval_graph_not_satisfied",
      "rollback_bundle_not_ready",
      "assurance_freeze_active"
    ]
  },
  "laterConsumers": ["418", "427", "428", "429", "430", "431", "440"],
  "invariants": [
    {
      "code": "change_impact_from_real_deltas",
      "description": "Change impact is derived from typed deltas, not manual checkboxes alone."
    },
    {
      "code": "exact_regulatory_trigger_routing",
      "description": "Regulatory triggers are explicit booleans with exact blocker codes."
    },
    {
      "code": "im1_not_ai_specific_technical_assurance",
      "description": "IM1 packaging remains separate from local AI model technical assurance."
    },
    {
      "code": "baseline_snapshot_pins_guidance_versions",
      "description": "Baselines pin IM1, DTAC, DCB, SCAL, DPIA, medical-device, evaluation, replay, supplier, disclosure, and safety evidence refs."
    },
    {
      "code": "stale_baseline_blocks_promotion",
      "description": "Stale, superseded, or withdrawn baselines block promotion."
    },
    {
      "code": "no_self_approval_and_independent_safety_review",
      "description": "A requester cannot approve their own change and an independent safety reviewer is mandatory."
    },
    {
      "code": "rollback_readiness_required_for_promotion",
      "description": "Promotion requires compatible rollback target, kill switch, runbook, parity, and verification proof."
    },
    {
      "code": "release_actions_bind_exact_candidate_hashes",
      "description": "Approve, promote, freeze, unfreeze, and rollback bind exact candidate hash and evidence tuple hashes."
    },
    {
      "code": "supplier_drift_opens_assurance_freeze",
      "description": "Supplier or subprocessor stale, drifted, suspended, or withdrawn states create assurance freeze blockers."
    },
    {
      "code": "governed_evidence_exports_only",
      "description": "Evidence exports are governed artifacts with artifact-presentation and outbound-navigation refs."
    },
    {
      "code": "medical_device_boundary_reassessment_required",
      "description": "Medical-purpose and intended-use boundary changes require MHRA or medical-device reassessment flags."
    },
    {
      "code": "approval_graph_covers_all_active_triggers",
      "description": "Approval roles expand from active regulatory, safety, IG, and rollback triggers."
    }
  ]
}
