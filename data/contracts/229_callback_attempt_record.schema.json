{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_callback_attempt_record.schema.json",
  "title": "229 CallbackAttemptRecord",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "attemptId",
    "callbackCaseRef",
    "callbackIntentLeaseRef",
    "requestLifecycleLeaseRef",
    "attemptOrdinal",
    "attemptFenceEpoch",
    "ownershipEpochRef",
    "fencingToken",
    "dialTargetRef",
    "channelProviderRef",
    "commandActionRecordRef",
    "idempotencyRecordRef",
    "adapterDispatchAttemptRef",
    "latestReceiptCheckpointRef",
    "initiatedAt",
    "settlementState",
    "idempotencyKey"
  ],
  "properties": {
    "attemptId": {
      "$ref": "#/$defs/id"
    },
    "callbackCaseRef": {
      "$ref": "#/$defs/id"
    },
    "callbackIntentLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "requestLifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "attemptOrdinal": {
      "type": "integer",
      "minimum": 1
    },
    "attemptFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "ownershipEpochRef": {
      "$ref": "#/$defs/id"
    },
    "fencingToken": {
      "$ref": "#/$defs/id"
    },
    "dialTargetRef": {
      "$ref": "#/$defs/id"
    },
    "channelProviderRef": {
      "$ref": "#/$defs/id"
    },
    "commandActionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "idempotencyRecordRef": {
      "$ref": "#/$defs/id"
    },
    "adapterDispatchAttemptRef": {
      "$ref": "#/$defs/id"
    },
    "latestReceiptCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "initiatedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "settlementState": {
      "type": "string",
      "enum": [
        "initiated",
        "provider_acked",
        "outcome_pending",
        "settled",
        "reconcile_required"
      ]
    },
    "idempotencyKey": {
      "$ref": "#/$defs/id"
    }
  },
  "x-governedInvariants": [
    "CallbackAttemptRecord is the idempotent and exclusive callback attempt fence.",
    "Duplicate taps, retries, or provider callbacks on the same attempt fence must reuse this record instead of emitting a second live callback outcome."
  ]
}
