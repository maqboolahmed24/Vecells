{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/192_continuation_redemption_outcome.schema.json",
  "title": "ContinuationRedemptionOutcome",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "continuationRedemptionOutcomeRef",
    "redemptionIdempotencyKey",
    "schemaVersion",
    "policyVersion",
    "callSessionRef",
    "continuationContextRef",
    "accessGrantRef",
    "grantRedemptionRef",
    "redemptionState",
    "replayed",
    "secureLinkSessionRef",
    "secureLinkSessionProjectionRef",
    "recoveryContinuationRef",
    "routeIntentBindingRef",
    "csrfSecretRef",
    "grantTokenReuseBlocked",
    "reasonCodes",
    "redeemedAt",
    "recordedBy"
  ],
  "properties": {
    "continuationRedemptionOutcomeRef": {
      "type": "string",
      "pattern": "^tcro_"
    },
    "redemptionIdempotencyKey": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "192.phase2.telephony-continuation.v1"
    },
    "policyVersion": {
      "const": "phase2-telephony-continuation-grants-192.v1"
    },
    "callSessionRef": {
      "type": "string"
    },
    "continuationContextRef": {
      "type": ["string", "null"]
    },
    "accessGrantRef": {
      "type": ["string", "null"]
    },
    "grantRedemptionRef": {
      "type": ["string", "null"]
    },
    "redemptionState": {
      "type": "string",
      "enum": [
        "session_established",
        "replay_returned",
        "step_up_interrupted",
        "stale_link_recovery",
        "superseded_recovery",
        "denied"
      ]
    },
    "replayed": {
      "type": "boolean"
    },
    "secureLinkSessionRef": {
      "type": ["string", "null"]
    },
    "secureLinkSessionProjectionRef": {
      "type": ["string", "null"]
    },
    "recoveryContinuationRef": {
      "type": ["string", "null"]
    },
    "routeIntentBindingRef": {
      "type": ["string", "null"]
    },
    "csrfSecretRef": {
      "type": ["string", "null"]
    },
    "grantTokenReuseBlocked": {
      "const": true
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "redeemedAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedBy": {
      "const": "TelephonyContinuationGrantService"
    }
  }
}
