{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_channel_context_schema.json",
  "title": "ChannelContextAndEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["channelContext", "channelContextEvidence", "embeddedEntryToken"],
  "properties": {
    "channelContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channelType",
        "entryMode",
        "trustTier",
        "resolutionDisposition",
        "isEmbedded",
        "userAgentEvidence",
        "queryEvidence",
        "signedContextEvidence",
        "assertedIdentityPresent",
        "deepLinkPresent",
        "jumpOffSource",
        "channelConfidence"
      ],
      "properties": {
        "channelType": {
          "type": "string",
          "enum": ["standalone_web", "nhs_app_webview", "secure_link", "unknown"]
        },
        "entryMode": {
          "type": "string",
          "enum": [
            "jump_off",
            "site_link",
            "deep_link",
            "post_auth_return",
            "direct_browser",
            "recovery"
          ]
        },
        "trustTier": {
          "type": "string",
          "enum": [
            "trusted_embedded",
            "verified_sso_embedded",
            "hinted_embedded",
            "standalone_or_unknown"
          ]
        },
        "resolutionDisposition": {
          "type": "string",
          "enum": [
            "embedded_live",
            "embedded_revalidate_only",
            "embedded_styling_only",
            "standalone",
            "safe_browser_handoff",
            "bounded_recovery",
            "blocked"
          ]
        },
        "isEmbedded": {
          "type": "boolean"
        },
        "userAgentEvidence": {
          "type": "object"
        },
        "queryEvidence": {
          "type": "object"
        },
        "signedContextEvidence": {
          "type": ["object", "null"]
        },
        "assertedIdentityPresent": {
          "type": "boolean"
        },
        "deepLinkPresent": {
          "type": "boolean"
        },
        "jumpOffSource": {
          "type": ["string", "null"]
        },
        "channelConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "channelContextEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceId",
        "source",
        "observedAt",
        "expiresAt",
        "nonce",
        "signatureState",
        "requestedShell",
        "expectedJourneyPath",
        "cohortRef"
      ],
      "properties": {
        "evidenceId": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "signed_entry_token",
            "validated_sso",
            "user_agent",
            "query_hint",
            "bridge_detection"
          ]
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "nonce": {
          "type": "string"
        },
        "signatureState": {
          "type": "string",
          "enum": ["valid", "missing", "invalid", "expired", "not_applicable"]
        },
        "requestedShell": {
          "type": "string",
          "enum": ["embedded", "standalone", "recovery"]
        },
        "expectedJourneyPath": {
          "type": "string"
        },
        "cohortRef": {
          "type": "string"
        }
      }
    },
    "embeddedEntryToken": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entryTokenId",
        "journeyPathId",
        "issuedAt",
        "expiresAt",
        "cohortRef",
        "intendedChannel",
        "contextClaims"
      ],
      "properties": {
        "entryTokenId": {
          "type": "string"
        },
        "journeyPathId": {
          "type": "string"
        },
        "issuedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "cohortRef": {
          "type": "string"
        },
        "intendedChannel": {
          "type": "string",
          "const": "nhs_app_webview"
        },
        "contextClaims": {
          "type": "object"
        }
      }
    }
  }
}
