{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_approval_requirement_assessment.schema.json",
  "title": "228 ApprovalRequirementAssessment",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "approvalRequirementAssessmentId",
    "taskId",
    "decisionEpochRef",
    "endpointDecisionRef",
    "endpointClass",
    "approvalPolicyMatrixRef",
    "tenantPolicyRef",
    "pathwayRef",
    "riskBurdenClass",
    "assistiveProvenanceState",
    "sensitiveOverrideState",
    "matchedPolicyRuleRefs",
    "requiredApprovalMode",
    "checkpointState",
    "reasonCodeRefs",
    "evaluatedAt"
  ],
  "properties": {
    "approvalRequirementAssessmentId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "endpointDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "endpointClass": {
      "type": "string"
    },
    "approvalPolicyMatrixRef": {
      "$ref": "#/$defs/id"
    },
    "tenantPolicyRef": {
      "$ref": "#/$defs/id"
    },
    "pathwayRef": {
      "$ref": "#/$defs/id"
    },
    "riskBurdenClass": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "urgent",
        "any"
      ]
    },
    "assistiveProvenanceState": {
      "type": "string",
      "enum": [
        "none",
        "seeded",
        "seeded_or_override",
        "any"
      ]
    },
    "sensitiveOverrideState": {
      "type": "string",
      "enum": [
        "none",
        "tenant_sensitive_override",
        "manual_override",
        "any"
      ]
    },
    "matchedPolicyRuleRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "requiredApprovalMode": {
      "type": "string",
      "enum": [
        "not_required",
        "required"
      ]
    },
    "checkpointState": {
      "type": "string",
      "enum": [
        "not_required",
        "required",
        "pending",
        "approved",
        "rejected",
        "superseded"
      ]
    },
    "reasonCodeRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "evaluatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "ApprovalRequirementAssessment binds to one exact decisionEpochRef and one current policy matrix version.",
    "Approval burden evaluation must consider endpoint class, payload content, tenant policy, pathway, risk burden, assistive provenance, and sensitive override posture."
  ]
}
