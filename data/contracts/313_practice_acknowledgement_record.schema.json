{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_practice_acknowledgement_record.schema.json",
  "title": "PracticeAcknowledgementRecord",
  "description": "Generation-bound acknowledgement record. Only current-generation evidence on the live tuple may clear current debt.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "acknowledgementId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable acknowledgement identifier."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "practiceContinuityMessageRef": {
      "type": "string",
      "minLength": 1,
      "description": "PracticeContinuityMessage being acknowledged."
    },
    "ackGeneration": {
      "type": "integer",
      "minimum": 0,
      "description": "Acknowledgement generation referenced by this evidence."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash."
    },
    "causalToken": {
      "type": "string",
      "minLength": 1,
      "description": "Causal token matching the message and projection."
    },
    "ackState": {
      "type": "string",
      "enum": [
        "pending",
        "received",
        "superseded",
        "exception_recorded"
      ],
      "description": "Acknowledgement state."
    },
    "ackEvidenceKind": {
      "type": "string",
      "enum": [
        "message_reply",
        "api_receipt",
        "manual_attestation",
        "policy_exception"
      ],
      "description": "Kind of acknowledgement evidence received."
    },
    "acknowledgedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Time at which acknowledgement was recorded."
    },
    "acknowledgedByRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Mailbox, API principal, or attesting actor."
    },
    "visibilityEnvelopeVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Visibility envelope version used by the acknowledged payload."
    },
    "policyEvaluationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Policy evaluation ref active when the acknowledgement was accepted."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "acknowledgementId",
    "hubCoordinationCaseId",
    "practiceContinuityMessageRef",
    "ackGeneration",
    "truthTupleHash",
    "causalToken",
    "ackState",
    "ackEvidenceKind",
    "visibilityEnvelopeVersionRef",
    "policyEvaluationRef",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
