{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells://contracts/ProviderSearchSlice",
  "title": "ProviderSearchSlice",
  "description": "Per-provider search slice covering coverage truth, degradation, and raw payload lineage.",
  "type": "object",
  "additionalProperties": false,
  "x-taskId": "seq_280",
  "x-contractVersion": "280.phase4.booking-flow-freeze.v1",
  "required": [
    "providerSearchSliceId",
    "slotSearchSessionRef",
    "supplierRef",
    "searchWindowStartAt",
    "searchWindowEndAt",
    "coverageState",
    "returnedRawCount",
    "normalizedCount",
    "deduplicatedCount",
    "filteredCount",
    "surfacedCount",
    "rawPayloadRef",
    "completedAt"
  ],
  "properties": {
    "providerSearchSliceId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable ProviderSearchSlice identifier."
    },
    "slotSearchSessionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Owning SlotSearchSession ref."
    },
    "supplierRef": {
      "type": "string",
      "minLength": 1,
      "description": "Supplier or source system reference."
    },
    "searchWindowStartAt": {
      "type": "string",
      "format": "date-time",
      "description": "Slice-specific lower time bound."
    },
    "searchWindowEndAt": {
      "type": "string",
      "format": "date-time",
      "description": "Slice-specific upper time bound."
    },
    "coverageState": {
      "type": "string",
      "enum": [
        "complete",
        "partial_coverage",
        "timeout",
        "degraded",
        "failed"
      ],
      "description": "Provider coverage or degradation state."
    },
    "returnedRawCount": {
      "type": "integer",
      "minimum": 0
    },
    "normalizedCount": {
      "type": "integer",
      "minimum": 0
    },
    "deduplicatedCount": {
      "type": "integer",
      "minimum": 0
    },
    "filteredCount": {
      "type": "integer",
      "minimum": 0
    },
    "surfacedCount": {
      "type": "integer",
      "minimum": 0
    },
    "rejectReasonCounters": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Reject counters for filter and supplier-specific unsupported reasons."
    },
    "rawPayloadRef": {
      "type": "string",
      "minLength": 1,
      "description": "Audit-safe raw payload reference."
    },
    "degradationReasonRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Completion or final timeout timestamp."
    }
  },
  "x-sourceRefs": [
    "blueprint/phase-4-the-booking-engine.md",
    "blueprint/platform-runtime-and-release-blueprint.md"
  ]
}
