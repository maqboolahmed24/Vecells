{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells/contracts/236_more_info_reminder_schedule.schema.json",
  "title": "MoreInfoReminderSchedule",
  "type": "object",
  "required": [
    "scheduleId",
    "cycleId",
    "checkpointRef",
    "scheduleState",
    "cadencePolicyRef",
    "reminderOffsetsMinutes",
    "maxReminderCount",
    "dispatchedReminderCount",
    "callbackFallbackState",
    "createdAt",
    "updatedAt",
    "version"
  ],
  "properties": {
    "scheduleId": { "type": "string" },
    "cycleId": { "type": "string" },
    "checkpointRef": { "type": "string" },
    "scheduleState": {
      "type": "string",
      "enum": ["scheduled", "suppressed", "exhausted", "completed", "cancelled"]
    },
    "cadencePolicyRef": { "type": "string" },
    "reminderOffsetsMinutes": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "maxReminderCount": { "type": "integer", "minimum": 0 },
    "dispatchedReminderCount": { "type": "integer", "minimum": 0 },
    "quietHoursPolicyRef": { "type": ["string", "null"] },
    "quietHoursWindow": { "type": ["object", "null"] },
    "lastReminderSentAt": { "type": ["string", "null"], "format": "date-time" },
    "nextQuietHoursReleaseAt": { "type": ["string", "null"], "format": "date-time" },
    "suppressedReasonRef": { "type": ["string", "null"] },
    "callbackFallbackState": {
      "type": "string",
      "enum": ["not_eligible", "eligible", "seeded"]
    },
    "callbackFallbackSeedRef": { "type": ["string", "null"] },
    "completedAt": { "type": ["string", "null"], "format": "date-time" },
    "cancelledAt": { "type": ["string", "null"], "format": "date-time" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
