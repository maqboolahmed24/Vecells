{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_endpoint_decision_settlement.schema.json",
  "title": "228 EndpointDecisionSettlement",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "endpointDecisionSettlementId",
    "endpointDecisionActionRecordRef",
    "decisionEpochRef",
    "commandSettlementRecordRef",
    "transitionEnvelopeRef",
    "audienceSurfaceRuntimeBindingRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "releasePublicationParityRef",
    "releaseRecoveryDispositionRef",
    "result",
    "recordedAt"
  ],
  "properties": {
    "endpointDecisionSettlementId": {
      "$ref": "#/$defs/id"
    },
    "endpointDecisionActionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "selfCareBoundaryDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "boundaryTupleHash": {
      "type": [
        "string",
        "null"
      ]
    },
    "boundaryDecisionState": {
      "type": [
        "string",
        "null"
      ]
    },
    "clinicalMeaningState": {
      "type": [
        "string",
        "null"
      ]
    },
    "operationalFollowUpScope": {
      "type": [
        "string",
        "null"
      ]
    },
    "commandSettlementRecordRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "releasePublicationParityRef": {
      "$ref": "#/$defs/id"
    },
    "releaseRecoveryDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "humanApprovalGateAssessmentRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "presentationArtifactRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "draft_saved",
        "preview_ready",
        "submitted",
        "stale_recoverable",
        "blocked_policy",
        "blocked_approval_gate",
        "failed"
      ]
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "Endpoint consequence may not settle from local UI acknowledgement alone.",
    "stale_recoverable and blocked_approval_gate preserve payload and preview provenance in the same shell instead of collapsing to generic failure."
  ]
}
