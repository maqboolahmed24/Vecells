{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells/contracts/150_safety_rule_pack_schema.json",
  "title": "Phase 1 Synchronous Safety Rule Pack",
  "type": "object",
  "required": ["schemaVersion", "packs"],
  "properties": {
    "schemaVersion": {
      "const": "PHASE1_SYNCHRONOUS_SAFETY_RULE_PACK_REGISTRY_V1"
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "rulePackId",
          "rulePackVersion",
          "rulePackVersionRef",
          "upstreamRulebookRef",
          "calibratorVersionRef",
          "thresholdUrgent",
          "thresholdResidual",
          "contradictionThreshold",
          "missingnessThreshold",
          "dependencyGroups",
          "rules"
        ],
        "properties": {
          "rulePackId": { "type": "string", "minLength": 1 },
          "rulePackVersion": { "type": "string", "minLength": 1 },
          "rulePackVersionRef": { "type": "string", "minLength": 1 },
          "upstreamRulebookRef": { "type": "string", "minLength": 1 },
          "authoredConfigReasonCodes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "calibratorVersionRef": { "type": "string", "minLength": 1 },
          "thresholdUrgent": { "type": "number", "minimum": 0, "maximum": 1 },
          "thresholdResidual": { "type": "number", "minimum": 0, "maximum": 1 },
          "contradictionThreshold": { "type": "number", "minimum": 0, "maximum": 1 },
          "missingnessThreshold": { "type": "number", "minimum": 0, "maximum": 1 },
          "betaUrgent": { "type": "number" },
          "betaResidual": { "type": "number" },
          "betaConflictUrgent": { "type": "number" },
          "betaConflictResidual": { "type": "number" },
          "betaMissingUrgent": { "type": "number" },
          "betaMissingResidual": { "type": "number" },
          "dependencyGroups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["dependencyGroupRef", "urgentCap", "residualCap"],
              "properties": {
                "dependencyGroupRef": { "type": "string", "minLength": 1 },
                "urgentCap": { "type": "number", "minimum": 0 },
                "residualCap": { "type": "number", "minimum": 0 }
              }
            }
          },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "ruleId",
                "ruleVersion",
                "humanReadableName",
                "clinicalRationale",
                "owningApproverRef",
                "effectiveDate",
                "fixtureSetRefs",
                "severityClass",
                "dependencyGroupRef",
                "logLikelihoodWeight",
                "criticalFeatureRefs",
                "missingnessMode",
                "contradictionMode",
                "calibrationStratumRef",
                "validityWindowRef",
                "scoreAxis"
              ],
              "properties": {
                "ruleId": { "type": "string", "minLength": 1 },
                "ruleVersion": { "type": "string", "minLength": 1 },
                "humanReadableName": { "type": "string", "minLength": 1 },
                "clinicalRationale": { "type": "string", "minLength": 1 },
                "owningApproverRef": { "type": "string", "minLength": 1 },
                "effectiveDate": { "type": "string", "format": "date" },
                "fixtureSetRefs": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "severityClass": {
                  "enum": [
                    "hard_stop",
                    "urgent_contributor",
                    "residual_contributor",
                    "reachability_contributor"
                  ]
                },
                "dependencyGroupRef": { "type": "string", "minLength": 1 },
                "logLikelihoodWeight": { "type": "number", "minimum": 0 },
                "criticalFeatureRefs": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "missingnessMode": {
                  "enum": ["ignore", "conservative_hold", "urgent_review"]
                },
                "contradictionMode": {
                  "enum": [
                    "require_resolution",
                    "clinician_override_only",
                    "latest_highest_assurance"
                  ]
                },
                "calibrationStratumRef": { "type": "string", "minLength": 1 },
                "validityWindowRef": { "type": "string", "minLength": 1 },
                "scoreAxis": { "enum": ["urgent", "residual", "both"] },
                "requestTypes": {
                  "type": "array",
                  "items": {
                    "enum": ["Symptoms", "Meds", "Admin", "Results"]
                  },
                  "uniqueItems": true
                }
              }
            }
          }
        }
      }
    }
  }
}
