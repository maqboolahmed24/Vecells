{
  "schemaVersion": "388.phase7.embedded-entry-corridor.v1",
  "visualMode": "NHSApp_Embedded_Entry_Corridor",
  "routeFamilyCount": 5,
  "routeEntryPaths": [
    "/nhs-app/entry",
    "/embedded-entry",
    "/auth/nhs-app/entry",
    "/nhs-app/sign-in"
  ],
  "components": [
    "EmbeddedEntryLanding",
    "EmbeddedIdentityResolverView",
    "EmbeddedEntryStateCard",
    "EmbeddedConsentDeniedView",
    "EmbeddedExpiredSessionView",
    "EmbeddedSafeReentryView",
    "EmbeddedWrongContextRecoveryView",
    "EmbeddedEntryProgressRail",
    "EmbeddedEntryActionCluster",
    "EmbeddedEntryHeaderFrame",
    "EmbeddedEntryStateMachineAdapter"
  ],
  "contractObjects": [
    "SSOEntryGrant",
    "AuthBridgeTransaction",
    "SessionMergePolicy",
    "IdentityAssertionBinding",
    "SessionMergeDecision",
    "ReturnIntent",
    "SSOReturnDisposition"
  ],
  "routing": {
    "appRouteBeforeShellCatchAll": true,
    "successfulHandoff": "buildEmbeddedShellUrl(route, embedded)",
    "historyMode": "replace"
  },
  "privacy": {
    "visibleCopyRawAuthPlumbing": false,
    "automationAnchorsRawAuthPlumbing": false,
    "clientConsoleRawAuthPlumbing": false,
    "canonicalEntryQueryKeys": ["entry", "route", "channel"]
  },
  "layout": {
    "surfaceMaxRem": 34,
    "stateCardMaxRem": 32,
    "cardPaddingPx": 20,
    "safeAreaActionBottomPx": 16
  },
  "requiredPostures": [
    "Opening your NHS login",
    "Confirming your details",
    "We could not sign you in here",
    "Please go back to the NHS App and try again",
    "You chose not to use your NHS login",
    "Your session has ended"
  ]
}

