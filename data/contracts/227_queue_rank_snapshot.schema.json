{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_queue_rank_snapshot.schema.json",
  "title": "227 QueueRankSnapshot",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "rankSnapshotId",
    "queueRef",
    "queueRankPlanRef",
    "asOfAt",
    "sourceFactCutRef",
    "eligibleTaskRefs",
    "excludedTaskRefs",
    "overloadState",
    "fairnessCycleStateRef",
    "rowOrderHash",
    "generatedAt"
  ],
  "properties": {
    "rankSnapshotId": {
      "$ref": "#/$defs/id"
    },
    "queueRef": {
      "$ref": "#/$defs/id"
    },
    "queueRankPlanRef": {
      "$ref": "#/$defs/id"
    },
    "asOfAt": {
      "$ref": "#/$defs/dateTime"
    },
    "sourceFactCutRef": {
      "$ref": "#/$defs/id"
    },
    "trustInputRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "eligibleTaskRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "excludedTaskRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "overloadState": {
      "type": "string",
      "enum": [
        "nominal",
        "overload_critical"
      ]
    },
    "fairnessCycleStateRef": {
      "$ref": "#/$defs/id"
    },
    "rowOrderHash": {
      "$ref": "#/$defs/id"
    },
    "generatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "QueueRankSnapshot binds one queue order to one consistent fact cut and one active QueueRankPlan.",
    "Queue rows, preview digests, next-task candidates, and supervisor drill-down must not publish before the snapshot exists."
  ]
}
