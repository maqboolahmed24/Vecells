{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_admin_resolution_case.schema.json",
  "title": "229 AdminResolutionCase",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "adminResolutionCaseId",
    "episodeRef",
    "requestRef",
    "requestLineageRef",
    "lineageCaseLinkRef",
    "sourceTriageTaskRef",
    "adminResolutionSubtypeRef",
    "boundaryDecisionRef",
    "boundaryTupleHash",
    "clinicalMeaningState",
    "operationalFollowUpScope",
    "adminMutationAuthorityState",
    "decisionEpochRef",
    "decisionSupersessionRecordRef",
    "policyBundleRef",
    "lineageFenceEpoch",
    "caseVersionRef",
    "currentOwnerRef",
    "caseState",
    "waitingState",
    "currentActionRecordRef",
    "completionArtifactRef",
    "dependencySetRef",
    "reopenState",
    "experienceProjectionRef",
    "releaseWatchRef",
    "watchWindowRef",
    "openedAt"
  ],
  "properties": {
    "adminResolutionCaseId": {
      "$ref": "#/$defs/id"
    },
    "episodeRef": {
      "$ref": "#/$defs/id"
    },
    "requestRef": {
      "$ref": "#/$defs/id"
    },
    "requestLineageRef": {
      "$ref": "#/$defs/id"
    },
    "lineageCaseLinkRef": {
      "$ref": "#/$defs/id"
    },
    "sourceTriageTaskRef": {
      "$ref": "#/$defs/id"
    },
    "adminResolutionSubtypeRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "boundaryTupleHash": {
      "$ref": "#/$defs/id"
    },
    "clinicalMeaningState": {
      "type": "string",
      "enum": [
        "bounded_admin_only",
        "clinician_reentry_required"
      ]
    },
    "operationalFollowUpScope": {
      "type": "string",
      "enum": [
        "bounded_admin_resolution"
      ]
    },
    "adminMutationAuthorityState": {
      "type": "string",
      "enum": [
        "bounded_admin_only",
        "frozen"
      ]
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "policyBundleRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "caseVersionRef": {
      "$ref": "#/$defs/id"
    },
    "currentOwnerRef": {
      "$ref": "#/$defs/id"
    },
    "caseState": {
      "type": "string",
      "enum": [
        "queued",
        "in_progress",
        "awaiting_internal_action",
        "awaiting_external_dependency",
        "awaiting_practice_action",
        "patient_notified",
        "completed",
        "closed",
        "reopened"
      ]
    },
    "waitingState": {
      "type": "string",
      "enum": [
        "none",
        "awaiting_internal_action",
        "awaiting_external_dependency",
        "awaiting_practice_action",
        "patient_document_return",
        "identity_verification"
      ]
    },
    "currentActionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "completionArtifactRef": {
      "$ref": "#/$defs/id"
    },
    "dependencySetRef": {
      "$ref": "#/$defs/id"
    },
    "reopenState": {
      "type": "string",
      "enum": [
        "stable",
        "reopen_required",
        "reopened",
        "blocked_pending_review"
      ]
    },
    "experienceProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "releaseWatchRef": {
      "$ref": "#/$defs/id"
    },
    "watchWindowRef": {
      "$ref": "#/$defs/id"
    },
    "openedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "closedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "x-canonicalPrimaryPath": [
    "queued",
    "in_progress",
    "awaiting_internal_action",
    "awaiting_external_dependency",
    "awaiting_practice_action",
    "patient_notified",
    "completed",
    "closed"
  ],
  "x-canonicalReopenPath": [
    "closed",
    "reopened",
    "in_progress"
  ],
  "x-governedInvariants": [
    "AdminResolutionCase may remain consequence-bearing only while SelfCareBoundaryDecision still declares bounded_admin_only and bounded_admin_resolution.",
    "Generic waiting is invalid; waiting posture must be typed, owned, and backed by AdviceAdminDependencySet."
  ]
}
