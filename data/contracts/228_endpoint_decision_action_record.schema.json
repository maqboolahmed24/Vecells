{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_endpoint_decision_action_record.schema.json",
  "title": "228 EndpointDecisionActionRecord",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "endpointDecisionActionRecordId",
    "taskId",
    "endpointDecisionRef",
    "decisionEpochRef",
    "routeIntentBindingRef",
    "actionType",
    "reviewVersionRef",
    "policyBundleRef",
    "lineageFenceEpoch",
    "selectedAnchorRef",
    "selectedAnchorTupleHashRef",
    "assistiveSeedMode",
    "assistiveSourceRefs",
    "commandActionRecordRef",
    "submittedBy",
    "submittedAt"
  ],
  "properties": {
    "endpointDecisionActionRecordId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "endpointDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "selfCareBoundaryDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "boundaryTupleHash": {
      "type": [
        "string",
        "null"
      ]
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "actionType": {
      "type": "string",
      "enum": [
        "select_endpoint",
        "update_payload",
        "preview_outcome",
        "submit_endpoint",
        "regenerate_preview"
      ]
    },
    "reviewVersionRef": {
      "$ref": "#/$defs/id"
    },
    "policyBundleRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorTupleHashRef": {
      "$ref": "#/$defs/id"
    },
    "assistiveSeedMode": {
      "type": "string",
      "enum": [
        "absent",
        "present"
      ]
    },
    "assistiveSessionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "assistiveCapabilityTrustEnvelopeRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "assistiveFeedbackChainRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "assistiveSourceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "humanApprovalGateAssessmentRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "finalHumanArtifactRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "approvalGatePolicyBundleRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "commandActionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "submittedBy": {
      "$ref": "#/$defs/id"
    },
    "submittedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "actionType": {
            "const": "submit_endpoint"
          },
          "assistiveSeedMode": {
            "const": "present"
          }
        }
      },
      "then": {
        "required": [
          "assistiveSessionRef",
          "assistiveCapabilityTrustEnvelopeRef",
          "assistiveFeedbackChainRef",
          "humanApprovalGateAssessmentRef",
          "finalHumanArtifactRef",
          "approvalGatePolicyBundleRef"
        ],
        "properties": {
          "assistiveSourceRefs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "x-governedInvariants": [
    "EndpointDecisionActionRecord is part of the canonical route-intent, command-action, settlement, and recovery chain.",
    "Assistive-seeded submit_endpoint remains fail-closed unless the current trust, approval, and final-human-artifact refs are pinned to the same review version and selected anchor."
  ]
}
