{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_more_info_reply_window_checkpoint.schema.json",
  "title": "227 MoreInfoReplyWindowCheckpoint",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "checkpointId",
    "cycleRef",
    "policyVersionRef",
    "lineageFenceEpoch",
    "windowOpenedAt",
    "dueAt",
    "lateReplyReviewUntilAt",
    "nextReminderDueAt",
    "reachabilityDependencyRef",
    "reachabilityEpochRef",
    "currentAuthoritativeAt",
    "replyWindowState",
    "dominantReasonRef",
    "computedAt"
  ],
  "properties": {
    "checkpointId": {
      "$ref": "#/$defs/id"
    },
    "cycleRef": {
      "$ref": "#/$defs/id"
    },
    "policyVersionRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "windowOpenedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "dueAt": {
      "$ref": "#/$defs/dateTime"
    },
    "lateReplyReviewUntilAt": {
      "$ref": "#/$defs/dateTime"
    },
    "nextReminderDueAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityEpochRef": {
      "$ref": "#/$defs/id"
    },
    "supersededByCycleRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "currentAuthoritativeAt": {
      "$ref": "#/$defs/dateTime"
    },
    "replyWindowState": {
      "type": "string",
      "enum": [
        "open",
        "reminder_due",
        "late_review",
        "expired",
        "superseded",
        "settled",
        "blocked_repair"
      ]
    },
    "dominantReasonRef": {
      "$ref": "#/$defs/id"
    },
    "computedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "MoreInfoReplyWindowCheckpoint is the sole authority for due state, reminder eligibility, late-review grace, expiry posture, and same-shell reply eligibility.",
    "Client countdowns, secure-link TTL, and cached queue badges are derived views only."
  ]
}
