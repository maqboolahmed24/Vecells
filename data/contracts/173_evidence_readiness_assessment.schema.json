{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/173_evidence_readiness_assessment.schema.json",
  "title": "TelephonyEvidenceReadinessAssessment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "telephonyEvidenceReadinessAssessmentId",
    "callSessionRef",
    "submissionEnvelopeRef",
    "urgentLiveAssessmentRef",
    "transcriptReadinessRef",
    "structuredCaptureRefs",
    "identityEvidenceRefs",
    "contactRouteEvidenceRefs",
    "manualReviewDispositionRef",
    "continuationEligibilityRef",
    "usabilityState",
    "promotionReadiness",
    "routineSubmissionAllowed",
    "reasonCodes",
    "assessmentInputs",
    "assessedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "173.phase2.telephony.evidence-readiness.v1"
    },
    "telephonyEvidenceReadinessAssessmentId": {
      "type": "string",
      "pattern": "^tel_era_[A-Za-z0-9_:-]+$"
    },
    "callSessionRef": {
      "type": "string"
    },
    "submissionEnvelopeRef": {
      "type": ["string", "null"]
    },
    "urgentLiveAssessmentRef": {
      "type": ["string", "null"]
    },
    "transcriptReadinessRef": {
      "type": ["string", "null"]
    },
    "structuredCaptureRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "identityEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contactRouteEvidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manualReviewDispositionRef": {
      "type": ["string", "null"]
    },
    "continuationEligibilityRef": {
      "type": ["string", "null"]
    },
    "usabilityState": {
      "type": "string",
      "enum": [
        "awaiting_recording",
        "awaiting_transcript",
        "awaiting_structured_capture",
        "urgent_live_only",
        "safety_usable",
        "manual_review_only",
        "unusable_terminal"
      ]
    },
    "promotionReadiness": {
      "type": "string",
      "enum": ["blocked", "continuation_only", "ready_to_seed", "ready_to_promote"]
    },
    "routineSubmissionAllowed": {
      "type": "boolean",
      "description": "May be true only when usabilityState=safety_usable and promotionReadiness=ready_to_promote."
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "assessmentInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recordingAvailabilityState",
        "transcriptState",
        "coverageClass",
        "structuredCaptureState",
        "identityPosture",
        "destinationPosture"
      ],
      "properties": {
        "recordingAvailabilityState": {
          "type": "string",
          "enum": [
            "expected",
            "available",
            "fetched",
            "quarantined",
            "verified",
            "missing",
            "expired"
          ]
        },
        "transcriptState": {
          "type": "string",
          "enum": ["not_started", "queued", "running", "partial", "ready", "failed", "superseded"]
        },
        "coverageClass": {
          "type": "string",
          "enum": ["none", "keyword_only", "partial_utterance", "clinically_sufficient"]
        },
        "structuredCaptureState": {
          "type": "string",
          "enum": ["not_started", "partial", "sufficient", "contradictory"]
        },
        "identityPosture": {
          "type": "string",
          "enum": ["unknown", "partial", "challenge_ok", "high_assurance", "ambiguous"]
        },
        "destinationPosture": {
          "type": "string",
          "enum": ["unknown", "untrusted", "challenge_required", "verified_for_subject"]
        }
      }
    },
    "assessedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "routineSubmissionAllowed": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "usabilityState": {
            "const": "safety_usable"
          },
          "promotionReadiness": {
            "const": "ready_to_promote"
          }
        }
      }
    }
  ]
}
