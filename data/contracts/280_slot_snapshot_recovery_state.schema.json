{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vecells://contracts/SlotSnapshotRecoveryState",
  "title": "SlotSnapshotRecoveryState",
  "description": "Same-shell recovery-state authority for slot-search surfaces.",
  "type": "object",
  "additionalProperties": false,
  "x-taskId": "seq_280",
  "x-contractVersion": "280.phase4.booking-flow-freeze.v1",
  "required": [
    "slotSnapshotRecoveryStateId",
    "slotSetSnapshotRef",
    "viewState",
    "coverageState",
    "reasonCodes",
    "supportHelpVisible",
    "generatedAt"
  ],
  "properties": {
    "slotSnapshotRecoveryStateId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable recovery-state ref."
    },
    "slotSetSnapshotRef": {
      "type": "string",
      "minLength": 1,
      "description": "Owning SlotSetSnapshot ref."
    },
    "viewState": {
      "type": "string",
      "enum": [
        "renderable",
        "partial_coverage",
        "stale_refresh_required",
        "no_supply_confirmed",
        "support_fallback"
      ],
      "description": "Renderable recovery state for the booking shell."
    },
    "coverageState": {
      "type": "string",
      "enum": [
        "complete",
        "partial_coverage",
        "timeout",
        "degraded",
        "failed"
      ],
      "description": "Coverage state used to derive viewState."
    },
    "reasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "supportHelpVisible": {
      "type": "boolean"
    },
    "sameShellActionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Dominant same-shell action or recovery route ref."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Recovery state generation time."
    }
  },
  "x-sourceRefs": [
    "blueprint/phase-4-the-booking-engine.md",
    "blueprint/patient-portal-experience-architecture-blueprint.md"
  ]
}
