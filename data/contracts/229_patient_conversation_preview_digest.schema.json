{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_patient_conversation_preview_digest.schema.json",
  "title": "229 PatientConversationPreviewDigest",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "digestId",
    "clusterRef",
    "threadId",
    "typedSubthreadRefs",
    "latestCommunicationEnvelopeRef",
    "latestReminderPlanRef",
    "patientShellConsistencyRef",
    "visibilityProjectionRef",
    "visibilityTier",
    "releaseState",
    "routeIntentBindingRef",
    "requiredReleaseApprovalFreezeRef",
    "channelReleaseFreezeState",
    "requiredAssuranceSliceTrustRefs",
    "embeddedSessionRef",
    "latestReceiptEnvelopeRef",
    "latestSettlementRef",
    "latestSupportActionSettlementRef",
    "latestCallbackStatusRef",
    "reachabilityDependencyRef",
    "reachabilityAssessmentRef",
    "reachabilityEpoch",
    "contactRepairJourneyRef",
    "unreadCount",
    "replyNeededState",
    "awaitingReviewState",
    "deliveryDisputeState",
    "deliveryRiskState",
    "authoritativeOutcomeState",
    "repairRequiredState",
    "stateConfidenceBand",
    "dominantNextActionRef",
    "transitionEnvelopeRef",
    "placeholderContractRef",
    "recoveryRouteRef",
    "experienceContinuityEvidenceRef",
    "receiptGrammarVersionRef",
    "threadTupleHash",
    "monotoneRevision",
    "computedAt"
  ],
  "properties": {
    "digestId": {
      "$ref": "#/$defs/id"
    },
    "clusterRef": {
      "$ref": "#/$defs/id"
    },
    "threadId": {
      "$ref": "#/$defs/id"
    },
    "typedSubthreadRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "latestCommunicationEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "latestReminderPlanRef": {
      "$ref": "#/$defs/id"
    },
    "patientShellConsistencyRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityTier": {
      "type": "string"
    },
    "releaseState": {
      "type": "string"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "requiredReleaseApprovalFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "channelReleaseFreezeState": {
      "type": "string",
      "enum": [
        "permitted",
        "guarded",
        "blocked"
      ]
    },
    "requiredAssuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "embeddedSessionRef": {
      "$ref": "#/$defs/id"
    },
    "latestReceiptEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "latestSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "latestSupportActionSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "latestCallbackStatusRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityAssessmentRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "contactRepairJourneyRef": {
      "$ref": "#/$defs/id"
    },
    "unreadCount": {
      "type": "integer",
      "minimum": 0
    },
    "replyNeededState": {
      "type": "string"
    },
    "awaitingReviewState": {
      "type": "string"
    },
    "deliveryDisputeState": {
      "type": "string"
    },
    "deliveryRiskState": {
      "type": "string",
      "enum": [
        "on_track",
        "at_risk",
        "likely_failed",
        "disputed"
      ]
    },
    "authoritativeOutcomeState": {
      "type": "string",
      "enum": [
        "awaiting_delivery_truth",
        "awaiting_reply",
        "callback_scheduled",
        "awaiting_review",
        "reviewed",
        "settled",
        "recovery_required"
      ]
    },
    "repairRequiredState": {
      "type": "string"
    },
    "stateConfidenceBand": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "dominantNextActionRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "placeholderContractRef": {
      "$ref": "#/$defs/id"
    },
    "recoveryRouteRef": {
      "$ref": "#/$defs/id"
    },
    "experienceContinuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "receiptGrammarVersionRef": {
      "$ref": "#/$defs/id"
    },
    "threadTupleHash": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    },
    "computedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "PatientConversationPreviewDigest is the only source for list-state badges, summary copy, and closed or awaiting-review posture.",
    "It may not appear calmer or more settled than the latest PatientReceiptEnvelope, ConversationCommandSettlement, reachability truth, and continuity evidence allow."
  ]
}
