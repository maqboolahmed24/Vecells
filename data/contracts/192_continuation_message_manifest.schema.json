{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/192_continuation_message_manifest.schema.json",
  "title": "ContinuationMessageManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "messageManifestRef",
    "schemaVersion",
    "policyVersion",
    "continuationContextRef",
    "grantFamily",
    "templateRef",
    "bodyCopyCode",
    "bodyPreview",
    "containsPhi",
    "includesSignedUrl",
    "linkPlaceholderRef",
    "reasonCodes",
    "createdAt",
    "recordedBy"
  ],
  "properties": {
    "messageManifestRef": {
      "type": "string",
      "pattern": "^tcmm_"
    },
    "schemaVersion": {
      "const": "192.phase2.telephony-continuation.v1"
    },
    "policyVersion": {
      "const": "phase2-telephony-continuation-message-mask-192.v1"
    },
    "continuationContextRef": {
      "type": "string"
    },
    "grantFamily": {
      "type": "string",
      "enum": ["continuation_seeded_verified", "continuation_challenge"]
    },
    "templateRef": {
      "type": "string"
    },
    "bodyCopyCode": {
      "type": "string",
      "enum": ["CONTINUE_SECURELY", "CONTINUE_WITH_IDENTITY_CHECK"]
    },
    "bodyPreview": {
      "type": "string",
      "not": {
        "pattern": "(NHS number|patient_|request detail|diagnosis|symptom)"
      }
    },
    "containsPhi": {
      "const": false
    },
    "includesSignedUrl": {
      "const": false
    },
    "linkPlaceholderRef": {
      "type": "string",
      "pattern": "^link-placeholder://"
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedBy": {
      "const": "TelephonyContinuationGrantService"
    }
  }
}
