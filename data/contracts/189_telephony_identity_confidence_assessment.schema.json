{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/189_telephony_identity_confidence_assessment.schema.json",
  "title": "TelephonyIdentityConfidenceAssessment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identityConfidenceAssessmentRef",
    "schemaVersion",
    "policyVersion",
    "callSessionRef",
    "candidateSetRef",
    "routeSensitivity",
    "calibrationVersionRef",
    "thresholdProfileRef",
    "alphaId",
    "candidateScores",
    "bestCandidateRef",
    "runnerUpCandidateRef",
    "bestPId",
    "bestLcbIdAlpha",
    "bestUcbIdAlpha",
    "runnerUpPId",
    "runnerUpUcbIdAlpha",
    "gap_id",
    "callerIdOnlyBlocked",
    "reasonCodes",
    "assessedAt"
  ],
  "properties": {
    "identityConfidenceAssessmentRef": { "type": "string", "pattern": "^tida_" },
    "schemaVersion": { "const": "189.phase2.telephony-verification.v1" },
    "policyVersion": { "const": "phase2-telephony-verification-189.v1" },
    "callSessionRef": { "type": "string" },
    "candidateSetRef": { "type": "string", "pattern": "^tvcs_" },
    "routeSensitivity": { "type": "string" },
    "calibrationVersionRef": { "const": "Cal_id_189_synthetic_adjudicated_v1" },
    "thresholdProfileRef": { "type": "string" },
    "alphaId": { "type": "number", "minimum": 0, "maximum": 1 },
    "candidateScores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidatePatientRef",
          "featureVector",
          "z_id",
          "P_id",
          "LCB_id_alpha",
          "UCB_id_alpha",
          "callerIdOnly"
        ],
        "properties": {
          "candidatePatientRef": { "type": "string" },
          "featureVector": { "type": "object" },
          "z_id": { "type": "number" },
          "P_id": { "type": "number", "minimum": 0, "maximum": 1 },
          "LCB_id_alpha": { "type": "number", "minimum": 0, "maximum": 1 },
          "UCB_id_alpha": { "type": "number", "minimum": 0, "maximum": 1 },
          "callerIdOnly": { "type": "boolean" }
        }
      }
    },
    "bestCandidateRef": { "type": ["string", "null"] },
    "runnerUpCandidateRef": { "type": ["string", "null"] },
    "bestPId": { "type": "number", "minimum": 0, "maximum": 1 },
    "bestLcbIdAlpha": { "type": "number", "minimum": 0, "maximum": 1 },
    "bestUcbIdAlpha": { "type": "number", "minimum": 0, "maximum": 1 },
    "runnerUpPId": { "type": "number", "minimum": 0, "maximum": 1 },
    "runnerUpUcbIdAlpha": { "type": "number", "minimum": 0, "maximum": 1 },
    "gap_id": { "type": "number" },
    "callerIdOnlyBlocked": { "type": "boolean" },
    "reasonCodes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TEL_VERIFY_189_" }
    },
    "assessedAt": { "type": "string", "format": "date-time" }
  }
}
