{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_endpoint_decision_binding.schema.json",
  "title": "228 EndpointDecisionBinding",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "endpointDecisionBindingId",
    "taskId",
    "reviewSessionRef",
    "decisionEpochRef",
    "currentEndpointDecisionRef",
    "boundaryTupleHash",
    "boundaryDecisionState",
    "clinicalMeaningState",
    "operationalFollowUpScope",
    "reviewVersionRef",
    "selectedAnchorRef",
    "selectedAnchorTupleHashRef",
    "staffWorkspaceConsistencyProjectionRef",
    "workspaceSliceTrustProjectionRef",
    "audienceSurfaceRuntimeBindingRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "releasePublicationParityRef",
    "releaseRecoveryDispositionRef",
    "bindingState"
  ],
  "properties": {
    "endpointDecisionBindingId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "reviewSessionRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "currentEndpointDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "selfCareBoundaryDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "boundaryTupleHash": {
      "$ref": "#/$defs/id"
    },
    "boundaryDecisionState": {
      "type": "string",
      "enum": [
        "none",
        "self_care",
        "admin_resolution",
        "clinician_governed"
      ]
    },
    "clinicalMeaningState": {
      "type": "string",
      "enum": [
        "informational_only",
        "bounded_admin_only",
        "clinician_review_required",
        "downstream_handoff_required",
        "urgent_required"
      ]
    },
    "operationalFollowUpScope": {
      "type": "string",
      "enum": [
        "self_serve_guidance",
        "bounded_admin_resolution",
        "clinician_message",
        "clinician_callback",
        "booking_handoff",
        "pharmacy_handoff",
        "urgent_escalation"
      ]
    },
    "latestDecisionSupersessionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviewVersionRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorTupleHashRef": {
      "$ref": "#/$defs/id"
    },
    "staffWorkspaceConsistencyProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "workspaceSliceTrustProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "releasePublicationParityRef": {
      "$ref": "#/$defs/id"
    },
    "releaseRecoveryDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "bindingState": {
      "type": "string",
      "enum": [
        "live",
        "preview_only",
        "stale",
        "blocked"
      ]
    }
  },
  "x-governedInvariants": [
    "Endpoint rails are writable only while EndpointDecisionBinding.bindingState = live and the bound DecisionEpoch remains current.",
    "Self-care and admin consequence may not remain live if boundaryTupleHash drifts across the decision, settlement, and boundary decision."
  ]
}
