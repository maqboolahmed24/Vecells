{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_hub_commit_attempt.schema.json",
  "title": "HubCommitAttempt",
  "description": "Fenced, tuple-bound commit attempt. This is the only object allowed to perform native booking side effects or ingest imported confirmation toward booked outcome.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "commitAttemptId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for the commit attempt."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "commitMode": {
      "type": "string",
      "enum": [
        "native_api",
        "manual_pending_confirmation",
        "imported_confirmation"
      ],
      "description": "Commit mode preserved explicitly; never inferred later."
    },
    "selectedCandidateRef": {
      "type": "string",
      "minLength": 1,
      "description": "Selected candidate reference carried into commit."
    },
    "selectedOfferSessionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Offer session that produced the selected candidate."
    },
    "selectedOfferEntryRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Selected ranked offer entry when applicable."
    },
    "reservationFenceToken": {
      "type": "string",
      "minLength": 1,
      "description": "Current reservation or reservation-fence token."
    },
    "providerAdapterBindingHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current provider adapter binding hash."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy tuple hash."
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1,
      "description": "Idempotency key for replay-safe commit execution."
    },
    "attemptState": {
      "type": "string",
      "enum": [
        "draft",
        "executing",
        "awaiting_confirmation",
        "reconciliation_required",
        "disputed",
        "confirmed",
        "failed",
        "superseded"
      ],
      "description": "Current commit state. Superseded or reconciliation-required attempts remain explicit."
    },
    "commandActionRef": {
      "type": "string",
      "minLength": 1,
      "description": "CommandActionRecord reference for the writable action."
    },
    "commandSettlementRef": {
      "type": "string",
      "minLength": 1,
      "description": "CommandSettlementRecord reference for settlement."
    },
    "commitStartedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Time at which commit execution began."
    },
    "commitFinishedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "Time at which commit execution finished."
    },
    "blockingReasonRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Typed blocking reasons or stale-write reasons."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "commitAttemptId",
    "hubCoordinationCaseId",
    "commitMode",
    "selectedCandidateRef",
    "reservationFenceToken",
    "providerAdapterBindingHash",
    "truthTupleHash",
    "policyTupleHash",
    "idempotencyKey",
    "attemptState",
    "commandActionRef",
    "commandSettlementRef",
    "commitStartedAt",
    "blockingReasonRefs",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
