{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_hub_service_obligation_policy.schema.json",
  "title": "HubServiceObligationPolicy",
  "description": "Policy family that governs minutes-per-1,000 tracking, comparable offer obligations, and cancellation make-up without influencing candidate order.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "serviceObligationPolicyId",
    "policyVersion",
    "policyTupleHash",
    "weeklyMinutesPer1000AdjustedPopulation",
    "bankHolidayMakeUpWindowHours",
    "comparableOfferRule",
    "ledgerMode",
    "serviceObligationDisposition",
    "sourceRefs"
  ],
  "properties": {
    "serviceObligationPolicyId": {
      "type": "string",
      "minLength": 1,
      "description": "Service-obligation policy identifier."
    },
    "policyVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Policy version."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Compiled tuple hash."
    },
    "weeklyMinutesPer1000AdjustedPopulation": {
      "type": "integer",
      "minimum": 0,
      "description": "Required weekly Enhanced Access minutes per 1,000 adjusted population."
    },
    "bankHolidayMakeUpWindowHours": {
      "type": "integer",
      "minimum": 0,
      "description": "Time allowed to re-provide cancelled capacity unless commissioner agrees otherwise."
    },
    "comparableOfferRule": {
      "type": "string",
      "minLength": 1,
      "description": "Rule ref for comparable service offer across all PCN patients."
    },
    "ledgerMode": {
      "type": "string",
      "enum": [
        "minutes_ledger_required",
        "minutes_ledger_optional"
      ],
      "description": "Whether minutes and make-up ledgers are mandatory."
    },
    "serviceObligationDisposition": {
      "type": "string",
      "enum": [
        "within_obligation",
        "make_up_required",
        "obligation_risk",
        "commissioner_exception_active"
      ],
      "description": "Resolved service-obligation posture."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5C. Enhanced Access policy engine and network capacity ingestion",
    "blueprint/phase-5-the-network-horizon.md#5D. Coordination queue, candidate ranking, and SLA engine",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#ranking-order-and-visible-cues-must-derive-from-persisted-proof",
    "blueprint/phase-0-the-foundation-protocol.md#publication-and-bundle-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#assurance-and-trust-carry-forward",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md"
  ]
}
