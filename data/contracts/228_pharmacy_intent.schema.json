{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_pharmacy_intent.schema.json",
  "title": "228 PharmacyIntent",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "intentId",
    "episodeRef",
    "requestId",
    "requestLineageRef",
    "sourceTriageTaskRef",
    "lineageCaseLinkRef",
    "suspectedPathway",
    "eligibilityFacts",
    "exclusionFlags",
    "patientChoicePending",
    "createdFromDecisionId",
    "decisionEpochRef",
    "decisionSupersessionRecordRef"
  ],
  "properties": {
    "intentId": {
      "$ref": "#/$defs/id"
    },
    "episodeRef": {
      "$ref": "#/$defs/id"
    },
    "requestId": {
      "$ref": "#/$defs/id"
    },
    "requestLineageRef": {
      "$ref": "#/$defs/id"
    },
    "sourceTriageTaskRef": {
      "$ref": "#/$defs/id"
    },
    "lineageCaseLinkRef": {
      "$ref": "#/$defs/id"
    },
    "suspectedPathway": {
      "type": "string"
    },
    "eligibilityFacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "exclusionFlags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patientChoicePending": {
      "type": "boolean"
    },
    "createdFromDecisionId": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-governedInvariants": [
    "PharmacyIntent must echo the current DecisionEpoch and fail closed after supersession.",
    "Pharmacy handoff seeds remain structured domain contracts rather than ad hoc referral text."
  ]
}
