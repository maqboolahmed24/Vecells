{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase1/submission-envelope-validation-verdict.schema.json",
  "title": "SubmissionEnvelopeValidationVerdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdictSchemaVersion",
    "validationMode",
    "verdictState",
    "verdictHash",
    "envelopeRef",
    "draftPublicId",
    "bundleRef",
    "requestType",
    "issues",
    "questionStates",
    "stepStates",
    "requiredFieldMeaningMap",
    "activeQuestionKeys",
    "supersededQuestionKeys",
    "activeStructuredAnswers",
    "normalizedSubmissionCandidate",
    "submitReadiness"
  ],
  "properties": {
    "verdictSchemaVersion": {
      "type": "string",
      "const": "SUBMISSION_ENVELOPE_VALIDATION_VERDICT_V1"
    },
    "validationMode": {
      "type": "string",
      "enum": [
        "draft_save",
        "submit"
      ]
    },
    "verdictState": {
      "type": "string",
      "enum": [
        "shape_valid",
        "shape_invalid",
        "submit_ready",
        "submit_blocked",
        "submit_review_required"
      ]
    },
    "verdictHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "envelopeRef": {
      "type": "string"
    },
    "draftPublicId": {
      "type": "string",
      "pattern": "^dft_[a-z0-9]{10,32}$"
    },
    "bundleRef": {
      "type": "string"
    },
    "requestType": {
      "type": "string",
      "enum": [
        "Symptoms",
        "Meds",
        "Admin",
        "Results"
      ]
    },
    "issues": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validationIssue"
      }
    },
    "questionStates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/questionState"
      }
    },
    "stepStates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stepState"
      }
    },
    "requiredFieldMeaningMap": {
      "$ref": "145_required_field_meaning_map.schema.json"
    },
    "activeQuestionKeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersededQuestionKeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "activeStructuredAnswers": {
      "type": "object"
    },
    "normalizedSubmissionCandidate": {
      "type": "object"
    },
    "submitReadiness": {
      "$ref": "#/$defs/submitReadiness"
    }
  },
  "$defs": {
    "validationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "scope",
        "severity",
        "blocking"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "enum": [
            "field",
            "field_group",
            "step",
            "attachment",
            "contact_authority",
            "submit_preflight"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "questionKey": {
          "type": "string"
        },
        "stepKey": {
          "type": "string"
        },
        "groupKey": {
          "type": "string"
        },
        "attachmentRef": {
          "type": "string"
        },
        "reasonRef": {
          "type": "string"
        }
      }
    },
    "questionState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "questionKey",
        "requestType",
        "stepKey",
        "visible",
        "required",
        "answerPresent",
        "state",
        "normalizationTarget",
        "summaryRenderer",
        "safetyRelevance",
        "answerType",
        "cardinality"
      ],
      "properties": {
        "questionKey": {
          "type": "string"
        },
        "requestType": {
          "type": "string",
          "enum": [
            "Symptoms",
            "Meds",
            "Admin",
            "Results"
          ]
        },
        "stepKey": {
          "type": "string"
        },
        "visible": {
          "type": "boolean"
        },
        "required": {
          "type": "boolean"
        },
        "answerPresent": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": [
            "valid",
            "missing",
            "invalid",
            "superseded",
            "inactive",
            "optional_unanswered"
          ]
        },
        "normalizationTarget": {
          "type": "string"
        },
        "summaryRenderer": {
          "type": "string"
        },
        "safetyRelevance": {
          "type": "string",
          "enum": [
            "none",
            "triage_relevant",
            "safety_relevant"
          ]
        },
        "answerType": {
          "type": "string",
          "enum": [
            "single_select",
            "multi_select",
            "boolean",
            "date",
            "partial_date",
            "short_text",
            "short_text_or_unknown",
            "long_text"
          ]
        },
        "cardinality": {
          "type": "string",
          "enum": [
            "single",
            "multiple"
          ]
        }
      }
    },
    "stepState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stepKey",
        "missingQuestionKeys",
        "invalidQuestionKeys",
        "supersededQuestionKeys",
        "blockerCodes"
      ],
      "properties": {
        "stepKey": {
          "type": "string"
        },
        "missingQuestionKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "invalidQuestionKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supersededQuestionKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockerCodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "submitReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "blockerCodes",
        "missingRequiredQuestionKeys",
        "invalidQuestionKeys",
        "attachmentBlockerRefs",
        "contactAuthorityState",
        "urgentDecisionState",
        "convergenceState",
        "gapRefs"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "ready",
            "blocked",
            "review_required"
          ]
        },
        "blockerCodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingRequiredQuestionKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "invalidQuestionKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attachmentBlockerRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contactAuthorityState": {
          "type": "string",
          "enum": [
            "verified",
            "assumed_self_service_browser_minimum",
            "rebind_required",
            "blocked"
          ]
        },
        "urgentDecisionState": {
          "type": "string",
          "enum": [
            "clear",
            "pending",
            "urgent_diversion_required",
            "urgent_diverted"
          ]
        },
        "convergenceState": {
          "type": "string",
          "enum": [
            "valid",
            "invalid"
          ]
        },
        "gapRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
