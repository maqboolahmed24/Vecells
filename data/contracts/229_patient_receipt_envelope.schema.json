{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_patient_receipt_envelope.schema.json",
  "title": "229 PatientReceiptEnvelope",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "envelopeId",
    "clusterRef",
    "threadId",
    "activeSubthreadRef",
    "latestCommunicationEnvelopeRef",
    "channel",
    "payloadRef",
    "patientShellConsistencyRef",
    "visibilityProjectionRef",
    "embeddedSessionRef",
    "routeIntentBindingRef",
    "requiredReleaseApprovalFreezeRef",
    "channelReleaseFreezeState",
    "requiredAssuranceSliceTrustRefs",
    "governingCommandRef",
    "latestCallbackStatusRef",
    "reachabilityDependencyRef",
    "reachabilityAssessmentRef",
    "reachabilityEpoch",
    "contactRepairJourneyRef",
    "localAckState",
    "transportAckState",
    "deliveryEvidenceState",
    "deliveryRiskState",
    "authoritativeOutcomeState",
    "stateConfidenceBand",
    "placeholderContractRef",
    "settlementRef",
    "latestSupportActionSettlementRef",
    "transitionEnvelopeRef",
    "recoveryContinuationRef",
    "experienceContinuityEvidenceRef",
    "receiptGrammarVersionRef",
    "threadTupleHash",
    "causalToken",
    "monotoneRevision",
    "receiptArtifactRefs"
  ],
  "properties": {
    "envelopeId": {
      "$ref": "#/$defs/id"
    },
    "clusterRef": {
      "$ref": "#/$defs/id"
    },
    "threadId": {
      "$ref": "#/$defs/id"
    },
    "activeSubthreadRef": {
      "$ref": "#/$defs/id"
    },
    "latestCommunicationEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "channel": {
      "type": "string",
      "enum": [
        "sms",
        "email",
        "portal",
        "callback"
      ]
    },
    "payloadRef": {
      "$ref": "#/$defs/id"
    },
    "patientShellConsistencyRef": {
      "$ref": "#/$defs/id"
    },
    "visibilityProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "embeddedSessionRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "requiredReleaseApprovalFreezeRef": {
      "$ref": "#/$defs/id"
    },
    "channelReleaseFreezeState": {
      "type": "string",
      "enum": [
        "permitted",
        "guarded",
        "blocked"
      ]
    },
    "requiredAssuranceSliceTrustRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "governingCommandRef": {
      "$ref": "#/$defs/id"
    },
    "latestCallbackStatusRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityDependencyRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityAssessmentRef": {
      "$ref": "#/$defs/id"
    },
    "reachabilityEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "contactRepairJourneyRef": {
      "$ref": "#/$defs/id"
    },
    "localAckState": {
      "type": "string",
      "enum": [
        "none",
        "shown",
        "superseded"
      ]
    },
    "transportAckState": {
      "type": "string",
      "enum": [
        "none",
        "accepted",
        "rejected",
        "timed_out"
      ]
    },
    "deliveryEvidenceState": {
      "type": "string",
      "enum": [
        "pending",
        "delivered",
        "disputed",
        "failed",
        "expired",
        "suppressed"
      ]
    },
    "deliveryRiskState": {
      "type": "string",
      "enum": [
        "on_track",
        "at_risk",
        "likely_failed",
        "disputed"
      ]
    },
    "authoritativeOutcomeState": {
      "type": "string",
      "enum": [
        "awaiting_delivery_truth",
        "awaiting_reply",
        "callback_scheduled",
        "awaiting_review",
        "reviewed",
        "settled",
        "recovery_required"
      ]
    },
    "stateConfidenceBand": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "placeholderContractRef": {
      "$ref": "#/$defs/id"
    },
    "settlementRef": {
      "$ref": "#/$defs/id"
    },
    "latestSupportActionSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "recoveryContinuationRef": {
      "$ref": "#/$defs/id"
    },
    "experienceContinuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "receiptGrammarVersionRef": {
      "$ref": "#/$defs/id"
    },
    "threadTupleHash": {
      "$ref": "#/$defs/id"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    },
    "receiptArtifactRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    }
  },
  "x-governedInvariants": [
    "PatientReceiptEnvelope keeps local acknowledgement, transport acceptance, delivery evidence, and authoritative outcome distinct.",
    "Local or transport acknowledgement may not mark a thread reviewed or settled on its own."
  ]
}
