{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/192_continuation_dispatch_intent.schema.json",
  "title": "ContinuationDispatchIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dispatchIntentRef",
    "dispatchIdempotencyKey",
    "schemaVersion",
    "policyVersion",
    "callSessionRef",
    "continuationContextRef",
    "accessGrantRef",
    "messageManifestRef",
    "grantFamily",
    "dispatchOutcome",
    "targetChannel",
    "destinationHash",
    "maskedDestination",
    "noPhiBody",
    "signedUrlMaterializedInManifest",
    "reasonCodes",
    "createdAt",
    "recordedBy"
  ],
  "properties": {
    "dispatchIntentRef": {
      "type": "string",
      "pattern": "^tcdi_"
    },
    "dispatchIdempotencyKey": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "192.phase2.telephony-continuation.v1"
    },
    "policyVersion": {
      "const": "phase2-telephony-continuation-grants-192.v1"
    },
    "callSessionRef": {
      "type": "string"
    },
    "continuationContextRef": {
      "type": "string"
    },
    "accessGrantRef": {
      "type": ["string", "null"]
    },
    "messageManifestRef": {
      "type": ["string", "null"]
    },
    "grantFamily": {
      "type": "string",
      "enum": ["continuation_seeded_verified", "continuation_challenge", "manual_only"]
    },
    "dispatchOutcome": {
      "type": "string",
      "enum": ["queued", "no_redeemable_grant", "manual_followup"]
    },
    "targetChannel": {
      "type": "string",
      "enum": ["sms", "support_callback", "none"]
    },
    "destinationHash": {
      "type": ["string", "null"],
      "pattern": "^(sha256:[a-f0-9]{64})$"
    },
    "maskedDestination": {
      "type": ["string", "null"]
    },
    "noPhiBody": {
      "const": true
    },
    "signedUrlMaterializedInManifest": {
      "const": false
    },
    "providerDeliveryRef": {
      "type": ["string", "null"]
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedBy": {
      "const": "TelephonyContinuationGrantService"
    }
  }
}
