{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_cancellation_make_up_ledger.schema.json",
  "title": "CancellationMakeUpLedger",
  "description": "Operational ledger that tracks cancelled network time, replacement capacity, and the current make-up obligation window.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cancellationMakeUpLedgerId",
    "pcnRef",
    "policyTupleHash",
    "serviceDate",
    "cancelledMinutes",
    "replacementMinutes",
    "makeUpDueAt",
    "makeUpState",
    "sourceRefs"
  ],
  "properties": {
    "cancellationMakeUpLedgerId": {
      "type": "string",
      "minLength": 1,
      "description": "Ledger identifier."
    },
    "pcnRef": {
      "type": "string",
      "minLength": 1,
      "description": "PCN or network ref."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy tuple hash."
    },
    "serviceDate": {
      "type": "string",
      "format": "date-time",
      "description": "Date or timestamp of the cancelled service block."
    },
    "cancelledMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Cancelled minutes."
    },
    "replacementMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Replacement minutes delivered."
    },
    "makeUpDueAt": {
      "type": "string",
      "format": "date-time",
      "description": "Deadline for replacement capacity."
    },
    "commissionerExceptionRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Optional commissioner exception or override."
    },
    "makeUpState": {
      "type": "string",
      "enum": [
        "replacement_due",
        "replacement_provided",
        "exception_granted",
        "expired"
      ],
      "description": "Current make-up posture."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
