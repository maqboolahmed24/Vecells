{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/192_secure_link_session_projection.schema.json",
  "title": "SecureLinkSessionProjection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projectionRef",
    "schemaVersion",
    "continuationContextRef",
    "accessGrantRef",
    "grantRedemptionRef",
    "secureLinkSessionRef",
    "sessionEpochRef",
    "csrfSecretRef",
    "routeIntentBindingRef",
    "disclosurePosture",
    "patientDataDisclosureAllowed",
    "urlGrantReusable",
    "reasonCodes",
    "createdAt",
    "expiresAt",
    "recordedBy"
  ],
  "properties": {
    "projectionRef": {
      "type": "string",
      "pattern": "^tcslsp_"
    },
    "schemaVersion": {
      "const": "192.phase2.telephony-continuation.v1"
    },
    "continuationContextRef": {
      "type": "string"
    },
    "accessGrantRef": {
      "type": "string"
    },
    "grantRedemptionRef": {
      "type": "string"
    },
    "secureLinkSessionRef": {
      "type": "string"
    },
    "sessionEpochRef": {
      "type": "string"
    },
    "csrfSecretRef": {
      "type": "string"
    },
    "routeIntentBindingRef": {
      "type": ["string", "null"]
    },
    "disclosurePosture": {
      "type": "string",
      "enum": ["seeded_verified", "challenge_minimal", "recovery_only"]
    },
    "patientDataDisclosureAllowed": {
      "type": "boolean"
    },
    "urlGrantReusable": {
      "const": false
    },
    "reasonCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "recordedBy": {
      "const": "TelephonyContinuationGrantService"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "disclosurePosture": {
            "const": "challenge_minimal"
          }
        }
      },
      "then": {
        "properties": {
          "patientDataDisclosureAllowed": {
            "const": false
          }
        }
      }
    }
  ]
}
