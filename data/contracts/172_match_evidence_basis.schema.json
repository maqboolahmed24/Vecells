{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/172_match_evidence_basis.schema.json",
  "title": "MatchEvidenceBasis",
  "description": "Immutable feature and provenance basis for a single patient-link candidate. Evidence values remain behind vault or source-system references; the basis stores normalized features, penalties, missingness, and model versions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "matchEvidenceBasisId",
    "schemaVersion",
    "policyVersion",
    "candidateSetRef",
    "subjectRef",
    "candidatePatientRef",
    "rawEvidenceRefs",
    "normalizedFeatureValues",
    "provenancePenalties",
    "missingnessFlags",
    "calibratorVersionRef",
    "thresholdVersionRef",
    "policyVersionRef",
    "confidenceModelState",
    "driftScore",
    "createdAt"
  ],
  "properties": {
    "matchEvidenceBasisId": {
      "type": "string",
      "pattern": "^meb_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "172.phase2.patient-link.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-patient-link-v[0-9]+$"
    },
    "candidateSetRef": {
      "type": "string"
    },
    "subjectRef": {
      "type": "string"
    },
    "candidatePatientRef": {
      "type": "string"
    },
    "rawEvidenceRefs": {
      "type": "array",
      "minItems": 1,
      "description": "Opaque references to vault or provider evidence. This array never stores evidence payload values.",
      "items": {
        "type": "string"
      }
    },
    "normalizedFeatureValues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nhsNumberHashAgreement",
        "dateOfBirthAgreement",
        "nameSimilarity",
        "postcodeSimilarity",
        "phoneEmailAgreementWithProvenancePenalty",
        "addressTokenSimilarity",
        "sourceReliability",
        "stepUpSupport"
      ],
      "properties": {
        "nhsNumberHashAgreement": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "dateOfBirthAgreement": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "nameSimilarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "postcodeSimilarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "phoneEmailAgreementWithProvenancePenalty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "addressTokenSimilarity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sourceReliability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stepUpSupport": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "provenancePenalties": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["featureName", "penalty", "reasonCode"],
        "properties": {
          "featureName": {
            "type": "string"
          },
          "penalty": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reasonCode": {
            "type": "string",
            "pattern": "^LINK_172_[A-Z0-9_]+$"
          }
        }
      }
    },
    "missingnessFlags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "missing_nhs_number_hash",
          "missing_postcode",
          "missing_contact_claim",
          "missing_pds_demographic_ref",
          "missing_step_up_support",
          "missing_address_tokens"
        ]
      }
    },
    "calibratorVersionRef": {
      "type": "string"
    },
    "thresholdVersionRef": {
      "type": "string"
    },
    "policyVersionRef": {
      "type": "string"
    },
    "confidenceModelState": {
      "type": "string",
      "enum": ["calibrated", "drift_review", "out_of_domain"]
    },
    "driftScore": {
      "type": "number",
      "minimum": 0
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
