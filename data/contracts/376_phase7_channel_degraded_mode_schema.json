{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/376_phase7_channel_degraded_mode_schema.json",
  "title": "ChannelDegradedMode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "modeId",
    "patientDegradedModeProjectionRef",
    "routeFreezeDispositionRef",
    "releaseRecoveryDispositionRef",
    "affectedRoutes",
    "copyVariant",
    "fallbackBehaviour",
    "noticeCopyRef",
    "primaryActionRef",
    "supportCodeRef",
    "activationRule",
    "killSwitchRef",
    "activatedAt"
  ],
  "properties": {
    "modeId": {
      "type": "string"
    },
    "patientDegradedModeProjectionRef": {
      "type": "string"
    },
    "routeFreezeDispositionRef": {
      "type": "string"
    },
    "releaseRecoveryDispositionRef": {
      "type": "string"
    },
    "affectedRoutes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "copyVariant": {
      "type": "string",
      "enum": [
        "read_only",
        "placeholder_only",
        "bounded_recovery",
        "safe_browser_handoff",
        "identity_hold"
      ]
    },
    "fallbackBehaviour": {
      "type": "string"
    },
    "noticeCopyRef": {
      "type": "string"
    },
    "primaryActionRef": {
      "type": "string"
    },
    "supportCodeRef": {
      "type": "string"
    },
    "activationRule": {
      "type": "string"
    },
    "killSwitchRef": {
      "type": "string"
    },
    "activatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
