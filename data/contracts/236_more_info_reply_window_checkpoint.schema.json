{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells/contracts/236_more_info_reply_window_checkpoint.schema.json",
  "title": "MoreInfoReplyWindowCheckpoint",
  "type": "object",
  "required": [
    "checkpointId",
    "cycleId",
    "requestId",
    "requestLineageRef",
    "checkpointRevision",
    "replyWindowState",
    "opensAt",
    "dueAt",
    "lateReviewStartsAt",
    "expiresAt",
    "currentLineageFenceEpoch",
    "createdAt",
    "updatedAt",
    "version"
  ],
  "properties": {
    "checkpointId": { "type": "string" },
    "cycleId": { "type": "string" },
    "requestId": { "type": "string" },
    "requestLineageRef": { "type": "string" },
    "checkpointRevision": { "type": "integer", "minimum": 1 },
    "replyWindowState": {
      "type": "string",
      "enum": [
        "open",
        "reminder_due",
        "late_review",
        "expired",
        "superseded",
        "settled",
        "blocked_repair"
      ]
    },
    "opensAt": { "type": "string", "format": "date-time" },
    "dueAt": { "type": "string", "format": "date-time" },
    "lateReviewStartsAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "nextReminderDueAt": { "type": ["string", "null"], "format": "date-time" },
    "grantNarrowingExpiresAt": { "type": ["string", "null"], "format": "date-time" },
    "repairRequiredReasonRef": { "type": ["string", "null"] },
    "settledAt": { "type": ["string", "null"], "format": "date-time" },
    "supersededAt": { "type": ["string", "null"], "format": "date-time" },
    "currentLineageFenceEpoch": { "type": "integer", "minimum": 0 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": false
}
