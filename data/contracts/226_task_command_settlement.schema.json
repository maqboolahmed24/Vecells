{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/226_task_command_settlement.schema.json",
  "title": "226 TaskCommandSettlement",
  "description": "Workspace-facing receipt over the canonical mutation chain. Local acknowledgement, processing acceptance, external observation, and authoritative outcome are intentionally separate.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "settlementId",
    "taskId",
    "actionScope",
    "governingObjectRef",
    "canonicalObjectDescriptorRef",
    "governingObjectVersionRef",
    "routeIntentTupleHash",
    "routeIntentBindingRef",
    "commandActionRecordRef",
    "commandSettlementRecordRef",
    "transitionEnvelopeRef",
    "releaseRecoveryDispositionRef",
    "result",
    "localAckState",
    "processingAcceptanceState",
    "externalObservationState",
    "authoritativeOutcomeState",
    "settlementRevision",
    "causalToken",
    "recordedAt"
  ],
  "properties": {
    "settlementId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "actionScope": {
      "type": "string",
      "enum": [
        "task_claim",
        "task_release",
        "start_review",
        "resume_review",
        "request_more_info",
        "resolve_duplicate_cluster",
        "select_endpoint",
        "approve",
        "escalate",
        "reopen",
        "close",
        "next_task_launch"
      ]
    },
    "governingObjectRef": {
      "$ref": "#/$defs/id"
    },
    "canonicalObjectDescriptorRef": {
      "$ref": "#/$defs/id"
    },
    "governingObjectVersionRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentTupleHash": {
      "$ref": "#/$defs/id"
    },
    "idempotencyRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "commandActionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "commandSettlementRecordRef": {
      "$ref": "#/$defs/id"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "transitionEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "runtimePublicationBundleRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "releaseRecoveryDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "uiTransitionSettlementRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "uiTelemetryDisclosureFenceRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "presentationArtifactRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "applied",
        "projection_pending",
        "stale_recoverable",
        "denied_scope",
        "review_required"
      ]
    },
    "localAckState": {
      "type": "string",
      "enum": [
        "none",
        "shown",
        "superseded"
      ]
    },
    "processingAcceptanceState": {
      "type": "string",
      "enum": [
        "not_started",
        "accepted_for_processing",
        "awaiting_external_confirmation",
        "externally_accepted",
        "externally_rejected",
        "timed_out"
      ]
    },
    "externalObservationState": {
      "type": "string",
      "enum": [
        "unobserved",
        "projection_visible",
        "external_effect_observed",
        "review_disposition_observed",
        "recovery_observed",
        "disputed",
        "failed",
        "expired"
      ]
    },
    "authoritativeOutcomeState": {
      "type": "string",
      "enum": [
        "pending",
        "projection_pending",
        "review_required",
        "stale_recoverable",
        "recovery_required",
        "settled",
        "failed",
        "expired",
        "superseded"
      ]
    },
    "settlementRevision": {
      "type": "integer",
      "minimum": 0
    },
    "receiptTextRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "recoveryRouteRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-settlementChain": [
    "RouteIntentBinding",
    "CommandActionRecord",
    "CommandSettlementRecord",
    "TransitionEnvelope",
    "ReleaseRecoveryDisposition"
  ],
  "x-governedInvariants": [
    "localAckState is presentation-only and may not stand in for authoritative outcome.",
    "authoritativeOutcomeState must remain semantically aligned to canonical CommandSettlementRecord truth.",
    "stale_recoverable and review_required are same-shell recovery dispositions, not detached error pages."
  ]
}
