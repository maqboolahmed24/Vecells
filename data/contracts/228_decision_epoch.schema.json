{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_decision_epoch.schema.json",
  "title": "228 DecisionEpoch",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "decisionEpochId",
    "taskId",
    "reviewSessionRef",
    "reviewVersionRef",
    "selectedAnchorRef",
    "selectedAnchorTupleHashRef",
    "governingSnapshotRef",
    "compiledPolicyBundleRef",
    "lineageFenceEpoch",
    "ownershipEpochRef",
    "audienceSurfaceRuntimeBindingRef",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "releasePublicationParityRef",
    "workspaceSliceTrustProjectionRef",
    "continuityEvidenceRef",
    "epochState",
    "openedAt"
  ],
  "properties": {
    "decisionEpochId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "reviewSessionRef": {
      "$ref": "#/$defs/id"
    },
    "reviewVersionRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorTupleHashRef": {
      "$ref": "#/$defs/id"
    },
    "governingSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "compiledPolicyBundleRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "ownershipEpochRef": {
      "$ref": "#/$defs/id"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRouteContractRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "releasePublicationParityRef": {
      "$ref": "#/$defs/id"
    },
    "workspaceSliceTrustProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "continuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "epochState": {
      "type": "string",
      "enum": [
        "live",
        "superseded",
        "committed",
        "blocked"
      ]
    },
    "currentEndpointDecisionRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "openedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "supersededAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "committedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "x-governedInvariants": [
    "DecisionEpoch is the only writable fence for endpoint choice, preview, approval, escalation, and downstream seed creation.",
    "A stale, blocked, or superseded epoch may preserve provenance but may not authorize new consequence-bearing actions."
  ]
}
