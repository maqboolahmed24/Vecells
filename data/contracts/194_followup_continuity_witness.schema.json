{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/194_followup_continuity_witness.schema.json",
  "title": "FollowupContinuityWitness",
  "description": "Allow-listed witness proving that late phone or continuation evidence may attach to the same request. Score-only attachment is forbidden.",
  "type": ["object", "null"],
  "additionalProperties": false,
  "required": [
    "witnessClass",
    "witnessRef",
    "requestId",
    "episodeId",
    "routeFenceCurrent",
    "subjectFenceCurrent",
    "verifiedAt",
    "verifiedByRef"
  ],
  "properties": {
    "witnessClass": {
      "type": "string",
      "enum": [
        "active_continuation_lineage",
        "telephony_lineage_authority",
        "operator_confirmed_case_id",
        "same_request_convergence_outcome",
        "human_review_override",
        "none"
      ]
    },
    "witnessRef": { "type": ["string", "null"] },
    "requestId": { "type": ["string", "null"] },
    "episodeId": { "type": ["string", "null"] },
    "requestLineageRef": { "type": ["string", "null"] },
    "sourceLineageRef": { "type": ["string", "null"] },
    "activeContinuationLineageRef": { "type": ["string", "null"] },
    "telephonyLineageRef": { "type": ["string", "null"] },
    "authoritativeRequestContextRef": { "type": ["string", "null"] },
    "operatorConfirmedCaseIdRef": { "type": ["string", "null"] },
    "routeFenceCurrent": { "type": "boolean" },
    "subjectFenceCurrent": { "type": "boolean" },
    "releaseFenceCurrent": { "type": "boolean" },
    "verifiedAt": { "type": "string", "format": "date-time" },
    "verifiedByRef": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": { "properties": { "witnessClass": { "const": "active_continuation_lineage" } } },
      "then": { "required": ["activeContinuationLineageRef"] }
    },
    {
      "if": { "properties": { "witnessClass": { "const": "telephony_lineage_authority" } } },
      "then": { "required": ["telephonyLineageRef", "authoritativeRequestContextRef"] }
    },
    {
      "if": { "properties": { "witnessClass": { "const": "operator_confirmed_case_id" } } },
      "then": { "required": ["operatorConfirmedCaseIdRef", "authoritativeRequestContextRef"] }
    },
    {
      "if": { "properties": { "witnessClass": { "const": "same_request_convergence_outcome" } } },
      "then": { "required": ["authoritativeRequestContextRef"] }
    }
  ]
}
