{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/193_telephony_convergence_command.schema.json",
  "title": "TelephonyConvergenceCommandContract",
  "type": "object",
  "required": [
    "commandId",
    "idempotencyKey",
    "tenantId",
    "sourceLineageRef",
    "ingressChannel",
    "requestType",
    "identityContext",
    "sourceTimestamp",
    "channelCapabilityCeiling",
    "contactAuthorityClass"
  ],
  "properties": {
    "commandId": { "type": "string", "minLength": 1 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "sourceLineageRef": { "type": "string", "minLength": 1 },
    "submissionEnvelopeRef": { "type": ["string", "null"] },
    "requestLineageRef": { "type": ["string", "null"] },
    "ingressChannel": {
      "type": "string",
      "enum": [
        "self_service_form",
        "telephony_capture",
        "secure_link_continuation",
        "support_assisted_capture"
      ]
    },
    "surfaceChannelProfile": {
      "type": ["string", "null"],
      "enum": ["browser", "embedded", "telephony", "secure_link", "support_console", null]
    },
    "captureAuthorityClass": {
      "type": "string",
      "enum": [
        "patient_self_entered",
        "patient_spoken",
        "patient_verified_reply",
        "support_assisted",
        "staff_transcribed"
      ]
    },
    "requestType": { "type": "string", "enum": ["Symptoms", "Meds", "Admin", "Results"] },
    "narratives": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "web": { "type": ["string", "null"] },
        "spoken": { "type": ["string", "null"] },
        "transcript": { "type": ["string", "null"] },
        "keypad": { "type": ["string", "null"] },
        "continuation": { "type": ["string", "null"] },
        "support": { "type": ["string", "null"] }
      }
    },
    "structuredAnswers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "identityContext": {
      "type": "object",
      "required": [
        "bindingState",
        "subjectRefPresence",
        "claimResumeState",
        "actorBindingState",
        "identityEvidenceRefs",
        "contactRouteEvidenceRefs"
      ],
      "properties": {
        "bindingState": {
          "type": "string",
          "enum": ["anonymous", "partial", "verified", "uplift_pending", "identity_repair_required"]
        },
        "subjectRefPresence": { "type": "string", "enum": ["none", "masked", "bound"] },
        "claimResumeState": {
          "type": "string",
          "enum": ["not_required", "pending", "granted", "blocked"]
        },
        "actorBindingState": {
          "type": "string",
          "enum": ["anonymous", "partial", "verified", "uplift_pending", "identity_repair_required"]
        },
        "identityEvidenceRefs": { "type": "array", "items": { "type": "string" } },
        "contactRouteEvidenceRefs": { "type": "array", "items": { "type": "string" } },
        "authorityBindingRef": { "type": ["string", "null"] }
      }
    },
    "attachmentRefs": { "type": "array", "items": { "type": "string" } },
    "audioRefs": { "type": "array", "items": { "type": "string" } },
    "contactPreferencesRef": { "type": ["string", "null"] },
    "sourceTimestamp": { "type": "string", "format": "date-time" },
    "patientMatchConfidenceRef": { "type": ["string", "null"] },
    "evidenceReadinessState": {
      "type": "string",
      "enum": [
        "evidence_pending",
        "urgent_live_only",
        "safety_usable",
        "manual_review_only",
        "unusable_terminal"
      ]
    },
    "channelCapabilityCeiling": {
      "type": "object",
      "required": [
        "canUploadFiles",
        "canRenderTrackStatus",
        "canRenderEmbedded",
        "mutatingResumeState",
        "maxDisclosurePosture"
      ],
      "properties": {
        "canUploadFiles": { "type": "boolean" },
        "canRenderTrackStatus": { "type": "boolean" },
        "canRenderEmbedded": { "type": "boolean" },
        "mutatingResumeState": {
          "type": "string",
          "enum": ["allowed", "rebind_required", "blocked"]
        },
        "maxDisclosurePosture": {
          "type": "string",
          "enum": ["full_self_service", "minimal_secure_link", "support_console", "manual_only"]
        }
      }
    },
    "contactAuthorityClass": {
      "type": "string",
      "enum": [
        "self_asserted",
        "nhs_login_claim",
        "verified_destination",
        "authority_confirmed",
        "support_attested"
      ]
    },
    "receiptSeedRef": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
