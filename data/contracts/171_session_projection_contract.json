{
  "schemaVersion": "171.phase2.auth-session.v1",
  "policyVersion": "phase2-auth-session-v1",
  "surfaceMode": "Auth_Return_Journey_Board",
  "projectionPostures": [
    {
      "posture": "signed_in",
      "sessionDecision": "create_fresh",
      "writableAuthorityState": "writable",
      "dominantAction": "Continue to your account",
      "copyKey": "AUTH_171_COPY_SIGNED_IN_READY",
      "revealPolicy": "masked_account_shell_only_until_patient_link_succeeds",
      "routeIntentDisposition": "bind_current_route_intent"
    },
    {
      "posture": "claim_pending",
      "sessionDecision": "bounded_recovery",
      "writableAuthorityState": "read_only",
      "dominantAction": "Confirm this request",
      "copyKey": "AUTH_171_COPY_CLAIM_PENDING",
      "revealPolicy": "no_phi_before_binding_authority_accepts_claim",
      "routeIntentDisposition": "same_shell_claim_review"
    },
    {
      "posture": "read_only",
      "sessionDecision": "reuse_existing",
      "writableAuthorityState": "read_only",
      "dominantAction": "View safely",
      "copyKey": "AUTH_171_COPY_READ_ONLY",
      "revealPolicy": "read_only_summary_with_claim_evidence_suppressed",
      "routeIntentDisposition": "preserve_last_safe_anchor"
    },
    {
      "posture": "re_auth_required",
      "sessionDecision": "bounded_recovery",
      "writableAuthorityState": "blocked",
      "dominantAction": "Sign in again",
      "copyKey": "AUTH_171_COPY_RE_AUTH_REQUIRED",
      "revealPolicy": "no_writable_or_phi_rich_reveal",
      "routeIntentDisposition": "same_shell_re_auth"
    },
    {
      "posture": "session_expired",
      "sessionDecision": "bounded_recovery",
      "writableAuthorityState": "blocked",
      "dominantAction": "Return to sign in",
      "copyKey": "AUTH_171_COPY_SESSION_EXPIRED",
      "revealPolicy": "preserve_last_safe_summary_only",
      "routeIntentDisposition": "safe_re_entry"
    },
    {
      "posture": "consent_declined",
      "sessionDecision": "bounded_recovery",
      "writableAuthorityState": "blocked",
      "dominantAction": "Continue without sharing details",
      "copyKey": "AUTH_171_COPY_CONSENT_DECLINED",
      "revealPolicy": "no_identity_claims_received",
      "routeIntentDisposition": "same_shell_recovery"
    },
    {
      "posture": "subject_conflict",
      "sessionDecision": "deny",
      "writableAuthorityState": "blocked",
      "dominantAction": "Get help with this account",
      "copyKey": "AUTH_171_COPY_SUBJECT_CONFLICT",
      "revealPolicy": "no_patient_specific_reveal",
      "routeIntentDisposition": "identity_hold"
    },
    {
      "posture": "stale_return",
      "sessionDecision": "bounded_recovery",
      "writableAuthorityState": "blocked",
      "dominantAction": "Start from the latest safe step",
      "copyKey": "AUTH_171_COPY_STALE_RETURN",
      "revealPolicy": "last_safe_anchor_only",
      "routeIntentDisposition": "reject_stale_binding"
    },
    {
      "posture": "bounded_recovery",
      "sessionDecision": "bounded_recovery",
      "writableAuthorityState": "blocked",
      "dominantAction": "Choose a safe next step",
      "copyKey": "AUTH_171_COPY_BOUNDED_RECOVERY",
      "revealPolicy": "no_phi_no_technical_identifiers",
      "routeIntentDisposition": "bounded_safe_options"
    }
  ],
  "nhsLoginButtonRule": {
    "placement": "primary action in pre-auth entry and re-auth pages",
    "styleRule": "standard NHS login button placement; do not restyle or split the button",
    "trustNote": "Use one short trust note adjacent to the button; no security-theatre clutter."
  },
  "holdingScreenRule": {
    "copyKey": "AUTH_171_COPY_CALLBACK_HOLDING",
    "motionBudgetMs": 140,
    "meaning": "Carefully confirming sign-in details inside the governed shell; not a generic spinner."
  },
  "gapClosures": [
    "GAP_RESOLVED_PHASE2_AUTH_DEDICATED_BRIDGE_CONTRACT_V1",
    "GAP_RESOLVED_PHASE2_AUTH_GOVERNED_RETURN_INTENT_V1",
    "GAP_RESOLVED_PHASE2_AUTH_SESSION_DECISION_PATH_V1",
    "GAP_RESOLVED_PHASE2_AUTH_TERMINATION_PROJECTION_V1",
    "GAP_RESOLVED_PHASE2_AUTH_UI_GRAMMAR_V1"
  ]
}
