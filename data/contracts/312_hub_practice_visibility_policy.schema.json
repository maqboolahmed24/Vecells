{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_hub_practice_visibility_policy.schema.json",
  "title": "HubPracticeVisibilityPolicy",
  "description": "Policy family that freezes minimum-necessary origin-practice visibility and acknowledgement-debt generation without touching candidate order.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "practiceVisibilityPolicyId",
    "policyVersion",
    "policyTupleHash",
    "minimumNecessaryContractRef",
    "originPracticeVisibleFieldRefs",
    "visibilityDeltaRule",
    "ackGenerationMode",
    "practiceVisibilityDisposition",
    "sourceRefs"
  ],
  "properties": {
    "practiceVisibilityPolicyId": {
      "type": "string",
      "minLength": 1,
      "description": "Practice-visibility policy identifier."
    },
    "policyVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Policy version."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Compiled tuple hash."
    },
    "minimumNecessaryContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Ref to the minimum-necessary contract."
    },
    "originPracticeVisibleFieldRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Fields visible to the origin practice."
    },
    "hiddenFieldRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Fields that must remain hidden from the origin practice."
    },
    "visibilityDeltaRule": {
      "type": "string",
      "minLength": 1,
      "description": "Rule ref for visibility delta generation."
    },
    "ackGenerationMode": {
      "type": "string",
      "enum": [
        "generation_bound",
        "generation_bound_with_exception"
      ],
      "description": "Generation model for acknowledgement debt."
    },
    "practiceVisibilityDisposition": {
      "type": "string",
      "enum": [
        "standard_origin_visibility",
        "visibility_restricted",
        "ack_debt_open",
        "delta_required"
      ],
      "description": "Resolved practice-visibility posture."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
