{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/190_recording_asset_quarantine_assessment.schema.json",
  "title": "RecordingAssetQuarantineAssessmentContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "quarantineAssessmentRef",
    "schemaVersion",
    "policyVersion",
    "recordingFetchJobRef",
    "callSessionRef",
    "providerRecordingRef",
    "quarantineObjectRef",
    "mediaFamily",
    "detectedMediaType",
    "byteSize",
    "durationSeconds",
    "checksumSha256",
    "transportIntegrityState",
    "providerAuthenticityState",
    "formatPolicyState",
    "malwareScanState",
    "quarantineOutcome",
    "manualReviewDispositionRef",
    "reasonCodes",
    "assessedAt",
    "recordedBy"
  ],
  "properties": {
    "quarantineAssessmentRef": {
      "type": "string",
      "pattern": "^tel_recording_quarantine_assessment_190_"
    },
    "schemaVersion": { "const": "190.phase2.recording-ingest.v1" },
    "policyVersion": { "const": "phase2-audio-format-scan-policy-190.v1" },
    "recordingFetchJobRef": { "type": "string" },
    "callSessionRef": { "type": "string" },
    "providerRecordingRef": { "type": "string" },
    "quarantineObjectRef": { "type": ["string", "null"] },
    "mediaFamily": { "const": "audio" },
    "detectedMediaType": { "type": ["string", "null"] },
    "byteSize": { "type": ["integer", "null"], "minimum": 0 },
    "durationSeconds": { "type": ["integer", "null"], "minimum": 0 },
    "checksumSha256": { "type": ["string", "null"] },
    "transportIntegrityState": { "enum": ["passed", "failed", "not_supplied"] },
    "providerAuthenticityState": { "enum": ["passed", "failed"] },
    "formatPolicyState": { "enum": ["allowed", "unsupported", "size_or_duration_exceeded"] },
    "malwareScanState": { "enum": ["clean", "malware", "unreadable", "scanner_timeout"] },
    "quarantineOutcome": {
      "enum": [
        "clean",
        "retryable_hold",
        "blocked_malware",
        "blocked_integrity",
        "blocked_unsupported_format",
        "blocked_missing",
        "blocked_size_duration",
        "blocked_provider_ref_mismatch"
      ]
    },
    "manualReviewDispositionRef": { "type": ["string", "null"] },
    "reasonCodes": { "type": "array", "items": { "type": "string" } },
    "assessedAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyRecordingIngestPipeline" }
  }
}
