  "providerFamilies": [
    {
      "family": "telephony",
      "displayName": "Telephony voice and IVR",
      "mockProvider": "vecells_internal_voice_twin",
      "actualCandidates": ["twilio_voice", "vonage_voice"],
      "callbackTargets": [
        {
          "endpointId": "edge.signal.telephony.provider_callback.v1",
          "callbackUrlPath": "/edge/signal/telephony/provider-callback",
          "endpointScope": "edge",
          "environmentIds": ["local", "sandbox_twin", "provider_candidate", "live_candidate"],
          "adapterContractRef": "docs/api/187_telephony_provider_webhook_contract.md",
          "acceptsProviderPayload": true,
          "downstreamPayload": "NormalizedTelephonyEvent",
          "requiredEvents": [
            "call_status_initiated",
            "call_status_ringing",
            "call_status_answered",
            "ivr_gather_completed",
            "call_status_completed",
            "recording_status_available",
            "recording_status_failed"
          ]
        }
      ],
      "signatureVerification": {
        "required": true,
        "providerSchemes": [
          {
            "provider": "vecells_internal_voice_twin",
            "scheme": "vecells-hmac-sha256",
            "requiredHeadersOrFields": [
              "x-vecells-simulator-signature",
              "x-vecells-simulator-timestamp"
            ],
            "credentialRef": "credential://phase2/signal/voice-twin/hmac"
          },
          {
            "provider": "twilio_voice",
            "scheme": "twilio-request-validator",
            "requiredHeadersOrFields": ["x-twilio-signature", "raw-url", "raw-form-or-body"],
            "credentialRef": "credential://phase2/signal/twilio/auth-token"
          },
          {
            "provider": "vonage_voice",
            "scheme": "vonage-signed-request",
            "requiredHeadersOrFields": ["authorization-or-signature", "timestamp-or-jwt-claims"],
            "credentialRef": "credential://phase2/signal/vonage/signing-material"
          }
        ],
        "missingSignatureOutcome": "reject_401_quarantine_raw_receipt_no_normalized_event"
      },
      "replayProtection": {
        "required": true,
        "replayWindowSeconds": 300,
        "idempotencyKey": "provider|provider_event_id|provider_call_id|event_type|occurred_at",
        "collisionOutcome": "reject_same_key_different_digest"
      },
      "eventSubscriptions": [
        {
          "eventKey": "call_status_initiated",
          "mandatory": true,
          "canonicalEvent": "call_started",
          "authoritativeEffect": "open_call_session"
        },
        {
          "eventKey": "call_status_ringing",
          "mandatory": true,
          "canonicalEvent": "call_started",
          "authoritativeEffect": "preserve_provider_progress"
        },
        {
          "eventKey": "call_status_answered",
