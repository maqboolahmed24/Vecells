{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase2/188_call_session_timeout_policy.schema.json",
  "title": "CallSessionTimeoutPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policyVersionRef",
    "menuSelectedTimeoutSeconds",
    "identityInProgressTimeoutSeconds",
    "recordingExpectedTimeoutSeconds",
    "timeoutClock",
    "timeoutDisposition",
    "createdByAuthority"
  ],
  "properties": {
    "schemaVersion": { "const": "188.phase2.call-session-timeout-policy.v1" },
    "policyVersionRef": { "const": "phase2-call-session-timeout-policy-188.v1" },
    "menuSelectedTimeoutSeconds": { "const": 180 },
    "identityInProgressTimeoutSeconds": { "const": 240 },
    "recordingExpectedTimeoutSeconds": { "const": 600 },
    "timeoutClock": { "const": "last_state_transition_updated_at" },
    "timeoutDisposition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["menu_selected", "identity_in_progress", "recording_expected"],
      "properties": {
        "menu_selected": { "const": "abandoned" },
        "identity_in_progress": { "const": "manual_followup_required" },
        "recording_expected": { "const": "recording_missing" }
      }
    },
    "createdByAuthority": { "const": "TelephonyCallSessionService" }
  }
}
