{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/phase1/draft-session-lease.schema.json",
  "title": "DraftSessionLease",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "leaseId",
    "draftPublicId",
    "leaseMode",
    "leaseState",
    "routeFamilyRef",
    "routeIntentBindingRef",
    "audienceSurfaceRuntimeBindingRef",
    "releaseApprovalFreezeRef",
    "channelReleaseFreezeState",
    "manifestVersionRef",
    "leaseEpoch",
    "fencingToken",
    "governingEnvelopeVersion",
    "acquiredAt",
    "expiresAt"
  ],
  "properties": {
    "leaseId": {
      "type": "string"
    },
    "draftPublicId": {
      "type": "string",
      "pattern": "^dft_[a-z0-9]{10,32}$"
    },
    "leaseMode": {
      "type": "string",
      "enum": ["foreground_mutating", "background_read_only"]
    },
    "leaseState": {
      "type": "string",
      "enum": ["live", "superseded", "expired", "released"]
    },
    "routeFamilyRef": {
      "type": "string"
    },
    "routeIntentBindingRef": {
      "type": "string"
    },
    "audienceSurfaceRuntimeBindingRef": {
      "type": "string"
    },
    "releaseApprovalFreezeRef": {
      "type": "string"
    },
    "channelReleaseFreezeState": {
      "type": "string",
      "enum": ["released", "monitoring", "frozen"]
    },
    "manifestVersionRef": {
      "type": "string"
    },
    "sessionEpochRef": {
      "type": ["string", "null"]
    },
    "subjectBindingVersionRef": {
      "type": ["string", "null"]
    },
    "subjectRef": {
      "type": ["string", "null"]
    },
    "leaseEpoch": {
      "type": "integer",
      "minimum": 1
    },
    "fencingToken": {
      "type": "string"
    },
    "governingEnvelopeVersion": {
      "type": "integer",
      "minimum": 1
    },
    "acquiredAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "supersededAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "supersededByLeaseRef": {
      "type": ["string", "null"]
    },
    "releaseReason": {
      "type": ["string", "null"]
    },
    "recoveryRecordRef": {
      "type": ["string", "null"]
    }
  }
}
