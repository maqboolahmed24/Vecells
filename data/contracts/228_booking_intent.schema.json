{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_booking_intent.schema.json",
  "title": "228 BookingIntent",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "intentId",
    "episodeRef",
    "requestId",
    "requestLineageRef",
    "sourceTriageTaskRef",
    "lineageCaseLinkRef",
    "priorityBand",
    "timeframe",
    "modality",
    "clinicianType",
    "continuityPreference",
    "accessNeeds",
    "patientPreferenceSummary",
    "createdFromDecisionId",
    "decisionEpochRef",
    "decisionSupersessionRecordRef"
  ],
  "properties": {
    "intentId": {
      "$ref": "#/$defs/id"
    },
    "episodeRef": {
      "$ref": "#/$defs/id"
    },
    "requestId": {
      "$ref": "#/$defs/id"
    },
    "requestLineageRef": {
      "$ref": "#/$defs/id"
    },
    "sourceTriageTaskRef": {
      "$ref": "#/$defs/id"
    },
    "lineageCaseLinkRef": {
      "$ref": "#/$defs/id"
    },
    "priorityBand": {
      "type": "string"
    },
    "timeframe": {
      "type": "string"
    },
    "modality": {
      "type": "string"
    },
    "clinicianType": {
      "type": "string"
    },
    "continuityPreference": {
      "type": "string"
    },
    "accessNeeds": {
      "type": "string"
    },
    "patientPreferenceSummary": {
      "type": "string"
    },
    "createdFromDecisionId": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "x-governedInvariants": [
    "BookingIntent must echo the current DecisionEpoch and fail closed after supersession.",
    "Booking handoff seeds are forward-stable contracts, not browser-local launch payloads."
  ]
}
