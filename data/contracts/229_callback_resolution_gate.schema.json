{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_callback_resolution_gate.schema.json",
  "title": "229 CallbackResolutionGate",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "resolutionGateId",
    "callbackCaseRef",
    "latestAttemptRef",
    "latestOutcomeEvidenceRef",
    "latestExpectationEnvelopeRef",
    "decision",
    "decisionReasonRef",
    "nextActionAt",
    "stalePromiseRevocationRef",
    "requiresLifecycleReview",
    "causalToken",
    "monotoneRevision"
  ],
  "properties": {
    "resolutionGateId": {
      "$ref": "#/$defs/id"
    },
    "callbackCaseRef": {
      "$ref": "#/$defs/id"
    },
    "latestAttemptRef": {
      "$ref": "#/$defs/id"
    },
    "latestOutcomeEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "latestExpectationEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "decision": {
      "type": "string",
      "enum": [
        "retry",
        "escalate",
        "complete",
        "cancel",
        "expire"
      ]
    },
    "decisionReasonRef": {
      "$ref": "#/$defs/id"
    },
    "nextActionAt": {
      "$ref": "#/$defs/dateTime"
    },
    "stalePromiseRevocationRef": {
      "$ref": "#/$defs/id"
    },
    "requiresLifecycleReview": {
      "type": "boolean"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    }
  },
  "x-governedInvariants": [
    "CallbackResolutionGate is the sole authority for retry, escalation, completion, cancel, or expiry.",
    "It must revoke stale callback promise envelopes and block terminal closure while reachability repair, safety preemption, or unsettled callback evidence remains."
  ]
}
