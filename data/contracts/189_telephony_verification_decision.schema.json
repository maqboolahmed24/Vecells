{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/189_telephony_verification_decision.schema.json",
  "title": "TelephonyVerificationDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "telephonyVerificationDecisionRef",
    "schemaVersion",
    "policyVersion",
    "callSessionRef",
    "routeSensitivity",
    "outcome",
    "thresholdProfileRef",
    "calibrationVersionRefs",
    "identityConfidenceAssessmentRef",
    "destinationConfidenceAssessmentRef",
    "candidateSetRef",
    "bestCandidateRef",
    "runnerUpCandidateRef",
    "lowerBoundsUsed",
    "thresholdValues",
    "reasonCodes",
    "nextAllowedContinuationPosture",
    "submittedEvidencePackageRef",
    "authoritySubmissionRef",
    "localBindingMutation",
    "decidedAt"
  ],
  "properties": {
    "telephonyVerificationDecisionRef": { "type": "string", "pattern": "^tvd_" },
    "schemaVersion": { "const": "189.phase2.telephony-verification.v1" },
    "policyVersion": { "const": "phase2-telephony-verification-189.v1" },
    "callSessionRef": { "type": "string" },
    "routeSensitivity": { "type": "string" },
    "outcome": {
      "enum": [
        "telephony_verified_seeded",
        "telephony_verified_challenge",
        "manual_followup_required",
        "identity_failed",
        "insufficient_calibration",
        "destination_untrusted",
        "ambiguous_candidate_set"
      ]
    },
    "thresholdProfileRef": { "type": "string" },
    "calibrationVersionRefs": { "type": "array", "items": { "type": "string" } },
    "identityConfidenceAssessmentRef": { "type": ["string", "null"] },
    "destinationConfidenceAssessmentRef": { "type": ["string", "null"] },
    "candidateSetRef": { "type": ["string", "null"] },
    "bestCandidateRef": { "type": ["string", "null"] },
    "runnerUpCandidateRef": { "type": ["string", "null"] },
    "lowerBoundsUsed": {
      "type": "object",
      "required": [
        "LCB_id_alpha",
        "UCB_runner_up_alpha",
        "LCB_dest_alpha",
        "seededLowerBound",
        "gap_id"
      ],
      "properties": {
        "LCB_id_alpha": { "type": "number" },
        "UCB_runner_up_alpha": { "type": "number" },
        "LCB_dest_alpha": { "type": "number" },
        "seededLowerBound": { "type": "number" },
        "gap_id": { "type": "number" }
      }
    },
    "thresholdValues": {
      "type": "object",
      "required": [
        "tau_id",
        "tau_runner_up",
        "delta_id",
        "tau_dest",
        "tau_seeded",
        "tau_challenge",
        "tau_runner_up_challenge",
        "delta_challenge"
      ]
    },
    "reasonCodes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TEL_VERIFY_189_" }
    },
    "nextAllowedContinuationPosture": {
      "enum": [
        "seeded_continuation_candidate",
        "challenge_continuation_only",
        "manual_followup_only",
        "no_continuation"
      ]
    },
    "submittedEvidencePackageRef": { "type": ["string", "null"] },
    "authoritySubmissionRef": { "type": ["string", "null"] },
    "localBindingMutation": { "const": "forbidden" },
    "decidedAt": { "type": "string", "format": "date-time" }
  }
}
