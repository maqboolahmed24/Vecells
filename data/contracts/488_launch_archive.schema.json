{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/488_launch_archive.schema.json",
  "title": "Task 488 Launch evidence archive contract",
  "type": "object",
  "required": ["recordType", "taskId", "schemaVersion", "generatedAt", "recordHash"],
  "properties": {
    "recordType": {
      "type": "string"
    },
    "taskId": {
      "const": "seq_488"
    },
    "schemaVersion": {
      "const": "488.programme.launch-evidence-archive.v1"
    },
    "archiveVerdict": {
      "enum": ["sealed", "sealed_with_exceptions", "blocked"]
    },
    "blockerRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recordHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}
