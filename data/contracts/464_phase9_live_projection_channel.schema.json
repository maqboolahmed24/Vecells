{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase9/464_live_projection_channel.schema.json",
  "title": "Phase 9 live projection channel contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "channelId",
    "surfaceCode",
    "route",
    "tenantRef",
    "environmentRef",
    "routeFamilyRef",
    "scopeTupleHash",
    "runtimePublicationBundleRef",
    "projectionContractVersion",
    "expectedProjectionContractVersion",
    "surfaceBindingRef",
    "queryContractRef",
    "liveUpdateChannelRef",
    "cachePolicyRef",
    "telemetryDisclosureFenceRef",
    "rawEventBrowserJoinAllowed",
    "rawDomainEventPayloadAllowed",
    "requiresRuntimeBinding",
    "failureMode",
    "reconnectPolicy",
    "cleanupRef",
    "subscriptionKey"
  ],
  "properties": {
    "schemaVersion": {
      "const": "464.phase9.live-projection-channel.v1"
    },
    "channelId": {
      "type": "string",
      "pattern": "^live-channel-464-"
    },
    "surfaceCode": {
      "enum": [
        "operations_overview",
        "assurance_center",
        "audit_explorer",
        "resilience_board",
        "incident_desk",
        "records_governance",
        "tenant_governance",
        "access_studio",
        "compliance_ledger",
        "conformance_scorecard"
      ]
    },
    "route": {
      "type": "string",
      "pattern": "^/ops"
    },
    "tenantRef": {
      "type": "string",
      "minLength": 1
    },
    "environmentRef": {
      "type": "string",
      "minLength": 1
    },
    "routeFamilyRef": {
      "enum": ["rf_ops_shell", "rf_governance_shell"]
    },
    "scopeTupleHash": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "runtimePublicationBundleRef": {
      "type": "string",
      "pattern": "^runtime-publication-bundle:"
    },
    "projectionContractVersion": {
      "type": "string",
      "pattern": "^projection-contract:"
    },
    "expectedProjectionContractVersion": {
      "type": "string",
      "pattern": "^projection-contract:"
    },
    "surfaceBindingRef": {
      "type": "string",
      "minLength": 1
    },
    "queryContractRef": {
      "type": "string",
      "pattern": "^projection-query-contract:"
    },
    "liveUpdateChannelRef": {
      "type": "string",
      "pattern": "^live-update-channel-contract:"
    },
    "cachePolicyRef": {
      "type": "string",
      "pattern": "^client-cache-policy:"
    },
    "telemetryDisclosureFenceRef": {
      "const": "UITelemetryDisclosureFence"
    },
    "rawEventBrowserJoinAllowed": {
      "const": false
    },
    "rawDomainEventPayloadAllowed": {
      "const": false
    },
    "requiresRuntimeBinding": {
      "const": true
    },
    "failureMode": {
      "enum": [
        "block_on_missing_projection_version",
        "block_on_missing_runtime_binding",
        "slice_bounded_quarantine"
      ]
    },
    "reconnectPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxBufferedBatchCount", "reconnectBackoffMs", "staleAfterMs"],
      "properties": {
        "maxBufferedBatchCount": {
          "const": 4
        },
        "reconnectBackoffMs": {
          "type": "array",
          "prefixItems": [{ "const": 250 }, { "const": 750 }, { "const": 1500 }],
          "minItems": 3,
          "maxItems": 3
        },
        "staleAfterMs": {
          "const": 45000
        }
      }
    },
    "cleanupRef": {
      "type": "string",
      "pattern": "^subscription-cleanup:phase9:"
    },
    "subscriptionKey": {
      "type": "string",
      "pattern": "^sha256:"
    }
  }
}
