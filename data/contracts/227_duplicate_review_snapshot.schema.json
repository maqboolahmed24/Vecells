{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/227_duplicate_review_snapshot.schema.json",
  "title": "227 DuplicateReviewSnapshot",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "duplicateReviewSnapshotId",
    "taskId",
    "duplicateClusterRef",
    "candidateRequestRefs",
    "pairEvidenceRefs",
    "currentResolutionDecisionRef",
    "continuityWitnessSummaryRef",
    "instabilityState",
    "authorityBoundary",
    "lastRenderedAt"
  ],
  "properties": {
    "duplicateReviewSnapshotId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "duplicateClusterRef": {
      "$ref": "#/$defs/id"
    },
    "candidateRequestRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "pairEvidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "winningPairEvidenceRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "competingPairEvidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "currentResolutionDecisionRef": {
      "$ref": "#/$defs/id"
    },
    "continuityWitnessSummaryRef": {
      "$ref": "#/$defs/id"
    },
    "instabilityState": {
      "type": "string",
      "enum": [
        "stable",
        "oscillating",
        "blocked_conflict"
      ]
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duplicateClusterAuthority",
        "sameRequestAttachAuthority",
        "replayAuthority",
        "reviewProjectionMode"
      ],
      "properties": {
        "duplicateClusterAuthority": {
          "type": "string",
          "const": "DuplicateCluster"
        },
        "sameRequestAttachAuthority": {
          "type": "string",
          "const": "DuplicateResolutionDecision"
        },
        "replayAuthority": {
          "type": "string",
          "const": "IdempotencyRecord"
        },
        "reviewProjectionMode": {
          "type": "string",
          "const": "phase0_projection_reuse"
        }
      }
    },
    "lastRenderedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "DuplicateReviewSnapshot is a projection over canonical Phase 0 duplicate authority, not a narrower triage-local replacement.",
    "Replay recognition, same-request attach, and duplicate-cluster review are separate authorities."
  ]
}
