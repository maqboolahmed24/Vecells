{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/235_evidence_delta_packet.schema.json",
  "title": "235 EvidenceDeltaPacket",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "evidenceDeltaPacketId",
    "taskId",
    "baselineSnapshotRef",
    "currentSnapshotRef",
    "deltaClass",
    "changedFieldRefs",
    "contradictionRefs",
    "actionInvalidations",
    "changes",
    "summaryDeltaRef",
    "primaryChangedAnchorRef",
    "supersededJudgmentContext",
    "supersessionMarkerRefs",
    "acknowledgementState",
    "returnToQuietEligibility",
    "requiresExplicitReview",
    "deltaDigest",
    "generatedAt"
  ],
  "properties": {
    "evidenceDeltaPacketId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "baselineSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "currentSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "deltaClass": {
      "type": "string",
      "enum": [
        "decisive",
        "consequential",
        "contextual",
        "clerical"
      ]
    },
    "changedFieldRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "contradictionRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "actionInvalidations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "invalidationRef",
          "invalidationType",
          "priorRef",
          "currentRef",
          "reason"
        ],
        "properties": {
          "invalidationRef": {
            "$ref": "#/$defs/id"
          },
          "invalidationType": {
            "type": "string",
            "enum": [
              "endpoint_assumption_drift",
              "approval_posture_changed",
              "ownership_changed",
              "duplicate_lineage_supersession",
              "decision_epoch_supersession"
            ]
          },
          "priorRef": {
            "type": [
              "string",
              "null"
            ]
          },
          "currentRef": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "supersededJudgmentContext": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "contextRef",
          "contextType",
          "priorRef",
          "currentRef",
          "reason"
        ],
        "properties": {
          "contextRef": {
            "$ref": "#/$defs/id"
          },
          "contextType": {
            "type": "string",
            "enum": [
              "endpoint_assumption",
              "approval_posture",
              "ownership",
              "duplicate_lineage",
              "decision_epoch"
            ]
          },
          "priorRef": {
            "$ref": "#/$defs/id"
          },
          "currentRef": {
            "type": [
              "string",
              "null"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summaryDeltaRef": {
      "$ref": "#/$defs/id"
    },
    "primaryChangedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "supersessionMarkerRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "acknowledgementState": {
      "type": "string",
      "enum": [
        "pending_review",
        "acknowledged",
        "recommit_required"
      ]
    },
    "returnToQuietEligibility": {
      "type": "string",
      "enum": [
        "blocked",
        "on_ack",
        "on_resolve"
      ]
    },
    "requiresExplicitReview": {
      "type": "boolean"
    },
    "deltaDigest": {
      "$ref": "#/$defs/id"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-governedInvariants": [
    "EvidenceDeltaPacket is the only changed-since-seen contract for resumed review.",
    "Superseded judgment context may not disappear when new evidence lands.",
    "DecisionEpoch supersession and duplicate reversal must invalidate preview-coupled assumptions explicitly."
  ]
}
