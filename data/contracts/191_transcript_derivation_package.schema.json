{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/191_transcript_derivation_package.schema.json",
  "title": "TranscriptDerivationPackageContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "derivationPackageRef",
    "schemaVersion",
    "callSessionRef",
    "transcriptJobRef",
    "captureBundleRef",
    "derivationClass",
    "inputArtifactRefs",
    "derivationVersionRef",
    "outputRef",
    "outputHash",
    "transcriptArtifactRef",
    "transcriptArtifactDigest",
    "materialityClass",
    "supersedesDerivationPackageRef",
    "derivedAt",
    "recordedBy"
  ],
  "properties": {
    "derivationPackageRef": { "type": "string", "pattern": "^evidence_derivation_package_191_" },
    "schemaVersion": { "const": "191.phase2.telephony-readiness.v1" },
    "callSessionRef": { "type": "string" },
    "transcriptJobRef": { "type": "string" },
    "captureBundleRef": { "type": "string" },
    "derivationClass": { "const": "telephony_transcript_and_fact_extraction" },
    "inputArtifactRefs": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
    "derivationVersionRef": { "const": "phase2-telephony-fact-extractor-191.v1" },
    "outputRef": { "type": "string" },
    "outputHash": { "type": "string" },
    "transcriptArtifactRef": { "type": "string", "pattern": "^artifact://telephony-transcript/" },
    "transcriptArtifactDigest": { "type": "string" },
    "materialityClass": { "const": "clinically_material" },
    "supersedesDerivationPackageRef": { "type": ["string", "null"] },
    "derivedAt": { "type": "string", "format": "date-time" },
    "recordedBy": { "const": "TelephonyReadinessPipeline" }
  }
}
