{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/374_phase7_nhs_app_integration_manifest_schema.json",
  "title": "NHSAppIntegrationManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestId",
    "manifestVersion",
    "baseUrlsByEnvironment",
    "allowedJourneyPaths",
    "jumpOffMappings",
    "requiresNhsLogin",
    "supportsEmbeddedMode",
    "minimumBridgeCapabilitiesRef",
    "telemetryContractRef",
    "cohortRules",
    "serviceDeskProfileRef",
    "evidencePackRef",
    "configFingerprint",
    "releaseCandidateRef",
    "releaseApprovalFreezeRef",
    "behaviorContractSetRef",
    "surfaceSchemaSetRef",
    "compatibilityEvidenceRef",
    "approvedAt",
    "supersedesManifestId",
    "changeNoticeRef",
    "currentReleaseState"
  ],
  "properties": {
    "manifestId": {
      "type": "string",
      "minLength": 1
    },
    "manifestVersion": {
      "type": "string",
      "minLength": 1
    },
    "baseUrlsByEnvironment": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "format": "uri"
      },
      "required": ["local_preview", "sandpit", "aos", "limited_release", "full_release"]
    },
    "allowedJourneyPaths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "jumpOffMappings": {
      "type": "array",
      "items": {
        "$ref": "374_phase7_jump_off_mapping_schema.json"
      },
      "minItems": 1
    },
    "requiresNhsLogin": {
      "type": "boolean",
      "const": true
    },
    "supportsEmbeddedMode": {
      "type": "boolean",
      "const": true
    },
    "minimumBridgeCapabilitiesRef": {
      "type": "string",
      "minLength": 1
    },
    "telemetryContractRef": {
      "type": "string",
      "minLength": 1
    },
    "cohortRules": {
      "type": "object"
    },
    "serviceDeskProfileRef": {
      "type": "string",
      "minLength": 1
    },
    "evidencePackRef": {
      "type": "string",
      "minLength": 1
    },
    "configFingerprint": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "releaseCandidateRef": {
      "type": "string",
      "minLength": 1
    },
    "releaseApprovalFreezeRef": {
      "type": "string",
      "minLength": 1
    },
    "behaviorContractSetRef": {
      "type": "string",
      "minLength": 1
    },
    "surfaceSchemaSetRef": {
      "type": "string",
      "minLength": 1
    },
    "compatibilityEvidenceRef": {
      "type": "string",
      "minLength": 1
    },
    "approvedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "supersedesManifestId": {
      "type": ["string", "null"]
    },
    "changeNoticeRef": {
      "type": "string",
      "minLength": 1
    },
    "currentReleaseState": {
      "type": "string",
      "enum": [
        "draft",
        "contract_frozen_not_promoted",
        "sandpit_ready",
        "aos_ready",
        "limited_release_ready",
        "full_release_ready",
        "promotion_blocked",
        "withdrawn",
        "superseded"
      ]
    }
  }
}
