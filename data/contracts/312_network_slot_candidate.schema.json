{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/312_network_slot_candidate.schema.json",
  "title": "NetworkSlotCandidate",
  "description": "Normalized network slot candidate contract carrying site, trust, freshness, window fit, manage capability, accessibility fit, and persisted ranking-proof fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidateId",
    "networkCandidateSnapshotRef",
    "siteId",
    "sourceRef",
    "sourceTrustRef",
    "sourceTrustState",
    "sourceTrustTier",
    "sourceFreshnessState",
    "startAt",
    "endAt",
    "timezone",
    "modality",
    "clinicianType",
    "capacityUnitRef",
    "manageCapabilityState",
    "accessibilityFitScore",
    "travelMinutes",
    "waitMinutes",
    "stalenessMinutes",
    "requiredWindowFit",
    "windowClass",
    "offerabilityState",
    "baseUtility",
    "uncertaintyRadius",
    "robustFit",
    "capacityRankExplanationRef",
    "sourceRefs"
  ],
  "properties": {
    "candidateId": {
      "type": "string",
      "minLength": 1,
      "description": "Candidate identifier."
    },
    "networkCandidateSnapshotRef": {
      "type": "string",
      "minLength": 1,
      "description": "Owning snapshot ref."
    },
    "siteId": {
      "type": "string",
      "minLength": 1,
      "description": "Servicing site ref."
    },
    "siteLabel": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable site label."
    },
    "sourceRef": {
      "type": "string",
      "minLength": 1,
      "description": "Capacity source ref."
    },
    "sourceTrustRef": {
      "type": "string",
      "minLength": 1,
      "description": "AssuranceSliceTrustRecord or equivalent trust evidence ref."
    },
    "sourceTrustState": {
      "type": "string",
      "enum": [
        "trusted",
        "degraded",
        "quarantined"
      ],
      "description": "Current source-trust state."
    },
    "sourceTrustTier": {
      "type": "integer",
      "minimum": 0,
      "description": "Trust tier where 2 = trusted, 1 = degraded, 0 = quarantined."
    },
    "sourceFreshnessState": {
      "type": "string",
      "enum": [
        "fresh",
        "aging",
        "stale"
      ],
      "description": "Freshness band."
    },
    "startAt": {
      "type": "string",
      "format": "date-time",
      "description": "Candidate start time."
    },
    "endAt": {
      "type": "string",
      "format": "date-time",
      "description": "Candidate end time."
    },
    "timezone": {
      "type": "string",
      "minLength": 1,
      "description": "Site-local timezone."
    },
    "modality": {
      "type": "string",
      "minLength": 1,
      "description": "Offered modality."
    },
    "clinicianType": {
      "type": "string",
      "minLength": 1,
      "description": "Servicing clinician type."
    },
    "capacityUnitRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical capacity unit ref."
    },
    "manageCapabilityState": {
      "type": "string",
      "enum": [
        "network_manage_ready",
        "read_only",
        "blocked"
      ],
      "description": "Current network-manage capability state."
    },
    "accessibilityFitScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized accessibility fit."
    },
    "travelMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Estimated travel burden."
    },
    "waitMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Estimated wait until start."
    },
    "stalenessMinutes": {
      "type": "integer",
      "minimum": 0,
      "description": "Age of the source snapshot."
    },
    "requiredWindowFit": {
      "type": "integer",
      "minimum": 0,
      "description": "Resolved window fit as 2, 1, or 0."
    },
    "windowClass": {
      "type": "integer",
      "minimum": 0,
      "description": "Persisted window class value."
    },
    "offerabilityState": {
      "type": "string",
      "enum": [
        "direct_commit",
        "patient_offerable",
        "callback_only_reasoning",
        "diagnostic_only"
      ],
      "description": "Current surfaced offerability state."
    },
    "baseUtility": {
      "type": "number",
      "description": "Persisted within-band base utility."
    },
    "uncertaintyRadius": {
      "type": "number",
      "minimum": 0,
      "description": "Persisted uncertainty radius."
    },
    "robustFit": {
      "type": "number",
      "description": "Persisted robust-fit score."
    },
    "capacityRankExplanationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Linked explanation ref."
    },
    "patientReasonCueRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Patient-safe explanation cue refs."
    },
    "staffReasonRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Staff replay reason refs."
    },
    "blockedByPolicyReasonRefs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Reason refs for blocked or demoted exposure."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Grounding refs."
    }
  },
  "x-taskId": "seq_312",
  "x-contractVersion": "312.phase5.policy-capacity-ranking-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5C. Enhanced Access policy engine and network capacity ingestion",
    "blueprint/phase-5-the-network-horizon.md#5D. Coordination queue, candidate ranking, and SLA engine",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#ranking-order-and-visible-cues-must-derive-from-persisted-proof",
    "blueprint/phase-0-the-foundation-protocol.md#publication-and-bundle-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#assurance-and-trust-carry-forward",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md"
  ]
}
