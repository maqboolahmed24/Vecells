{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_practice_visibility_projection.schema.json",
  "title": "PracticeVisibilityProjection",
  "description": "Minimum-necessary origin-practice projection. Bound to one envelope version, one acting scope, one policy tuple, and one acknowledgement generation.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "practiceVisibilityProjectionId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable projection identifier."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "visibilityEnvelopeVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current visibility envelope version."
    },
    "crossOrganisationVisibilityEnvelopeRef": {
      "type": "string",
      "minLength": 1,
      "description": "Cross-organisation visibility envelope reference."
    },
    "actingScopeTupleRef": {
      "type": "string",
      "minLength": 1,
      "description": "Acting scope tuple reference."
    },
    "practiceVisibilityPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Practice visibility policy ref."
    },
    "serviceObligationPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Service-obligation policy ref."
    },
    "policyEvaluationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy evaluation ref."
    },
    "minimumNecessaryContractRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current minimum-necessary contract ref."
    },
    "policyTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current policy tuple hash."
    },
    "ackGeneration": {
      "type": "integer",
      "minimum": 0,
      "description": "Acknowledgement generation represented by this projection."
    },
    "practiceAcknowledgementState": {
      "type": "string",
      "enum": [
        "not_required",
        "ack_pending",
        "acknowledged",
        "exception_recorded",
        "superseded"
      ],
      "description": "Acknowledgement state carried into the projection."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash."
    },
    "patientSafeStatus": {
      "type": "string",
      "minLength": 1,
      "description": "Patient-safe macro status visible to the origin practice."
    },
    "projectionState": {
      "type": "string",
      "enum": [
        "not_published",
        "published_pending_ack",
        "acknowledged",
        "stale",
        "superseded"
      ],
      "description": "Projection freshness or supersession state."
    },
    "visibleFieldRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Allowed visible field refs for origin-practice surfaces."
    },
    "hiddenFieldRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Fields that must remain hidden from origin-practice visibility."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "practiceVisibilityProjectionId",
    "hubCoordinationCaseId",
    "visibilityEnvelopeVersionRef",
    "crossOrganisationVisibilityEnvelopeRef",
    "actingScopeTupleRef",
    "practiceVisibilityPolicyRef",
    "serviceObligationPolicyRef",
    "policyEvaluationRef",
    "minimumNecessaryContractRef",
    "policyTupleHash",
    "ackGeneration",
    "practiceAcknowledgementState",
    "truthTupleHash",
    "patientSafeStatus",
    "projectionState",
    "visibleFieldRefs",
    "hiddenFieldRefs",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
