{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_callback_outcome_evidence_bundle.schema.json",
  "title": "229 CallbackOutcomeEvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "bundleId",
    "attemptRef",
    "attemptFenceEpoch",
    "outcome",
    "recordedByActorRef",
    "recordedAt",
    "routeEvidenceRef",
    "providerDispositionRef",
    "patientAcknowledgementRef",
    "safetyClassification",
    "causalToken"
  ],
  "properties": {
    "bundleId": {
      "$ref": "#/$defs/id"
    },
    "attemptRef": {
      "$ref": "#/$defs/id"
    },
    "attemptFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "outcome": {
      "type": "string",
      "enum": [
        "answered",
        "no_answer",
        "voicemail_left",
        "route_invalid",
        "provider_failure"
      ]
    },
    "recordedByActorRef": {
      "$ref": "#/$defs/id"
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    },
    "routeEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "providerDispositionRef": {
      "$ref": "#/$defs/id"
    },
    "patientAcknowledgementRef": {
      "$ref": "#/$defs/id"
    },
    "safetyClassification": {
      "type": "string",
      "enum": [
        "nonclinical_control_delta",
        "potentially_clinical",
        "contact_safety_relevant",
        "technical_only"
      ]
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    }
  },
  "x-governedInvariants": [
    "CallbackOutcomeEvidenceBundle is the durable proof for answered, no-answer, voicemail, route-invalid, and provider-failure callback outcomes.",
    "Callback completion or escalation may not advance without this evidence bundle."
  ]
}
