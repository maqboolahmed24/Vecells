{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/279_booking_capability_resolution.schema.json",
  "title": "279 BookingCapabilityResolution",
  "description": "Live capability tuple verdict for one audience, action scope, and governing booking or appointment context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bookingCapabilityResolutionId",
    "schemaVersion",
    "bookingCaseId",
    "appointmentId",
    "tenantId",
    "practiceRef",
    "organisationRef",
    "supplierRef",
    "integrationMode",
    "deploymentType",
    "selectionAudience",
    "requestedActionScope",
    "providerCapabilityMatrixRef",
    "capabilityMatrixVersionRef",
    "providerAdapterBindingRef",
    "providerAdapterBindingHash",
    "adapterContractProfileRef",
    "dependencyDegradationProfileRef",
    "authoritativeReadAndConfirmationPolicyRef",
    "gpLinkageCheckpointRef",
    "localConsumerCheckpointRef",
    "prerequisiteState",
    "routeTuple",
    "governingObjectDescriptorRef",
    "governingObjectRef",
    "governingObjectVersionRef",
    "parentAnchorRef",
    "capabilityTupleHash",
    "capabilityState",
    "allowedActionScopes",
    "blockedActionReasonCodes",
    "fallbackActionRefs",
    "evidenceRefs",
    "evaluatedAt",
    "expiresAt"
  ],
  "properties": {
    "bookingCapabilityResolutionId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable capability-resolution id."
    },
    "schemaVersion": {
      "const": "279.phase4.booking-capability-freeze.v1"
    },
    "bookingCaseId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "BookingCase ref if the governing object is a case."
    },
    "appointmentId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Appointment ref if the governing object is an appointment."
    },
    "tenantId": {
      "type": "string",
      "minLength": 1,
      "description": "Tenant scope."
    },
    "practiceRef": {
      "type": "string",
      "minLength": 1,
      "description": "Practice scope."
    },
    "organisationRef": {
      "type": "string",
      "minLength": 1,
      "description": "Organisation scope."
    },
    "supplierRef": {
      "type": "string",
      "minLength": 1,
      "description": "Supplier scope."
    },
    "integrationMode": {
      "type": "string",
      "enum": [
        "im1_patient_api",
        "im1_transaction_api",
        "gp_connect_existing",
        "local_gateway_component",
        "manual_assist_only"
      ],
      "description": "Resolved integration mode."
    },
    "deploymentType": {
      "type": "string",
      "minLength": 1,
      "description": "Resolved deployment type."
    },
    "selectionAudience": {
      "type": "string",
      "enum": [
        "patient",
        "staff"
      ],
      "description": "Audience requesting actionability."
    },
    "requestedActionScope": {
      "type": "string",
      "enum": [
        "search_slots",
        "book_slot",
        "cancel_appointment",
        "reschedule_appointment",
        "view_appointment",
        "hold_slot",
        "launch_local_component",
        "repair_gp_linkage",
        "request_staff_assist",
        "manage_appointment",
        "view_booking_summary"
      ],
      "description": "Requested action scope."
    },
    "providerCapabilityMatrixRef": {
      "type": "string",
      "minLength": 1,
      "description": "Matrix row ref."
    },
    "capabilityMatrixVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Matrix version ref."
    },
    "providerAdapterBindingRef": {
      "type": "string",
      "minLength": 1,
      "description": "Chosen binding ref."
    },
    "providerAdapterBindingHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Current compiled binding hash."
    },
    "adapterContractProfileRef": {
      "type": "string",
      "minLength": 1,
      "description": "Chosen AdapterContractProfile."
    },
    "dependencyDegradationProfileRef": {
      "type": "string",
      "minLength": 1,
      "description": "Chosen DependencyDegradationProfile."
    },
    "authoritativeReadAndConfirmationPolicyRef": {
      "type": "string",
      "minLength": 1,
      "description": "Chosen authoritative-read and confirmation policy."
    },
    "gpLinkageCheckpointRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Optional GP linkage checkpoint ref."
    },
    "localConsumerCheckpointRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Optional local consumer checkpoint ref."
    },
    "prerequisiteState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gpLinkageStatus",
        "localConsumerStatus",
        "supplierDegradationStatus",
        "publicationState",
        "assuranceTrustState"
      ],
      "properties": {
        "gpLinkageStatus": {
          "type": "string",
          "enum": [
            "linked",
            "missing",
            "not_required"
          ],
          "description": "Resolved GP-linkage prerequisite status."
        },
        "localConsumerStatus": {
          "type": "string",
          "enum": [
            "ready",
            "missing",
            "not_required"
          ],
          "description": "Resolved local-component prerequisite status."
        },
        "supplierDegradationStatus": {
          "type": "string",
          "enum": [
            "nominal",
            "degraded_manual"
          ],
          "description": "Supplier degradation posture."
        },
        "publicationState": {
          "type": "string",
          "enum": [
            "published",
            "frozen",
            "withdrawn"
          ],
          "description": "Published route or release posture."
        },
        "assuranceTrustState": {
          "type": "string",
          "enum": [
            "writable",
            "read_only",
            "blocked"
          ],
          "description": "Assurance or trust posture."
        }
      }
    },
    "routeTuple": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "routeIntentBindingRef",
        "surfaceRouteContractRef",
        "surfacePublicationRef",
        "runtimePublicationBundleRef",
        "routeTupleHash"
      ],
      "properties": {
        "routeIntentBindingRef": {
          "type": "string",
          "minLength": 1,
          "description": "Route-intent binding ref."
        },
        "surfaceRouteContractRef": {
          "type": "string",
          "minLength": 1,
          "description": "AudienceSurfaceRouteContract ref."
        },
        "surfacePublicationRef": {
          "type": "string",
          "minLength": 1,
          "description": "SurfacePublication ref."
        },
        "runtimePublicationBundleRef": {
          "type": "string",
          "minLength": 1,
          "description": "RuntimePublicationBundle ref."
        },
        "routeTupleHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Lower-hex SHA-256 of the canonical route tuple."
        }
      }
    },
    "governingObjectDescriptorRef": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical governing object descriptor."
    },
    "governingObjectRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current governing object ref."
    },
    "governingObjectVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current governing object version ref."
    },
    "parentAnchorRef": {
      "type": "string",
      "minLength": 1,
      "description": "Selected anchor or parent shell anchor ref."
    },
    "capabilityTupleHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Lower-hex SHA-256 over the ordered capability tuple fields."
    },
    "capabilityState": {
      "type": "string",
      "enum": [
        "live_self_service",
        "live_staff_assist",
        "assisted_only",
        "linkage_required",
        "local_component_required",
        "degraded_manual",
        "recovery_only",
        "blocked"
      ],
      "description": "Resolved capability state."
    },
    "allowedActionScopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "search_slots",
          "book_slot",
          "cancel_appointment",
          "reschedule_appointment",
          "view_appointment",
          "hold_slot",
          "launch_local_component",
          "repair_gp_linkage",
          "request_staff_assist",
          "manage_appointment",
          "view_booking_summary"
        ],
        "description": "Allowed action scope"
      }
    },
    "blockedActionReasonCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "reason_gp_linkage_required",
          "reason_local_component_required",
          "reason_self_service_not_supported",
          "reason_staff_assist_only",
          "reason_supplier_degraded_manual",
          "reason_publication_frozen",
          "reason_assurance_read_only",
          "reason_governing_object_stale",
          "reason_action_scope_not_supported",
          "reason_confirmation_gate_pending",
          "reason_policy_blocked"
        ],
        "description": "Blocked-action reason code"
      }
    },
    "fallbackActionRefs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "fallback_repair_gp_linkage",
          "fallback_launch_local_component",
          "fallback_request_staff_assist",
          "fallback_contact_practice_support",
          "fallback_continue_read_only",
          "fallback_wait_for_confirmation",
          "fallback_manual_hub_booking"
        ],
        "description": "Fallback action ref"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "x-capabilityTupleHashInputOrder": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Canonical field order that must be hashed using normalized JSON and SHA-256 lower hex."
    }
  }
}
