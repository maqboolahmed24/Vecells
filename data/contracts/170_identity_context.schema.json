{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/phase2/170_identity_context.schema.json",
  "title": "IdentityContext",
  "description": "Phase 2 trust-kernel identity posture consumed by route capability evaluation. It carries references and policy posture only; evidence values remain behind the evidence vault boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identityContextId",
    "schemaVersion",
    "policyVersion",
    "subjectRef",
    "identitySource",
    "assuranceState",
    "verificationLevel",
    "bindingFenceRef",
    "sessionEpochRef",
    "evidenceEnvelopeRef",
    "freshness",
    "restrictions",
    "capabilityCeiling"
  ],
  "properties": {
    "identityContextId": {
      "type": "string",
      "pattern": "^icx_[A-Za-z0-9_:-]+$"
    },
    "schemaVersion": {
      "const": "170.phase2.trust.v1"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^phase2-trust-v[0-9]+$"
    },
    "subjectRef": {
      "type": "string",
      "description": "Opaque subject reference or draft actor reference. Never a direct patient identifier."
    },
    "identitySource": {
      "type": "string",
      "enum": [
        "anonymous",
        "nhs_login",
        "secure_link",
        "sms_continuation",
        "staff_override",
        "system"
      ]
    },
    "assuranceState": {
      "type": "string",
      "enum": ["none", "claimed", "verified", "weakened", "repair_hold"]
    },
    "verificationLevel": {
      "type": "string",
      "enum": ["none", "contact_seeded", "nhs_low", "nhs_p9", "nhs_p5_plus", "manual_verified"]
    },
    "patientLinkPosture": {
      "type": "string",
      "enum": ["unlinked", "candidate", "linked", "conflict", "repair_hold", "restricted"]
    },
    "bindingFenceRef": {
      "type": "string",
      "description": "Current IdentityBinding fence reference owned by IdentityBindingAuthority."
    },
    "sessionEpochRef": {
      "type": "string",
      "description": "Local session epoch reference. The session governor may rotate this but may not mutate IdentityBinding."
    },
    "evidenceEnvelopeRef": {
      "type": "string",
      "description": "Reference to an append-only IdentityEvidenceEnvelope held behind the vault boundary."
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observedAt", "expiresAt", "maxAgeSeconds", "staleBehavior"],
      "properties": {
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "maxAgeSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "staleBehavior": {
          "type": "string",
          "enum": ["step_up_required", "recover_only", "deny"]
        }
      }
    },
    "restrictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["restrictionCode", "restrictionClass", "appliesTo", "decisionBias"],
        "properties": {
          "restrictionCode": {
            "type": "string",
            "enum": [
              "age_policy_proxy_required",
              "identity_repair_hold",
              "patient_link_conflict",
              "manual_override_narrowed",
              "session_stale",
              "future_surface_placeholder"
            ]
          },
          "restrictionClass": {
            "type": "string",
            "enum": ["age_policy", "repair", "linkage", "manual_override", "freshness", "future"]
          },
          "appliesTo": {
            "type": "string"
          },
          "decisionBias": {
            "type": "string",
            "enum": ["step_up_required", "recover_only", "deny"]
          },
          "authoritySignalRef": {
            "type": "string"
          }
        }
      }
    },
    "capabilityCeiling": {
      "type": "string",
      "enum": [
        "anonymous_public",
        "recover_only",
        "signed_in_basic",
        "signed_in_verified",
        "restricted",
        "deny"
      ]
    },
    "grantCeiling": {
      "type": "string",
      "enum": [
        "none",
        "draft_lease_only",
        "continuation_recovery_only",
        "authenticated_draft_only",
        "request_status_read",
        "request_attachment_write",
        "future_denied"
      ]
    }
  }
}
