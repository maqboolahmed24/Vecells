{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/232_workspace_trust_envelope.schema.json",
  "title": "232 WorkspaceTrustEnvelope",
  "description": "Canonical staff-workspace authority for writability, interruption pacing, calm completion, same-shell recovery, and trusted tuple hashes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspaceTrustEnvelopeId",
    "workspaceFamily",
    "workspaceRef",
    "taskOrCaseRef",
    "queueKey",
    "workspaceConsistencyProjectionRef",
    "workspaceSliceTrustProjectionRef",
    "taskCompletionSettlementEnvelopeRef",
    "surfaceRuntimeBindingRef",
    "surfacePublicationRef",
    "runtimePublicationBundleRef",
    "selectedAnchorRef",
    "selectedAnchorTupleHashRef",
    "sourceQueueRankSnapshotRef",
    "continuityEvidenceRef",
    "consistencyTupleHash",
    "trustTupleHash",
    "envelopeState",
    "mutationAuthorityState",
    "interruptionPacingState",
    "completionCalmState",
    "blockingReasonRefs",
    "requiredRecoveryAction",
    "computedAt"
  ],
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "nullableId": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "workspaceFamily": {
      "type": "string",
      "enum": [
        "staff_review",
        "support_ticket",
        "hub_coordination",
        "governance_review",
        "ops_intervention"
      ]
    },
    "envelopeState": {
      "type": "string",
      "enum": [
        "interactive",
        "observe_only",
        "stale_recoverable",
        "recovery_required",
        "reassigned"
      ]
    },
    "mutationAuthorityState": {
      "type": "string",
      "enum": [
        "live",
        "frozen",
        "blocked"
      ]
    },
    "interruptionPacingState": {
      "type": "string",
      "enum": [
        "live",
        "buffered",
        "blocking_only",
        "recovery_only"
      ]
    },
    "completionCalmState": {
      "type": "string",
      "enum": [
        "not_eligible",
        "pending_settlement",
        "eligible",
        "blocked"
      ]
    },
    "recoveryAction": {
      "type": "string",
      "enum": [
        "none",
        "refresh_projection",
        "repair_anchor",
        "reacquire_lease",
        "supervised_takeover",
        "review_consequence_drift"
      ]
    },
    "reasonCode": {
      "type": "string",
      "enum": [
        "WORKSPACE_232_ROUTE_FAMILY_DRIFT",
        "WORKSPACE_232_ROUTE_CONTRACT_DRIFT",
        "WORKSPACE_232_SURFACE_PUBLICATION_DRIFT",
        "WORKSPACE_232_RUNTIME_PUBLICATION_DRIFT",
        "WORKSPACE_232_RELEASE_TRUST_DEGRADED",
        "WORKSPACE_232_RELEASE_TRUST_RECOVERY_BOUND",
        "WORKSPACE_232_RELEASE_TRUST_QUARANTINED",
        "WORKSPACE_232_REVIEW_FRESHNESS_QUEUED_UPDATES",
        "WORKSPACE_232_REVIEW_FRESHNESS_REVIEW_REQUIRED",
        "WORKSPACE_232_REVIEW_ACTION_LEASE_MISSING",
        "WORKSPACE_232_REVIEW_ACTION_LEASE_EXPIRED",
        "WORKSPACE_232_REQUEST_LIFECYCLE_LEASE_MISSING",
        "WORKSPACE_232_REQUEST_LIFECYCLE_LEASE_EXPIRED",
        "WORKSPACE_232_OWNERSHIP_EPOCH_MISMATCH",
        "WORKSPACE_232_FENCING_TOKEN_MISMATCH",
        "WORKSPACE_232_LINEAGE_FENCE_DRIFT",
        "WORKSPACE_232_SELECTED_ANCHOR_REMAPPABLE",
        "WORKSPACE_232_SELECTED_ANCHOR_LOST",
        "WORKSPACE_232_QUEUE_SNAPSHOT_DRIFT",
        "WORKSPACE_232_TASK_COMPLETION_PENDING",
        "WORKSPACE_232_CONTINUITY_EVIDENCE_DEGRADED",
        "WORKSPACE_232_CONTINUITY_EVIDENCE_STALE",
        "WORKSPACE_232_CONTINUITY_EVIDENCE_BLOCKED",
        "WORKSPACE_232_FOCUS_BUFFERING_ACTIVE",
        "WORKSPACE_232_PROTECTED_COMPOSITION_INVALIDATED",
        "WORKSPACE_232_CONSEQUENCE_REVIEW_REQUIRED",
        "WORKSPACE_232_CONSEQUENCE_SUPERSEDED",
        "WORKSPACE_232_STALE_OWNER_RECOVERY_OPEN",
        "WORKSPACE_232_DEPENDENCY_SLICE_DEGRADED",
        "WORKSPACE_232_DEPENDENCY_SLICE_QUARANTINED"
      ]
    }
  },
  "properties": {
    "workspaceTrustEnvelopeId": {
      "$ref": "#/$defs/id"
    },
    "workspaceFamily": {
      "$ref": "#/$defs/workspaceFamily"
    },
    "workspaceRef": {
      "$ref": "#/$defs/id"
    },
    "taskOrCaseRef": {
      "$ref": "#/$defs/id"
    },
    "queueKey": {
      "$ref": "#/$defs/id"
    },
    "workspaceConsistencyProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "workspaceSliceTrustProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "primaryActionLeaseRef": {
      "$ref": "#/$defs/nullableId"
    },
    "requestLifecycleLeaseRef": {
      "$ref": "#/$defs/nullableId"
    },
    "focusProtectionLeaseRef": {
      "$ref": "#/$defs/nullableId"
    },
    "protectedCompositionStateRef": {
      "$ref": "#/$defs/nullableId"
    },
    "taskCompletionSettlementEnvelopeRef": {
      "$ref": "#/$defs/id"
    },
    "surfaceRuntimeBindingRef": {
      "$ref": "#/$defs/id"
    },
    "surfacePublicationRef": {
      "$ref": "#/$defs/id"
    },
    "runtimePublicationBundleRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorTupleHashRef": {
      "$ref": "#/$defs/id"
    },
    "sourceQueueRankSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "continuityEvidenceRef": {
      "$ref": "#/$defs/id"
    },
    "consistencyTupleHash": {
      "$ref": "#/$defs/id"
    },
    "trustTupleHash": {
      "$ref": "#/$defs/id"
    },
    "envelopeState": {
      "$ref": "#/$defs/envelopeState"
    },
    "mutationAuthorityState": {
      "$ref": "#/$defs/mutationAuthorityState"
    },
    "interruptionPacingState": {
      "$ref": "#/$defs/interruptionPacingState"
    },
    "completionCalmState": {
      "$ref": "#/$defs/completionCalmState"
    },
    "blockingReasonRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reasonCode"
      }
    },
    "requiredRecoveryAction": {
      "$ref": "#/$defs/recoveryAction"
    },
    "computedAt": {
      "$ref": "#/$defs/dateTime"
    }
  }
}
