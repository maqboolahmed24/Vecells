{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_message_dispatch_envelope.schema.json",
  "title": "229 MessageDispatchEnvelope",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "dispatchEnvelopeId",
    "threadRef",
    "threadVersionRef",
    "draftRef",
    "approvedByRef",
    "deliveryPlanRef",
    "routeIntentBindingRef",
    "requestLifecycleLeaseRef",
    "dispatchFenceEpoch",
    "ownershipEpochRef",
    "fencingToken",
    "commandActionRecordRef",
    "idempotencyRecordRef",
    "adapterDispatchAttemptRef",
    "latestReceiptCheckpointRef",
    "repairIntent",
    "channelTemplateRef",
    "transportState",
    "deliveryEvidenceState",
    "currentDeliveryConfidenceRef",
    "deliveryModelVersionRef",
    "calibrationVersion",
    "causalToken",
    "monotoneRevision",
    "idempotencyKey"
  ],
  "properties": {
    "dispatchEnvelopeId": {
      "$ref": "#/$defs/id"
    },
    "threadRef": {
      "$ref": "#/$defs/id"
    },
    "threadVersionRef": {
      "$ref": "#/$defs/id"
    },
    "draftRef": {
      "$ref": "#/$defs/id"
    },
    "approvedByRef": {
      "$ref": "#/$defs/id"
    },
    "deliveryPlanRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "requestLifecycleLeaseRef": {
      "$ref": "#/$defs/id"
    },
    "dispatchFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "ownershipEpochRef": {
      "$ref": "#/$defs/id"
    },
    "fencingToken": {
      "$ref": "#/$defs/id"
    },
    "commandActionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "idempotencyRecordRef": {
      "$ref": "#/$defs/id"
    },
    "adapterDispatchAttemptRef": {
      "$ref": "#/$defs/id"
    },
    "latestReceiptCheckpointRef": {
      "$ref": "#/$defs/id"
    },
    "supportMutationAttemptRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "supportActionRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "repairIntent": {
      "type": "string",
      "enum": [
        "initial_send",
        "controlled_resend",
        "channel_change",
        "attachment_recovery"
      ]
    },
    "channelTemplateRef": {
      "$ref": "#/$defs/id"
    },
    "transportState": {
      "type": "string",
      "enum": [
        "drafted",
        "approved",
        "dispatching",
        "provider_accepted",
        "provider_rejected"
      ]
    },
    "deliveryEvidenceState": {
      "type": "string",
      "enum": [
        "unobserved",
        "delivered",
        "failed",
        "disputed",
        "expired"
      ]
    },
    "currentDeliveryConfidenceRef": {
      "$ref": "#/$defs/id"
    },
    "deliveryModelVersionRef": {
      "$ref": "#/$defs/id"
    },
    "calibrationVersion": {
      "$ref": "#/$defs/id"
    },
    "causalToken": {
      "$ref": "#/$defs/id"
    },
    "monotoneRevision": {
      "type": "integer",
      "minimum": 1
    },
    "idempotencyKey": {
      "$ref": "#/$defs/id"
    }
  },
  "x-governedInvariants": [
    "MessageDispatchEnvelope is the immutable send or resend fence for a thread version.",
    "Provider retries and support repair retries on the same dispatch fence must reuse this envelope rather than creating a second live send chain."
  ]
}
