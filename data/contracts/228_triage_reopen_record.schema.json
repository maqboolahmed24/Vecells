{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_triage_reopen_record.schema.json",
  "title": "228 TriageReopenRecord",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "reopenRecordId",
    "taskId",
    "sourceDomain",
    "reasonCode",
    "evidenceRefs",
    "supersededDecisionEpochRef",
    "decisionSupersessionRecordRef",
    "priorityOverride",
    "reopenedByMode",
    "reopenedAt"
  ],
  "properties": {
    "reopenRecordId": {
      "$ref": "#/$defs/id"
    },
    "taskId": {
      "$ref": "#/$defs/id"
    },
    "sourceDomain": {
      "type": "string",
      "enum": [
        "urgent_escalation",
        "direct_resolution",
        "booking_handoff",
        "pharmacy_handoff",
        "callback",
        "clinician_message",
        "supervisor_review"
      ]
    },
    "reasonCode": {
      "type": "string"
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "supersededDecisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "priorityOverride": {
      "type": "string"
    },
    "reopenedByMode": {
      "type": "string",
      "enum": [
        "automatic",
        "reviewer_manual",
        "supervisor_manual"
      ]
    },
    "reopenedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "TriageReopenRecord is the canonical explanation for why a prior consequence path returned to triage.",
    "Reopen mechanics must preserve lineage to the superseded DecisionEpoch and the supersession record."
  ]
}
