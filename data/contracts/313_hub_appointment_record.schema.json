{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/313_hub_appointment_record.schema.json",
  "title": "HubAppointmentRecord",
  "description": "Durable appointment truth emitted only after authoritative confirmation on the current tuple.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "hubAppointmentId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier for the hub appointment record."
    },
    "hubCoordinationCaseId": {
      "type": "string",
      "minLength": 1,
      "description": "Owning hub coordination case."
    },
    "commitAttemptId": {
      "type": "string",
      "minLength": 1,
      "description": "Commit attempt that lawfully created or updated this record."
    },
    "sourceBookingReference": {
      "type": "string",
      "minLength": 1,
      "description": "Supplier-side booking reference or equivalent booking identifier."
    },
    "supplierAppointmentRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Supplier appointment identifier where provided."
    },
    "patientFacingReference": {
      "type": "string",
      "minLength": 1,
      "description": "Patient-facing booking or reference number."
    },
    "appointmentVersionRef": {
      "type": "string",
      "minLength": 1,
      "description": "Current appointment version used by manage and visibility layers."
    },
    "appointmentState": {
      "type": "string",
      "enum": [
        "pending_confirmation",
        "confirmed_pending_practice_ack",
        "confirmed",
        "disputed",
        "cancelled"
      ],
      "description": "Current appointment posture."
    },
    "externalConfirmationState": {
      "type": "string",
      "enum": [
        "none",
        "pending",
        "disputed",
        "confirmed"
      ],
      "description": "External confirmation posture after the confirmation gate ran."
    },
    "practiceAcknowledgementState": {
      "type": "string",
      "enum": [
        "not_required",
        "ack_pending",
        "acknowledged",
        "exception_recorded",
        "superseded"
      ],
      "description": "Practice acknowledgement posture kept separate from patient confirmation."
    },
    "manageCapabilitiesRef": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 0,
      "description": "Current NetworkManageCapabilities lease."
    },
    "truthTupleHash": {
      "type": "string",
      "minLength": 1,
      "description": "Current truth tuple hash."
    },
    "sourceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Algorithm source refs carried into the contract pack."
    }
  },
  "required": [
    "hubAppointmentId",
    "hubCoordinationCaseId",
    "commitAttemptId",
    "sourceBookingReference",
    "patientFacingReference",
    "appointmentVersionRef",
    "appointmentState",
    "externalConfirmationState",
    "practiceAcknowledgementState",
    "truthTupleHash",
    "sourceRefs"
  ],
  "x-taskId": "seq_313",
  "x-contractVersion": "313.phase5.commit-visibility-freeze.v1",
  "x-sourceRefs": [
    "blueprint/phase-5-the-network-horizon.md#5E. Alternative offer generation, open choice, callback fallback, and patient continuity",
    "blueprint/phase-5-the-network-horizon.md#5F. Native hub booking commit, practice continuity, and cross-org messaging",
    "blueprint/phase-5-the-network-horizon.md#5H. Patient communications, network reminders, manage flows, and practice visibility",
    "blueprint/phase-cards.md#Card-6",
    "blueprint/phase-4-the-booking-engine.md#booking-truth-confirmation-and-practice-visibility-carry-forward",
    "blueprint/phase-4-the-booking-engine.md#manage-and-artifact-exposure-must-follow-current-truth",
    "blueprint/phase-0-the-foundation-protocol.md#replay-idempotency-and-external-effect-discipline",
    "blueprint/phase-0-the-foundation-protocol.md#adapter-receipts-checkpoints-and-external-settlement",
    "docs/architecture/311_phase5_hub_case_and_acting_context_contract.md",
    "docs/architecture/312_phase5_policy_capacity_and_candidate_ranking_contract.md",
    "docs/api/312_phase5_candidate_snapshot_and_rank_contract.md"
  ]
}
