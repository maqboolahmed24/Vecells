{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/374_phase7_integration_evidence_pack_schema.json",
  "title": "IntegrationEvidencePack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidencePackId",
    "demoEnvironmentUrl",
    "uxAuditRefs",
    "clinicalSafetyRefs",
    "privacyRefs",
    "SCALRefs",
    "incidentRunbookRefs"
  ],
  "properties": {
    "evidencePackId": {
      "type": "string",
      "minLength": 1
    },
    "demoEnvironmentUrl": {
      "type": "string",
      "format": "uri"
    },
    "uxAuditRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "clinicalSafetyRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "privacyRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "SCALRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "incidentRunbookRefs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
