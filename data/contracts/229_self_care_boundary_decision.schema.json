{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/229_self_care_boundary_decision.schema.json",
  "title": "229 SelfCareBoundaryDecision",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "selfCareBoundaryDecisionId",
    "requestRef",
    "evidenceSnapshotRef",
    "decisionEpochRef",
    "decisionSupersessionRecordRef",
    "decisionState",
    "clinicalMeaningState",
    "operationalFollowUpScope",
    "adminMutationAuthorityState",
    "reasonCodeRefs",
    "adminResolutionSubtypeRef",
    "routeIntentBindingRef",
    "selectedAnchorRef",
    "lineageFenceEpoch",
    "dependencySetRef",
    "adviceRenderSettlementRef",
    "adminResolutionCaseRef",
    "selfCareExperienceProjectionRef",
    "adminResolutionExperienceProjectionRef",
    "reopenTriggerRefs",
    "reopenState",
    "boundaryState",
    "boundaryTupleHash",
    "compiledPolicyBundleRef",
    "decidedAt"
  ],
  "properties": {
    "selfCareBoundaryDecisionId": {
      "$ref": "#/$defs/id"
    },
    "requestRef": {
      "$ref": "#/$defs/id"
    },
    "evidenceSnapshotRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "decisionSupersessionRecordRef": {
      "$ref": "#/$defs/id"
    },
    "decisionState": {
      "type": "string",
      "enum": [
        "self_care",
        "admin_resolution",
        "clinician_review_required",
        "blocked_pending_review"
      ]
    },
    "clinicalMeaningState": {
      "type": "string",
      "enum": [
        "informational_only",
        "bounded_admin_only",
        "clinician_reentry_required"
      ]
    },
    "operationalFollowUpScope": {
      "type": "string",
      "enum": [
        "none",
        "self_serve_guidance",
        "bounded_admin_resolution"
      ]
    },
    "adminMutationAuthorityState": {
      "type": "string",
      "enum": [
        "none",
        "bounded_admin_only",
        "frozen"
      ]
    },
    "reasonCodeRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "minItems": 1
    },
    "adminResolutionSubtypeRef": {
      "$ref": "#/$defs/id"
    },
    "routeIntentBindingRef": {
      "$ref": "#/$defs/id"
    },
    "selectedAnchorRef": {
      "$ref": "#/$defs/id"
    },
    "lineageFenceEpoch": {
      "type": "integer",
      "minimum": 0
    },
    "dependencySetRef": {
      "$ref": "#/$defs/id"
    },
    "adviceRenderSettlementRef": {
      "$ref": "#/$defs/id"
    },
    "adminResolutionCaseRef": {
      "$ref": "#/$defs/id"
    },
    "selfCareExperienceProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "adminResolutionExperienceProjectionRef": {
      "$ref": "#/$defs/id"
    },
    "reopenTriggerRefs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "reopenState": {
      "type": "string",
      "enum": [
        "stable",
        "reopen_required",
        "reopened",
        "blocked_pending_review"
      ]
    },
    "boundaryState": {
      "type": "string",
      "enum": [
        "live",
        "superseded",
        "reopened",
        "blocked"
      ]
    },
    "boundaryTupleHash": {
      "$ref": "#/$defs/id"
    },
    "compiledPolicyBundleRef": {
      "$ref": "#/$defs/id"
    },
    "decidedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "SelfCareBoundaryDecision is the sole classifier for self-care, admin-resolution, or clinician re-entry.",
    "Subtype labels, advice wording, and route copy may not redefine the boundary once boundaryTupleHash is published."
  ]
}
