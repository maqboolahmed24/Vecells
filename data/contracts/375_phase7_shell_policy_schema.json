{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/contracts/375_phase7_shell_policy_schema.json",
  "title": "ShellPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "shellPolicyId",
    "channelType",
    "showHeader",
    "showFooter",
    "showBackLink",
    "safeAreaInsetsMode",
    "externalLinkMode",
    "downloadMode"
  ],
  "properties": {
    "shellPolicyId": {
      "type": "string"
    },
    "channelType": {
      "type": "string",
      "enum": ["standalone_web", "nhs_app_webview", "secure_link", "unknown"]
    },
    "showHeader": {
      "type": "boolean"
    },
    "showFooter": {
      "type": "boolean"
    },
    "showBackLink": {
      "type": "boolean"
    },
    "safeAreaInsetsMode": {
      "type": "string",
      "enum": ["browser_default", "native_safe_area", "compact_embedded"]
    },
    "externalLinkMode": {
      "type": "string",
      "enum": ["standard_browser", "outbound_grant_required", "blocked"]
    },
    "downloadMode": {
      "type": "string",
      "enum": ["browser_default", "bridge_byte_grant_required", "summary_only", "blocked"]
    }
  }
}
