{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/contracts/228_urgent_escalation_outcome.schema.json",
  "title": "228 UrgentEscalationOutcome",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "urgentEscalationOutcomeId",
    "dutyEscalationRecordRef",
    "decisionEpochRef",
    "outcomeClass",
    "recordedAt"
  ],
  "properties": {
    "urgentEscalationOutcomeId": {
      "$ref": "#/$defs/id"
    },
    "dutyEscalationRecordRef": {
      "$ref": "#/$defs/id"
    },
    "decisionEpochRef": {
      "$ref": "#/$defs/id"
    },
    "outcomeClass": {
      "type": "string",
      "enum": [
        "direct_non_appointment",
        "downstream_handoff",
        "return_to_triage",
        "cancelled",
        "expired"
      ]
    },
    "endpointDecisionSettlementRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "bookingIntentRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "pharmacyIntentRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "triageReopenRecordRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "presentationArtifactRef": {
      "type": [
        "string",
        "null"
      ]
    },
    "recordedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "x-governedInvariants": [
    "Urgent escalation outcomes must resolve to direct outcome, downstream handoff, return to triage, cancellation, or expiry with typed lineage.",
    "Downstream handoff and reopen outcomes must carry the same current DecisionEpoch and fail closed after supersession."
  ]
}
