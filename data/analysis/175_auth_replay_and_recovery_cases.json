  "parallelInterfaceGaps": [
    {
      "gapId": "PARALLEL_INTERFACE_GAP_PHASE2_AUTH_BRIDGE_ISOLATED_OIDC_V1",
      "closure": "NHS login simulator discovery, authorize URL creation, code exchange, and JWKS-style validation sit behind NhsLoginOidcAdapter."
    },
    {
      "gapId": "PARALLEL_INTERFACE_GAP_PHASE2_AUTH_TRANSACTION_FENCE_CAS_V1",
      "closure": "AuthTransaction stores state digest, nonce digest, PKCE digest, exact redirect URI, callback outcome, consumption state, and CAS version."
    },
    {
      "gapId": "PARALLEL_INTERFACE_GAP_PHASE2_AUTH_RETURN_INTENT_ONLY_V1",
      "closure": "PostAuthReturnIntent is frozen before redirect and uses redirectMode route_intent_binding_only; arbitrary return targets are not accepted."
    },
    {
      "gapId": "PARALLEL_INTERFACE_GAP_PHASE2_AUTH_SESSION_GOVERNOR_PORT_V1",
      "closure": "Successful callbacks call SessionGovernorPort and do not create local session state."
    },
    {
      "gapId": "PARALLEL_INTERFACE_GAP_PHASE2_AUTH_EVIDENCE_VAULT_ONLY_V1",
      "closure": "Raw claims and raw token envelope are passed only to IdentityEvidenceVaultPort with vault_reference_only."
    },
    {
      "gapId": "PARALLEL_INTERFACE_GAP_PHASE2_AUTH_REPLAY_EXACT_ONCE_V1",
      "closure": "Duplicate and stale callbacks return replayed_callback and do not repeat downstream port writes."
    }
  ],
  "cases": [
