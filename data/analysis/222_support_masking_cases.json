{
  "taskId": "par_222_crosscutting_track_Playwright_or_other_appropriate_tooling_frontend_build_support_masking_read_only_fallback_and_contextual_playbook_panels",
  "cases": [
    {
      "caseId": "history_summary_default",
      "route": "/ops/support/tickets/:supportTicketId/history",
      "scenario": "calm",
      "maskScope": "mask_scope_support_summary",
      "expectedBehavior": "History remains summary-first and the disclosure gate is visible."
    },
    {
      "caseId": "history_disclosure_expanded",
      "route": "/ops/support/tickets/:supportTicketId/history",
      "scenario": "active",
      "disclosureState": "expanded",
      "maskScope": "mask_scope_support_governed_expand",
      "expectedBehavior": "Expanded rows appear only when the disclosure record is active."
    },
    {
      "caseId": "knowledge_stale_binding",
      "route": "/ops/support/tickets/:supportTicketId/knowledge",
      "scenario": "degraded",
      "assistState": "stale",
      "expectedBehavior": "Knowledge cards remain visible, but executable apply posture collapses in place."
    },
    {
      "caseId": "observe_summary_only",
      "route": "/ops/support/tickets/:supportTicketId/observe/:supportObserveSessionId",
      "scenario": "calm",
      "expectedBehavior": "Observe breadcrumb remains visible and the action dock stays suppressed."
    },
    {
      "caseId": "observe_session_drift",
      "route": "/ops/support/tickets/:supportTicketId/observe/:supportObserveSessionId",
      "scenario": "blocked",
      "fallbackReason": "observe_session_drift",
      "expectedBehavior": "Read-only fallback stays same-shell and offers observe reacquire paths."
    },
    {
      "caseId": "replay_boundary_active",
      "route": "/ops/support/replay/:supportReplaySessionId",
      "scenario": "calm",
      "expectedBehavior": "Replay boundary shows included events and excluded drafts while mutating controls remain unavailable."
    },
    {
      "caseId": "replay_restore_failure",
      "route": "/ops/support/replay/:supportReplaySessionId",
      "scenario": "blocked",
      "fallbackReason": "replay_restore_failure",
      "expectedBehavior": "Replay downgrade preserves the current anchor and strongest artifact instead of leaving the shell."
    }
  ]
}
