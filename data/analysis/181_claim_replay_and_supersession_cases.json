{
  "schemaVersion": "181.phase2.access-grant.v1",
  "authority": "AccessGrantService",
  "manualOnlyRule": "manual_only is not a redeemable grant",
  "requiredAuthorities": [
    "CapabilityDecisionEngine",
    "IdentityBindingAuthority",
    "SessionGovernor",
    "RouteIntentBinding"
  ],
  "cases": [
    {
      "caseId": "ACCESS181_SCOPE_ENVELOPE_IMMUTABLE",
      "grantFamily": "draft_resume_minimal",
      "decision": "issued",
      "checks": [
        "AccessGrantScopeEnvelope",
        "immutableScopeHash",
        "tokenHash"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_SCOPE_ENVELOPE_V1"
    },
    {
      "caseId": "ACCESS181_EXACT_ONCE_REDEMPTION",
      "grantFamily": "public_status_minimal",
      "decision": "redeemed",
      "checks": [
        "AccessGrantRedemptionRecord",
        "idempotencyKey",
        "same settled outcome"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_EXACT_ONCE_REDEMPTION_V1"
    },
    {
      "caseId": "ACCESS181_DUPLICATE_CLICK_REPLAY",
      "grantFamily": "continuation_challenge",
      "decision": "replayed",
      "checks": [
        "tokenHash replay",
        "no second redemption",
        "no second supersession"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_EXACT_ONCE_REDEMPTION_V1"
    },
    {
      "caseId": "ACCESS181_STALE_SCOPE_RECOVERY",
      "grantFamily": "support_recovery_minimal",
      "decision": "recover_only",
      "checks": [
        "RouteIntentBinding drift",
        "same-lineage recovery",
        "AccessGrantSupersessionRecord"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_SCOPE_ENVELOPE_V1"
    },
    {
      "caseId": "ACCESS181_ROUTE_DRIFT_DENIED",
      "grantFamily": "public_status_minimal",
      "decision": "denied",
      "checks": [
        "AccessGrantScopeEnvelope mismatch",
        "no recovery lineage",
        "terminal AccessGrantRedemptionRecord"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_EXACT_ONCE_REDEMPTION_V1"
    },
    {
      "caseId": "ACCESS181_CLAIM_CONFIRMED",
      "grantFamily": "claim_step_up",
      "decision": "claim_confirmed",
      "checks": [
        "SessionEstablishmentDecision claim_pending",
        "CapabilityDecision allow",
        "RouteIntentBinding live",
        "IdentityBindingAuthority claim_confirmed",
        "SessionGovernor rotation"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_CLAIM_AUTHORITY_HANDOFF_V1"
    },
    {
      "caseId": "ACCESS181_CLAIM_STEP_UP_REQUIRED",
      "grantFamily": "claim_step_up",
      "decision": "step_up_required",
      "checks": [
        "active session",
        "insufficient verification",
        "preserved return path"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_EXACT_ONCE_REDEMPTION_V1"
    },
    {
      "caseId": "ACCESS181_PUBLIC_GRANT_SUPERSEDED_AFTER_CLAIM",
      "grantFamily": "public_status_minimal",
      "decision": "superseded",
      "checks": [
        "AccessGrantSupersessionRecord",
        "claim_completed",
        "no stale public grant reuse"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_SUPERSESSION_CHAIN_V1"
    },
    {
      "caseId": "ACCESS181_LOGOUT_REVOKES_GRANT",
      "grantFamily": "draft_resume_minimal",
      "decision": "revoked",
      "checks": [
        "logout",
        "AccessGrantSupersessionRecord",
        "SessionGovernor"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_SESSION_ROTATION_V1"
    },
    {
      "caseId": "ACCESS181_MANUAL_ONLY_DENIED",
      "grantFamily": "manual_only",
      "decision": "denied",
      "checks": [
        "manual_only is not a redeemable grant",
        "AccessGrantService rejects issuance"
      ],
      "gapClosure": "PARALLEL_INTERFACE_GAP_PHASE2_ACCESS_GRANT_CANONICAL_SERVICE_V1"
    }
  ]
}
