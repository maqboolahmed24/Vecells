      "expectedReasonCodes": [
        "BINDING_179_STALE_EXPECTED_VERSION",
        "BINDING_179_CAS_CONFLICT_REFUSED"
      ]
    },
    {
      "caseId": "BINDING179_FREEZE_BLOCKS_ORDINARY",
      "intentType": "verified_bind",
      "activeFreezeHold": true,
      "repairAuthorized": false,
      "expectedDecision": "freeze_blocked",
      "expectedNewBindingVersion": false,
      "expectedReasonCodes": ["BINDING_179_FREEZE_ACTIVE_REFUSED"]
    },
    {
      "caseId": "BINDING179_CORRECTION_SUPERSEDES",
      "intentType": "correction_applied",
      "activeFreezeHold": true,
      "repairAuthorized": true,
      "expectedDecision": "accepted",
      "expectedBindingState": "corrected",
      "expectedSupersessionLink": true,
      "expectedReasonCodes": [
        "BINDING_179_REPAIR_AUTHORITY_RELEASED",
        "BINDING_179_DERIVED_PATIENT_REF_ADVANCED"
      ]
    },
    {
      "caseId": "BINDING179_REVOKE_CLEARS_LINEAGE",
      "intentType": "revoked",
      "expectedDecision": "accepted",
      "expectedBindingState": "revoked",
      "expectedDerivedRefAction": "clear_request_and_episode_refs",
      "expectedReasonCodes": ["BINDING_179_REVOKED"]
