{
  "taskId": "seq_202",
  "schemaVersion": "202.phase2.nhs-login-gates.v1",
  "visualMode": "Identity_Config_Control_Board",
  "defaultMode": "dry_run",
  "environmentGates": [
    {
      "environmentId": "local",
      "lane": "Mock_now_execution",
      "mutationAllowed": false,
      "requiredEvidence": [
        "manifest_validation_passed",
        "control_board_screenshot",
        "selector_snapshot",
        "redaction_scan_passed"
      ],
      "gateState": "pass_for_dry_run"
    },
    {
      "environmentId": "sandbox_twin",
      "lane": "Mock_now_execution",
      "mutationAllowed": false,
      "requiredEvidence": [
        "sandpit_form_field_rehearsal",
        "scope_list_review",
        "redirect_state_routing_review",
        "redacted_screenshot"
      ],
      "gateState": "pass_for_dry_run"
    },
    {
      "environmentId": "sandpit_candidate",
      "lane": "Actual_provider_strategy_later",
      "mutationAllowed": false,
      "requiredEvidence": [
        "explicit_live_mutation_flag_true",
        "target_environment_declared",
        "credential_refs_resolve",
        "named_approver_present",
        "rollback_snapshot_captured",
        "redacted_screenshots_enabled"
      ],
      "gateState": "blocked_until_approved"
    },
    {
      "environmentId": "integration_candidate",
      "lane": "Actual_provider_strategy_later",
      "mutationAllowed": false,
      "requiredEvidence": [
        "sandpit_completion_evidence",
        "product_demo_completion_evidence",
        "dspt_or_ods_posture_recorded",
        "conformance_test_plan",
        "integration_test_user_pack_reference",
        "rollback_snapshot_captured"
      ],
      "gateState": "blocked_until_approved"
    }
  ],
  "redactionChecklist": [
    {
      "checkId": "REDACT_CLIENT_IDENTIFIER",
      "required": true,
      "replacement": "client_[REDACTED]"
    },
    {
      "checkId": "REDACT_SECRET_REFERENCES",
      "required": true,
      "replacement": "secret://[REDACTED]"
    },
    {
      "checkId": "REDACT_TEST_USER_CREDENTIALS",
      "required": true,
      "replacement": "[TEST-USER-CREDENTIAL-REDACTED]"
    },
    {
      "checkId": "REDACT_PROVIDER_HOST_WHEN_SCREENSHOTTING",
      "required": true,
      "replacement": "https://[REDACTED-HOST]/..."
    }
  ],
  "rollbackChecklist": [
    {
      "checkId": "SNAPSHOT_BEFORE_MUTATION",
      "required": true,
      "artifactPattern": "output/playwright/202-nhs-login-config-snapshot-*.json"
    },
    {
      "checkId": "PREVIOUS_MANIFEST_REAPPLY_DRY_RUN",
      "required": true,
      "artifactPattern": "data/contracts/202_nhs_login_client_config_manifest.json"
    },
    {
      "checkId": "REAL_PROVIDER_ROLLBACK_APPROVAL",
      "required": true,
      "artifactPattern": "approval-record-redacted"
    }
  ],
  "blockedMutationReasons": [
    "production_is_out_of_scope_for_seq_202",
    "raw_credentials_are_not_available_in_repo",
    "named_approver_not_recorded",
    "selector_snapshot_must_be_current",
    "rollback_snapshot_required"
  ]
}
