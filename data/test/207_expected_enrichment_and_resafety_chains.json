  "pdsChain": [
    {
      "step": "gate",
      "authority": "PdsEnrichmentOrchestrator",
      "mustAttemptAdapterWhenDenied": false,
      "mustMutateBinding": false
    },
    {
      "step": "adapter",
      "authority": "PdsAdapter",
      "allowedResultStates": ["matched", "not_found", "timeout", "provider_error", "parse_error"],
      "mustStoreRawDemographics": false
    },
    {
      "step": "normalize",
      "authority": "PdsEnrichmentOrchestrator",
      "allowedStoredClasses": ["hashes", "digests", "refs", "freshness", "provenance"],
      "mustOverwriteCommunicationPreferences": false
    },
    {
      "step": "settle",
      "authority": "PatientLinker",
      "mustProceedWithoutPds": true,
      "mustTreatPdsAsBindingAuthority": false
    }
  ],
  "followupChain": [
    {
      "step": "freeze",
      "authority": "PhoneFollowupResafetyService",
      "mustCreateSecondReceipt": false
    },
    {
      "step": "duplicate",
      "authority": "FollowupDuplicateEvaluation",
      "allowedClasses": [
        "exact_replay",
        "exact_retry_collapse",
        "semantic_replay",
        "same_request_attach",
        "duplicate_attachment",
        "review_required"
      ]
    },
    {
      "step": "materiality",
      "authority": "MaterialDeltaAssessment",
      "mustTriggerResafetyForMaterialClinicalChange": true
    },
    {
      "step": "projection",
      "authority": "PhoneFollowupProjectionHold",
      "mustExposeStaleCalmStatus": false
    }
  ],
