      "channelContext": {
        "channelType": "nhs_app_webview",
        "entryMode": "jump_off",
        "trustTier": "trusted_embedded",
        "resolutionDisposition": "embedded_live",
        "isEmbedded": true,
        "userAgentEvidence": {
          "marker": "nhsapp-ios/5.0.0",
          "authority": "evidence_only"
