        "queryEvidence": {
          "from": "nhsApp",
          "authority": "styling_hint_only"
        },
        "signedContextEvidence": {
          "signatureState": "valid",
          "expectedJourneyPath": "jp_request_status"
        },
        "assertedIdentityPresent": false,
        "deepLinkPresent": false,
        "jumpOffSource": "gp_services_request_status",
        "channelConfidence": 0.99
      },
      "expectedShellPolicyRef": "ShellPolicy:embedded-nhs-app-v1"
    },
