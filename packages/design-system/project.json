{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "package-design-system",
  "sourceRoot": "packages/design-system/src",
  "projectType": "library",
  "tags": ["artifact:package", "context:design_system", "class:shared_design_package"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} lint"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} test"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir {projectRoot} typecheck"
      }
    }
  }
}
