{
  "name": "@vecells/design-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Design System shared contract package with 2 contract families.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "exports": {
    ".": "./src/index.tsx",
    "./foundation.css": "./src/foundation.css",
    "./component-primitives.css": "./src/component-primitives.css",
    "./contracts/design-contract-publication.schema.json": "./contracts/design-contract-publication.schema.json",
    "./contracts/design-token-foundation.schema.json": "./contracts/design-token-foundation.schema.json",
    "./contracts/ui-contract-kernel.schema.json": "./contracts/ui-contract-kernel.schema.json",
    "./contracts/component-primitives.schema.json": "./contracts/component-primitives.schema.json"
  },
  "types": "./src/index.tsx"
}
