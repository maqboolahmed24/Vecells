{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.design/contracts/design-token-foundation.schema.json",
  "title": "Design Token Foundation Artifact",
  "type": "object",
  "required": [
    "task_id",
    "generated_at",
    "captured_on",
    "visual_mode",
    "mission",
    "source_precedence",
    "summary",
    "designTokenFoundation",
    "tokenKernelLayeringPolicy",
    "designTokenExportArtifact",
    "primitiveTokenGroups",
    "semanticAliases",
    "componentAliases",
    "profileTokens",
    "compositeTokens",
    "profileSelectionResolutions",
    "specimen"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "captured_on": {
      "type": "string"
    },
    "visual_mode": {
      "type": "string"
    },
    "mission": {
      "type": "string"
    },
    "source_precedence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "summary": {
      "type": "object"
    },
    "designTokenFoundation": {
      "type": "object",
      "required": [
        "designTokenFoundationRef",
        "visualLanguage",
        "overlay",
        "tokenArchitecture",
        "modeTupleCoverageRef"
      ],
      "properties": {
        "designTokenFoundationRef": {
          "type": "string"
        },
        "visualLanguage": {
          "type": "string"
        },
        "overlay": {
          "type": "string"
        },
        "tokenArchitecture": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 4
        },
        "modeTupleCoverageRef": {
          "type": "string"
        }
      }
    },
    "tokenKernelLayeringPolicy": {
      "$ref": "#/$defs/tokenKernelLayeringPolicy"
    },
    "designTokenExportArtifact": {
      "$ref": "#/$defs/designTokenExportArtifact"
    },
    "primitiveTokenGroups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/primitiveTokenGroup"
      },
      "minItems": 1
    },
    "semanticAliases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/aliasToken"
      },
      "minItems": 1
    },
    "componentAliases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/aliasToken"
      },
      "minItems": 1
    },
    "profileTokens": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profileToken"
      },
      "minItems": 1
    },
    "compositeTokens": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "profileSelectionResolutions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profileSelectionResolution"
      },
      "minItems": 1
    },
    "specimen": {
      "type": "object",
      "required": [
        "brandMarkPath",
        "shellProfiles",
        "semanticStates",
        "breakpointFrames",
        "paritySeries",
        "digestChips"
      ],
      "properties": {
        "brandMarkPath": {
          "type": "string"
        },
        "shellProfiles": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "minItems": 1
        },
        "semanticStates": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "minItems": 1
        },
        "breakpointFrames": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "minItems": 1
        },
        "paritySeries": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "minItems": 1
        },
        "digestChips": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "minItems": 1
        }
      }
    }
  },
  "$defs": {
    "colorValue": {
      "type": "object",
      "required": [
        "hex",
        "oklch"
      ],
      "properties": {
        "hex": {
          "type": "string"
        },
        "oklch": {
          "type": "string"
        }
      }
    },
    "primitiveTokenGroup": {
      "type": "object",
      "required": [
        "groupId",
        "label",
        "tokens"
      ],
      "properties": {
        "groupId": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "tokens": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "tokenId",
              "label",
              "valueType"
            ],
            "properties": {
              "tokenId": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "valueType": {
                "type": "string"
              },
              "value": {},
              "modeValues": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "aliasToken": {
      "type": "object",
      "required": [
        "tokenId",
        "label",
        "aliasOf",
        "valueType"
      ],
      "properties": {
        "tokenId": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "aliasOf": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "valueType": {
          "type": "string"
        },
        "modeValues": {
          "type": "object"
        }
      }
    },
    "profileToken": {
      "type": "object",
      "required": [
        "tokenId",
        "shellType",
        "label",
        "quietPosture",
        "accentRole",
        "defaultDensityMode",
        "defaultMotionMode",
        "allowedTopologyMetricRefs",
        "allowedSurfaceRoleRefs",
        "notes"
      ],
      "properties": {
        "tokenId": {
          "type": "string"
        },
        "shellType": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "quietPosture": {
          "type": "string"
        },
        "accentRole": {
          "type": "string"
        },
        "defaultDensityMode": {
          "type": "string"
        },
        "defaultMotionMode": {
          "type": "string"
        },
        "allowedTopologyMetricRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "allowedSurfaceRoleRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "profileSelectionResolution": {
      "type": "object",
      "required": [
        "profileSelectionResolutionId",
        "designTokenExportArtifactRef",
        "tokenKernelLayeringPolicyRef",
        "profileTokenRef",
        "shellType",
        "routeClassRef",
        "breakpointCoverageRefs",
        "densityModeRefs",
        "motionModeRefs",
        "allowedTopologyMetricRefs",
        "allowedSurfaceRoleRefs",
        "semanticColorProfileRef",
        "selectionDigestRef",
        "effectiveAt"
      ],
      "properties": {
        "profileSelectionResolutionId": {
          "type": "string"
        },
        "designTokenExportArtifactRef": {
          "type": "string"
        },
        "tokenKernelLayeringPolicyRef": {
          "type": "string"
        },
        "profileTokenRef": {
          "type": "string"
        },
        "shellType": {
          "type": "string"
        },
        "routeClassRef": {
          "type": "string"
        },
        "breakpointCoverageRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "densityModeRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "motionModeRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "allowedTopologyMetricRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "allowedSurfaceRoleRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "semanticColorProfileRef": {
          "type": "string"
        },
        "selectionDigestRef": {
          "type": "string"
        },
        "effectiveAt": {
          "type": "string"
        }
      }
    },
    "tokenKernelLayeringPolicy": {
      "type": "object",
      "required": [
        "tokenKernelLayeringPolicyId",
        "designTokenFoundationRef",
        "primitiveLayerNamespace",
        "semanticLayerNamespace",
        "componentLayerNamespace",
        "profileLayerNamespace",
        "requiredAliasOrder",
        "allowedShellVariationRefs",
        "allowedModeVariationRefs",
        "forbiddenOverrideClasses",
        "requiredKernelStatePropagationRef",
        "layeringDigestRef",
        "effectiveAt"
      ],
      "properties": {
        "tokenKernelLayeringPolicyId": {
          "type": "string"
        },
        "designTokenFoundationRef": {
          "type": "string"
        },
        "primitiveLayerNamespace": {
          "type": "string"
        },
        "semanticLayerNamespace": {
          "type": "string"
        },
        "componentLayerNamespace": {
          "type": "string"
        },
        "profileLayerNamespace": {
          "type": "string"
        },
        "requiredAliasOrder": {
          "type": "string"
        },
        "allowedShellVariationRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "allowedModeVariationRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "forbiddenOverrideClasses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "requiredKernelStatePropagationRef": {
          "type": "string"
        },
        "layeringDigestRef": {
          "type": "string"
        },
        "effectiveAt": {
          "type": "string"
        }
      }
    },
    "designTokenExportArtifact": {
      "type": "object",
      "required": [
        "designTokenExportArtifactId",
        "designTokenFoundationRef",
        "tokenKernelLayeringPolicyRef",
        "modeTupleCoverageRef",
        "primitiveTokenGroupRefs",
        "semanticAliasRefs",
        "componentAliasRefs",
        "profileResolutionRefs",
        "compositeTokenRefs",
        "exportFormatRefs",
        "tokenValueDigestRef",
        "generatedAt"
      ],
      "properties": {
        "designTokenExportArtifactId": {
          "type": "string"
        },
        "designTokenFoundationRef": {
          "type": "string"
        },
        "tokenKernelLayeringPolicyRef": {
          "type": "string"
        },
        "modeTupleCoverageRef": {
          "type": "string"
        },
        "primitiveTokenGroupRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "semanticAliasRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "componentAliasRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "profileResolutionRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "compositeTokenRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "exportFormatRefs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "tokenValueDigestRef": {
          "type": "string"
        },
        "generatedAt": {
          "type": "string"
        }
      }
    }
  }
}
