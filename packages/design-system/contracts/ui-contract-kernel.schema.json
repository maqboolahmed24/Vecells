    "ArtifactModePresentationProfile": {
      "type": "object",
      "required": [
        "artifactModePresentationProfileId",
        "artifactSurfaceFrameRef",
        "artifactStageRef",
        "summaryPolicyRef",
        "previewPolicyRef",
        "printPolicyRef",
        "downloadPolicyRef",
        "exportPolicyRef",
        "handoffPolicyRef",
        "returnAnchorRef",
        "designContractVocabularyTupleRef",
        "presentationDigestRef",
        "effectiveAt"
