        "dominantActionMarkerRef": { "type": "string" },
        "selectedAnchorMarkerRef": { "type": "string" },
        "artifactMarkerRef": { "type": "string" },
        "continuityMarkerRef": { "type": "string" },
        "designContractVocabularyTupleRef": { "type": "string" },
        "domMarkerSchemaRef": { "type": "string" },
        "telemetryBindingProfileRef": { "type": "string" },
        "anchorMapDigestRef": { "type": "string" },
        "publishedAt": { "type": "string" }
      }
    },
    "TelemetryBindingProfile": {
      "type": "object",
      "required": [
        "telemetryBindingProfileId",
        "surfaceRef",
        "requiredUiEventRefs",
        "designContractVocabularyTupleRef",
        "requiredDomMarkerSchemaRef",
        "redactionProfileRef",
        "bindingDigestRef",
        "publishedAt"
      ],
      "properties": {
        "telemetryBindingProfileId": { "type": "string" },
        "surfaceRef": { "type": "string" },
        "requiredUiEventRefs": {
          "type": "array",
