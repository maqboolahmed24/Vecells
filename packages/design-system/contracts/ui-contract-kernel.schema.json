          "type": "array",
          "items": { "type": "string" }
        },
        "freshnessAccessibilityContractRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assistiveTextPolicyRef": { "type": "string" },
        "automationAnchorProfileRef": { "type": "string" },
        "automationAnchorMapRef": { "type": "string" },
        "surfaceStateSemanticsProfileRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "surfaceStateKernelBindingRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "designContractPublicationBundleRef": { "type": "string" },
        "requiredBreakpointClassRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["compact", "narrow", "medium", "expanded", "wide"]
          }
        },
        "missionStackCoverageRef": { "type": "string" },
        "hostResizeCoverageRef": { "type": "string" },
