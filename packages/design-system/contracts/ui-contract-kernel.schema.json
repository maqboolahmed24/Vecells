{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/design-system/ui-contract-kernel.schema.json",
  "title": "UI Contract Kernel Publication Artifact",
  "type": "object",
  "required": [
    "task_id",
    "generated_at",
    "captured_on",
    "visual_mode",
    "summary",
    "designContractPublicationBundles",
    "visualTokenProfiles",
    "surfaceStateSemanticsProfiles",
    "surfaceStateKernelBindings",
    "accessibilitySemanticCoverageProfiles",
    "automationAnchorMaps",
    "telemetryBindingProfiles",
    "artifactModePresentationProfiles",
    "designContractVocabularyTuples"
  ],
  "properties": {
    "task_id": { "type": "string", "const": "par_104" },
    "generated_at": { "type": "string" },
    "captured_on": { "type": "string" },
    "visual_mode": { "type": "string", "const": "Kernel_Atlas" },
    "summary": {
      "type": "object",
      "required": [
        "bundle_count",
        "route_family_count",
        "exact_binding_count",
        "stale_binding_count",
        "blocked_binding_count",
        "lint_pass_count",
        "lint_blocked_count"
      ],
      "properties": {
        "bundle_count": { "type": "number" },
        "route_family_count": { "type": "number" },
        "exact_binding_count": { "type": "number" },
        "stale_binding_count": { "type": "number" },
        "blocked_binding_count": { "type": "number" },
        "lint_pass_count": { "type": "number" },
        "lint_blocked_count": { "type": "number" }
      }
    },
    "designContractPublicationBundles": {
      "type": "array",
      "items": { "$ref": "#/$defs/DesignContractPublicationBundle" }
    },
    "visualTokenProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/VisualTokenProfile" }
    },
    "surfaceStateSemanticsProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/SurfaceStateSemanticsProfile" }
    },
    "surfaceStateKernelBindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/SurfaceStateKernelBinding" }
    },
    "accessibilitySemanticCoverageProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/AccessibilitySemanticCoverageProfile" }
    },
    "automationAnchorMaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/AutomationAnchorMap" }
    },
    "telemetryBindingProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/TelemetryBindingProfile" }
    },
    "artifactModePresentationProfiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/ArtifactModePresentationProfile" }
    },
    "designContractVocabularyTuples": {
      "type": "array",
      "items": { "$ref": "#/$defs/DesignContractVocabularyTuple" }
    }
  },
  "$defs": {
    "VisualTokenProfile": {
      "type": "object",
      "required": [
        "visualTokenProfileId",
        "shellType",
        "routeFamilyRef",
        "designTokenFoundationRef",
        "designTokenExportArtifactRef",
        "tokenKernelLayeringPolicyRef",
        "profileSelectionResolutionRef",
        "breakpointClass",
        "densityProfileRef",
        "semanticColorProfileRef",
        "topologyMetricRef",
        "motionProfileRef",
        "profileDigestRef",
        "effectiveAt"
      ],
      "properties": {
        "visualTokenProfileId": { "type": "string" },
        "shellType": { "type": "string" },
        "routeFamilyRef": { "type": "string" },
        "designTokenFoundationRef": { "type": "string" },
        "designTokenExportArtifactRef": { "type": "string" },
        "tokenKernelLayeringPolicyRef": { "type": "string" },
        "profileSelectionResolutionRef": { "type": "string" },
        "breakpointClass": {
          "type": "string",
          "enum": ["compact", "narrow", "medium", "expanded", "wide"]
        },
        "densityProfileRef": { "type": "string" },
        "semanticColorProfileRef": { "type": "string" },
        "topologyMetricRef": { "type": "string" },
        "motionProfileRef": { "type": "string" },
        "profileDigestRef": { "type": "string" },
        "effectiveAt": { "type": "string" }
      }
    },
    "SurfaceStateSemanticsProfile": {
      "type": "object",
      "required": [
        "surfaceStateSemanticsProfileId",
        "surfaceRef",
        "visualTokenProfileRef",
        "surfacePostureFrameRef",
        "surfaceStateFrameRef",
        "artifactStageRef",
        "statusOwnerRef",
        "effectiveSeverity",
        "effectiveDisplayState",
        "effectiveTone",
        "ariaLiveMode",
        "motionIntentRef",
        "designContractVocabularyTupleRef",
        "telemetryBindingProfileRef",
        "automationAnchorMapRef",
        "surfaceStateKernelBindingRef",
        "stateSemanticsDigestRef",
        "resolvedAt"
      ],
      "properties": {
        "surfaceStateSemanticsProfileId": { "type": "string" },
        "surfaceRef": { "type": "string" },
        "visualTokenProfileRef": { "type": "string" },
        "surfacePostureFrameRef": { "type": "string" },
        "surfaceStateFrameRef": { "type": "string" },
        "artifactStageRef": { "type": "string" },
        "statusOwnerRef": { "type": "string" },
        "effectiveSeverity": { "type": "number" },
        "effectiveDisplayState": {
          "type": "string",
          "enum": [
            "blocked",
            "recovery",
            "degraded",
            "stale",
            "read_only",
            "settled_pending_confirmation",
            "loading",
            "empty",
            "sparse",
            "ready"
          ]
        },
        "effectiveTone": {
          "type": "string",
          "enum": [
            "neutral",
            "accent_active",
            "accent_review",
            "accent_insight",
            "accent_success",
            "accent_danger"
          ]
        },
        "ariaLiveMode": {
          "type": "string",
          "enum": ["polite", "assertive", "off"]
        },
        "motionIntentRef": { "type": "string" }
      }
    },
    "SurfaceStateKernelBinding": {
      "type": "object",
      "required": [
        "surfaceStateKernelBindingId",
        "routeFamilyRef",
        "surfaceRef",
        "visualTokenProfileRef",
        "surfaceStateSemanticsProfileRef",
        "accessibilitySemanticCoverageProfileRef",
        "automationAnchorMapRef",
        "telemetryBindingProfileRef",
        "artifactModePresentationProfileRef",
        "designContractVocabularyTupleRef",
        "bindingState",
        "kernelPropagationDigestRef",
        "resolvedAt"
      ],
      "properties": {
        "surfaceStateKernelBindingId": { "type": "string" },
        "routeFamilyRef": { "type": "string" },
        "surfaceRef": { "type": "string" },
        "visualTokenProfileRef": { "type": "string" },
        "surfaceStateSemanticsProfileRef": { "type": "string" },
        "accessibilitySemanticCoverageProfileRef": { "type": "string" },
        "automationAnchorMapRef": { "type": "string" },
        "telemetryBindingProfileRef": { "type": "string" },
        "artifactModePresentationProfileRef": { "type": "string" },
        "designContractVocabularyTupleRef": { "type": "string" },
        "bindingState": {
          "type": "string",
          "enum": ["exact", "stale", "blocked"]
        },
        "kernelPropagationDigestRef": { "type": "string" },
        "resolvedAt": { "type": "string" }
      }
    },
    "AutomationAnchorMap": {
      "type": "object",
      "required": [
        "automationAnchorMapId",
        "surfaceRef",
        "requiredDomMarkers",
        "dominantActionMarkerRef",
        "selectedAnchorMarkerRef",
        "artifactMarkerRef",
        "continuityMarkerRef",
        "designContractVocabularyTupleRef",
        "domMarkerSchemaRef",
        "telemetryBindingProfileRef",
        "anchorMapDigestRef",
        "publishedAt"
