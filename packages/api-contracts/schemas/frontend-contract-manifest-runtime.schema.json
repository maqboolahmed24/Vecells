{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/schemas/frontend-contract-manifest-runtime.schema.json",
  "title": "FrontendContractManifestRuntime",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "frontendContractManifestId",
    "audienceSurface",
    "routeFamilyRefs",
    "gatewaySurfaceRef",
    "gatewaySurfaceRefs",
    "surfaceRouteContractRef",
    "surfacePublicationRef",
    "audienceSurfaceRuntimeBindingRef",
    "designContractPublicationBundleRef",
    "tokenKernelLayeringPolicyRef",
    "profileSelectionResolutionRefs",
    "surfaceStateKernelBindingRefs",
    "projectionContractVersionSetRef",
    "runtimePublicationBundleRef",
    "projectionQueryContractRefs",
    "projectionQueryContractDigestRefs",
    "mutationCommandContractRefs",
    "mutationCommandContractDigestRefs",
    "liveUpdateChannelContractRefs",
    "liveUpdateChannelDigestRefs",
    "clientCachePolicyRef",
    "clientCachePolicyRefs",
    "clientCachePolicyDigestRefs",
    "commandSettlementSchemaRef",
    "commandSettlementSchemaRefs",
    "transitionEnvelopeSchemaRef",
    "transitionEnvelopeSchemaRefs",
    "releaseRecoveryDispositionRef",
    "releaseRecoveryDispositionRefs",
    "routeFreezeDispositionRef",
    "routeFreezeDispositionRefs",
    "browserPostureState",
    "frontendContractDigestRef",
    "designContractDigestRef",
    "surfaceAuthorityTupleHash",
    "frontendContractDigestVerdict",
    "designContractDigestVerdict",
    "surfaceAuthorityTupleVerdict",
    "designContractLintVerdictRef",
    "designContractLintState",
    "profileLayeringDigestRef",
    "kernelPropagationDigestRef",
    "accessibilitySemanticCoverageProfileRefs",
    "automationAnchorProfileRefs",
    "surfaceStateSemanticsProfileRefs",
    "accessibilityCoverageDigestRef",
    "accessibilityCoverageState",
    "projectionCompatibilityDigestRef",
    "projectionCompatibilityState",
    "runtimeBindingState",
    "runtimePublicationState",
    "publicationParityState",
    "manifestState",
    "driftState",
    "generatedAt",
    "source_refs"
  ],
  "properties": {
    "frontendContractManifestId": { "type": "string" },
    "audienceSurface": { "type": "string" },
    "routeFamilyRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "gatewaySurfaceRef": { "type": "string" },
    "gatewaySurfaceRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "surfaceRouteContractRef": { "type": "string" },
    "surfacePublicationRef": { "type": "string" },
    "audienceSurfaceRuntimeBindingRef": { "type": "string" },
    "designContractPublicationBundleRef": { "type": "string" },
    "tokenKernelLayeringPolicyRef": { "type": "string" },
    "profileSelectionResolutionRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "surfaceStateKernelBindingRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "projectionContractVersionSetRef": { "type": "string" },
    "runtimePublicationBundleRef": { "type": "string" },
    "projectionQueryContractRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "projectionQueryContractDigestRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "mutationCommandContractRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "mutationCommandContractDigestRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "liveUpdateChannelContractRefs": { "type": "array", "items": { "type": "string" } },
    "liveUpdateChannelDigestRefs": { "type": "array", "items": { "type": "string" } },
    "clientCachePolicyRef": { "type": "string" },
    "clientCachePolicyRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "clientCachePolicyDigestRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "commandSettlementSchemaRef": { "type": "string" },
    "commandSettlementSchemaRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "transitionEnvelopeSchemaRef": { "type": "string" },
    "transitionEnvelopeSchemaRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "releaseRecoveryDispositionRef": { "type": "string" },
    "releaseRecoveryDispositionRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "routeFreezeDispositionRef": { "type": "string" },
    "routeFreezeDispositionRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "browserPostureState": {
      "type": "string",
      "enum": ["publishable_live", "read_only", "recovery_only", "blocked"]
    },
    "frontendContractDigestRef": { "type": "string" },
    "designContractDigestRef": { "type": "string" },
    "surfaceAuthorityTupleHash": { "type": "string" },
    "frontendContractDigestVerdict": {
      "type": "string",
      "enum": ["exact", "drifted", "missing"]
    },
    "designContractDigestVerdict": {
      "type": "string",
      "enum": ["exact", "drifted", "missing"]
    },
    "surfaceAuthorityTupleVerdict": {
      "type": "string",
      "enum": ["exact", "drifted", "missing"]
    },
    "designContractLintVerdictRef": { "type": "string" },
    "designContractLintState": {
      "type": "string",
      "enum": ["pass", "drifted", "blocked"]
    },
    "profileLayeringDigestRef": { "type": "string" },
    "kernelPropagationDigestRef": { "type": "string" },
    "accessibilitySemanticCoverageProfileRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "automationAnchorProfileRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "surfaceStateSemanticsProfileRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "accessibilityCoverageDigestRef": { "type": "string" },
    "accessibilityCoverageState": {
      "type": "string",
      "enum": ["complete", "degraded", "blocked"]
    },
    "projectionCompatibilityDigestRef": { "type": "string" },
    "projectionCompatibilityState": {
      "type": "string",
      "enum": ["exact", "additive_compatible", "constrained", "recovery_only", "blocked"]
    },
    "runtimeBindingState": {
      "type": "string",
      "enum": ["exact", "stale", "blocked"]
    },
    "runtimePublicationState": {
      "type": "string",
      "enum": ["published", "stale", "conflict", "withdrawn"]
    },
    "publicationParityState": {
      "type": "string",
      "enum": ["exact", "stale", "conflict", "withdrawn"]
    },
    "manifestState": {
      "type": "string",
      "enum": ["current", "drifted", "rejected"]
    },
    "driftState": {
      "type": "string",
      "enum": [
        "current",
        "stale_design_tuple",
        "stale_accessibility_tuple",
        "stale_runtime_binding",
        "digest_mismatch",
        "blocked"
      ]
    },
    "generatedAt": { "type": "string" },
    "source_refs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
