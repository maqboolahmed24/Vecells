{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/schemas/frontend-contract-manifest-verdict.schema.json",
  "title": "FrontendContractManifestVerdict",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "manifestRef",
    "routeFamilyRefs",
    "validationState",
    "safeToConsume",
    "declaredBrowserPosture",
    "effectiveBrowserPosture",
    "driftState",
    "frontendContractDigestVerdict",
    "designContractDigestVerdict",
    "surfaceAuthorityTupleVerdict",
    "issueCodes",
    "issues",
    "generatedAt"
  ],
  "properties": {
    "manifestRef": { "type": "string" },
    "routeFamilyRefs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "validationState": { "type": "string", "enum": ["valid", "degraded", "rejected"] },
    "safeToConsume": { "type": "boolean" },
    "declaredBrowserPosture": {
      "type": "string",
      "enum": ["publishable_live", "read_only", "recovery_only", "blocked"]
    },
    "effectiveBrowserPosture": {
      "type": "string",
      "enum": ["publishable_live", "read_only", "recovery_only", "blocked"]
    },
    "driftState": {
      "type": "string",
      "enum": [
        "current",
        "stale_design_tuple",
        "stale_accessibility_tuple",
        "stale_runtime_binding",
        "digest_mismatch",
        "blocked"
      ]
    },
    "frontendContractDigestVerdict": {
      "type": "string",
      "enum": ["exact", "drifted", "missing"]
    },
    "designContractDigestVerdict": {
      "type": "string",
      "enum": ["exact", "drifted", "missing"]
    },
    "surfaceAuthorityTupleVerdict": {
      "type": "string",
      "enum": ["exact", "drifted", "missing"]
    },
    "issueCodes": { "type": "array", "items": { "type": "string" } },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "field"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "message": { "type": "string" },
          "field": { "type": ["string", "null"] }
        }
      }
    },
    "generatedAt": { "type": "string" }
  }
}
