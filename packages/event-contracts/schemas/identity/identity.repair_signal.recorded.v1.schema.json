{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/schemas/events/identity/identity.repair_signal.recorded.v1.schema.json",
  "title": "identity.repair_signal.recorded envelope",
  "description": "The event names one canonical lifecycle transition so projections, analytics, assurance, and replay share the same semantic authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventName",
    "canonicalEventContractRef",
    "namespaceRef",
    "schemaVersionRef",
    "tenantId",
    "producerRef",
    "producerScopeRef",
    "sourceBoundedContextRef",
    "governingBoundedContextRef",
    "governingAggregateRef",
    "governingLineageRef",
    "edgeCorrelationId",
    "piiClass",
    "disclosureClass",
    "occurredAt",
    "emittedAt",
    "payload",
    "commandActionRecordRef",
    "payloadArtifactRef",
    "payloadHash",
    "subjectRef"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventName": {
      "const": "identity.repair_signal.recorded"
    },
    "canonicalEventContractRef": {
      "const": "CEC_IDENTITY_REPAIR_SIGNAL_RECORDED"
    },
    "namespaceRef": {
      "const": "CEN_IDENTITY"
    },
    "schemaVersionRef": {
      "const": "CESV_IDENTITY_REPAIR_SIGNAL_RECORDED_V1"
    },
    "tenantId": {
      "type": "string"
    },
    "producerRef": {
      "type": "string"
    },
    "producerScopeRef": {
      "type": "string"
    },
    "sourceBoundedContextRef": {
      "const": "identity_access"
    },
    "governingBoundedContextRef": {
      "type": "string"
    },
    "governingAggregateRef": {
      "type": "string"
    },
    "governingLineageRef": {
      "type": "string"
    },
    "routeIntentRef": {
      "type": "string"
    },
    "commandActionRecordRef": {
      "type": "string"
    },
    "commandSettlementRef": {
      "type": "string"
    },
    "edgeCorrelationId": {
      "type": "string"
    },
    "causalToken": {
      "type": "string"
    },
    "effectKeyRef": {
      "type": "string"
    },
    "continuityFrameRef": {
      "type": "string"
    },
    "subjectRef": {
      "type": "string"
    },
    "piiClass": {
      "type": "string"
    },
    "disclosureClass": {
      "type": "string"
    },
    "payloadArtifactRef": {
      "type": "string"
    },
    "payloadHash": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "emittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governingRef",
        "governingVersionRef",
        "previousState",
        "nextState",
        "stateAxis"
      ],
      "properties": {
        "governingRef": {
          "type": "string",
          "description": "Canonical reference to the governing object instance."
        },
        "governingVersionRef": {
          "type": "string",
          "description": "Opaque version or epoch ref for the governing object."
        },
        "previousState": {
          "type": "string",
          "description": "Prior canonical state or posture."
        },
        "nextState": {
          "type": "string",
          "description": "Next canonical state or posture."
        },
        "stateAxis": {
          "type": "string",
          "description": "Named axis or dimension the state change applies to."
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "properties": {
          "payload": {
            "anyOf": [
              {
                "required": ["rawPhoneNumber"]
              },
              {
                "required": ["rawMessageBody"]
              },
              {
                "required": ["rawTranscriptText"]
              },
              {
                "required": ["binaryArtifactPayload"]
              },
              {
                "required": ["freeTextPhi"]
              }
            ]
          }
        }
      }
    }
  ]
}
