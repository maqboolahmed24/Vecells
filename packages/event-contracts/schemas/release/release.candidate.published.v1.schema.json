{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/schemas/events/release/release.candidate.published.v1.schema.json",
  "title": "release.candidate.published envelope",
  "description": "Policy and release changes must be published as explicit runtime truth rather than implicit deployment order.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventName",
    "canonicalEventContractRef",
    "namespaceRef",
    "schemaVersionRef",
    "tenantId",
    "producerRef",
    "producerScopeRef",
    "sourceBoundedContextRef",
    "governingBoundedContextRef",
    "governingAggregateRef",
    "governingLineageRef",
    "edgeCorrelationId",
    "piiClass",
    "disclosureClass",
    "occurredAt",
    "emittedAt",
    "payload",
    "commandActionRecordRef",
    "effectKeyRef"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventName": {
      "const": "release.candidate.published"
    },
    "canonicalEventContractRef": {
      "const": "CEC_RELEASE_CANDIDATE_PUBLISHED"
    },
    "namespaceRef": {
      "const": "CEN_RELEASE"
    },
    "schemaVersionRef": {
      "const": "CESV_RELEASE_CANDIDATE_PUBLISHED_V1"
    },
    "tenantId": {
      "type": "string"
    },
    "producerRef": {
      "type": "string"
    },
    "producerScopeRef": {
      "type": "string"
    },
    "sourceBoundedContextRef": {
      "const": "release_control"
    },
    "governingBoundedContextRef": {
      "type": "string"
    },
    "governingAggregateRef": {
      "type": "string"
    },
    "governingLineageRef": {
      "type": "string"
    },
    "routeIntentRef": {
      "type": "string"
    },
    "commandActionRecordRef": {
      "type": "string"
    },
    "commandSettlementRef": {
      "type": "string"
    },
    "edgeCorrelationId": {
      "type": "string"
    },
    "causalToken": {
      "type": "string"
    },
    "effectKeyRef": {
      "type": "string"
    },
    "continuityFrameRef": {
      "type": "string"
    },
    "subjectRef": {
      "type": "string"
    },
    "piiClass": {
      "type": "string"
    },
    "disclosureClass": {
      "type": "string"
    },
    "payloadArtifactRef": {
      "type": "string"
    },
    "payloadHash": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "emittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["governingRef", "policyBundleRef", "policyHash", "effectiveAt"],
      "properties": {
        "governingRef": {
          "type": "string",
          "description": "Canonical reference to the governing object instance."
        },
        "policyBundleRef": {
          "type": "string",
          "description": "Compiled policy or contract bundle ref."
        },
        "policyHash": {
          "type": "string",
          "description": "Hash of the published policy content."
        },
        "effectiveAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the governing bundle becomes effective."
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "properties": {
          "payload": {
            "anyOf": [
              {
                "required": ["rawPhoneNumber"]
              },
              {
                "required": ["rawMessageBody"]
              },
              {
                "required": ["rawTranscriptText"]
              },
              {
                "required": ["binaryArtifactPayload"]
              },
              {
                "required": ["freeTextPhi"]
              }
            ]
          }
        }
      }
    }
  ]
}
