{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/schemas/events/booking/booking.case.created.v1.schema.json",
  "title": "booking.case.created envelope",
  "description": "BookingCase creation is the only public booking lifecycle event owned by 282 after the 281 owner remap.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventName",
    "canonicalEventContractRef",
    "namespaceRef",
    "schemaVersionRef",
    "tenantId",
    "producerRef",
    "producerScopeRef",
    "sourceBoundedContextRef",
    "governingBoundedContextRef",
    "governingAggregateRef",
    "governingLineageRef",
    "edgeCorrelationId",
    "piiClass",
    "disclosureClass",
    "occurredAt",
    "emittedAt",
    "payload",
    "commandActionRecordRef",
    "commandSettlementRef",
    "routeIntentRef",
    "payloadArtifactRef",
    "payloadHash",
    "subjectRef"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventName": {
      "const": "booking.case.created"
    },
    "canonicalEventContractRef": {
      "const": "CEC_BOOKING_CASE_CREATED"
    },
    "namespaceRef": {
      "const": "CEN_BOOKING"
    },
    "schemaVersionRef": {
      "const": "CESV_BOOKING_CASE_CREATED_V1"
    },
    "tenantId": {
      "type": "string"
    },
    "producerRef": {
      "type": "string"
    },
    "producerScopeRef": {
      "type": "string"
    },
    "sourceBoundedContextRef": {
      "const": "booking"
    },
    "governingBoundedContextRef": {
      "const": "booking"
    },
    "governingAggregateRef": {
      "type": "string"
    },
    "governingLineageRef": {
      "type": "string"
    },
    "routeIntentRef": {
      "type": "string"
    },
    "commandActionRecordRef": {
      "type": "string"
    },
    "commandSettlementRef": {
      "type": "string"
    },
    "edgeCorrelationId": {
      "type": "string"
    },
    "causalToken": {
      "type": "string"
    },
    "effectKeyRef": {
      "type": "string"
    },
    "continuityFrameRef": {
      "type": "string"
    },
    "subjectRef": {
      "type": "string"
    },
    "piiClass": {
      "type": "string"
    },
    "disclosureClass": {
      "type": "string"
    },
    "payloadArtifactRef": {
      "type": "string"
    },
    "payloadHash": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "emittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governingRef",
        "governingVersionRef",
        "previousState",
        "nextState",
        "stateAxis",
        "bookingIntentId",
        "sourceDecisionEpochRef"
      ],
      "properties": {
        "governingRef": {
          "type": "string",
          "description": "Canonical reference to the BookingCase instance."
        },
        "governingVersionRef": {
          "type": "string",
          "description": "Opaque BookingCase version or monotone journal ref."
        },
        "previousState": {
          "const": "none"
        },
        "nextState": {
          "const": "handoff_received"
        },
        "stateAxis": {
          "const": "case_state"
        },
        "bookingIntentId": {
          "type": "string"
        },
        "sourceDecisionEpochRef": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "properties": {
          "payload": {
            "anyOf": [
              {
                "required": [
                  "rawPhoneNumber"
                ]
              },
              {
                "required": [
                  "rawMessageBody"
                ]
              },
              {
                "required": [
                  "rawTranscriptText"
                ]
              },
              {
                "required": [
                  "binaryArtifactPayload"
                ]
              },
              {
                "required": [
                  "freeTextPhi"
                ]
              }
            ]
          }
        }
      }
    }
  ]
}
