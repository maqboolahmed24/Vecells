{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/schemas/events/intake/intake.resume.continuity.updated.v1.schema.json",
  "title": "intake.resume.continuity.updated envelope",
  "description": "Continuity and recovery surfaces must consume this canonical event instead of route-local session or cache heuristics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventName",
    "canonicalEventContractRef",
    "namespaceRef",
    "schemaVersionRef",
    "tenantId",
    "producerRef",
    "producerScopeRef",
    "sourceBoundedContextRef",
    "governingBoundedContextRef",
    "governingAggregateRef",
    "governingLineageRef",
    "edgeCorrelationId",
    "piiClass",
    "disclosureClass",
    "occurredAt",
    "emittedAt",
    "payload",
    "continuityFrameRef",
    "commandActionRecordRef",
    "payloadArtifactRef",
    "payloadHash",
    "subjectRef"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventName": {
      "const": "intake.resume.continuity.updated"
    },
    "canonicalEventContractRef": {
      "const": "CEC_INTAKE_RESUME_CONTINUITY_UPDATED"
    },
    "namespaceRef": {
      "const": "CEN_INTAKE"
    },
    "schemaVersionRef": {
      "const": "CESV_INTAKE_RESUME_CONTINUITY_UPDATED_V1"
    },
    "tenantId": {
      "type": "string"
    },
    "producerRef": {
      "type": "string"
    },
    "producerScopeRef": {
      "type": "string"
    },
    "sourceBoundedContextRef": {
      "const": "intake_safety"
    },
    "governingBoundedContextRef": {
      "type": "string"
    },
    "governingAggregateRef": {
      "type": "string"
    },
    "governingLineageRef": {
      "type": "string"
    },
    "routeIntentRef": {
      "type": "string"
    },
    "commandActionRecordRef": {
      "type": "string"
    },
    "commandSettlementRef": {
      "type": "string"
    },
    "edgeCorrelationId": {
      "type": "string"
    },
    "causalToken": {
      "type": "string"
    },
    "effectKeyRef": {
      "type": "string"
    },
    "continuityFrameRef": {
      "type": "string"
    },
    "subjectRef": {
      "type": "string"
    },
    "piiClass": {
      "type": "string"
    },
    "disclosureClass": {
      "type": "string"
    },
    "payloadArtifactRef": {
      "type": "string"
    },
    "payloadHash": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "emittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governingRef",
        "continuityControlCode",
        "continuityArtifactRef",
        "continuityHash"
      ],
      "properties": {
        "governingRef": {
          "type": "string",
          "description": "Canonical reference to the governing object instance."
        },
        "continuityControlCode": {
          "type": "string",
          "description": "Continuity control family or projection code."
        },
        "continuityArtifactRef": {
          "type": "string",
          "description": "Governed continuity artifact ref."
        },
        "continuityHash": {
          "type": "string",
          "description": "Stable digest proving the continuity view."
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "properties": {
          "payload": {
            "anyOf": [
              {
                "required": ["rawPhoneNumber"]
              },
              {
                "required": ["rawMessageBody"]
              },
              {
                "required": ["rawTranscriptText"]
              },
              {
                "required": ["binaryArtifactPayload"]
              },
              {
                "required": ["freeTextPhi"]
              }
            ]
          }
        }
      }
    }
  ]
}
