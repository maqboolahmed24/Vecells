{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.local/schemas/events/pharmacy/pharmacy.dispatch.proof_missing.v1.schema.json",
  "title": "pharmacy.dispatch.proof_missing envelope",
  "description": "This event prevents downstream projections from reverse-engineering blocker truth from unrelated state changes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventName",
    "canonicalEventContractRef",
    "namespaceRef",
    "schemaVersionRef",
    "tenantId",
    "producerRef",
    "producerScopeRef",
    "sourceBoundedContextRef",
    "governingBoundedContextRef",
    "governingAggregateRef",
    "governingLineageRef",
    "edgeCorrelationId",
    "piiClass",
    "disclosureClass",
    "occurredAt",
    "emittedAt",
    "payload",
    "commandActionRecordRef",
    "commandSettlementRef",
    "routeIntentRef",
    "payloadArtifactRef",
    "payloadHash",
    "subjectRef"
  ],
  "properties": {
    "eventId": {
      "type": "string"
    },
    "eventName": {
      "const": "pharmacy.dispatch.proof_missing"
    },
    "canonicalEventContractRef": {
      "const": "CEC_PHARMACY_DISPATCH_PROOF_MISSING"
    },
    "namespaceRef": {
      "const": "CEN_PHARMACY"
    },
    "schemaVersionRef": {
      "const": "CESV_PHARMACY_DISPATCH_PROOF_MISSING_V1"
    },
    "tenantId": {
      "type": "string"
    },
    "producerRef": {
      "type": "string"
    },
    "producerScopeRef": {
      "type": "string"
    },
    "sourceBoundedContextRef": {
      "const": "pharmacy"
    },
    "governingBoundedContextRef": {
      "type": "string"
    },
    "governingAggregateRef": {
      "type": "string"
    },
    "governingLineageRef": {
      "type": "string"
    },
    "routeIntentRef": {
      "type": "string"
    },
    "commandActionRecordRef": {
      "type": "string"
    },
    "commandSettlementRef": {
      "type": "string"
    },
    "edgeCorrelationId": {
      "type": "string"
    },
    "causalToken": {
      "type": "string"
    },
    "effectKeyRef": {
      "type": "string"
    },
    "continuityFrameRef": {
      "type": "string"
    },
    "subjectRef": {
      "type": "string"
    },
    "piiClass": {
      "type": "string"
    },
    "disclosureClass": {
      "type": "string"
    },
    "payloadArtifactRef": {
      "type": "string"
    },
    "payloadHash": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "emittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governingRef",
        "blockerReasonCode",
        "blockerSetHash",
        "recoveryMode",
        "dispatchAttemptRef"
      ],
      "properties": {
        "governingRef": {
          "type": "string",
          "description": "Canonical reference to the governing object instance."
        },
        "blockerReasonCode": {
          "type": "string",
          "description": "Reason code for blocker or recovery posture."
        },
        "blockerSetHash": {
          "type": "string",
          "description": "Stable hash over the current blocker set."
        },
        "recoveryMode": {
          "type": "string",
          "description": "Named recovery or degraded mode required after the event."
        },
        "dispatchAttemptRef": {
          "type": "string",
          "description": "Provider dispatch attempt ref."
        }
      }
    }
  },
  "allOf": [
    {
      "not": {
        "properties": {
          "payload": {
            "anyOf": [
              {
                "required": ["rawPhoneNumber"]
              },
              {
                "required": ["rawMessageBody"]
              },
              {
                "required": ["rawTranscriptText"]
              },
              {
                "required": ["binaryArtifactPayload"]
              },
              {
                "required": ["freeTextPhi"]
              }
            ]
          }
        }
      }
    }
  ]
}
