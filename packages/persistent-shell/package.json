{
  "name": "@vecells/persistent-shell",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Persistent shell framework package with 2 contract families.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests --ext .ts,.tsx",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@vecells/api-contracts": "workspace:*",
    "@vecells/design-system": "workspace:*",
    "@vecells/observability": "workspace:*",
    "@vecells/release-controls": "workspace:*"
  },
  "exports": {
    ".": "./src/index.tsx",
    "./persistent-shell.css": "./src/persistent-shell.css",
    "./contracts/selected-anchor-manager.schema.json": "./contracts/selected-anchor-manager.schema.json"
  },
  "types": "./src/index.tsx"
}
