{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/schemas/fhir-resource-record.schema.json",
  "title": "FhirResourceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fhirResourceRecordId",
    "representationSetRef",
    "resourceType",
    "profileCanonicalUrl",
    "logicalId",
    "versionId",
    "payloadArtifactRef",
    "payloadHash",
    "sourceAggregateRefs",
    "identifierSetHash",
    "storageDisposition",
    "materializationState",
    "writtenAt",
    "recordVersion",
    "persistenceSchemaVersion",
    "payload"
  ],
  "properties": {
    "fhirResourceRecordId": { "type": "string", "minLength": 1 },
    "representationSetRef": { "type": "string", "minLength": 1 },
    "resourceType": {
      "type": "string",
      "enum": [
        "Task",
        "ServiceRequest",
        "DocumentReference",
        "Communication",
        "Consent",
        "AuditEvent",
        "Provenance",
        "Bundle"
      ]
    },
    "profileCanonicalUrl": {
      "type": "string",
      "pattern": "^https://.+/fhir/StructureDefinition/.+$"
    },
    "logicalId": { "type": "string", "minLength": 1 },
    "versionId": { "type": "string", "minLength": 1 },
    "subjectRef": { "type": ["string", "null"] },
    "payloadArtifactRef": { "type": "string", "minLength": 1 },
    "payloadHash": { "type": "string", "minLength": 1 },
    "sourceAggregateRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "identifierSetHash": { "type": "string", "minLength": 1 },
    "provenanceAuditJoinRef": { "type": ["string", "null"] },
    "storageDisposition": {
      "type": "string",
      "enum": ["clinical_store", "interchange_only", "callback_cache", "derived_view"]
    },
    "materializationState": {
      "type": "string",
      "enum": ["staged", "written", "superseded", "invalidated"]
    },
    "supersededByRepresentationSetRef": { "type": ["string", "null"] },
    "invalidationReasonRef": { "type": ["string", "null"] },
    "writtenAt": { "type": "string", "minLength": 1 },
    "recordVersion": { "type": "integer", "minimum": 1 },
    "persistenceSchemaVersion": { "const": 1 },
    "payload": { "type": "object" }
  }
}
