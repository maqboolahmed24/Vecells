{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/schemas/fhir-representation-set.schema.json",
  "title": "FhirRepresentationSet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fhirRepresentationSetId",
    "representationContractRef",
    "governingAggregateType",
    "governingAggregateRef",
    "governingAggregateVersionRef",
    "governingLineageRef",
    "representationPurpose",
    "resourceRecordRefs",
    "setHash",
    "causalToken",
    "monotoneRevision",
    "representationState",
    "generatedAt",
    "recordVersion",
    "persistenceSchemaVersion"
  ],
  "properties": {
    "fhirRepresentationSetId": { "type": "string", "minLength": 1 },
    "representationContractRef": { "type": "string", "minLength": 1 },
    "governingAggregateType": { "type": "string", "minLength": 1 },
    "governingAggregateRef": { "type": "string", "minLength": 1 },
    "governingAggregateVersionRef": { "type": "string", "minLength": 1 },
    "governingLineageRef": { "type": "string", "minLength": 1 },
    "evidenceSnapshotRef": { "type": ["string", "null"] },
    "representationPurpose": {
      "type": "string",
      "enum": [
        "clinical_persistence",
        "external_interchange",
        "partner_callback_correlation",
        "audit_companion"
      ]
    },
    "resourceRecordRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "bundleArtifactRef": { "type": ["string", "null"] },
    "setHash": { "type": "string", "minLength": 1 },
    "causalToken": { "type": "string", "minLength": 1 },
    "monotoneRevision": { "type": "integer", "minimum": 1 },
    "representationState": {
      "type": "string",
      "enum": ["staged", "emitted", "superseded", "invalidated"]
    },
    "supersedesRepresentationSetRef": { "type": ["string", "null"] },
    "supersededByRepresentationSetRef": { "type": ["string", "null"] },
    "invalidationReasonRef": { "type": ["string", "null"] },
    "generatedAt": { "type": "string", "minLength": 1 },
    "recordVersion": { "type": "integer", "minimum": 1 },
    "persistenceSchemaVersion": { "const": 1 }
  }
}
