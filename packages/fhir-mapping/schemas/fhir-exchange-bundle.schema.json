{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vecells.example/schemas/fhir-exchange-bundle.schema.json",
  "title": "FhirExchangeBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fhirExchangeBundleId",
    "representationSetRef",
    "adapterContractProfileRef",
    "direction",
    "bundleType",
    "transportPayloadRef",
    "transportPayloadHash",
    "correlationKey",
    "exchangeState",
    "createdAt",
    "bundlePolicyRef",
    "recordVersion",
    "persistenceSchemaVersion",
    "bundlePayload"
  ],
  "properties": {
    "fhirExchangeBundleId": { "type": "string", "minLength": 1 },
    "representationSetRef": { "type": "string", "minLength": 1 },
    "adapterContractProfileRef": { "type": "string", "minLength": 1 },
    "direction": { "type": "string", "enum": ["outbound", "inbound"] },
    "bundleType": {
      "type": "string",
      "enum": ["transaction", "message", "document", "collection", "searchset", "history", "batch"]
    },
    "transportPayloadRef": { "type": "string", "minLength": 1 },
    "transportPayloadHash": { "type": "string", "minLength": 1 },
    "targetPartnerRef": { "type": ["string", "null"] },
    "correlationKey": { "type": "string", "minLength": 1 },
    "receiptCheckpointRef": { "type": ["string", "null"] },
    "exchangeState": {
      "type": "string",
      "enum": ["staged", "dispatched", "accepted", "replayed", "failed", "superseded"]
    },
    "createdAt": { "type": "string", "minLength": 1 },
    "closedAt": { "type": ["string", "null"] },
    "bundlePolicyRef": { "type": "string", "minLength": 1 },
    "supersededByBundleRef": { "type": ["string", "null"] },
    "invalidationReasonRef": { "type": ["string", "null"] },
    "recordVersion": { "type": "integer", "minimum": 1 },
    "persistenceSchemaVersion": { "const": 1 },
    "bundlePayload": { "type": "object" }
  }
}
