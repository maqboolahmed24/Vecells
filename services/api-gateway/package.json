{
  "name": "@vecells/api-gateway",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "API Gateway runtime scaffold with typed config, readiness endpoints, and contract seams.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests --ext .ts,.js",
    "test": "vitest run --testTimeout=15000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@vecells/api-contracts": "workspace:*",
    "@vecells/authz-policy": "workspace:*",
    "@vecells/observability": "workspace:*",
    "@vecells/release-controls": "workspace:*"
  }
}
