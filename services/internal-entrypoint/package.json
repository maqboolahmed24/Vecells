{
  "name": "@vecells/internal-entrypoint",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Protected internal Render entrypoint for team test deployments.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/services/internal-entrypoint/src/index.js",
    "hash-password": "tsx src/hash-password.ts"
  }
}
